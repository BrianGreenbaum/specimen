---
import type { CollectionEntry } from 'astro:content';
export interface Props {
  prev?: CollectionEntry<'fonts'>;
  next?: CollectionEntry<'fonts'>;
}
const { prev, next } = Astro.props;
---
<footer class="site-footer">
  {(prev || next) && (
    <div class="container footer-nav">
      <div class="footer-nav__cell">
        {prev && (
          <a href={`/fonts/${prev.id}`} class="footer-nav__link">
            <span class="label">← Previous</span>
            <span class="footer-nav__name" style={`font-family:${prev.data.fontFamily}`}>{prev.data.name}</span>
          </a>
        )}
      </div>
      <div class="footer-nav__cell footer-nav__cell--right">
        {next && (
          <a href={`/fonts/${next.id}`} class="footer-nav__link footer-nav__link--right">
            <span class="label">Next →</span>
            <span class="footer-nav__name" style={`font-family:${next.data.fontFamily}`}>{next.data.name}</span>
          </a>
        )}
      </div>
    </div>
  )}

  <div class="container footer-base">
    <div class="footer-base__brand">
      <span class="wordmark__mark">Specimen</span>
      <span class="label">A living library of type</span>
    </div>
    <p class="label footer-base__note">
      Specimens are independent editorial showcases. Each typeface is free and open source under its own
      licence. Built with self-hosted fonts · {new Date().getFullYear()}.
    </p>
    <a href="/#index" class="label footer-base__top">Back to index ↑</a>
  </div>
</footer>

<style>
  .site-footer { border-top: 1px solid var(--fg); margin-top: var(--sp-7); }
  .footer-nav {
    display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-4);
    padding-block: var(--sp-6); border-bottom: 1px solid var(--line);
  }
  .footer-nav__cell--right { text-align: right; }
  .footer-nav__link { display: inline-flex; flex-direction: column; gap: 0.4rem; }
  .footer-nav__link--right { align-items: flex-end; }
  .footer-nav__name { font-size: var(--step-2); line-height: 1; transition: color 0.2s var(--ease); }
  .footer-nav__link:hover .footer-nav__name { color: var(--accent); }

  .footer-base {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--sp-5);
    align-items: center;
    padding-block: var(--sp-5);
  }
  .footer-base__brand { display: flex; flex-direction: column; gap: 2px; }
  .footer-base__brand .wordmark__mark { font-family: var(--font-ui); font-weight: 650; font-size: 1.1rem; letter-spacing: -0.02em; }
  .footer-base__note { max-width: 48ch; }
  .footer-base__top { white-space: nowrap; }
  .footer-base__top:hover { color: var(--fg); }

  @media (max-width: 720px) {
    .footer-base { grid-template-columns: 1fr; gap: var(--sp-3); }
  }
</style>
