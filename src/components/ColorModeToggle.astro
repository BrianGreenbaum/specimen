---
// A light/dark toggle. Behaviour lives in Layout.astro (delegated click).
---
<button class="mode-toggle" data-mode-toggle aria-label="Toggle colour mode" title="Toggle colour">
  <svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
    <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.5" />
    <path d="M12 3a9 9 0 0 0 0 18Z" fill="currentColor" />
  </svg>
</button>

<style>
  .mode-toggle {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--line);
    color: var(--fg-2);
    transition: color 0.25s var(--ease), border-color 0.25s var(--ease), transform 0.4s var(--ease);
  }
  .mode-toggle:hover { color: var(--fg); border-color: var(--fg); transform: rotate(180deg); }
  .mode-toggle svg { display: block; }
</style>
