---
// The wow centrepiece: one letter rendered across every era, with an animated
// readout of the four dimensions that actually change — serif, contrast,
// stress, terminals — plus accent spotlights drawn on the letter itself.
// Scrub the timeline and watch the letterform's DNA shift, era by era.
import type { CollectionEntry } from 'astro:content';
export interface Props {
  eras: CollectionEntry<'eras'>[];
  compact?: boolean;
}
const { eras, compact = false } = Astro.props;
const data = eras.map((e) => ({
  slug: e.data.slug,
  name: e.data.name,
  period: e.data.period,
  family: e.data.specimenFont.family,
  weight: e.data.specimenFont.weight,
  evolution: e.data.evolution,
  accent: e.data.theme.accent,
  traits: e.data.traits ?? { serif: 0, contrast: 0, stress: 0, terminals: 0 },
  spotlightGlyph: e.data.spotlightGlyph,
  spotlightFocus: e.data.spotlightFocus,
}));
const letters = ['R', 'G', 'A', 'E', 'Q', 'M'];
const dims = [
  { key: 'serif', label: 'Serif', lo: 'none', hi: 'slab' },
  { key: 'contrast', label: 'Contrast', lo: 'monoline', hi: 'extreme' },
  { key: 'stress', label: 'Stress', lo: 'vertical', hi: 'diagonal' },
  { key: 'terminals', label: 'Terminals', lo: 'blunt', hi: 'ball' },
];
const n = data.length;
---
<section
  class:list={['evo', { 'evo--compact': compact }]}
  data-evo
  data-eras={JSON.stringify(data)}
>
  <div class="evo__grid">
    <div class="evo__stage">
      <span class="evo__stage-tag" data-evo-tag aria-hidden="true"></span>
      <svg class="evo__svg" data-evo-svg preserveAspectRatio="xMidYMid meet" role="img" aria-label="Letter shown across the history of type"></svg>
    </div>

    <div class="evo__readout">
      <div class="evo__letters" role="group" aria-label="Choose a letter">
        {letters.map((l, i) => (
          <button class:list={['evo__letter', { 'is-on': i === 0 }]} data-evo-letter={l} aria-pressed={i === 0 ? 'true' : 'false'}>
            <span>{l}</span>
          </button>
        ))}
      </div>

      <span class="evo__period label" data-evo-period></span>
      <h3 class="evo__name" data-evo-name></h3>
      <p class="evo__note" data-evo-note></p>

      <div class="evo__dims" data-evo-dims>
        {dims.map((d) => (
          <div class="evo__dim" data-dim={d.key}>
            <div class="evo__dim-head">
              <span class="evo__dim-label">{d.label}</span>
              <span class="evo__dim-value" data-dim-value></span>
            </div>
            <div class="evo__dim-track">
              <span class="evo__dim-fill" data-dim-fill></span>
              <span class="evo__dim-marker" data-dim-marker></span>
            </div>
            <div class="evo__dim-ends">
              <span>{d.lo}</span>
              <span>{d.hi}</span>
            </div>
          </div>
        ))}
      </div>

      <a class="evo__link" data-evo-link>Read the chapter →</a>
    </div>
  </div>

  <div class="evo__timeline">
    <div
      class="evo__track"
      role="slider"
      tabindex="0"
      aria-valuemin="0"
      aria-valuemax={n - 1}
      aria-valuenow="0"
      aria-label="Scrub through the history of type"
      data-evo-track
      style={`--n:${n}`}
    >
      <span class="evo__track-line" aria-hidden="true"></span>
      <span class="evo__track-fill" data-evo-fill aria-hidden="true"></span>
      {data.map((e, i) => (
        <button
          class:list={['evo__stop', { 'is-on': i === 0 }]}
          data-evo-stop={i}
          style={`--i:${i}`}
          aria-label={`${e.name} — ${e.period}`}
        >
          <span class="evo__stop-dot" aria-hidden="true"></span>
          <span class="evo__stop-label">
            <span class="evo__stop-name">{e.name}</span>
            <span class="evo__stop-period">{e.period}</span>
          </span>
        </button>
      ))}
    </div>
  </div>
</section>

<script>
  import { renderGlyphDiagram } from '../../lib/diagram';

  const pct = (v: number) => `${(Math.max(0, Math.min(1, v)) * 100).toFixed(1)}%`;
  const valueWord = (v: number) =>
    v < 0.12 ? 'none' : v < 0.34 ? 'low' : v < 0.62 ? 'mid' : v < 0.85 ? 'high' : 'max';

  document.querySelectorAll<HTMLElement>('[data-evo]').forEach((root) => {
    const eras = JSON.parse(root.dataset.eras || '[]');
    const svg = root.querySelector('[data-evo-svg]') as SVGElement;
    const tag = root.querySelector('[data-evo-tag]') as HTMLElement;
    const period = root.querySelector('[data-evo-period]') as HTMLElement;
    const name = root.querySelector('[data-evo-name]') as HTMLElement;
    const note = root.querySelector('[data-evo-note]') as HTMLElement;
    const link = root.querySelector('[data-evo-link]') as HTMLAnchorElement;
    const track = root.querySelector('[data-evo-track]') as HTMLElement;
    const fill = root.querySelector('[data-evo-fill]') as HTMLElement;
    const stops = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-evo-stop]'));
    const letterBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-evo-letter]'));
    const dimRows = Array.from(root.querySelectorAll<HTMLElement>('.evo__dim'));

    const n = eras.length;
    let idx = 0;
    let letter = 'R';

    const setDims = (e: any) => {
      dimRows.forEach((row) => {
        const key = row.dataset.dim!;
        const v = e.traits?.[key] ?? 0;
        (row.querySelector('[data-dim-fill]') as HTMLElement).style.width = pct(v);
        (row.querySelector('[data-dim-marker]') as HTMLElement).style.left = pct(v);
        (row.querySelector('[data-dim-value]') as HTMLElement).textContent = valueWord(v);
      });
    };

    const render = () => {
      const e = eras[idx];
      root.style.setProperty('--accent', e.accent);
      const num = String(idx + 1).padStart(2, '0');
      period.textContent = `${num} · ${e.period}`;
      tag.textContent = `${num} / ${String(n).padStart(2, '0')}`;
      name.textContent = e.name;
      note.textContent = e.evolution;
      link.href = `/history/${e.slug}`;

      stops.forEach((s, i) => s.classList.toggle('is-on', i === idx));
      track.setAttribute('aria-valuenow', String(idx));
      track.setAttribute('aria-valuetext', `${e.name}, ${e.period}`);
      fill.style.width = n > 1 ? `${(idx / (n - 1)) * 100}%` : '0%';

      setDims(e);

      const annotated = letter === e.spotlightGlyph;
      letterBtns.forEach((b) => b.classList.toggle('is-annotated', b.dataset.evoLetter === e.spotlightGlyph));

      svg.classList.remove('is-in');
      renderGlyphDiagram(svg, {
        family: e.family,
        glyph: letter,
        weight: e.weight,
        guides: ['cap', 'baseline'],
        focus: annotated ? e.spotlightFocus : [],
        fill: 0.74,
      }).then(() => requestAnimationFrame(() => svg.classList.add('is-in')));
    };

    const setIdx = (i: number) => {
      const next = Math.max(0, Math.min(n - 1, i));
      if (next === idx) return;
      idx = next;
      render();
    };

    // Click a stop
    stops.forEach((s, i) => s.addEventListener('click', () => setIdx(i)));

    // Drag / click anywhere along the track → nearest stop
    const idxFromX = (clientX: number) => {
      const r = track.getBoundingClientRect();
      const ratio = (clientX - r.left) / r.width;
      return Math.round(ratio * (n - 1));
    };
    let dragging = false;
    track.addEventListener('pointerdown', (ev) => {
      // Let direct stop clicks handle themselves; otherwise scrub.
      if ((ev.target as HTMLElement).closest('.evo__stop')) return;
      dragging = true;
      track.setPointerCapture(ev.pointerId);
      setIdx(idxFromX(ev.clientX));
    });
    track.addEventListener('pointermove', (ev) => { if (dragging) setIdx(idxFromX(ev.clientX)); });
    track.addEventListener('pointerup', () => { dragging = false; });
    track.addEventListener('pointercancel', () => { dragging = false; });

    // Keyboard on the slider track
    track.addEventListener('keydown', (ev) => {
      const k = ev.key;
      if (k === 'ArrowRight' || k === 'ArrowUp') { ev.preventDefault(); setIdx(idx + 1); }
      else if (k === 'ArrowLeft' || k === 'ArrowDown') { ev.preventDefault(); setIdx(idx - 1); }
      else if (k === 'Home') { ev.preventDefault(); setIdx(0); }
      else if (k === 'End') { ev.preventDefault(); setIdx(n - 1); }
    });

    // Letter switching
    letterBtns.forEach((b) =>
      b.addEventListener('click', () => {
        letter = b.dataset.evoLetter!;
        letterBtns.forEach((x) => {
          const on = x === b;
          x.classList.toggle('is-on', on);
          x.setAttribute('aria-pressed', on ? 'true' : 'false');
        });
        render();
      })
    );

    if ((document as any).fonts?.ready) (document as any).fonts.ready.then(render);
    else render();
  });
</script>

<style>
  .evo {
    border: 1px solid var(--line);
    background: var(--bg);
    display: grid;
    grid-template-rows: 1fr auto;
  }
  .evo__grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    min-height: 0;
  }

  /* ---------- Stage ---------- */
  .evo__stage {
    position: relative;
    aspect-ratio: 4 / 3;
    max-height: clamp(360px, 56vh, 560px);
    border-right: 1px solid var(--line);
    display: grid;
    place-items: center;
    overflow: hidden;
    background:
      radial-gradient(120% 120% at 28% 0%, color-mix(in srgb, var(--accent) 12%, transparent), transparent 62%),
      var(--bg-2);
    transition: background 0.6s var(--ease);
  }
  .evo--compact .evo__stage { aspect-ratio: 16 / 11; max-height: clamp(300px, 44vh, 460px); }
  .evo__stage-tag {
    position: absolute; top: var(--sp-3); left: var(--sp-3); z-index: 2;
    font-family: var(--font-mono); font-size: var(--step--1); letter-spacing: 0.1em;
    color: var(--accent); font-weight: 600;
  }
  .evo__svg { width: 100%; height: 100%; opacity: 0.25; }
  .evo__svg.is-in { opacity: 1; transition: opacity 0.45s var(--ease); }
  .evo__svg .dg-glyph { fill: var(--fg); }

  /* ---------- Readout ---------- */
  .evo__readout {
    padding: clamp(1.4rem, 3.4vw, 2.6rem);
    display: flex; flex-direction: column;
    gap: var(--sp-3); justify-content: center; min-height: 0;
  }
  .evo--compact .evo__readout { gap: var(--sp-2); }

  .evo__letters { display: flex; gap: 0.35rem; margin-bottom: var(--sp-1); }
  .evo__letter {
    position: relative;
    width: 40px; height: 40px;
    border: 1px solid var(--line); border-radius: var(--radius);
    font-family: var(--font-mono); font-size: 0.92rem; color: var(--fg-3);
    display: grid; place-items: center;
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease), background-color 0.2s var(--ease);
  }
  .evo__letter:hover { border-color: var(--fg); color: var(--fg); }
  .evo__letter.is-on { background: var(--accent); color: var(--accent-contrast); border-color: var(--accent); }
  /* a dot marks the letter that carries on-glyph spotlights */
  .evo__letter.is-annotated::after {
    content: ''; position: absolute; top: 5px; right: 5px;
    width: 4px; height: 4px; border-radius: 50%; background: var(--accent);
  }
  .evo__letter.is-annotated.is-on::after { background: var(--accent-contrast); }

  .evo__period { color: var(--accent); }
  .evo__name {
    font-family: var(--font-ui); font-size: var(--step-2); font-weight: 650;
    letter-spacing: -0.02em; line-height: 1;
  }
  .evo--compact .evo__name { font-size: var(--step-1); }
  .evo__note { color: var(--fg-2); font-size: var(--step-0); line-height: 1.5; max-width: 42ch; }
  .evo--compact .evo__note { display: none; }

  /* ---------- Trait dimensions ---------- */
  .evo__dims { display: grid; gap: var(--sp-3); margin-top: var(--sp-2); }
  .evo--compact .evo__dims { gap: var(--sp-2); margin-top: var(--sp-1); }
  .evo__dim-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 0.45rem; }
  .evo__dim-label {
    font-family: var(--font-mono); font-size: var(--step--1); font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase; color: var(--fg);
  }
  .evo__dim-value {
    font-family: var(--font-mono); font-size: var(--step--1); letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--accent);
  }
  .evo__dim-track {
    position: relative; height: 2px; background: var(--line);
  }
  .evo__dim-fill {
    position: absolute; left: 0; top: 0; height: 100%; width: 0;
    background: var(--accent); transition: width 0.5s var(--ease);
  }
  .evo__dim-marker {
    position: absolute; top: 50%; left: 0;
    width: 11px; height: 11px; border-radius: 50%;
    background: var(--accent); border: 2px solid var(--bg);
    box-shadow: 0 0 0 1px var(--accent);
    transform: translate(-50%, -50%);
    transition: left 0.5s var(--ease);
  }
  .evo__dim-ends {
    display: flex; justify-content: space-between; margin-top: 0.4rem;
    font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.04em;
    text-transform: uppercase; color: var(--fg-3);
  }
  .evo--compact .evo__dim-ends { display: none; }

  .evo__link {
    font-family: var(--font-mono); font-size: var(--step--1); color: var(--accent);
    text-transform: uppercase; letter-spacing: 0.04em; margin-top: var(--sp-2);
    width: fit-content; border-bottom: 1px solid transparent; transition: border-color 0.2s var(--ease);
  }
  .evo__link:hover { border-color: var(--accent); }

  /* ---------- Timeline ---------- */
  .evo__timeline { border-top: 1px solid var(--line); padding: var(--sp-5) clamp(1.4rem, 3.4vw, 2.6rem) clamp(2.4rem, 4vw, 3rem); }
  .evo__track {
    position: relative; height: 12px; margin-top: 0.5rem;
    cursor: pointer; touch-action: none;
  }
  .evo__track:focus-visible { outline: 2px solid var(--accent); outline-offset: 8px; border-radius: 2px; }
  .evo__track-line {
    position: absolute; left: 0; right: 0; top: 50%; height: 2px;
    background: var(--line); transform: translateY(-50%);
  }
  .evo__track-fill {
    position: absolute; left: 0; top: 50%; height: 2px; width: 0;
    background: var(--accent); transform: translateY(-50%);
    transition: width 0.45s var(--ease);
  }
  .evo__stop {
    position: absolute; top: 50%; left: calc(var(--i) / (var(--n) - 1) * 100%);
    transform: translate(-50%, -50%);
    width: 22px; height: 22px; display: grid; place-items: center;
  }
  .evo__stop-dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--bg); border: 1.5px solid var(--fg-3);
    transition: all 0.2s var(--ease);
  }
  .evo__stop:hover .evo__stop-dot { border-color: var(--fg); transform: scale(1.2); }
  .evo__stop.is-on .evo__stop-dot {
    background: var(--accent); border-color: var(--accent); transform: scale(1.45);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 18%, transparent);
  }
  .evo__stop-label {
    position: absolute; top: 1.4rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; gap: 1px; text-align: center;
    white-space: nowrap; pointer-events: none;
    opacity: 0; transition: opacity 0.2s var(--ease);
  }
  .evo__stop:hover .evo__stop-label,
  .evo__stop.is-on .evo__stop-label { opacity: 1; }
  .evo__stop-name { font-size: var(--step--1); font-weight: 600; color: var(--fg); line-height: 1.1; }
  .evo__stop-period { font-family: var(--font-mono); font-size: 0.66rem; color: var(--fg-3); }
  /* keep the very first/last labels from clipping the edges */
  .evo__stop:first-of-type .evo__stop-label { left: 0; transform: none; text-align: left; }
  .evo__stop:last-of-type .evo__stop-label { left: auto; right: 0; transform: none; text-align: right; }

  /* ---------- Responsive ---------- */
  @media (max-width: 860px) {
    .evo__grid { grid-template-columns: 1fr; }
    .evo__stage { border-right: 0; border-bottom: 1px solid var(--line); aspect-ratio: 4 / 3; max-height: 42vh; }
    .evo--compact .evo__stage { aspect-ratio: 4 / 3; max-height: 38vh; }
  }
  @media (max-width: 560px) {
    .evo__stop-label { display: none; }
    .evo__track { height: 16px; }
    .evo__stop { width: 28px; height: 28px; }
    .evo__dim-ends { display: none; }
    /* show the active era name above the dots instead */
    .evo__timeline { padding-bottom: var(--sp-5); }
  }
</style>
