---
// "The Letter, Through Time" — one letter rendered across every era, with a
// read-only readout of the four dimensions that actually change (serif, contrast,
// stress, terminals). Grab the letter and DRAG it left/right to travel the
// timeline; a slim scrub track beneath shows where you are. The letter itself
// is the control — no sliders, no labelled rail.
import type { CollectionEntry } from 'astro:content';
export interface Props {
  eras: CollectionEntry<'eras'>[];
  compact?: boolean;
}
const { eras, compact = false } = Astro.props;
const data = eras.map((e) => ({
  slug: e.data.slug,
  name: e.data.name,
  period: e.data.period,
  family: e.data.specimenFont.family,
  weight: e.data.specimenFont.weight,
  evolution: e.data.evolution,
  traits: e.data.traits ?? { serif: 0, contrast: 0, stress: 0, terminals: 0 },
}));
const letters = ['R', 'G', 'A', 'E', 'Q', 'M'];
const dims = [
  { key: 'serif', label: 'Serif', lo: 'none', hi: 'slab' },
  { key: 'contrast', label: 'Contrast', lo: 'monoline', hi: 'extreme' },
  { key: 'stress', label: 'Stress', lo: 'vertical', hi: 'diagonal' },
  { key: 'terminals', label: 'Terminals', lo: 'blunt', hi: 'ball' },
];
const n = data.length;
---
<section
  class:list={['evo', { 'evo--compact': compact }]}
  data-evo
  data-eras={JSON.stringify(data)}
>
  <div class="evo__grid">
    <!-- The stage IS the control: grab the letter and drag through time. -->
    <div
      class="evo__stage"
      role="slider"
      tabindex="0"
      aria-valuemin="0"
      aria-valuemax={n - 1}
      aria-valuenow="0"
      aria-label="Drag the letter through the history of type"
      data-evo-stage
    >
      <span class="evo__stage-tag" data-evo-tag aria-hidden="true"></span>
      <svg class="evo__svg" data-evo-svg preserveAspectRatio="xMidYMid meet" role="img" aria-label="A letter shown across the history of type" draggable="false"></svg>
      <span class="evo__hint" data-evo-hint aria-hidden="true">
        <span class="evo__hint-arrow">←</span> drag <span class="evo__hint-arrow">→</span>
      </span>
    </div>

    <div class="evo__readout">
      <div class="evo__letters" role="group" aria-label="Choose a letter">
        {letters.map((l, i) => (
          <button class:list={['evo__letter', { 'is-on': i === 0 }]} data-evo-letter={l} aria-pressed={i === 0 ? 'true' : 'false'}>
            <span>{l}</span>
          </button>
        ))}
      </div>

      <span class="evo__period label" data-evo-period></span>
      <h3 class="evo__name" data-evo-name></h3>
      <p class="evo__note" data-evo-note></p>

      <div class="evo__dims" data-evo-dims>
        {dims.map((d) => (
          <div class="evo__dim" data-dim={d.key}>
            <div class="evo__dim-head">
              <span class="evo__dim-label">{d.label}</span>
              <span class="evo__dim-value" data-dim-value></span>
            </div>
            <div class="evo__dim-track">
              <span class="evo__dim-ghost" data-dim-ghost></span>
              <span class="evo__dim-fill" data-dim-fill></span>
            </div>
            <div class="evo__dim-ends">
              <span>{d.lo}</span>
              <span>{d.hi}</span>
            </div>
          </div>
        ))}
      </div>

      <a class="evo__link" data-evo-link>Read the chapter <span aria-hidden="true">→</span></a>
    </div>
  </div>

  <!-- Refined scrub track: position only, no labels, no per-era colour wash. -->
  <div class="evo__scrub" data-evo-scrub>
    <ol class="evo__ticks">
      <span class="evo__scrub-line" aria-hidden="true"></span>
      <span class="evo__scrub-fill" data-evo-fill aria-hidden="true"></span>
      {data.map((e, i) => (
        <li>
          <button
            class:list={['evo__tick', { 'is-on': i === 0 }]}
            data-evo-tick={i}
            title={`${e.name} — ${e.period}`}
            aria-label={`${e.name} — ${e.period}`}
          ></button>
        </li>
      ))}
    </ol>
  </div>
</section>

<script>
  import { renderGlyphDiagram } from '../../lib/diagram';

  const pct = (v: number) => `${(Math.max(0, Math.min(1, v)) * 100).toFixed(1)}%`;
  const valueWord = (v: number) =>
    v < 0.12 ? 'none' : v < 0.34 ? 'low' : v < 0.62 ? 'mid' : v < 0.85 ? 'high' : 'max';
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll<HTMLElement>('[data-evo]').forEach((root) => {
    const eras = JSON.parse(root.dataset.eras || '[]');
    const stage = root.querySelector('[data-evo-stage]') as HTMLElement;
    const svg = root.querySelector('[data-evo-svg]') as SVGElement;
    const tag = root.querySelector('[data-evo-tag]') as HTMLElement;
    const period = root.querySelector('[data-evo-period]') as HTMLElement;
    const name = root.querySelector('[data-evo-name]') as HTMLElement;
    const note = root.querySelector('[data-evo-note]') as HTMLElement;
    const link = root.querySelector('[data-evo-link]') as HTMLAnchorElement;
    const fill = root.querySelector('[data-evo-fill]') as HTMLElement;
    const tickBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-evo-tick]'));
    const letterBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-evo-letter]'));
    const dimRows = Array.from(root.querySelectorAll<HTMLElement>('.evo__dim'));

    const n = eras.length;
    let idx = 0;
    let prevIdx = 0;
    let letter = 'R';

    const setDims = (e: any, prev: any) => {
      dimRows.forEach((row) => {
        const key = row.dataset.dim!;
        const v = e.traits?.[key] ?? 0;
        const pv = prev?.traits?.[key] ?? v;
        (row.querySelector('[data-dim-fill]') as HTMLElement).style.width = pct(v);
        (row.querySelector('[data-dim-ghost]') as HTMLElement).style.width = pct(pv);
        (row.querySelector('[data-dim-value]') as HTMLElement).textContent = valueWord(v);
      });
    };

    const render = (animate = true) => {
      const e = eras[idx];
      const prev = eras[prevIdx];
      // NB: the scrub UI keeps the page's own accent — we deliberately do NOT
      // repaint it with each era's colour, which both flashed badly while
      // dragging and broke contrast (e.g. a light accent on the light home).
      const num = String(idx + 1).padStart(2, '0');
      period.textContent = `${num} · ${e.period}`;
      tag.textContent = `${num} / ${String(n).padStart(2, '0')}`;
      name.textContent = e.name;
      note.textContent = e.evolution;
      link.href = `/history/${e.slug}`;

      tickBtns.forEach((t, i) => {
        t.classList.toggle('is-on', i === idx);
        t.classList.toggle('is-past', i < idx);
      });
      // fill spans between the first and last tick centres (each tick is 26px wide)
      const frac = n > 1 ? idx / (n - 1) : 0;
      fill.style.width = `calc((100% - 26px) * ${frac})`;

      stage.setAttribute('aria-valuenow', String(idx));
      stage.setAttribute('aria-valuetext', `${e.name}, ${e.period}`);

      setDims(e, prev);

      const dir = idx >= prevIdx ? 1 : -1;
      if (animate && !reduce) {
        svg.classList.remove('is-in');
        svg.style.transform = `translateX(${dir * 14}px)`;
      }
      renderGlyphDiagram(svg, {
        family: e.family,
        glyph: letter,
        weight: e.weight,
        guides: ['cap', 'baseline'],
        fill: 0.74,
      }).then(() => requestAnimationFrame(() => {
        svg.classList.add('is-in');
        svg.style.transform = '';
      }));
    };

    const setIdx = (i: number, animate = true) => {
      const next = Math.max(0, Math.min(n - 1, Math.round(i)));
      if (next === idx) return;
      prevIdx = idx;
      idx = next;
      render(animate);
    };

    // Click a tick on the scrub track to jump
    tickBtns.forEach((t, i) => t.addEventListener('click', () => setIdx(i)));

    // Drag the letter through time
    let dragging = false;
    let startX = 0;
    let startIdx = 0;
    const onDown = (ev: PointerEvent) => {
      ev.preventDefault(); // no text/image selection, no native image-drag
      dragging = true;
      startX = ev.clientX;
      startIdx = idx;
      stage.setPointerCapture(ev.pointerId);
      stage.classList.add('is-dragging');
      root.classList.add('evo--touched');
    };
    const onMove = (ev: PointerEvent) => {
      if (!dragging) return;
      const span = stage.getBoundingClientRect().width;
      // a full sweep across the stage covers the whole timeline
      const delta = ((ev.clientX - startX) / span) * (n - 1) * 1.25;
      setIdx(startIdx + delta, false); // instant during a drag — no flip stutter
    };
    const onUp = (ev: PointerEvent) => {
      dragging = false;
      stage.classList.remove('is-dragging');
      try { stage.releasePointerCapture(ev.pointerId); } catch {}
    };
    stage.addEventListener('pointerdown', onDown);
    stage.addEventListener('pointermove', onMove);
    stage.addEventListener('pointerup', onUp);
    stage.addEventListener('pointercancel', onUp);
    // Belt and braces: never let a drag start a selection on the stage.
    stage.addEventListener('dragstart', (e) => e.preventDefault());
    stage.addEventListener('selectstart', (e) => e.preventDefault());

    // Keyboard on the stage
    stage.addEventListener('keydown', (ev) => {
      const k = ev.key;
      if (k === 'ArrowRight' || k === 'ArrowUp') { ev.preventDefault(); setIdx(idx + 1); }
      else if (k === 'ArrowLeft' || k === 'ArrowDown') { ev.preventDefault(); setIdx(idx - 1); }
      else if (k === 'Home') { ev.preventDefault(); setIdx(0); }
      else if (k === 'End') { ev.preventDefault(); setIdx(n - 1); }
    });

    // Letter switching
    letterBtns.forEach((b) =>
      b.addEventListener('click', () => {
        letter = b.dataset.evoLetter!;
        letterBtns.forEach((x) => {
          const on = x === b;
          x.classList.toggle('is-on', on);
          x.setAttribute('aria-pressed', on ? 'true' : 'false');
        });
        render(false);
      })
    );

    if ((document as any).fonts?.ready) (document as any).fonts.ready.then(() => render(false));
    else render(false);
  });
</script>

<style>
  .evo {
    --evo-bg: color-mix(in srgb, var(--accent) 4%, var(--bg));
    border: 1px solid var(--line);
    background: var(--evo-bg);
    display: grid;
    grid-template-rows: 1fr auto;
    /* the whole widget is a control — never let a drag select its text/glyphs */
    user-select: none;
    -webkit-user-select: none;
    transition: background-color 0.6s var(--ease);
  }
  .evo__grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    min-height: 0;
  }

  /* ---------- Stage (the control) ---------- */
  .evo__stage {
    position: relative;
    aspect-ratio: 4 / 3;
    max-height: clamp(360px, 56vh, 560px);
    border-right: 1px solid var(--line);
    display: grid;
    place-items: center;
    overflow: hidden;
    cursor: grab;
    touch-action: none;
    background:
      radial-gradient(120% 120% at 30% 0%, color-mix(in srgb, var(--accent) 10%, transparent), transparent 62%),
      var(--bg-2);
    transition: background 0.6s var(--ease);
  }
  .evo__stage:focus-visible { outline: 2px solid var(--accent); outline-offset: -4px; }
  .evo__stage.is-dragging { cursor: grabbing; }
  .evo--compact .evo__stage { aspect-ratio: 16 / 11; max-height: clamp(300px, 44vh, 460px); }
  .evo__stage-tag {
    position: absolute; top: var(--sp-3); left: var(--sp-3); z-index: 2;
    font-family: var(--font-mono); font-size: var(--step--1); letter-spacing: 0.1em;
    color: var(--accent); font-weight: 600;
  }
  .evo__svg {
    width: 100%; height: 100%; opacity: 0.001;
    pointer-events: none; /* clicks/drag belong to the stage, not the glyph */
    transition: transform 0.5s var(--ease);
  }
  .evo__svg.is-in { opacity: 1; transition: opacity 0.4s var(--ease), transform 0.5s var(--ease); }
  .evo__svg .dg-glyph { fill: var(--fg); }

  .evo__hint {
    position: absolute; left: 50%; bottom: var(--sp-3); transform: translateX(-50%); z-index: 2;
    font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--fg-3); display: inline-flex; align-items: center; gap: 0.5em;
    pointer-events: none; transition: opacity 0.4s var(--ease);
  }
  .evo--touched .evo__hint { opacity: 0; }
  .evo__hint-arrow { animation: evo-nudge 1.8s var(--ease) infinite; color: var(--accent); }
  .evo__hint-arrow:last-child { animation-delay: 0.9s; }
  @keyframes evo-nudge { 0%, 100% { transform: translateX(0); } 50% { transform: translateX(3px); } }

  /* ---------- Readout ---------- */
  .evo__readout {
    padding: clamp(1.4rem, 3.4vw, 2.6rem);
    display: flex; flex-direction: column;
    gap: var(--sp-3); justify-content: center; min-height: 0;
  }
  .evo--compact .evo__readout { gap: var(--sp-2); }

  .evo__letters { display: flex; gap: 0.35rem; margin-bottom: var(--sp-1); }
  .evo__letter {
    position: relative;
    width: 40px; height: 40px;
    border: 1px solid var(--line); border-radius: var(--radius);
    font-family: var(--font-mono); font-size: 0.92rem; color: var(--fg-3);
    display: grid; place-items: center;
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease), background-color 0.2s var(--ease);
  }
  .evo__letter:hover { border-color: var(--fg); color: var(--fg); }
  .evo__letter.is-on { background: var(--accent); color: var(--accent-contrast); border-color: var(--accent); }

  .evo__period { color: var(--accent); }
  .evo__name {
    font-family: var(--font-ui); font-size: var(--step-2); font-weight: 650;
    letter-spacing: -0.02em; line-height: 1;
  }
  .evo--compact .evo__name { font-size: var(--step-1); }
  .evo__note { color: var(--fg-2); font-size: var(--step-0); line-height: 1.5; max-width: 42ch; }
  .evo--compact .evo__note { display: none; }

  /* ---------- Trait dimensions (read-only bars) ---------- */
  .evo__dims { display: grid; gap: var(--sp-3); margin-top: var(--sp-2); }
  .evo--compact .evo__dims { gap: var(--sp-2); margin-top: var(--sp-1); }
  .evo__dim-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 0.45rem; }
  .evo__dim-label {
    font-family: var(--font-mono); font-size: var(--step--1); font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase; color: var(--fg);
  }
  .evo__dim-value {
    font-family: var(--font-mono); font-size: var(--step--1); letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--accent);
  }
  .evo__dim-track {
    position: relative; height: 6px; background: color-mix(in srgb, var(--fg) 8%, transparent);
    border-radius: 100px; overflow: hidden;
  }
  /* faint trace of where the previous era sat */
  .evo__dim-ghost {
    position: absolute; left: 0; top: 0; height: 100%; width: 0;
    background: color-mix(in srgb, var(--accent) 22%, transparent);
    transition: width 0.6s var(--ease);
  }
  .evo__dim-fill {
    position: absolute; left: 0; top: 0; height: 100%; width: 0;
    background: var(--accent); border-radius: 100px;
    transition: width 0.55s var(--ease);
  }
  .evo__dim-ends {
    display: flex; justify-content: space-between; margin-top: 0.4rem;
    font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.04em;
    text-transform: uppercase; color: var(--fg-3);
  }
  .evo--compact .evo__dim-ends { display: none; }

  .evo__link {
    font-family: var(--font-mono); font-size: var(--step--1); color: var(--accent);
    text-transform: uppercase; letter-spacing: 0.04em; margin-top: var(--sp-2);
    width: fit-content; border-bottom: 1px solid transparent; transition: border-color 0.2s var(--ease);
  }
  .evo__link:hover { border-color: var(--accent); }

  /* ---------- Scrub track (position only) ---------- */
  .evo__scrub {
    position: relative;
    border-top: 1px solid var(--line);
    padding: var(--sp-4) clamp(1.4rem, 3.4vw, 2.6rem);
    min-height: 1px;
  }
  .evo__ticks {
    position: relative; display: flex; justify-content: space-between; align-items: center;
  }
  /* line + fill ride between the first and last tick centres (13px inset = half a tick) */
  .evo__scrub-line {
    position: absolute; left: 13px; right: 13px; top: 50%; height: 2px; transform: translateY(-50%);
    background: color-mix(in srgb, var(--fg) 12%, transparent); border-radius: 100px;
  }
  .evo__scrub-fill {
    position: absolute; left: 13px; top: 50%; height: 2px; width: 0; transform: translateY(-50%);
    background: color-mix(in srgb, var(--accent) 70%, transparent); border-radius: 100px;
    transition: width 0.45s var(--ease);
  }
  .evo__tick {
    position: relative; width: 26px; height: 26px;
    display: grid; place-items: center;
  }
  .evo__tick::after {
    content: ''; width: 9px; height: 9px; border-radius: 50%;
    background: var(--bg); border: 1.5px solid color-mix(in srgb, var(--fg) 28%, transparent);
    transition: transform 0.25s var(--ease), background-color 0.25s var(--ease), border-color 0.25s var(--ease);
  }
  .evo__tick:hover::after { border-color: var(--accent); transform: scale(1.18); }
  .evo__tick.is-past::after { background: color-mix(in srgb, var(--fg) 30%, transparent); border-color: transparent; }
  .evo__tick.is-on::after {
    background: var(--accent); border-color: var(--accent);
    transform: scale(1.25);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 16%, transparent);
  }
  /* ---------- Responsive ---------- */
  @media (max-width: 860px) {
    .evo__grid { grid-template-columns: 1fr; }
    .evo__stage { border-right: 0; border-bottom: 1px solid var(--line); aspect-ratio: 4 / 3; max-height: 42vh; }
    .evo--compact .evo__stage { aspect-ratio: 4 / 3; max-height: 38vh; }
  }
  @media (prefers-reduced-motion: reduce) {
    .evo__hint-arrow { animation: none; }
    .evo__svg, .evo__dim-fill, .evo__dim-ghost, .evo__scrub-fill, .evo__tick::after { transition: none; }
  }
</style>
