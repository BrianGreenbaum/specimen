---
// An oversized editorial pull quote, set in the era's representative face.
//   <PullQuote cite="Beatrice Warde, 1930" family="EB Garamond Variable">
//     The Crystal Goblet
//   </PullQuote>
export interface Props {
  cite?: string;
  family?: string;   // defaults to the chapter's --term-fam (era specimen family)
}
const { cite, family } = Astro.props;
const famStyle = family ? `font-family:'${family}'` : '';
---
<figure class="pq">
  <span class="pq__mark" aria-hidden="true">✳</span>
  <blockquote class="pq__quote" style={famStyle}>
    <slot />
  </blockquote>
  {cite && <figcaption class="pq__cite label">— {cite}</figcaption>}
</figure>

<style>
  .pq {
    margin-block: clamp(2.2rem, 6vw, 4rem);
    padding-left: clamp(1.2rem, 4vw, 2.6rem);
    border-left: 2px solid var(--accent);
    max-width: 30ch;
  }
  .pq__mark { color: var(--accent); font-size: 1rem; display: block; margin-bottom: var(--sp-2); }
  .pq__quote {
    font-family: var(--term-fam, var(--font-ui));
    font-size: clamp(1.8rem, 4.5vw, 3.2rem);
    line-height: 1.08; letter-spacing: -0.01em; color: var(--fg);
    font-style: italic;
  }
  .pq__cite { display: block; margin-top: var(--sp-3); color: var(--fg-3); font-style: normal; }
  /* float it to the side on wide screens for a magazine feel */
  @media (min-width: 1024px) {
    .pq { float: right; width: 30ch; margin-left: var(--sp-6); margin-right: calc(-1 * clamp(0rem, 6vw, 6rem)); }
  }
</style>
