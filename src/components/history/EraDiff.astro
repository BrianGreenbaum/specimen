---
// "What changed" — compares this era to the one before it, and lets you FEEL
// it: grab the letter and drag between the previous era's form and this one.
// The ghost/current letters crossfade and the four trait bars interpolate
// live with the drag. On scroll-in it plays the transition once by itself.
export interface EraSnapshot {
  name: string;
  period: string;
  family: string;
  weight: number;
  glyph: string;
  traits: { serif: number; contrast: number; stress: number; terminals: number };
}
export interface Props {
  prev: EraSnapshot;
  current: EraSnapshot;
  copy: string;          // the "what changed" prose (evolution / diffNote)
}
const { prev, current, copy } = Astro.props;
const dims = [
  { key: 'serif', label: 'Serif' },
  { key: 'contrast', label: 'Contrast' },
  { key: 'stress', label: 'Stress' },
  { key: 'terminals', label: 'Terminals' },
] as const;
const word = (v: number) =>
  v < 0.12 ? 'none' : v < 0.34 ? 'low' : v < 0.62 ? 'mid' : v < 0.85 ? 'high' : 'max';
// Use the current era's spotlight glyph (fall back to a shared 'R').
const glyph = current.glyph || 'R';
const payload = JSON.stringify({ prev, current, glyph });
---
<section class="diff" data-diff={payload}>
  <div class="diff__head">
    <span class="index-num">✳</span>
    <span class="label">What changed · since {prev.name}</span>
  </div>

  <div class="diff__grid">
    <div
      class="diff__stage"
      data-diff-stage
      role="slider"
      tabindex="0"
      aria-valuemin="0"
      aria-valuemax="100"
      aria-valuenow="100"
      aria-label={`Drag the letter ${glyph} between ${prev.name} and ${current.name}`}
    >
      <svg class="diff__svg diff__svg--ghost" data-diff-ghost preserveAspectRatio="xMidYMid meet" aria-hidden="true"></svg>
      <svg class="diff__svg diff__svg--now" data-diff-now preserveAspectRatio="xMidYMid meet" aria-hidden="true"></svg>
      <span class="diff__tag diff__tag--ghost" data-diff-tag-ghost style={`font-family:'${prev.family}'`}>{prev.name}</span>
      <span class="diff__tag diff__tag--now" data-diff-tag-now>{current.name}</span>
      <span class="diff__hint" data-diff-hint aria-hidden="true"><span class="diff__hint-arrow">←</span> drag <span class="diff__hint-arrow">→</span></span>
    </div>

    <div class="diff__body">
      <p class="diff__copy">{copy}</p>
      <ul class="diff__dims">
        {dims.map((d) => (
          <li class="diff__dim" data-diff-dim={d.key}>
            <div class="diff__dim-head">
              <span class="diff__dim-label">{d.label}</span>
              <span class="diff__dim-delta" data-diff-delta>
                {word(prev.traits[d.key])} <span class="diff__arrow">→</span> {word(current.traits[d.key])}
              </span>
            </div>
            <div class="diff__dim-track">
              <span class="diff__dim-fill" data-diff-fill></span>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<script>
  import { renderGlyphDiagram } from '../../lib/diagram';
  const pct = (v: number) => `${(Math.max(0, Math.min(1, v)) * 100).toFixed(1)}%`;
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const clamp01 = (v: number) => Math.max(0, Math.min(1, v));
  const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

  document.querySelectorAll<HTMLElement>('[data-diff]').forEach((root) => {
    const { prev, current, glyph } = JSON.parse(root.dataset.diff || '{}');
    const stage = root.querySelector('[data-diff-stage]') as HTMLElement;
    const ghost = root.querySelector('[data-diff-ghost]') as SVGElement;
    const now = root.querySelector('[data-diff-now]') as SVGElement;
    const tagGhost = root.querySelector('[data-diff-tag-ghost]') as HTMLElement;
    const tagNow = root.querySelector('[data-diff-tag-now]') as HTMLElement;
    const hint = root.querySelector('[data-diff-hint]') as HTMLElement;
    const rows = Array.from(root.querySelectorAll<HTMLElement>('[data-diff-dim]')).map((row) => ({
      key: row.dataset.diffDim as 'serif' | 'contrast' | 'stress' | 'terminals',
      fill: row.querySelector('[data-diff-fill]') as HTMLElement,
      row,
    }));

    renderGlyphDiagram(ghost, { family: prev.family, glyph, weight: prev.weight, fill: 0.82 });
    renderGlyphDiagram(now, { family: current.family, glyph, weight: current.weight, guides: ['cap', 'baseline'], fill: 0.82 });

    // t = 0 → fully the previous era; t = 1 → fully this era.
    let t = reduce ? 1 : 0;
    const apply = () => {
      ghost.style.opacity = String(0.9 * (1 - t) + 0.14 * t);
      now.style.opacity = String(Math.pow(t, 0.8));
      tagGhost.style.opacity = String(0.45 + 0.55 * (1 - t));
      tagNow.style.opacity = String(0.45 + 0.55 * t);
      for (const r of rows) {
        r.fill.style.width = pct(lerp(prev.traits[r.key] ?? 0, current.traits[r.key] ?? 0, t));
      }
      stage.setAttribute('aria-valuenow', String(Math.round(t * 100)));
    };
    apply();

    // Scroll-in: play the transition once, so the page reads even untouched.
    if (!reduce) {
      const io = new IntersectionObserver((entries) => {
        for (const en of entries) {
          if (!en.isIntersecting) continue;
          io.disconnect();
          const start = performance.now();
          const dur = 1500;
          const ease = (x: number) => 1 - Math.pow(1 - x, 3);
          const tick = (nowMs: number) => {
            if (root.classList.contains('is-touched')) return; // user took over
            t = ease(clamp01((nowMs - start) / dur));
            apply();
            if (t < 1) requestAnimationFrame(tick);
            else root.classList.add('is-live');
          };
          requestAnimationFrame(tick);
        }
      }, { rootMargin: '0px 0px -18% 0px', threshold: 0.2 });
      io.observe(root);
    }

    // Drag anywhere on the stage: position maps to t.
    let dragging = false;
    const fromEvent = (ev: PointerEvent) => {
      const r = stage.getBoundingClientRect();
      return clamp01((ev.clientX - r.left) / r.width);
    };
    stage.addEventListener('pointerdown', (ev) => {
      ev.preventDefault();
      dragging = true;
      root.classList.add('is-touched', 'is-live');
      if (hint) hint.style.opacity = '0';
      stage.setPointerCapture(ev.pointerId);
      stage.classList.add('is-dragging');
      t = fromEvent(ev);
      apply();
    });
    stage.addEventListener('pointermove', (ev) => {
      if (!dragging) return;
      t = fromEvent(ev);
      apply();
    });
    const up = (ev: PointerEvent) => {
      dragging = false;
      stage.classList.remove('is-dragging');
      try { stage.releasePointerCapture(ev.pointerId); } catch {}
    };
    stage.addEventListener('pointerup', up);
    stage.addEventListener('pointercancel', up);
    stage.addEventListener('selectstart', (e) => e.preventDefault());

    // Keyboard
    stage.addEventListener('keydown', (ev) => {
      const step = 0.1;
      if (ev.key === 'ArrowRight' || ev.key === 'ArrowUp') { ev.preventDefault(); t = clamp01(t + step); }
      else if (ev.key === 'ArrowLeft' || ev.key === 'ArrowDown') { ev.preventDefault(); t = clamp01(t - step); }
      else if (ev.key === 'Home') { ev.preventDefault(); t = 0; }
      else if (ev.key === 'End') { ev.preventDefault(); t = 1; }
      else return;
      root.classList.add('is-touched', 'is-live');
      if (hint) hint.style.opacity = '0';
      apply();
    });
  });
</script>

<style>
  .diff { padding-top: var(--sp-6); }
  .diff__head { display: flex; align-items: baseline; gap: var(--sp-3); margin-bottom: var(--sp-4); }
  .diff__head .index-num { color: var(--accent); }

  .diff__grid {
    display: grid; grid-template-columns: 0.85fr 1.15fr; gap: var(--sp-6); align-items: center;
    border: 1px solid var(--line);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--accent) 5%, transparent), transparent 40%),
      var(--bg-2);
    padding: clamp(1.4rem, 3.5vw, 2.6rem);
  }

  .diff__stage {
    position: relative; aspect-ratio: 1 / 1;
    display: grid; place-items: center;
    cursor: grab; touch-action: none;
    user-select: none; -webkit-user-select: none;
  }
  .diff__stage.is-dragging { cursor: grabbing; }
  .diff__stage:focus-visible { outline: 2px solid var(--accent); outline-offset: -4px; }
  .diff__svg { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; }
  .diff__svg--ghost { transform: translate(-6%, 2%) scale(0.97); }
  .diff__svg--ghost :global(.dg-glyph) { fill: var(--fg-3); }
  .diff__svg--now :global(.dg-glyph) { fill: var(--fg); }

  .diff__tag {
    position: absolute; bottom: 0; font-family: var(--font-mono);
    font-size: 0.66rem; letter-spacing: 0.1em; text-transform: uppercase;
    transition: opacity 0.2s linear;
  }
  .diff__tag--ghost { left: 0; color: var(--fg-3); }
  .diff__tag--now { right: 0; color: var(--accent); }

  .diff__hint {
    position: absolute; left: 50%; top: 0; transform: translateX(-50%);
    font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--fg-3); display: inline-flex; align-items: center; gap: 0.5em;
    pointer-events: none; transition: opacity 0.4s var(--ease);
  }
  .diff__hint-arrow { animation: diff-nudge 1.8s var(--ease) infinite; color: var(--accent); }
  .diff__hint-arrow:last-child { animation-delay: 0.9s; }
  @keyframes diff-nudge { 0%, 100% { transform: translateX(0); } 50% { transform: translateX(3px); } }

  .diff__copy {
    font-family: var(--font-ui); font-size: var(--step-1); line-height: 1.4;
    color: var(--fg); letter-spacing: -0.01em; margin-bottom: var(--sp-4); max-width: 40ch;
  }
  .diff__dims { display: grid; gap: var(--sp-3); }
  .diff__dim-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 0.4rem; }
  .diff__dim-label {
    font-family: var(--font-mono); font-size: var(--step--1); font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  .diff__dim-delta {
    font-family: var(--font-mono); font-size: var(--step--1); letter-spacing: 0.04em;
    text-transform: uppercase; color: var(--fg-2);
  }
  .diff__arrow { color: var(--accent); padding: 0 0.15em; }
  .diff__dim-track {
    position: relative; height: 6px; border-radius: 100px;
    background: color-mix(in srgb, var(--fg) 8%, transparent); overflow: hidden;
  }
  .diff__dim-fill {
    position: absolute; left: 0; top: 0; height: 100%; width: 0; border-radius: 100px;
    background: var(--accent);
  }

  @media (max-width: 760px) {
    .diff__grid { grid-template-columns: 1fr; gap: var(--sp-4); }
    .diff__stage { aspect-ratio: 3 / 2; width: 100%; max-width: 20rem; margin-inline: auto; }
  }
  @media (prefers-reduced-motion: reduce) {
    .diff__hint { display: none; }
    .diff__hint-arrow { animation: none; }
  }
</style>
