---
// Guided journey navigation for the paged History chapters.
// variant="rail"   → sticky top progress rail (✳ nodes) + "jump to any era" menu
// variant="footer" → big "Next chapter" call-to-action band
export interface EraRef { slug: string; name: string; order: number; period: string; accent: string; }
export interface Props {
  index: number;            // 1-based chapter number (era order)
  total: number;            // total chapters
  all: EraRef[];            // every era, sorted, for the rail + jump menu
  prev: EraRef;             // previous chapter (cyclic)
  next: EraRef;             // next chapter (cyclic)
  variant?: 'rail' | 'footer';
}
const { index, total, all, prev, next, variant = 'rail' } = Astro.props;
const nn = (n: number) => String(n).padStart(2, '0');
const loopsBack = next.order < index; // chapter 8 → back to the beginning
---
{variant === 'rail' && (
  <nav class="cnav" aria-label="History chapters">
    <div class="container cnav__inner">
      <a href="/history" class="cnav__home label"><span class="cnav__home-mark">✳</span> <span class="cnav__home-text">The History of Type</span></a>

      <ol class="cnav__rail" aria-hidden="true">
        {all.map((e) => (
          <li>
            <a
              href={`/history/${e.slug}`}
              class:list={['cnav__node', { 'is-on': e.order === index, 'is-past': e.order < index }]}
              style={`--node-accent:${e.accent}`}
              title={`${nn(e.order)} · ${e.name}`}
            >✳</a>
          </li>
        ))}
      </ol>

      <details class="cnav__jump">
        <summary class="label">
          <span class="cnav__count">Chapter {nn(index)} / {nn(total)}</span>
          <span class="cnav__jump-cue">Jump to era ▾</span>
        </summary>
        <ol class="cnav__menu">
          {all.map((e) => (
            <li>
              <a
                href={`/history/${e.slug}`}
                class:list={['cnav__menu-item', { 'is-on': e.order === index }]}
                style={`--node-accent:${e.accent}`}
              >
                <span class="cnav__menu-num">{nn(e.order)}</span>
                <span class="cnav__menu-name">{e.name}</span>
                <span class="cnav__menu-period">{e.period}</span>
              </a>
            </li>
          ))}
        </ol>
      </details>
    </div>
  </nav>
)}

{variant === 'footer' && (
  <nav class="cfoot" aria-label="Continue reading">
    <a
      href={`/history/${next.slug}`}
      class="cfoot__next"
      style={`--next-accent:${next.accent}`}
    >
      <span class="cfoot__kicker label">{loopsBack ? 'Full circle' : `Next · Chapter ${nn(next.order)}`}</span>
      <span class="cfoot__name">{next.name}</span>
      <span class="cfoot__arrow" aria-hidden="true">{loopsBack ? '↺' : '→'}</span>
    </a>
    <div class="cfoot__aside">
      <a href={`/history/${prev.slug}`} class="cfoot__link">
        <span class="label">← Chapter {nn(prev.order)}</span>
        <span class="cfoot__link-name">{prev.name}</span>
      </a>
      <a href="/history" class="cfoot__link cfoot__link--index">
        <span class="label">Index</span>
        <span class="cfoot__link-name">All {total} chapters ✳</span>
      </a>
    </div>
  </nav>
)}

<style>
  /* ---------- Rail ---------- */
  .cnav {
    position: sticky; top: 64px; z-index: 90;
    background: color-mix(in srgb, var(--bg) 86%, transparent);
    backdrop-filter: saturate(1.3) blur(12px);
    -webkit-backdrop-filter: saturate(1.3) blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .cnav__inner { display: flex; align-items: center; gap: var(--sp-4); min-height: 52px; }
  .cnav__home { color: var(--fg-2); white-space: nowrap; transition: color 0.2s var(--ease); }
  .cnav__home:hover { color: var(--accent); }

  .cnav__rail { display: flex; align-items: center; gap: clamp(0.5rem, 2.2vw, 1.4rem); margin-inline: auto; }
  .cnav__node {
    display: grid; place-items: center; width: 1.5rem; height: 1.5rem;
    font-size: 0.7rem; line-height: 1; color: var(--fg-3); opacity: 0.5;
    transition: all 0.3s var(--ease);
  }
  .cnav__node:hover { opacity: 1; color: var(--node-accent); transform: scale(1.25); }
  .cnav__node.is-past { opacity: 0.85; color: var(--node-accent); }
  .cnav__node.is-on {
    opacity: 1; color: var(--node-accent); font-size: 1rem;
    transform: scale(1.1);
    animation: cnav-spin 14s linear infinite;
  }
  @keyframes cnav-spin { to { transform: scale(1.1) rotate(360deg); } }

  /* ---------- Jump menu (native details) ---------- */
  .cnav__jump { position: relative; margin-left: auto; }
  .cnav__jump summary {
    display: flex; align-items: center; gap: 0.6rem; cursor: pointer; list-style: none;
    padding: 0.4rem 0; white-space: nowrap;
  }
  .cnav__jump summary::-webkit-details-marker { display: none; }
  .cnav__count { color: var(--fg); font-weight: 600; }
  .cnav__jump-cue { color: var(--accent); }
  .cnav__menu {
    position: absolute; right: 0; top: calc(100% + 0.6rem); z-index: 5;
    width: min(86vw, 320px); padding: 0.4rem;
    background: var(--bg); border: 1px solid var(--fg);
    box-shadow: 0 20px 50px -20px color-mix(in srgb, var(--fg) 40%, transparent);
  }
  .cnav__menu-item {
    display: grid; grid-template-columns: 2rem 1fr auto; align-items: baseline; gap: 0.7rem;
    padding: 0.6rem 0.7rem; transition: background 0.18s var(--ease);
  }
  .cnav__menu-item:hover { background: color-mix(in srgb, var(--node-accent) 12%, var(--bg)); }
  .cnav__menu-item.is-on { background: color-mix(in srgb, var(--node-accent) 16%, var(--bg)); }
  .cnav__menu-num { font-family: var(--font-mono); font-size: var(--step--1); color: var(--node-accent); }
  .cnav__menu-name { font-family: var(--font-ui); font-weight: 600; font-size: var(--step-0); }
  .cnav__menu-period { font-family: var(--font-mono); font-size: 0.66rem; color: var(--fg-3); }

  @media (max-width: 960px) {
    /* the rail itself stands in for the title; drop the words to keep the row roomy */
    .cnav__home-text { display: none; }
  }
  @media (max-width: 720px) {
    .cnav__rail { display: none; }
    .cnav__jump { margin-left: auto; }
  }
  @media (max-width: 460px) {
    .cnav__jump summary { gap: 0.4rem; }
    .cnav__jump-cue { white-space: nowrap; }
  }

  /* ---------- Footer CTA ---------- */
  .cfoot { margin-top: var(--sp-7); border-top: 1px solid var(--fg); }
  .cfoot__next {
    position: relative; display: flex; align-items: center; gap: var(--sp-4);
    padding: clamp(2.2rem, 7vw, 4.5rem) 0 clamp(1.8rem, 5vw, 3rem);
    overflow: hidden;
  }
  .cfoot__kicker { position: absolute; top: var(--sp-4); left: 0; color: var(--next-accent); }
  .cfoot__name {
    font-family: var(--font-ui); font-weight: 680; letter-spacing: -0.03em; line-height: 0.92;
    font-size: clamp(2.6rem, 9vw, 6.5rem);
    transition: color 0.3s var(--ease), transform 0.5s var(--ease);
  }
  .cfoot__arrow {
    font-size: clamp(2rem, 6vw, 4rem); color: var(--next-accent); margin-left: auto;
    transition: transform 0.4s var(--ease);
  }
  .cfoot__next:hover .cfoot__name { color: var(--next-accent); }
  .cfoot__next:hover .cfoot__arrow { transform: translateX(0.4rem); }

  .cfoot__aside {
    display: flex; justify-content: space-between; gap: var(--sp-4);
    padding-bottom: var(--sp-6); border-top: 1px solid var(--line); padding-top: var(--sp-4);
  }
  .cfoot__link { display: flex; flex-direction: column; gap: 0.25rem; }
  .cfoot__link--index { text-align: right; }
  .cfoot__link-name { font-family: var(--font-ui); font-size: var(--step-0); font-weight: 600; color: var(--fg-2); transition: color 0.2s var(--ease); }
  .cfoot__link:hover .cfoot__link-name { color: var(--accent); }

  @media (prefers-reduced-motion: reduce) {
    .cnav__node.is-on { animation: none; }
  }
</style>
