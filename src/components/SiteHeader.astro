---
import { getCollection } from 'astro:content';
import ColorModeToggle from './ColorModeToggle.astro';
export interface Props {
  current?: string; // current font name, shown as breadcrumb
  showToggle?: boolean; // hidden on fixed-theme (font/era) pages
}
const { current, showToggle = true } = Astro.props;

// Menus shown on hover/focus under the History and Fonts links.
const eras = (await getCollection('eras')).sort((a, b) => a.data.order - b.data.order);
const fonts = (await getCollection('fonts')).sort((a, b) => a.data.order - b.data.order);

// Lexicon sections — kept in sync with the groups in /glossary.
const lexSections = [
  { id: 'anatomy', name: 'Anatomy', meta: 'Parts of a letter' },
  { id: 'metrics', name: 'Metrics', meta: 'The guiding lines' },
  { id: 'setting', name: 'Setting', meta: 'Space & rhythm' },
  { id: 'lineage', name: 'Lineages', meta: 'Families of type' },
  { id: 'screen', name: 'On screen', meta: 'Type as technology' },
];
---
<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="wordmark" aria-label="Specimen — home">
      <span class="wordmark__mark">Specimen</span>
    </a>

    {current && (
      <div class="breadcrumb">
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span class="breadcrumb__name">{current}</span>
      </div>
    )}

    <nav class="site-header__nav">
      <div class="navitem">
        <a href="/history" class="header-link label">History</a>
        <div class="dropdown dropdown--list" role="menu" aria-label="Timeline sets">
          {eras.map((e) => (
            <a class="dropdown__item" role="menuitem" href={`/history/${e.data.slug}`}>
              <span class="dropdown__idx">{String(e.data.order).padStart(2, '0')}</span>
              <span class="dropdown__name">{e.data.name}</span>
              <span class="dropdown__meta">{e.data.period}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="navitem">
        <a href="/#index" class="header-link label">Fonts</a>
        <div class="dropdown dropdown--grid" role="menu" aria-label="Font specimens">
          {fonts.map((f) => (
            <a class="dropdown__item" role="menuitem" href={`/fonts/${f.id}`}>
              <span class="dropdown__name" style={`font-family:${f.data.fontFamily}`}>{f.data.name}</span>
              <span class="dropdown__meta">{f.data.category}</span>
            </a>
          ))}
        </div>
      </div>

      <a href="/compare" class="header-link label">Compare</a>

      <div class="navitem">
        <a href="/glossary" class="header-link label">Lexicon</a>
        <div class="dropdown dropdown--list" role="menu" aria-label="Lexicon sections">
          {lexSections.map((s, i) => (
            <a class="dropdown__item" role="menuitem" href={`/glossary#${s.id}`}>
              <span class="dropdown__idx">{String(i + 1).padStart(2, '0')}</span>
              <span class="dropdown__name">{s.name}</span>
              <span class="dropdown__meta">{s.meta}</span>
            </a>
          ))}
        </div>
      </div>

      {import.meta.env.DEV && (
        <button
          class="header-link label glyph-edit-btn"
          data-glyph-edit-toggle
          type="button"
          aria-pressed="false"
          title="Toggle glyph edit mode (local only)"
        >✎ Glyphs</button>
      )}

      {showToggle && <ColorModeToggle />}
    </nav>

    <button
      class="nav-toggle"
      data-nav-toggle
      type="button"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label="Open menu"
    >
      <span class="nav-toggle__bars" aria-hidden="true"><i></i><i></i><i></i></span>
    </button>
  </div>
</header>

<!-- Mobile navigation drawer (shown via the hamburger ≤760px).
     Must live OUTSIDE <header>: the header's backdrop-filter would otherwise
     become the containing block for this position:fixed panel. -->
<div class="mnav" id="mobile-nav" data-mnav aria-hidden="true">
    <nav class="mnav__inner container" aria-label="Primary">
      <div class="mnav__block">
        <a class="mnav__primary" href="/history">History</a>
        <div class="mnav__sub">
          {eras.map((e) => (
            <a class="mnav__subitem" href={`/history/${e.data.slug}`}>
              <span class="mnav__idx">{String(e.data.order).padStart(2, '0')}</span>
              <span>{e.data.name}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="mnav__block">
        <a class="mnav__primary" href="/#index">Fonts</a>
        <div class="mnav__sub mnav__sub--grid">
          {fonts.map((f) => (
            <a class="mnav__subitem" href={`/fonts/${f.id}`}>
              <span class="mnav__subname" style={`font-family:${f.data.fontFamily}`}>{f.data.name}</span>
              <span class="mnav__meta">{f.data.category}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="mnav__block">
        <a class="mnav__primary" href="/compare">Compare</a>
      </div>

      <div class="mnav__block">
        <a class="mnav__primary" href="/glossary">Lexicon</a>
        <div class="mnav__sub">
          {lexSections.map((s, i) => (
            <a class="mnav__subitem" href={`/glossary#${s.id}`}>
              <span class="mnav__idx">{String(i + 1).padStart(2, '0')}</span>
              <span>{s.name}</span>
            </a>
          ))}
        </div>
      </div>

      {showToggle && (
        <div class="mnav__foot"><ColorModeToggle /></div>
      )}
    </nav>
  </div>

<script>
  // Mobile drawer: toggle, Escape to close, scroll-lock, close on navigation.
  const header = document.querySelector<HTMLElement>('.site-header');
  const btn = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-mnav]');
  if (btn && panel) {
    const setOpen = (open: boolean) => {
      btn.setAttribute('aria-expanded', String(open));
      btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      panel.setAttribute('aria-hidden', String(!open));
      panel.classList.toggle('is-open', open);
      document.body.classList.toggle('mnav-open', open);
      // anchor the drawer just below the (sticky) header
      if (open && header) panel.style.setProperty('--header-h', `${header.offsetHeight}px`);
    };
    btn.addEventListener('click', () => setOpen(btn.getAttribute('aria-expanded') !== 'true'));
    panel.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) setOpen(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') setOpen(false);
    });
    // close if the viewport grows back to desktop
    window.matchMedia('(min-width: 761px)').addEventListener('change', (m) => {
      if (m.matches) setOpen(false);
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: saturate(1.4) blur(14px);
    -webkit-backdrop-filter: saturate(1.4) blur(14px);
    border-bottom: 1px solid var(--line-soft);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    min-height: 64px;
    padding-block: 0.6rem;
  }
  .wordmark { display: flex; flex-direction: column; line-height: 1; }
  .wordmark__mark {
    font-family: var(--font-ui);
    font-weight: 650;
    font-size: 1.12rem;
    letter-spacing: -0.02em;
  }

  .breadcrumb { display: flex; align-items: center; gap: 0.6rem; }
  .breadcrumb__sep { color: var(--fg-3); font-family: var(--font-mono); }
  .breadcrumb__name {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.02em;
    color: var(--fg-2);
  }

  .site-header__nav { margin-left: auto; display: flex; align-items: center; gap: var(--sp-4); }
  /* legible by default (not the faint --fg-3 the .label utility ships with) */
  .header-link { color: var(--fg-2); transition: color 0.2s var(--ease); }
  .header-link:hover { color: var(--accent); }
  .glyph-edit-btn { cursor: pointer; }
  .glyph-edit-btn[aria-pressed='true'] { color: var(--accent); }
  .glyph-edit-btn[aria-pressed='true']::before { content: '● '; }

  /* --- Hover/focus dropdown menus --- */
  .navitem { position: relative; display: flex; align-items: center; }
  .dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 0.6rem;
    max-height: min(74vh, 36rem);
    overflow-y: auto;
    padding: var(--sp-3);
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 5px;
    box-shadow: 0 14px 36px -12px rgba(0, 0, 0, 0.38);
    /* hidden until the nav item is hovered or focused */
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.18s var(--ease), transform 0.18s var(--ease), visibility 0.18s;
    z-index: 120;
  }
  /* a small invisible bridge so the cursor can cross the gap without closing */
  .dropdown::before {
    content: '';
    position: absolute;
    top: -0.6rem; left: 0; right: 0; height: 0.6rem;
  }
  .navitem:hover .dropdown,
  .navitem:focus-within .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  /* History — single column, wide enough that names never wrap and the
     period stays aligned to the right edge */
  .dropdown--list {
    width: min(92vw, 28rem);
  }
  .dropdown--list .dropdown__name { white-space: nowrap; }

  /* Fonts — two roomy columns; the wide cells keep names on one line and
     the category labels aligned right */
  .dropdown--grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.35rem 2rem;
    width: min(92vw, 42rem);
  }

  .dropdown__item {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    padding: 0.6rem 0.85rem;
    border-radius: 4px;
    color: var(--fg-2);
    transition: background 0.15s var(--ease), color 0.15s var(--ease);
  }
  .dropdown__item:hover { background: var(--bg-2); color: var(--fg); }
  .dropdown__idx { font-family: var(--font-mono); font-size: 0.72rem; color: var(--accent); }
  .dropdown__name { font-size: var(--step-0); line-height: 1.25; margin-right: auto; }
  .dropdown__meta {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--fg-3);
    white-space: nowrap;
  }

  /* --- Hamburger toggle (mobile only) --- */
  .nav-toggle { display: none; margin-left: auto; padding: 0.5rem; }
  .nav-toggle__bars { display: block; width: 26px; height: 16px; position: relative; }
  .nav-toggle__bars i {
    position: absolute; left: 0; width: 100%; height: 2px; border-radius: 2px;
    background: var(--fg-2);
    transition: transform 0.28s var(--ease), opacity 0.2s var(--ease), top 0.28s var(--ease), background 0.2s var(--ease);
  }
  .nav-toggle__bars i:nth-child(1) { top: 0; }
  .nav-toggle__bars i:nth-child(2) { top: 7px; }
  .nav-toggle__bars i:nth-child(3) { top: 14px; }
  .nav-toggle:hover .nav-toggle__bars i { background: var(--accent); }
  .nav-toggle[aria-expanded='true'] .nav-toggle__bars i:nth-child(1) { top: 7px; transform: rotate(45deg); }
  .nav-toggle[aria-expanded='true'] .nav-toggle__bars i:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded='true'] .nav-toggle__bars i:nth-child(3) { top: 7px; transform: rotate(-45deg); }

  /* --- Mobile drawer --- */
  .mnav {
    position: fixed;
    inset: var(--header-h, 64px) 0 0 0;
    z-index: 110;
    background: color-mix(in srgb, var(--bg) 96%, transparent);
    backdrop-filter: saturate(1.4) blur(18px);
    -webkit-backdrop-filter: saturate(1.4) blur(18px);
    overflow-y: auto;
    overscroll-behavior: contain;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 0.26s var(--ease), transform 0.26s var(--ease), visibility 0.26s;
  }
  .mnav.is-open { opacity: 1; visibility: visible; transform: none; }
  .mnav__inner { display: flex; flex-direction: column; padding-block: var(--sp-4) var(--sp-7); }
  .mnav__block { padding-block: var(--sp-3); border-top: 1px solid var(--line-soft); }
  .mnav__block:first-child { border-top: 0; }
  .mnav__primary {
    display: block;
    font-family: var(--font-ui);
    font-weight: 640;
    font-size: clamp(1.8rem, 9vw, 2.6rem);
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--fg);
    transition: color 0.2s var(--ease);
  }
  .mnav__primary:active { color: var(--accent); }
  .mnav__sub {
    margin-top: var(--sp-3);
    display: flex; flex-direction: column; gap: 0.15rem;
  }
  .mnav__sub--grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 0.15rem 1rem;
  }
  .mnav__subitem {
    display: flex; align-items: baseline; gap: 0.7rem;
    padding: 0.5rem 0; color: var(--fg-2);
  }
  .mnav__subitem:active { color: var(--accent); }
  .mnav__idx { font-family: var(--font-mono); font-size: 0.72rem; color: var(--accent); }
  .mnav__subname { font-size: var(--step-0); margin-right: auto; }
  .mnav__meta {
    font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.04em;
    text-transform: uppercase; color: var(--fg-3);
  }
  .mnav__foot { margin-top: var(--sp-4); }

  @media (max-width: 760px) {
    .breadcrumb { display: none; }
    .site-header__inner { gap: var(--sp-2); }
    .site-header__nav { display: none; }
    .nav-toggle { display: inline-flex; align-items: center; }
  }
  @media (min-width: 761px) {
    /* drawer never participates on desktop, even if a stale class lingers */
    .mnav { display: none; }
  }
</style>
