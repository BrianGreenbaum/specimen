---
import type { CollectionEntry } from 'astro:content';
// Shared annotated-glyph grid. Used by font Anatomy (font.callouts) and by
// era chapters (era.traitCallouts) — both carry the same callout shape.
export interface Props {
  callouts: CollectionEntry<'fonts'>['data']['callouts'];
  family: string;
  /** Source identity, so the dev Glyph-edit tool can save changes back. */
  editCollection?: 'fonts' | 'eras';
  editId?: string;
  editField?: string;
}
const { callouts, family, editCollection = 'fonts', editId, editField = 'callouts' } = Astro.props;
---
<div class="callouts" data-glossary style={`--fam:${family}; --term-fam:'${family}'`}>
  {callouts.map((c, i) => (
    <article class="callout" data-reveal style={`--reveal-delay:${i * 80}ms`}>
      <div class="callout__plate">
        <svg
          class="callout__diagram"
          data-callout
          data-glyph={c.glyph}
          data-weight={c.weight}
          data-guides={JSON.stringify(c.guides)}
          data-focus={JSON.stringify(c.focus)}
          data-family={family}
          data-edit-collection={editId ? editCollection : undefined}
          data-edit-id={editId}
          data-edit-field={editId ? editField : undefined}
          data-edit-index={i}
          preserveAspectRatio="xMidYMid meet"
          role="img"
          aria-label={`${c.glyph} — ${c.title}`}
        ></svg>
        <span class="callout__marker">{String(i + 1).padStart(2, '0')}</span>
      </div>
      <div class="callout__text">
        <h3 class="callout__title">{c.title}</h3>
        <p class="callout__body">{c.body}</p>
      </div>
    </article>
  ))}
</div>

<script>
  import { renderGlyphDiagram } from '../../lib/diagram';

  const draw = () => {
    document.querySelectorAll<SVGElement>('[data-callout]').forEach((svg) => {
      if (svg.dataset.drawn) return;
      const root = svg.closest('.callouts') as HTMLElement;
      const fam = root?.style.getPropertyValue('--fam').trim();
      if (!fam) return;
      svg.dataset.drawn = '1';
      renderGlyphDiagram(svg, {
        family: fam,
        glyph: svg.dataset.glyph!,
        weight: +(svg.dataset.weight || 400),
        guides: JSON.parse(svg.dataset.guides || '[]'),
        focus: JSON.parse(svg.dataset.focus || '[]'),
        fill: 0.62,
      }).then((layout) => {
        (svg as any).__layout = layout;
        // let the dev Glyph-edit tool (if active) attach to freshly drawn plates
        document.dispatchEvent(new CustomEvent('glyph-diagram-drawn', { detail: { svg } }));
      });
    });
  };
  // Fonts must be ready for accurate measurement
  (document as any).fonts?.ready.then(draw);
  draw();
</script>

<style>
  .callouts { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); }
  .callout { background: var(--bg); display: flex; flex-direction: column; }

  .callout__plate {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background:
      radial-gradient(120% 120% at 50% 0%, color-mix(in srgb, var(--accent) 7%, transparent), transparent 60%),
      var(--bg-2);
  }
  .callout__diagram { width: 100%; height: 100%; display: block; }

  .callout__marker {
    position: absolute; top: 0.9rem; left: 1rem; z-index: 2;
    font-family: var(--font-mono); font-size: 0.72rem; font-weight: 600;
    color: var(--accent);
  }

  .callout__text { padding: var(--sp-4); border-top: 1px solid var(--line); }
  .callout__title { font-size: var(--step-1); font-weight: 600; letter-spacing: -0.01em; margin-bottom: 0.5rem; }
  .callout__body { color: var(--fg-2); max-width: 52ch; line-height: 1.55; }

  @media (max-width: 720px) {
    .callouts { grid-template-columns: 1fr; }
  }
</style>
