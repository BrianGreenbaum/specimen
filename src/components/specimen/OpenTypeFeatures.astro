---
import type { CollectionEntry } from 'astro:content';
export interface Props {
  font: CollectionEntry<'fonts'>['data'];
}
const { font } = Astro.props;
---
<div class="otf" style={`--fam:${font.fontFamily}`}>
  {font.openType.map((f) => (
    <div class="otf__card" data-reveal>
      <div class="otf__head">
        <span class="otf__tag">{f.tag}</span>
        <span class="otf__label">{f.label}</span>
      </div>
      <div class="otf__demo">
        <div class="otf__state">
          <span class="label">Off</span>
          <p class="otf__sample" style={`font-feature-settings:'${f.tag}' 0`}>{f.sample}</p>
        </div>
        <div class="otf__arrow" aria-hidden="true">→</div>
        <div class="otf__state otf__state--on">
          <span class="label">On</span>
          <p class="otf__sample" style={`font-feature-settings:'${f.tag}' 1`}>{f.sample}</p>
        </div>
      </div>
    </div>
  ))}
</div>

<style>
  .otf { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(340px, 100%), 1fr)); gap: var(--sp-3); }
  .otf__card { border: 1px solid var(--line); padding: var(--sp-4); transition: border-color 0.25s var(--ease); }
  .otf__card:hover { border-color: var(--fg-3); }
  .otf__head { display: flex; align-items: baseline; gap: 0.7rem; margin-bottom: var(--sp-3); }
  .otf__tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-contrast);
    background: var(--accent);
    padding: 0.2em 0.5em;
    border-radius: 2px;
  }
  .otf__label { font-size: var(--step-0); font-weight: 500; }
  .otf__demo { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: var(--sp-3); }
  .otf__state { display: flex; flex-direction: column; gap: 0.4rem; }
  .otf__state .label { font-size: 0.6rem; }
  .otf__state--on .label { color: var(--accent); }
  .otf__sample {
    font-family: var(--fam);
    font-size: clamp(1.3rem, 3vw, 1.9rem);
    line-height: 1.1;
  }
  .otf__arrow { color: var(--fg-3); font-family: var(--font-mono); }
</style>
