---
export interface Props {
  sections: { id: string; label: string }[];
}
const { sections } = Astro.props;
---
<nav class="jumpnav" aria-label="Sections">
  <div class="container jumpnav__inner">
    <ul class="jumpnav__list">
      {sections.map((s, i) => (
        <li>
          <a href={`#${s.id}`} class="jumpnav__link" data-jump={s.id}>
            <span class="jumpnav__idx">{String(i + 1).padStart(2, '0')}</span>
            <span>{s.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-jump]'));
  const map = new Map(links.map((l) => [l.dataset.jump, l]));
  const spy = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          links.forEach((l) => l.classList.remove('is-active'));
          map.get(e.target.id)?.classList.add('is-active');
        }
      }
    },
    { rootMargin: '-45% 0px -50% 0px' }
  );
  links.forEach((l) => {
    const sec = document.getElementById(l.dataset.jump!);
    if (sec) spy.observe(sec);
  });
</script>

<style>
  .jumpnav {
    /* subnav — docked directly beneath the main header bar */
    position: sticky;
    top: 64px;
    z-index: 90;
    background: color-mix(in srgb, var(--bg) 86%, transparent);
    backdrop-filter: saturate(1.4) blur(14px);
    -webkit-backdrop-filter: saturate(1.4) blur(14px);
    border-bottom: 1px solid var(--line-soft);
  }
  .jumpnav__inner { overflow-x: auto; scrollbar-width: none; }
  .jumpnav__inner::-webkit-scrollbar { display: none; }
  .jumpnav__list {
    display: flex;
    /* roomier spacing between items */
    gap: 3.25rem;
    /* centre the labels vertically; underline sits just beneath the text */
    align-items: center;
    min-height: 42px;
    /* centre the row horizontally in the bar; still scrolls if it overflows */
    width: max-content;
    margin-inline: auto;
  }
  .jumpnav__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    /* no horizontal padding — the underline hugs just the number + label */
    padding: 0;
    white-space: nowrap;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--fg-3);
    border-bottom: 2px solid transparent;
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease);
  }
  .jumpnav__idx { color: var(--accent); opacity: 0.7; }
  .jumpnav__link:hover { color: var(--fg); }
  .jumpnav__link.is-active { color: var(--fg); border-color: var(--accent); }
  .jumpnav__link.is-active .jumpnav__idx { opacity: 1; }
</style>
