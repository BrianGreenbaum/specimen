---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// 01 — food-delivery order tracker (real px, interactive)
const steps = [
  { id: 'placed',   icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z',   label: 'Order placed',   sub: 'Nori Kitchen' },
  { id: 'prep',     icon: 'M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4', label: 'Preparing',     sub: 'In the kitchen' },
  { id: 'pickup',   icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z',                         label: 'Ready',          sub: 'Rider assigned' },
  { id: 'otw',      icon: 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',          label: 'On the way',     sub: '12 min away' },
  { id: 'done',     icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', label: 'Delivered!',    sub: 'Enjoy your meal' },
];

const items = [
  { name: 'Salmon Poke Bowl', price: '$14.50', note: '× 1 · No sesame' },
  { name: 'Edamame', price: '$4.00', note: '× 1 · Salted' },
  { name: 'Miso Soup', price: '$3.50', note: '× 2' },
];
---
<div class="iu" style={`--fam:${fam}`}>

  <!-- 01 — interactive food-delivery order tracker (real device scale) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Mobile app — food delivery tracker, real device scale (interactive)</span></figcaption>
    <div class="iu__scene iu__scene--phone">
      <div class="iu__device food" data-food>
        <!-- status bar -->
        <div class="food__bar">
          <span class="food__time">9:41</span>
          <span class="food__notch" aria-hidden="true"></span>
          <span class="food__icons" aria-hidden="true">
            <svg viewBox="0 0 16 12" class="food__sig"><rect x="0" y="8" width="3" height="4" rx="0.6"/><rect x="4" y="5" width="3" height="7" rx="0.6"/><rect x="8" y="2" width="3" height="10" rx="0.6"/><rect x="12" y="0" width="3" height="12" rx="0.6"/></svg>
            <svg viewBox="0 0 26 12" class="food__batt"><rect x="0.5" y="0.5" width="22" height="11" rx="2.5" fill="none" stroke="currentColor" stroke-width="1"/><rect x="24" y="3.5" width="2" height="5" rx="1" fill="currentColor"/><rect x="2" y="2" width="16" height="8" rx="1" fill="currentColor"/></svg>
          </span>
        </div>
        <!-- header -->
        <div class="food__head">
          <span class="food__logo">
            <svg viewBox="0 0 32 32" class="food__logomark" aria-hidden="true">
              <circle cx="16" cy="16" r="15" fill="var(--accent)" />
              <text x="16" y="22" text-anchor="middle" font-size="18" font-weight="700" fill="var(--accent-contrast)" font-family="var(--fam)">N</text>
            </svg>
            nori
          </span>
          <span class="food__ordid">Order #2847</span>
        </div>

        <!-- stepper track -->
        <div class="food__track" data-track>
          <div class="food__line" aria-hidden="true"><span class="food__linefill" data-linefill></span></div>
          {steps.map((s, i) => (
            <button class={`food__step ${i === 0 ? 'is-done' : ''}`} data-step={i} aria-label={s.label}>
              <span class="food__dot" data-dot>
                <svg viewBox="0 0 24 24" class="food__stepico" aria-hidden="true"><path d={s.icon} fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="food__steplabel">{s.label}</span>
              <span class="food__stepsub">{s.sub}</span>
            </button>
          ))}
        </div>

        <!-- ETA pill -->
        <div class="food__eta" data-etapill>
          <svg viewBox="0 0 24 24" class="food__etaico" aria-hidden="true"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M12 6v6l4 2" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
          <span data-etalabel>Arriving in 28 min</span>
        </div>

        <!-- order items -->
        <div class="food__items">
          <span class="food__sechead">Your order</span>
          {items.map((it) => (
            <div class="food__item">
              <div class="food__iteminfo">
                <span class="food__itemname">{it.name}</span>
                <span class="food__itemnote">{it.note}</span>
              </div>
              <span class="food__itemprice">{it.price}</span>
            </div>
          ))}
        </div>

        <!-- total row pinned above CTA -->
        <div class="food__total">
          <span>Total</span>
          <span class="food__totalv">$25.50</span>
        </div>

        <!-- action button -->
        <div class="food__foot">
          <button class="food__cta" data-cta>Track on map</button>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Tap each step or the button to advance the order — the tracker fills, ETA updates, and Fredoka Bold with rounded terminals reads warm at phone scale.</p>
  </figure>

  <!-- 02 — kids summer camp poster (wght + wdth axes, container-query scaled) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Poster — kids summer camp, wght + wdth axes live</span></figcaption>
    <div class="iu__scene camp-scene">
      <div class="camp" data-camp>
        <header class="camp__top">
          <span class="camp__edition">Summer 2026</span>
          <span class="camp__loc">Lakeside · Colorado</span>
        </header>

        <div class="camp__hero">
          <span class="camp__eyebrow">Camp Roundabout</span>
          <h3 class="camp__headline">
            <span class="camp__hl camp__hl--1" data-camphl>BIG</span>
            <span class="camp__hl camp__hl--2" data-camphl>FUN</span>
          </h3>
          <p class="camp__tagline">Swim · Hike · Create · Explore</p>
        </div>

        <!-- activities grid -->
        <div class="camp__grid">
          <div class="camp__pill">🏊 Swimming</div>
          <div class="camp__pill">🎨 Art Studio</div>
          <div class="camp__pill">🏕️ Camping</div>
          <div class="camp__pill">🎸 Music</div>
          <div class="camp__pill">🌿 Nature</div>
          <div class="camp__pill">🚀 Robotics</div>
        </div>

        <footer class="camp__foot">
          <div class="camp__dates">
            <span class="camp__datelbl">Ages 7–15</span>
            <span class="camp__dateval">Jul 7 – Aug 22</span>
          </div>
          <span class="camp__register">Register now →</span>
        </footer>

        <!-- axis controls -->
        <div class="camp__controls" aria-label="Axis controls">
          <label class="camp__ctrl">
            <span>wght</span>
            <input type="range" min="300" max="700" value="700" class="camp__slider" data-camp-wght />
            <span class="camp__ctrlval" data-camp-wghtval>700</span>
          </label>
          <label class="camp__ctrl">
            <span>wdth</span>
            <input type="range" min="75" max="125" value="125" class="camp__slider" data-camp-wdth />
            <span class="camp__ctrlval" data-camp-wdthval>125</span>
          </label>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Drag wght (300→700) and wdth (75→125) — the headline shifts from a breezy Light-wide to a squat, punchy Bold-condensed. Both Fredoka axes in one poster.</p>
  </figure>

  <!-- 03 — wellness brand identity board -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Brand — consumer wellness wordmark system</span></figcaption>
    <div class="iu__scene well-scene">
      <div class="well">
        <div class="well__hd">
          <span class="well__doc">Bloom — Brand System</span>
          <span class="well__ver">v2.0 · 2026</span>
        </div>

        <div class="well__grid">
          <!-- wordmark -->
          <div class="well__logo">
            <span class="well__wm">
              <span class="well__mark" aria-hidden="true"></span>
              bloom
            </span>
            <span class="well__cap">Primary wordmark · Fredoka SemiBold, wdth 105</span>
          </div>

          <!-- weight ramp -->
          <div class="well__rampC">
            <span class="well__lbl">Weight ramp · Light → Bold</span>
            <div class="well__ramp" data-wellramp>
              {[300,400,500,600,700].map((w) => (
                <span style={`font-weight:${w};font-variation-settings:'wght' ${w},'wdth' 100`}>{w === 300 ? 'Light' : w === 400 ? 'Regular' : w === 500 ? 'Medium' : w === 600 ? 'SemiBold' : 'Bold'}</span>
              ))}
            </div>
          </div>

          <!-- voice copy -->
          <div class="well__voiceC">
            <span class="well__lbl">Voice</span>
            <p class="well__voice">Feel good,<br/><span class="well__voiceaccent">every day.</span></p>
            <p class="well__voicesub">Gentle habits, generous design — a wellness companion built on rounded warmth and honest simplicity.</p>
          </div>

          <!-- colour swatches -->
          <div class="well__swatchC">
            <span class="well__lbl">Palette</span>
            <div class="well__sw">
              <span class="well__chip" style="background:var(--accent);color:var(--accent-contrast)">Sunrise<i>accent</i></span>
              <span class="well__chip" style="background:var(--fg);color:var(--bg)">Dusk<i>fg</i></span>
              <span class="well__chip well__chip--line" style="background:var(--bg-2);color:var(--fg)">Cream<i>bg-2</i></span>
            </div>
          </div>

          <!-- specimen strip -->
          <div class="well__specC">
            <span class="well__lbl">Specimen</span>
            <span class="well__alpha">AaBbCcGgOoRr <b>012345</b></span>
          </div>
        </div>

        <div class="well__ft">
          <span>Rounded Geometric Sans · Variable wght 300–700, wdth 75–125</span>
          <span>Soft terminals. Open forms. Genuine warmth.</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">The weight ramp auto-breathes through the axis at rest. Tap any stop to lock it at Bold — hover the ramp to hold all stops at Bold simultaneously.</p>
  </figure>

  <!-- 04 — community habit tracker poster (kinetic, interactive tiles) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">App poster — community habit tracker, rotating word + interactive tiles</span></figcaption>
    <div class="iu__scene habit-scene">
      <div class="habit" data-habit>

        <div class="habit__bg" aria-hidden="true">
          <span class="habit__blob habit__blob--1"></span>
          <span class="habit__blob habit__blob--2"></span>
          <span class="habit__blob habit__blob--3"></span>
        </div>

        <header class="habit__top">
          <span class="habit__brand">Habit Loop</span>
          <span class="habit__streak" data-streak>🔥 14-day streak</span>
        </header>

        <!-- big rotating word -->
        <div class="habit__center" aria-live="polite">
          <span class="habit__preword">Today's focus</span>
          <div class="habit__wordwrap">
            <span class="habit__word" data-habitword>Move</span>
          </div>
          <span class="habit__postword">Do it. Track it. Build it.</span>
        </div>

        <!-- habit tiles -->
        <div class="habit__tiles" data-habitiles>
          <button class="habit__tile is-done" data-tile="0">
            <span class="habit__tileico">💧</span>
            <span class="habit__tilename">Water</span>
            <span class="habit__tilesub">8 glasses</span>
            <span class="habit__tilecheck is-on" aria-label="Complete"></span>
          </button>
          <button class="habit__tile" data-tile="1">
            <span class="habit__tileico">🏃</span>
            <span class="habit__tilename">Move</span>
            <span class="habit__tilesub">30 min</span>
            <span class="habit__tilecheck" aria-label="Tap to complete"></span>
          </button>
          <button class="habit__tile" data-tile="2">
            <span class="habit__tileico">📖</span>
            <span class="habit__tilename">Read</span>
            <span class="habit__tilesub">20 pages</span>
            <span class="habit__tilecheck" aria-label="Tap to complete"></span>
          </button>
          <button class="habit__tile" data-tile="3">
            <span class="habit__tileico">🧘</span>
            <span class="habit__tilename">Breathe</span>
            <span class="habit__tilesub">10 min</span>
            <span class="habit__tilecheck" aria-label="Tap to complete"></span>
          </button>
        </div>

        <footer class="habit__foot">
          <span class="habit__progress" data-habprogress>1 of 4 complete</span>
          <span class="habit__date">Fri, Jun 6</span>
        </footer>
      </div>
    </div>
    <p class="iu__hint label">Tap any tile to complete it — the count updates. The hero word cycles every 3 s, driven at wdth 115 for Fredoka's widest, friendliest warmth.</p>
  </figure>

</div>

<script>
// ---- 01 · food delivery tracker ----
document.querySelectorAll<HTMLElement>('[data-food]').forEach((food) => {
  const stepEls = Array.from(food.querySelectorAll<HTMLButtonElement>('[data-step]'));
  const linefill = food.querySelector('[data-linefill]') as HTMLElement;
  const etaLabel = food.querySelector('[data-etalabel]') as HTMLElement;
  const cta = food.querySelector('[data-cta]') as HTMLButtonElement;

  const etas = ['Arriving in 28 min', 'Arriving in 22 min', 'Arriving in 16 min', 'Arriving in 8 min', 'Delivered! Enjoy 🎉'];
  const ctas = ['Track on map', 'Track on map', 'Track on map', 'Track on map', 'Rate your order'];
  let current = 0;

  function renderTracker(active: number) {
    stepEls.forEach((el, i) => {
      el.classList.toggle('is-done', i <= active);
      el.classList.toggle('is-active', i === active);
    });
    const pct = active / (stepEls.length - 1) * 100;
    linefill.style.height = pct + '%';
    etaLabel.textContent = etas[active];
    cta.textContent = ctas[active];
  }

  stepEls.forEach((btn) =>
    btn.addEventListener('click', () => {
      current = parseInt(btn.dataset.step!, 10);
      renderTracker(current);
    })
  );

  cta.addEventListener('click', () => {
    current = current < stepEls.length - 1 ? current + 1 : 0;
    renderTracker(current);
  });

  renderTracker(0);
});

// ---- 02 · camp poster axis sliders ----
document.querySelectorAll<HTMLElement>('[data-camp]').forEach((camp) => {
  const wghtSlider = camp.querySelector<HTMLInputElement>('[data-camp-wght]')!;
  const wdthSlider = camp.querySelector<HTMLInputElement>('[data-camp-wdth]')!;
  const wghtVal = camp.querySelector<HTMLElement>('[data-camp-wghtval]')!;
  const wdthVal = camp.querySelector<HTMLElement>('[data-camp-wdthval]')!;
  const hls = Array.from(camp.querySelectorAll<HTMLElement>('[data-camphl]'));

  function applyAxes() {
    const wg = wghtSlider.value;
    const wd = wdthSlider.value;
    wghtVal.textContent = wg;
    wdthVal.textContent = wd;
    hls.forEach((el) => {
      el.style.fontVariationSettings = `'wght' ${wg}, 'wdth' ${wd}`;
    });
  }

  wghtSlider.addEventListener('input', applyAxes);
  wdthSlider.addEventListener('input', applyAxes);
  applyAxes();
});

// ---- 03 · wellness ramp tap-to-lock ----
document.querySelectorAll<HTMLElement>('[data-wellramp]').forEach((ramp) => {
  const spans = Array.from(ramp.querySelectorAll<HTMLElement>('span'));
  spans.forEach((span) => {
    span.addEventListener('click', () => {
      const wasLocked = span.classList.contains('is-locked');
      spans.forEach((s) => s.classList.remove('is-locked'));
      if (!wasLocked) span.classList.add('is-locked');
    });
  });
});

// ---- 04 · habit tracker tiles ----
document.querySelectorAll<HTMLElement>('[data-habit]').forEach((habit) => {
  const tiles = Array.from(habit.querySelectorAll<HTMLButtonElement>('[data-tile]'));
  const progress = habit.querySelector<HTMLElement>('[data-habprogress]')!;
  const wordEl = habit.querySelector<HTMLElement>('[data-habitword]')!;
  const words = ['Move', 'Rest', 'Read', 'Flow', 'Grow'];
  let wordIdx = 0;

  function updateProgress() {
    const done = tiles.filter((t) => t.classList.contains('is-done')).length;
    progress.textContent = done + ' of ' + tiles.length + ' complete';
  }

  tiles.forEach((tile) => {
    tile.addEventListener('click', () => {
      tile.classList.toggle('is-done');
      const check = tile.querySelector<HTMLElement>('.habit__tilecheck');
      if (check) check.classList.toggle('is-on');
      updateProgress();
    });
  });

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reducedMotion) {
    setInterval(() => {
      wordIdx = (wordIdx + 1) % words.length;
      wordEl.classList.add('is-exit');
      setTimeout(() => {
        wordEl.textContent = words[wordIdx];
        wordEl.classList.remove('is-exit');
        wordEl.classList.add('is-enter');
        setTimeout(() => wordEl.classList.remove('is-enter'), 380);
      }, 250);
    }, 3000);
  }

  updateProgress();
});
</script>

<style>
  .iu__item { margin: 0; }
  .iu__hint { margin-top: var(--sp-2); color: var(--fg-3); }
  .iu * { font-family: var(--fam); }

  /* ---- shared scene framing ---- */
  .iu__scene {
    container-type: inline-size;
    position: relative;
    border: clamp(22px, 3.4vw, 44px) solid var(--bg-2);
    outline: 1px solid var(--line);
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--bg-2);
  }
  .iu__scene * { font-family: var(--fam); }

  /* S01 phone scene — remove heavy outer border, add warm atmospheric background */
  .iu__scene--phone {
    aspect-ratio: 16 / 10;
    display: grid;
    place-items: center;
    padding: clamp(14px, 3cqi, 34px) 0;
    /* replace the boxy border with a fine outline only */
    border: 1px solid var(--line);
    /* warm tonal wash: top-left glow + bottom-right vignette */
    background:
      radial-gradient(ellipse 70% 60% at 30% 20%, color-mix(in srgb, var(--accent) 14%, transparent), transparent 70%),
      radial-gradient(ellipse 55% 45% at 80% 85%, color-mix(in srgb, var(--accent) 8%, transparent), transparent 65%),
      color-mix(in srgb, var(--bg-2) 55%, var(--bg));
    /* soft rounded corners for the scene itself */
    border-radius: 6px;
  }
  /* floating accent blobs behind the phone for depth */
  .iu__scene--phone::before,
  .iu__scene--phone::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
  .iu__scene--phone::before {
    /* top-right warm circle */
    width: 28cqi; height: 28cqi;
    top: -6cqi; right: -2cqi;
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    filter: blur(clamp(18px, 5cqi, 48px));
  }
  .iu__scene--phone::after {
    /* bottom-left softer echo */
    width: 22cqi; height: 22cqi;
    bottom: -4cqi; left: 0cqi;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    filter: blur(clamp(14px, 4cqi, 36px));
  }
  @container (max-width: 540px) { .iu__scene--phone { aspect-ratio: 3 / 4; } }

  .camp-scene { aspect-ratio: 3 / 4; }
  @container (min-width: 720px) { .camp-scene { aspect-ratio: 5 / 7; } }

  .well-scene { aspect-ratio: 16 / 10; }
  .habit-scene { aspect-ratio: 4 / 5; }
  @container (min-width: 720px) { .habit-scene { aspect-ratio: 3 / 4; } }

  .iu__device {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    background: var(--bg); overflow: hidden;
  }

  /* ======================================================
     01 · FOOD DELIVERY TRACKER (real px, phone)
     ====================================================== */
  .iu__scene--phone .food {
    position: relative; inset: auto;
    width: 340px; max-width: 100%;
    height: 100%; max-height: 660px;
    aspect-ratio: 340 / 660;
    border-radius: 38px;
    border: 1px solid var(--line);
    box-shadow: 0 28px 64px -24px rgba(0,0,0,0.50), 0 0 0 8px color-mix(in srgb, var(--fg) 6%, transparent);
    font-size: 13px;
    background: var(--bg);
  }

  .food__bar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.4rem 1.3rem 0.2rem;
    flex: none;
    border-radius: 38px 38px 0 0;
    position: relative;
  }
  .food__time { font-size: 12px; font-weight: 600; font-feature-settings: 'tnum'; }
  .food__notch {
    position: absolute; left: 50%; top: 0.4rem; transform: translateX(-50%);
    width: 78px; height: 18px; border-radius: 100px;
    background: color-mix(in srgb, var(--fg) 86%, transparent);
  }
  .food__icons { display: inline-flex; align-items: center; gap: 5px; color: var(--fg-2); }
  .food__sig { width: 15px; height: 11px; } .food__sig rect { fill: currentColor; }
  .food__batt { width: 21px; height: 10px; }

  .food__head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.5rem 1.2rem 0.4rem;
    flex: none;
    border-bottom: 1px solid var(--line-soft);
  }
  .food__logo {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: 18px; font-weight: 700;
    letter-spacing: -0.02em;
    font-variation-settings: 'wght' 700;
  }
  .food__logomark { width: 28px; height: 28px; flex: none; border-radius: 50%; }
  .food__ordid { font-size: 11.5px; font-weight: 500; color: var(--fg-3); letter-spacing: 0.04em; }

  /* stepper */
  .food__track {
    position: relative;
    display: flex; flex-direction: column;
    padding: 0.6rem 1.3rem 0.4rem;
    flex: none;
  }
  .food__line {
    position: absolute; left: calc(1.3rem + 11px); top: 1.1rem;
    width: 3px; bottom: 0.6rem;
    background: color-mix(in srgb, var(--fg) 10%, transparent);
    border-radius: 100px; overflow: hidden;
  }
  .food__linefill {
    position: absolute; left: 0; right: 0; top: 0;
    height: 0; background: var(--accent);
