  /* ════════════════════════════════════════════════════════════════════
     03 · GIBBON — the spread (its own paper, declared for both modes)
     ════════════════════════════════════════════════════════════════════ */
  /* The pages are SET ON the canon they draw. Each leaf is a true 2:3 page;
     the live content lives in an absolutely-placed block whose insets are the
     Van de Graaf margins — inner 1/9 and outer 2/9 of the page width, head 1/9
     and foot 2/9 of the height — i.e. exactly the rect the SVG draws.
     .cz-book is its own inline-size container so every cqi below tracks the
     book, not the bleed scene. The unit --u = 1% of one page's width. */
  .cz-book-scene { background: color-mix(in srgb, var(--bg-2) 86%, var(--fg) 14%);
    padding: clamp(2rem, 4.5cqi, 4rem) clamp(1rem, 4cqi, 3.5rem) clamp(2.2rem, 5cqi, 4.5rem); }
  .cz-book { --paper: #f4edde; --paper-2: #ece2cc; --ink: #2c2417; --ink-2: #6b5d45; --canon: #a4642a;
    --u: 0.5cqi;
    max-width: 1180px; margin-inline: auto; container-type: inline-size;
    display: flex; flex-direction: column; align-items: flex-start; }
  .cz-book ::selection { background: var(--gilt-deep); color: #f4edde; }
  .cz-book__spread { display: grid; grid-template-columns: 1fr 1fr; width: 100%; }
  .cz-book__page {
    position: relative; aspect-ratio: 2 / 3; min-width: 0;
    background: linear-gradient(105deg, var(--paper), var(--paper-2) 96%);
    color: var(--ink);
  }
  .cz-book__page--verso { box-shadow: inset calc(-4.4 * var(--u)) 0 calc(5.2 * var(--u)) calc(-4.4 * var(--u)) rgba(58, 44, 22, 0.38); }
  .cz-book__page--recto { box-shadow: inset calc(4.4 * var(--u)) 0 calc(5.2 * var(--u)) calc(-4.4 * var(--u)) rgba(58, 44, 22, 0.30); }

  /* the text block = the canon rect (insets are % of the page box) */
  .cz-book__block {
    position: absolute; inset: 11.111% 11.111% 22.222% 22.222%;   /* verso: spine right */
    display: flex; flex-direction: column; align-items: center; text-align: center;
  }
  .cz-book__page--recto .cz-book__block { inset: 11.111% 22.222% 22.222% 11.111%;
    align-items: stretch; text-align: left; }

  /* verso — the Tschichold title page: centred, letterspaced capitals,
     no line wider than the text block, imprint on the block's foot line */
  .cz-book__author { font-size: calc(3 * var(--u)); letter-spacing: 0.4em; padding-left: 0.4em; }
