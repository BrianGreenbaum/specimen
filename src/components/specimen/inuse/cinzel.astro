---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;
---
<div class="iu" style={`--fam:${fam}`}>
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Lapidary — a carved inscription</span></figcaption>
    <div class="iu__scene scene16">
      <div class="iu__poster monument">
        <span class="monument__leaf" aria-hidden="true">❦</span>
        <p class="monument__small">IN·THE·YEAR·OF·THE·LETTER</p>
        <h3 class="monument__head">SENATVS<br/>POPVLVS<wbr/>QVE</h3>
        <p class="monument__rule" aria-hidden="true"></p>
        <p class="monument__date">· MMXXVI ·</p>
      </div>
    </div>
  </figure>

  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Brand — a luxury monogram</span></figcaption>
    <div class="iu__scene scene21">
      <div class="iu__poster mono">
        <div class="mono__mark">A&middot;C</div>
        <div class="mono__name">ATELIER CINZEL</div>
        <div class="mono__sub">PARFUMEUR · DEPUIS MMXII</div>
      </div>
    </div>
  </figure>
</div>

<style>
  .iu__item { margin: 0; }
  .scene16 { aspect-ratio: 16 / 9; }
  .scene21 { aspect-ratio: 21 / 9; }

  .monument {
    display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;
    padding: 5cqi; gap: 2cqi;
    background:
      linear-gradient(120deg, color-mix(in srgb, var(--fg) 4%, transparent), transparent 40%),
      var(--bg-2);
    color: var(--fg);
  }
  .monument__leaf { color: var(--accent); font-size: 5cqi; }
  .monument__small { font-size: 2.6cqi; letter-spacing: 0.3em; color: var(--fg-2); }
  .monument__head { font-size: 11cqi; line-height: 0.95; font-weight: 700; letter-spacing: 0.04em; }
  .monument__rule { width: 30%; height: 2px; background: var(--accent); opacity: 0.6; margin: 1cqi 0; }
  .monument__date { font-size: 3.4cqi; letter-spacing: 0.3em; color: var(--accent); }

  .mono { display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 1.5cqi; background: var(--fg); color: var(--bg); }
  .mono__mark { font-size: 16cqi; font-weight: 600; letter-spacing: 0.05em; }
  .mono__name { font-size: 4cqi; letter-spacing: 0.4em; }
  .mono__sub { font-size: 2cqi; letter-spacing: 0.3em; color: var(--accent); }
</style>
