---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// ── The sequence ─────────────────────────────────────────────────────────────
// TYPECASTING — Cinzel is the Trajan that escaped the foundry: the capital
// that always gets hired to play the emperor. Five engagements, one thread of
// gold (the gilt the Romans pressed into their bronze letters): the gold-leaf
// movie title (01) becomes the gilded medallion of a Roman maison (02), the
// gold-stamped canon of a classic text (03), the gilt title treatment of
// prestige streaming (04), until the pointer itself gilds the stone (05).
// Surfaces: black one-sheet → daylight paper → book paper → screen dark →
// black granite. Loud, quiet, quiet, device, loud.

// Honesty notes, verified against the woff2 (fontTools):
// · single axis wght 400–900 — the only axis ever performed here.
// · GSUB carries only `locl`: no liga/dlig/smcp/tnum claims anywhere.
// · Cinzel's lowercase slots carry true drawn SMALL CAPITALS (614/1000 vs cap
//   714/1000) — mixed-case strings give a genuine two-tier inscription.

const serif = "'Spectral', Georgia, serif";       // loaded site-wide
const cond  = "'Oswald Variable', 'Arial Narrow', sans-serif"; // loaded site-wide

// ── Act 01 — one film, four genres ───────────────────────────────────────────
const genres = [
  { id: 'epic',     name: 'Epic',     note: 'wght 800 · gold leaf' },
  { id: 'horror',   name: 'Horror',   note: 'wght 400 · letterspaced dread' },
  { id: 'romance',  name: 'Romance',  note: 'wght 500 · warm paper' },
  { id: 'prestige', name: 'Prestige', note: 'wght 600 · the laurels' },
];

// ── Act 04 — ÆTERNA, two seasons ─────────────────────────────────────────────
const seasons = [
  {
    id: 'i', label: 'Season I',
    eps: [
      { n: 'I',   title: 'The Wolf of the Capitol',  len: '58 min', desc: 'A widowed senator buys the silence of two legions — and misprices it.', prog: 100 },
      { n: 'II',  title: 'Bread, Salt and Iron',     len: '54 min', desc: 'The grain fleet is late. The city counts in days; the palace counts in heirs.', prog: 100 },
      { n: 'III', title: 'A Forum of Knives',        len: '61 min', desc: 'Every faction sends a friend to the games. None of them watches the sand.', prog: 42 },
      { n: 'IV',  title: 'The Gilded Hour',          len: '67 min', desc: 'At the triumph, the slave behind the emperor whispers the old words.', prog: 0 },
    ],
  },
  {
    id: 'ii', label: 'Season II',
    eps: [
      { n: 'I',   title: 'Ashes of the Census',      len: '57 min', desc: 'The new emperor orders the empire counted. The count comes back wrong.', prog: 0 },
      { n: 'II',  title: 'The Vestal’s Ledger',  len: '59 min', desc: 'A fire in the archive spares one shelf. It is the wrong shelf.', prog: 0 },
      { n: 'III', title: 'Crossing the Rubicon, Twice', len: '63 min', desc: 'An exiled general discovers the river has two banks — and two armies.', prog: 0 },
      { n: 'IV',  title: 'Littera Scripta Manet',    len: '71 min', desc: 'What was carved cannot be unsaid. The season’s knives come home.', prog: 0 },
    ],
  },
];

// ── Act 05 — the carving field ───────────────────────────────────────────────
// Static composition (no-JS / reduced-motion) = the carver's pass: weight
// sweeps 400 → 900 across each line, so the act is complete without motion.
const carveLines = ['LITTERA', 'SCRIPTA', 'MANET'].map((word) =>
  word.split('').map((ch, i, arr) => ({
    ch,
    w: Math.round(400 + (500 * i) / Math.max(1, arr.length - 1)),
  }))
);
---

<div class="iu cz" style={`--fam:${fam}; --serif:${serif}; --cond:${cond}`}>

  <!-- ════════════════════════════════════════════════════════════════════
       01 · ILLUSTRATION & COMMERCIAL — "IMMORTAL", the one-sheet four ways.
       Reference: Yves Peters' ScreenFonts studies (The FontFeed, 2005–2015),
       which documented how Trajan became "the movie font" — one Roman capital
       serving every genre on the one-sheet. Here the joke is played straight:
       the same title is recast by genre, and the only actor that changes is
       the weight axis (400 dread → 500 romance → 600 laurels → 800 gold).
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Illustration — the one-sheet, four genres</span></figcaption>
    <div class="iu__scene">
      <div class="cz-one" data-one data-genre="epic">
      <aside class="cz-one__rail">
        <span class="cz-one__kick">Trajan plays every genre<i>— after Yves Peters&rsquo; ScreenFonts</i></span>
        <div class="cz-one__tabs" role="group" aria-label="Recast the poster by genre">
          {genres.map((g, i) => (
            <button class={i === 0 ? 'is-on' : ''} type="button" data-genre-btn={g.id} aria-pressed={i === 0 ? 'true' : 'false'}>
              <b>{g.name.toUpperCase()}</b><span>{g.note}</span>
            </button>
          ))}
        </div>
        <span class="cz-one__railfoot">One title &middot; one face &middot; four castings</span>
      </aside>
      <div class="cz-one__sheet">
        <div class="cz-one__laurel" aria-hidden="true">
          <svg viewBox="0 0 46 30"><path d="M44 28C32 26 26 18 25 4m1 6c-3-1-5-4-5-7m5 12c-4 0-7-2-8-5m9 11c-4 1-8 0-10-3m12 8c-4 2-9 2-12-1" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
          <span>Official Selection<br/><b>VENEZIA &middot; CANNES &middot; TELLVRIDE</b></span>
          <svg viewBox="0 0 46 30" style="transform:scaleX(-1)"><path d="M44 28C32 26 26 18 25 4m1 6c-3-1-5-4-5-7m5 12c-4 0-7-2-8-5m9 11c-4 1-8 0-10-3m12 8c-4 2-9 2-12-1" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
        </div>
        <span class="cz-one__pres">AQVILA PICTVRES PRESENTS</span>
        <span class="cz-one__tag" data-tagline>EVERY EMPIRE FALLS</span>
        <h3 class="cz-one__title">IMMORTAL</h3>
        <span class="cz-one__dir">A film by Lucia Ferro</span>
        <div class="cz-one__credits">
          <p>AQVILA PICTVRES PRESENTS IN ASSOCIATION WITH MERIDIAN LIGHT A LUCIA FERRO FILM &ldquo;IMMORTAL&rdquo; ELENA VESPUCCI &nbsp;MARC&nbsp;DRAKOS &nbsp;ODILE&nbsp;NEARING &nbsp;AND&nbsp;TOMAS&nbsp;LE&nbsp;GALL</p>
          <p>CASTING&nbsp;BY PRISCA&nbsp;ADEYEMI&nbsp;CSA &nbsp;MUSIC&nbsp;BY HALVARD&nbsp;ROST &nbsp;COSTUME&nbsp;DESIGNER IRIS&nbsp;KANE &nbsp;EDITED&nbsp;BY PAUL&nbsp;OYELARAN &nbsp;PRODUCTION&nbsp;DESIGNER SOFIA&nbsp;BRANDT &nbsp;DIRECTOR&nbsp;OF&nbsp;PHOTOGRAPHY MATEO&nbsp;RUIZ&nbsp;AIC &nbsp;PRODUCED&nbsp;BY HANA&nbsp;OKAFOR &nbsp;WRITTEN&nbsp;AND&nbsp;DIRECTED&nbsp;BY LUCIA&nbsp;FERRO</p>
        </div>
        <div class="cz-one__bill">
          <span class="cz-one__rating">R</span>
          <span class="cz-one__date" data-dateline>CHRISTMAS DAY</span>
          <span class="cz-one__fmt">FILMED&nbsp;ENTIRELY&nbsp;IN&nbsp;70&nbsp;MM</span>
        </div>
      </div>
      </div>
    </div>
    <p class="iu__hint label">Yves Peters spent a decade logging Trajan on movie one-sheets — epic, horror, romance, Oscar bait — and the face never broke character. Recast the poster: only the surface, the tagline and Cinzel&rsquo;s weight axis change, from a letterspaced 400 dread to gold-leaf 800.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       02 · BRANDING & IDENTITY — AVRELIA, alta gioielleria di Roma.
       Reference: the Bulgari logotype (the modern house that sets its U as
       the Roman V, straight off the inscriptional model). The identity is
       carried by three honest devices of this file: the lapidary V, the true
       small capitals drawn in the lowercase slots, and the weight axis read
       as engraving depth — printed, embossed, carved.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Branding — Avrelia di Roma, an identity on the lapidary V</span></figcaption>
    <div class="iu__scene">
      <div class="cz-mai" data-mai>
        <div class="cz-mai__left">
          <span class="cz-mai__over">Alta Gioielleria <i>&middot;</i> Roma</span>
          <h3 class="cz-mai__word">A<b>V</b>RELIA</h3>
          <span class="cz-mai__est">Fondata in Roma &middot; MCMXXI</span>
          <p class="cz-mai__note">From the house rules: the U is cut as the lapicides cut it — <b>V</b>, never U. Secondary lines are set in the inscription&rsquo;s small capitals, and weight is reserved as depth of engraving — <i>stampata</i> on paper, <i>sbalzata</i> in relief, <i>scolpita</i> in stone.</p>
          <div class="cz-mai__depths" aria-label="The three engraving depths of the identity">
            <span style="font-variation-settings:'wght' 400">AVRELIA<i>stampata &middot; 400</i></span>
            <span style="font-variation-settings:'wght' 650">AVRELIA<i>sbalzata &middot; 650</i></span>
            <span style="font-variation-settings:'wght' 900">AVRELIA<i>scolpita &middot; 900</i></span>
          </div>
        </div>
        <div class="cz-mai__right">
          <div class="cz-mai__medal">
            <svg viewBox="0 0 240 240" role="img" aria-label="Gilded medallion: Avrelia, Roma, alta gioielleria, circling a carved A">
              <defs><path id="cz-mai-ring" d="M 120 26 A 94 94 0 1 1 119.9 26" fill="none" /></defs>
              <circle class="cz-mai__rim" cx="120" cy="120" r="113" />
              <circle class="cz-mai__rim cz-mai__rim--in" cx="120" cy="120" r="74" />
              <g class="cz-mai__spin">
                <text class="cz-mai__ringtext"><textPath href="#cz-mai-ring" startOffset="0">AVRELIA &middot; ROMA &middot; ALTA &middot; GIOIELLERIA &middot; ANNO &middot; MCMXXI &middot;</textPath></text>
              </g>
              <text class="cz-mai__mono" x="120" y="152" text-anchor="middle">A</text>
            </svg>
          </div>
          <i class="cz-mai__thread" aria-hidden="true"></i>
          <div class="cz-mai__card">
            <span class="cz-mai__cardname">A<b>V</b>RELIA</span>
            <span class="cz-mai__cardline">Via dei Condotti IX &middot; Roma</span>
            <span class="cz-mai__cardline cz-mai__cardline--soft">Su appuntamento &middot; Tel LXX&middot;IV&middot;XXI</span>
          </div>
          <i class="cz-mai__thread cz-mai__thread--short" aria-hidden="true"></i>
          <div class="cz-mai__hall"><span>AV</span><i>&#9670;</i><span>oro 750</span><i>&#9670;</i><span>roma</span><i>&#9670;</i><span>N&ordm; ccxiv</span></div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">The gold leaf of the one-sheet becomes a maison&rsquo;s gilding, after the Bulgari V. As the identity arrives, the wordmark eases out to inscription spacing — the slow cut of a letterspaced capital — and the medallion legend turns on a live SVG <code>textPath</code>. Every line marked <em>Roma</em> or <em>Su appuntamento</em> is typed as lowercase: Cinzel carries true drawn small capitals in those slots, so the maison&rsquo;s second voice is the same stone, cut shallower.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       03 · EDITORIAL — Gibbon set to Tschichold's canon.
       Reference: Jan Tschichold's Penguin reform (1947–49) — the centred,
       letterspaced-capital title page and the Composition Rules — and the
       Van de Graaf page canon he championed in "The Form of the Book."
       Cinzel does what Trajan-model titling was revived to do: carry a
       classical title page; the small caps lead the chapter in.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click="[data-canon]">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Editorial — Gibbon, set to Tschichold&rsquo;s canon</span></figcaption>
    <div class="iu__scene cz-book-scene">
      <div class="cz-book" data-book>
        <div class="cz-book__spread">
          <div class="cz-book__page cz-book__page--verso">
            <!-- Tschichold's title-page rule: the title block lives INSIDE the
                 text block — never wider, centred on the canon rect, not the leaf -->
            <div class="cz-book__block">
              <span class="cz-book__author">EDWARD GIBBON</span>
              <span class="cz-book__rule" aria-hidden="true"></span>
              <span class="cz-book__t1">THE HISTORY</span>
              <span class="cz-book__of">OF THE</span>
              <span class="cz-book__t2">DECLINE AND FALL</span>
              <span class="cz-book__of">OF THE</span>
              <span class="cz-book__t1">ROMAN EMPIRE</span>
              <span class="cz-book__vol">Volume the First</span>
              <span class="cz-book__device" aria-hidden="true">&middot;&#10022;&middot;</span>
              <span class="cz-book__imprint">LONDON &middot; THE AVREATE PRESS<br/>MMXXVI</span>
            </div>
            <svg class="cz-book__canon" viewBox="0 0 600 900" preserveAspectRatio="none" aria-hidden="true">
              <line x1="600" y1="900" x2="0" y2="0" /><line x1="600" y1="900" x2="0" y2="-900" class="cz-book__canon-spread" />
              <line x1="0" y1="900" x2="600" y2="0" />
              <rect x="133.3" y="100" width="400" height="600" />
            </svg>
          </div>
          <div class="cz-book__page cz-book__page--recto">
            <div class="cz-book__block cz-book__block--text">
              <div class="cz-book__rh"><span>The Decline and Fall</span><span>3</span></div>
              <span class="cz-book__ch">CHAPTER THE FIRST</span>
              <span class="cz-book__chrule" aria-hidden="true"></span>
              <p class="cz-book__arg">The extent and military force of the Empire in the age of the Antonines</p>
              <div class="cz-book__body">
                <p><span class="cz-book__drop">I</span><span class="cz-book__lead">n the second century</span> of the Christian &AElig;ra, the empire of Rome comprehended the fairest part of the earth, and the most civilized portion of mankind. The frontiers of that extensive monarchy were guarded by ancient renown and disciplined valour.</p>
                <p>The gentle but powerful influence of laws and manners had gradually cemented the union of the provinces. Their peaceful inhabitants enjoyed and abused the advantages of wealth and luxury; the image of a free constitution was preserved with decent reverence.</p>
              </div>
            </div>
            <span class="cz-book__catch" aria-hidden="true">The</span>
            <svg class="cz-book__canon" viewBox="0 0 600 900" preserveAspectRatio="none" aria-hidden="true">
              <line x1="0" y1="900" x2="600" y2="0" /><line x1="0" y1="900" x2="600" y2="-900" class="cz-book__canon-spread" />
              <line x1="600" y1="900" x2="0" y2="0" />
              <rect x="66.7" y="100" width="400" height="600" />
            </svg>
          </div>
        </div>
        <button class="cz-book__toggle" type="button" data-canon aria-pressed="false"><i aria-hidden="true"></i>SHOW THE CANON</button>
      </div>
    </div>
    <p class="iu__hint label">Tschichold&rsquo;s Penguin reform in miniature, and the pages are <em>set on</em> the geometry, not decorated by it: inner margin a ninth of the page, outer and foot two ninths, title block and text block filling exactly the Van de Graaf rect. Centred, letterspaced capitals carry the title — the rule Tschichold took from the inscriptions Cinzel descends from — and Cinzel&rsquo;s small caps lead the Spectral text in. Press <strong>SHOW THE CANON</strong> to draw the construction over the live page.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       04 · WEB & APP UI — ÆTERNA, a prestige-streaming title page.
       Reference: the post–Game of Thrones streaming idiom (the HBO Max /
       key-art detail page) in which a Trajan-style capital became
       television's shorthand for epic. Real device px, genuinely driven:
       season tabs, a My-List toggle, resumable episode rows.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Product UI — &AElig;terna, a streaming title page (real scale, interactive)</span></figcaption>
    <div class="iu__scene">
      <div class="iu__device cz-app" data-app>
        <div class="iu__chrome">
          <div class="iu__dots"><i></i><i></i><i></i></div>
          <span class="iu__addr">stream.aquila.tv/series/aeterna</span>
        </div>
        <div class="cz-app__body">
          <header class="cz-app__hero">
            <div class="cz-app__heroink">
              <span class="cz-app__net">AQVILA&nbsp;ORIGINALS</span>
              <h3 class="cz-app__logo">&AElig;TERNA</h3>
              <div class="cz-app__meta">
                <b>MMXXVI</b><i>TV-MA</i><span>II seasons</span><span>Epic</span>
              </div>
              <p class="cz-app__sell">Rome does not fall in a day. It falls in committee.</p>
              <div class="cz-app__cta">
                <button class="cz-app__play" type="button" data-play>&#9654;&nbsp;&nbsp;Resume&nbsp;S&middot;I&nbsp;E&middot;III</button>
                <button class="cz-app__list" type="button" data-mylist aria-pressed="false"><b>+</b>&nbsp;My list</button>
              </div>
            </div>
            <span class="cz-app__heroglyph" aria-hidden="true">&AElig;</span>
            <span class="cz-app__heroglyph cz-app__heroglyph--gilt" aria-hidden="true">&AElig;</span>
          </header>
          <nav class="cz-app__tabs" role="tablist" aria-label="Seasons">
            {seasons.map((s, i) => (
              <button class={i === 0 ? 'is-on' : ''} type="button" role="tab" aria-selected={i === 0 ? 'true' : 'false'} data-tab={s.id}>{s.label.toUpperCase()}</button>
            ))}
            <span class="cz-app__tabnote">IV episodes</span>
          </nav>
          {seasons.map((s, i) => (
            <ul class={`cz-app__eps${i === 0 ? ' is-on' : ''}`} data-eps={s.id}>
              {s.eps.map((e, j) => (
                <li class={`cz-app__ep${i === 0 && j === 2 ? ' is-now' : ''}`}>
                  <button type="button" data-ep={`${s.label.toUpperCase()} · E·${e.n}`}>
                    <span class="cz-app__epthumb" aria-hidden="true"><b>{e.n}</b>{e.prog > 0 && <i style={`width:${e.prog}%`}></i>}</span>
                    <span class="cz-app__epmain">
                      <span class="cz-app__eptitle"><b>{e.n}&middot;</b>{e.title}<em class="cz-app__now">Now playing</em></span>
                      <span class="cz-app__epdesc">{e.desc}</span>
                    </span>
                    <span class="cz-app__eplen">{e.len}</span>
                  </button>
                </li>
              ))}
            </ul>
          ))}
        </div>
      </div>
    </div>
    <p class="iu__hint label">The casting Trajan never auditioned for: after <em>Game of Thrones</em>, the Roman capital became streaming&rsquo;s shorthand for epic. Aqvila&rsquo;s page speaks its own house language — metadata in roman numerals and small caps, buttons set in the brand face (typed lowercase, rendered in Cinzel&rsquo;s drawn small capitals) over a UI sans for episode text. The key art&rsquo;s &AElig; is carved into the screen; pass the hand over it and the gilt is pressed into the incision. The active season swells on the weight axis, the logotype deepens as the pointer nears, and picking an episode re-arms the resume button.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       05 · INTERACTIVE & EXPERIMENTAL — Littera Scripta Manet.
       Reference: the pointer-reactive kinetic typography of Dia Studio
       (Mitch Paone) — type as an instrument the visitor plays. Here the
       pointer is the chisel: wherever the hand passes, the single wght axis
       cuts deeper, 400 → 900, and the incision takes the gilt. Without a
       pointer (or with reduced motion) the field rests as the carver's
       pass — weight sweeping across each line.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">05</span><span class="label">Experimental — Littera Scripta Manet, the pointer as chisel</span></figcaption>
    <div class="iu__scene cz-carve" data-carve>
      <div class="cz-carve__field" aria-label="Littera scripta manet — the written letter remains">
        {carveLines.map((line) => (
          <span class="cz-carve__line">
            {line.map((l) => (
              <b class="cz-carve__l" style={`--w:${l.w}`} data-l>{l.ch}</b>
            ))}
          </span>
        ))}
      </div>
      <span class="cz-carve__foot"><span class="cz-carve__sc">Littera scripta manet</span><span class="cz-carve__en">&mdash;&nbsp;the written letter remains</span></span>
    </div>
    <p class="iu__hint label">The thread ends where the face began: black granite, gilt in the cuts. Drag your hand across the stone — the pointer is the chisel, and Cinzel&rsquo;s one axis is the depth of the blow, swelling 400&nbsp;&rarr;&nbsp;900 under your touch and cooling to bronze behind you. Kinetic type in the school of Dia Studio; left alone, the carver cuts the three lines one after another, each cooling to bronze behind the chisel.</p>
  </figure>

</div>

<script>
  // ── 01 · recast the one-sheet by genre ─────────────────────────────────
  const TAGLINES: Record<string, [string, string]> = {
    epic:     ['EVERY EMPIRE FALLS', 'CHRISTMAS DAY'],
    horror:   ['IT REMEMBERS YOU', 'OCTOBER'],
    romance:  ['Love is the longest war', 'THIS VALENTINE’S'],
    prestige: ['From the director of “The Gilded Hour”', 'AWARDS SEASON'],
  };
  document.querySelectorAll<HTMLElement>('[data-one]').forEach((one) => {
    const tag = one.querySelector<HTMLElement>('[data-tagline]')!;
    const date = one.querySelector<HTMLElement>('[data-dateline]')!;
    const btns = Array.from(one.querySelectorAll<HTMLButtonElement>('[data-genre-btn]'));
    btns.forEach((b) => b.addEventListener('click', () => {
      const g = b.dataset.genreBtn!;
      one.dataset.genre = g;
      btns.forEach((x) => {
        x.classList.toggle('is-on', x === b);
        x.setAttribute('aria-pressed', String(x === b));
      });
      const [t, d] = TAGLINES[g];
      tag.textContent = t;
      date.textContent = d;
    }));
  });

  // ── 02 · the wordmark eases to inscription spacing on arrival ──────────
  // The act's one kinetic idea must exist without a pointer: when the
  // identity enters the viewport the letterspacing tracks out, slowly,
  // like the second pass of the chisel. Gated to no-preference.
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll<HTMLElement>('[data-mai]').forEach((mai) => {
      const io = new IntersectionObserver((es) => es.forEach((en) => {
        if (en.isIntersecting) { mai.classList.add('is-cut'); io.disconnect(); }
      }), { threshold: 0.45 });
      io.observe(mai);
    });
  }

  // ── 03 · the Van de Graaf canon toggle ─────────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-book]').forEach((book) => {
    const btn = book.querySelector<HTMLButtonElement>('[data-canon]')!;
    btn.addEventListener('click', () => {
      const on = book.classList.toggle('is-canon');
      btn.setAttribute('aria-pressed', String(on));
      btn.lastChild!.textContent = on ? 'HIDE THE CANON' : 'SHOW THE CANON';
    });
  });

  // ── 04 · ÆTERNA: tabs, my list, resume state ───────────────────────────
  document.querySelectorAll<HTMLElement>('[data-app]').forEach((app) => {
    const tabs = Array.from(app.querySelectorAll<HTMLButtonElement>('[data-tab]'));
    const lists = Array.from(app.querySelectorAll<HTMLElement>('[data-eps]'));
    tabs.forEach((t) => t.addEventListener('click', () => {
      tabs.forEach((x) => { x.classList.toggle('is-on', x === t); x.setAttribute('aria-selected', String(x === t)); });
      lists.forEach((l) => l.classList.toggle('is-on', l.dataset.eps === t.dataset.tab));
    }));
    const list = app.querySelector<HTMLButtonElement>('[data-mylist]')!;
    list.addEventListener('click', () => {
      const on = list.getAttribute('aria-pressed') !== 'true';
      list.setAttribute('aria-pressed', String(on));
      const mark = list.querySelector('b')!;
      mark.textContent = on ? '✓' : '+';
    });
    const play = app.querySelector<HTMLElement>('[data-play]')!;
    app.querySelectorAll<HTMLButtonElement>('[data-ep]').forEach((ep) => {
      ep.addEventListener('click', () => {
        app.querySelectorAll('.cz-app__ep').forEach((r) => r.classList.remove('is-now'));
        ep.closest('.cz-app__ep')!.classList.add('is-now');
        play.textContent = `▶  Resume ${(ep.dataset.ep || '').replace('SEASON ', 'S·')}`;
      });
    });
    // pointer over the key art: the ghost Æ takes the gilt where the hand
    // passes, and the logotype deepens on the weight axis with proximity
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const hero = app.querySelector<HTMLElement>('.cz-app__hero')!;
      const gilt = app.querySelector<HTMLElement>('.cz-app__heroglyph--gilt')!;
      const logo = app.querySelector<HTMLElement>('.cz-app__logo')!;
      hero.addEventListener('pointermove', (e) => {
        const g = gilt.getBoundingClientRect();
        gilt.style.setProperty('--mx', `${(e.clientX - g.left).toFixed(0)}px`);
        gilt.style.setProperty('--my', `${(e.clientY - g.top).toFixed(0)}px`);
        const l = logo.getBoundingClientRect();
        const d = Math.hypot(e.clientX - (l.left + l.width / 2), e.clientY - (l.top + l.height / 2));
        const f = Math.max(0, 1 - d / 420);
        logo.style.setProperty('--lw', String(Math.round(700 + 180 * f)));
      });
      hero.addEventListener('pointerleave', () => {
        gilt.style.setProperty('--mx', '-999px');
        gilt.style.setProperty('--my', '-999px');
        logo.style.setProperty('--lw', '700');
      });
    }
  });

  // ── 05 · the pointer as chisel ─────────────────────────────────────────
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduce) document.querySelectorAll<HTMLElement>('[data-carve]').forEach((carve) => {
    const lineEls = Array.from(carve.querySelectorAll<HTMLElement>('.cz-carve__line'));
    const letters = Array.from(carve.querySelectorAll<HTMLElement>('[data-l]'));
    const lits = new Float32Array(letters.length);   // heat persists, then cools
    // the server-rendered carver's sweep (the inline --w values) is the act's
    // rest state. It is a FLOOR, not a memory: every painted frame keeps each
    // letter at least as deep as its sweep weight, so no frame — parked,
    // cooling, or mid-cycle — ever reads flatter than the no-JS fallback.
    const sweep = letters.map((l) => l.style.getPropertyValue('--w'));
    const restW = sweep.map((w) => parseFloat(w) || 400);
    const restoreSweep = () => {
      letters.forEach((l, i) => {
        l.style.setProperty('--w', sweep[i]);
        l.style.removeProperty('--lit');
        lits[i] = 0;
      });
    };
    let centers: { x: number; y: number }[] = [];
    let lineGeo: { x0: number; x1: number; y: number }[] = [];
    let raf = 0;
    let px = -1e4, py = -1e4;        // pointer in page coords
    let lastMove = -Infinity;        // never moved ⇒ first paint is the carver's
    let visible = false;
    const measure = () => {
      centers = letters.map((l) => {
        const r = l.getBoundingClientRect();
        return { x: r.left + r.width / 2 + window.scrollX, y: r.top + r.height / 2 + window.scrollY };
      });
      lineGeo = lineEls.map((ln) => {
        const r = ln.getBoundingClientRect();
        return { x0: r.left + window.scrollX, x1: r.right + window.scrollX, y: r.top + r.height / 2 + window.scrollY };
      });
    };
    const ro = new ResizeObserver(measure);
    ro.observe(carve);
    document.fonts?.ready.then(measure);

    const PASS = 3000, REST = 650;   // ms per carved line, breath between lines
    const paint = (t: number) => {
      raf = 0;
      const R = Math.max(200, carve.clientWidth * 0.2);
      const idle = performance.now() - lastMove > 2400;
      let cx = px, cy = py;
      if (idle && lineGeo.length) {
        // the carver's own pass: LITTERA, then SCRIPTA, then MANET —
        // each line struck left to right while the last one cools
        const cycle = lineGeo.length * (PASS + REST);
        const ph = t % cycle;
        const k = Math.min(lineGeo.length - 1, Math.floor(ph / (PASS + REST)));
        const p = Math.min(1, (ph - k * (PASS + REST)) / PASS);
        const g = lineGeo[k];
        const pad = R * 0.7;
        cx = g.x0 - pad + (g.x1 - g.x0 + 2 * pad) * p;
        cy = g.y;
      }
      letters.forEach((l, i) => {
        const c = centers[i];
        if (!c) return;
        const d = Math.hypot(c.x - cx, c.y - cy);
        const f = Math.max(0, 1 - d / R);               // 0 far … 1 under the blow
        const lit = Math.max(f, lits[i] * 0.962);       // strike, then cool to bronze
        lits[i] = lit;
        // heat deepens the cut, but never above the blow nor below the sweep
        l.style.setProperty('--w', String(Math.round(Math.max(restW[i], 400 + 500 * lit * lit))));
        l.style.setProperty('--lit', lit.toFixed(3));
      });
      // while on stage the loop never parks (the carver's pass is the act's
      // idle state, so it must always be able to resume on its own clock);
      // offscreen the IO below stops it and puts the sweep back.
      if (visible) raf = requestAnimationFrame(paint);
    };
    const kick = () => { if (!raf) raf = requestAnimationFrame(paint); };
    carve.addEventListener('pointermove', (e) => {
      px = e.pageX; py = e.pageY; lastMove = performance.now(); kick();
    });
    // hand off the stone to the carver the moment the visitor leaves
    carve.addEventListener('pointerleave', () => { px = -1e4; py = -1e4; lastMove = -Infinity; kick(); });
    // start the idle pass when the act enters the viewport; rest it offscreen —
    // and never freeze mid-heat: restore the sweep so re-entry starts clean
    const io = new IntersectionObserver((es) => es.forEach((en) => {
      visible = en.isIntersecting;
      if (visible) kick();
      else { if (raf) { cancelAnimationFrame(raf); raf = 0; } restoreSweep(); }
    }), { threshold: 0.2 });
    io.observe(carve);
  });
</script>

<style>
  /* ── the stack: gold thread, slightly tighter pacing than default ────── */
  /* NOTE: never re-declare `.iu__item` margins here — the scoped selector
