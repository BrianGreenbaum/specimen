---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// --- 01 · Material 3 "Today" app (interactive, real device scale) ---------
// Roboto Slab's native habitat: Android / Material. Slab headlines on cards,
// real px, FAB, segmented chips. Three day-tabs reload the agenda + metrics;
// tabular figures ('tnum') hold the time column and temps on switch.
const days = [
  {
    id: 'mon', label: 'Mon', date: 'Jun 8', hi: 24, lo: 14, cond: 'Sunny', icon: '☀',
    steps: 8420, kcal: 642, focus: '3h 10m',
    agenda: [
      ['09:00', 'Design review', 'Studio · Room 4', 'work'],
      ['11:30', 'Run — riverside loop', '5.2 km', 'health'],
      ['14:00', '1:1 with Priya', 'Video call', 'work'],
      ['18:45', 'Pick up groceries', 'Market St', 'home'],
    ] as [string, string, string, string][],
  },
  {
    id: 'tue', label: 'Tue', date: 'Jun 9', hi: 19, lo: 12, cond: 'Showers', icon: '☂',
    steps: 5110, kcal: 488, focus: '4h 25m',
    agenda: [
      ['08:15', 'Standup', 'Room 4', 'work'],
      ['10:00', 'Deep work — spec', 'Focus block', 'work'],
      ['13:00', 'Lunch w/ Marco', 'Café Otto', 'home'],
      ['20:00', 'Yoga', 'Studio East', 'health'],
    ] as [string, string, string, string][],
  },
  {
    id: 'wed', label: 'Wed', date: 'Jun 10', hi: 27, lo: 16, cond: 'Clear', icon: '◐',
    steps: 11280, kcal: 905, focus: '2h 40m',
    agenda: [
      ['07:30', 'Long run — 10 km', 'Park gates', 'health'],
      ['09:30', 'Roadmap sync', 'Room 2', 'work'],
      ['15:30', 'Dentist', '120 Bell Rd', 'home'],
      ['19:00', 'Dinner — Anya', 'Home', 'home'],
    ] as [string, string, string, string][],
  },
];
const d0 = days[0];
---
<div class="iu" style={`--fam:${fam}`}>

  <!-- 01 — Material 3 "Today" app (interactive, real device scale) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Product UI — Material 3 "Today" app, real device scale</span></figcaption>
    <div class="iu__scene iu__scene--phone">
      <div class="iu__device md" data-md>
        <div class="md__chrome">
          <span class="md__time">9:41</span>
          <span class="md__status">
            <svg class="md__wifi" viewBox="0 0 16 12" aria-hidden="true"><rect x="0" y="8" width="3" height="4" rx="0.6"/><rect x="4" y="5" width="3" height="7" rx="0.6"/><rect x="8" y="2" width="3" height="10" rx="0.6"/><rect x="12" y="0" width="3" height="12" rx="0.6"/></svg>
            <svg class="md__batt" viewBox="0 0 26 12" aria-hidden="true"><rect x="0.5" y="0.5" width="22" height="11" rx="2.5" fill="none" stroke="currentColor" stroke-width="1"/><rect x="24" y="3.5" width="2" height="5" rx="1" fill="currentColor"/><rect x="2" y="2" width="17" height="8" rx="1" fill="currentColor"/></svg>
          </span>
        </div>
        <div class="md__appbar">
          <span class="md__menu" aria-hidden="true"><i></i><i></i><i></i></span>
          <span class="md__title">Today</span>
          <span class="md__avatar">RS</span>
        </div>
        <div class="md__days" role="tablist">
          {days.map((dy, i) => (
            <button class={`md__day ${i === 0 ? 'is-on' : ''}`} data-day={dy.id} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>
              <em>{dy.label}</em>
              <b data-day-date={dy.id}>{dy.date.split(' ')[1]}</b>
            </button>
          ))}
        </div>
        <div class="md__body">
          <div class="md__hero">
            <span class="md__hero-top">
              <span class="md__hero-place">Riverside</span>
              <span class="md__hero-date" data-fulldate>{d0.date}</span>
            </span>
            <span class="md__hero-display">
              <b class="md__temp" data-hi>{d0.hi}°</b>
              <span class="md__hero-side">
                <span class="md__hero-ic" data-icon>{d0.icon}</span>
                <span class="md__cond"><span data-cond>{d0.cond}</span></span>
                <span class="md__hilo"><i data-lo>L {d0.lo}°</i></span>
              </span>
            </span>
          </div>
          <div class="md__metrics">
            <div class="md__metric"><span class="md__metric-k">Steps</span><b class="md__metric-val" data-steps>{d0.steps.toLocaleString()}</b></div>
            <div class="md__metric"><span class="md__metric-k">Active kcal</span><b class="md__metric-val" data-kcal>{d0.kcal}</b></div>
            <div class="md__metric"><span class="md__metric-k">Focus</span><b class="md__metric-val" data-focus>{d0.focus}</b></div>
          </div>
          <div class="md__agenda-h">Agenda</div>
          <ul class="md__agenda" data-agenda>
            {d0.agenda.map((a) => (
              <li class={`md__ev md__ev--${a[3]}`}>
                <span class="md__ev-time">{a[0]}</span>
                <span class="md__ev-rail" aria-hidden="true"></span>
                <span class="md__ev-main"><b>{a[1]}</b><i>{a[2]}</i></span>
              </li>
            ))}
          </ul>
        </div>
        <button class="md__fab" aria-label="New event">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14M5 12h14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
        </button>
        <div class="md__nav">
          <span class="is-on">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 11.5 12 5l8 6.5M6 10v9h12v-9" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" stroke-linecap="round"/></svg>
            <em>Today</em>
          </span>
          <span>
            <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="5.5" width="16" height="15" rx="2.2" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M4 10h16M8 3.5v3.5M16 3.5v3.5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
            <em>Calendar</em>
          </span>
          <span>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 14l4-5 4 3 4-7 4 9" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" stroke-linecap="round"/><path d="M4 19h16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
            <em>Activity</em>
          </span>
          <span>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h10" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
            <em>More</em>
          </span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Tap a day — temperature pulses through the wght axis on switch, metrics reload, agenda rebuilds. Roboto Slab in its native Material habitat: variable-weight slab headings, tabular times that hold their column.</p>
  </figure>

  <!-- 02 — Material product marketing page (Pixel-style hardware launch) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Product marketing — Material hardware launch page, color picker</span></figcaption>
    <div class="iu__scene scene-tall">
      <div class="mk" data-mk>
        <div class="mk__nav">
          <span class="mk__logo">◖ Pixel</span>
          <nav class="mk__menu"><a>Phone</a><a>Watch</a><a>Buds</a><a class="mk__cta">Pre-order</a></nav>
        </div>
        <div class="mk__hero">
          <div class="mk__copy">
            <span class="mk__eyebrow">New · Tensor G4</span>
            <h3 class="mk__head">Pixel<br/>Pro</h3>
            <p class="mk__sub">The slab that reads as easily on a spec sheet as it commands on a billboard. Built for the screen, footed in ink.</p>
            <div class="mk__picker" role="group" aria-label="Finish">
              <button class="mk__chip is-on" data-fin="Obsidian" data-hex="#1d1c1a" style="--c:#1d1c1a" aria-label="Obsidian"></button>
              <button class="mk__chip" data-fin="Porcelain" data-hex="#e7e2d8" style="--c:#e7e2d8" aria-label="Porcelain"></button>
              <button class="mk__chip" data-fin="Bay" data-hex="#5b7c99" style="--c:#5b7c99" aria-label="Bay"></button>
              <button class="mk__chip" data-fin="Rose" data-hex="#c66b5a" style="--c:#c66b5a" aria-label="Rose"></button>
              <span class="mk__fin" data-fin-name>Obsidian</span>
            </div>
            <div class="mk__buy">
              <span class="mk__price">From £<i data-price>899</i></span>
              <button class="mk__order">Pre-order</button>
            </div>
          </div>
          <div class="mk__art" aria-hidden="true">
            <div class="mk__device" data-device>
              <div class="mk__screen" data-screen>
                <div class="mk__scr-top">
                  <span class="mk__scr-time">9:41</span>
                  <span class="mk__scr-icons">▲ ▲ ▐</span>
                </div>
                <div class="mk__scr-photo" data-scr-photo></div>
                <div class="mk__scr-caption" data-scr-cap>Morning light</div>
                <div class="mk__scr-actions">
                  <span class="mk__scr-btn">Edit</span>
                  <span class="mk__scr-btn mk__scr-btn--share">Share</span>
                </div>
              </div>
            </div>
            <span class="mk__bignum">G4</span>
          </div>
        </div>
        <div class="mk__specs">
          <div class="mk__spec"><b data-s1>50</b><i>MP main, ƒ/1.7</i></div>
          <div class="mk__spec"><b><span data-s2>6.7</span>″</b><i>120 Hz OLED</i></div>
          <div class="mk__spec"><b><span data-s3>24</span>h</b><i>battery life</i></div>
          <div class="mk__spec"><b data-s4>256</b><i>GB storage</i></div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">A Material hardware launch page. Pick a finish — the wordmark swings across the weight axis, the device screen recolors, the price and specs reset. Big slab numerals headline the specs.</p>
  </figure>

  <!-- 03 — Material 3 analytics dashboard (big slab metrics, tnum, range tabs) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Product UI — Material 3 analytics console, big slab metrics + tabular figures</span></figcaption>
    <div class="iu__scene scene-dash">
      <div class="iu__device dash" data-dash>
        <div class="dash__bar">
          <span class="dash__brand">◉ Console</span>
          <span class="dash__title">Overview</span>
          <div class="dash__range" role="tablist">
            <button class="dash__rng is-on" data-rng="7d" role="tab" aria-selected="true">7d</button>
            <button class="dash__rng" data-rng="28d" role="tab" aria-selected="false">28d</button>
            <button class="dash__rng" data-rng="90d" role="tab" aria-selected="false">90d</button>
          </div>
          <span class="dash__av">RS</span>
        </div>
        <div class="dash__grid">
          <div class="dash__card dash__card--feat">
            <span class="dash__k">Active users</span>
            <b class="dash__big" data-m-users>128,402</b>
            <span class="dash__delta dash__delta--up" data-d-users>▲ 12.4%</span>
            <span class="dash__spark" data-spark aria-hidden="true">
              <svg viewBox="0 0 120 36" preserveAspectRatio="none"><polyline data-poly points="" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/></svg>
            </span>
          </div>
          <div class="dash__card">
            <span class="dash__k">Revenue</span>
            <b class="dash__big" data-m-rev>$94,210</b>
            <span class="dash__delta dash__delta--up" data-d-rev>▲ 8.1%</span>
          </div>
          <div class="dash__card">
            <span class="dash__k">Sessions</span>
            <b class="dash__big" data-m-sess>312,860</b>
            <span class="dash__delta dash__delta--down" data-d-sess>▼ 2.3%</span>
          </div>
          <div class="dash__card dash__card--mid">
            <span class="dash__k">Avg. session</span>
            <b class="dash__big" data-m-dur>4:38</b>
            <span class="dash__delta dash__delta--up" data-d-dur>▲ 0.9%</span>
          </div>
          <div class="dash__card dash__card--mid dash__card--bounce">
            <span class="dash__k">Bounce rate</span>
            <b class="dash__big" data-m-bounce>34.2%</b>
            <span class="dash__delta dash__delta--down" data-d-bounce>▼ 1.8%</span>
          </div>
          <div class="dash__card dash__card--mid dash__card--ret">
            <span class="dash__k">Retention</span>
            <b class="dash__big" data-m-ret>68.9%</b>
            <span class="dash__delta dash__delta--up" data-d-ret>▲ 3.2%</span>
          </div>
          <div class="dash__card dash__card--mid dash__card--conv">
            <span class="dash__k">Conversions</span>
            <b class="dash__big" data-m-conv>2,841</b>
            <span class="dash__delta dash__delta--up" data-d-conv>▲ 5.9%</span>
          </div>
          <div class="dash__card dash__card--wide">
            <span class="dash__k">Top channels</span>
            <table class="dash__tbl">
              <tbody data-rows>
                <tr><td>Organic search</td><td class="num">48,120</td><td class="num pct">38.4%</td></tr>
                <tr><td>Direct</td><td class="num">31,540</td><td class="num pct">25.2%</td></tr>
                <tr><td>Referral</td><td class="num">22,910</td><td class="num pct">18.3%</td></tr>
                <tr><td>Social</td><td class="num">14,200</td><td class="num pct">11.3%</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">A Material 3 analytics console. Switch the date range — every metric, delta, sparkline and the channel table reflow. Big slab numerals headline the cards; tabular ('tnum') figures keep every column locked.</p>
  </figure>

  <!-- 04 — Material You launch wall: per-letter weight wave spells the headline -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Brand — Material You launch wall, per-letter weight wave</span></figcaption>
    <div class="iu__scene scene-tall">
      <div class="wall">
        <div class="wall__top">
          <span class="wall__brand">▱&nbsp;Android&nbsp;16 <i>Material You</i></span>
          <span class="wall__edition">Developer&nbsp;Preview</span>
        </div>
        <div class="wall__hero">
          <span class="wall__kick">The one type system that</span>
          <h3 class="wall__word" aria-label="ADAPTS" data-wave>
            <span style="--i:0">A</span><span style="--i:1">D</span><span style="--i:2">A</span><span style="--i:3">P</span><span style="--i:4">T</span><span style="--i:5">S</span>
          </h3>
          <span class="wall__mid">to <em>every</em> screen, weight and color</span>
        </div>
        <div class="wall__foot">
          <span class="wall__swatches" aria-hidden="true">
            <i style="--s:#b1551f"></i><i style="--s:#5b7c99"></i><i style="--s:#7a8b53"></i><i style="--s:#9a6f4e"></i><i style="--s:#6d5d8a"></i>
          </span>
          <span class="wall__rail">wght&nbsp;100 → 900</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">A Material You launch wall. A weight wave travels letter-by-letter across "ADAPTS" — each glyph swings the full 100→900 slab axis in sequence, the type literally adapting. Distinct from any forge poster.</p>
  </figure>
</div>

<script id="roboto-slab-day-data" type="application/json" set:html={JSON.stringify(days)} is:inline></script>

<script>
  // ============ 01 · MATERIAL "TODAY" APP ============
  type Day = {
    id: string; label: string; date: string; hi: number; lo: number; cond: string; icon: string;
    steps: number; kcal: number; focus: string;
    agenda: [string, string, string, string][];
  };
  const dayIsland = document.getElementById('roboto-slab-day-data');
  let days: Day[] = [];
  try { days = dayIsland ? JSON.parse(dayIsland.textContent || '[]') : []; } catch { days = []; }
  const byDay: Record<string, Day> = {};
  days.forEach((d) => (byDay[d.id] = d));

  document.querySelectorAll<HTMLElement>('[data-md]').forEach((md) => {
    if (!days.length) return;
    const q = (s: string) => md.querySelector(s) as HTMLElement | null;
    const icon = q('[data-icon]'), hi = q('[data-hi]'), cond = q('[data-cond]'), lo = q('[data-lo]');
    const fulldate = q('[data-fulldate]'), steps = q('[data-steps]'), kcal = q('[data-kcal]'), focus = q('[data-focus]');
    const agenda = q('[data-agenda]');

    function render(id: string) {
      const d = byDay[id];
      if (!d) return;
      if (icon) icon.textContent = d.icon;
      if (hi) {
        hi.textContent = `${d.hi}°`;
        // pulse wght axis on switch so the variable axis is visibly exercised
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!reduced) {
          hi.style.transition = 'none';
          hi.style.fontVariationSettings = "'wght' 200";
          requestAnimationFrame(() => {
            hi.style.transition = 'font-variation-settings 0.55s cubic-bezier(0.34,1.56,0.64,1)';
            hi.style.fontVariationSettings = "'wght' 800";
          });
        }
      }
      if (cond) cond.textContent = d.cond;
      if (lo) lo.textContent = `L ${d.lo}°`;
      if (fulldate) fulldate.textContent = d.date;
      if (steps) steps.textContent = d.steps.toLocaleString();
      if (kcal) kcal.textContent = String(d.kcal);
      if (focus) focus.textContent = d.focus;

      if (agenda) {
        agenda.replaceChildren();
        d.agenda.forEach((a) => {
          const li = document.createElement('li');
          li.className = `md__ev md__ev--${a[3]}`;
          const time = document.createElement('span');
          time.className = 'md__ev-time';
          time.textContent = a[0];
          const rail = document.createElement('span');
          rail.className = 'md__ev-rail';
          rail.setAttribute('aria-hidden', 'true');
          const main = document.createElement('span');
          main.className = 'md__ev-main';
          const title = document.createElement('b');
          title.textContent = a[1];
          const sub = document.createElement('i');
          sub.textContent = a[2];
          main.append(title, sub);
          li.append(time, rail, main);
          agenda.appendChild(li);
        });
      }

      md.querySelectorAll('[data-day]').forEach((b) => {
        const on = (b as HTMLElement).dataset.day === id;
        b.classList.toggle('is-on', on);
        b.setAttribute('aria-selected', on ? 'true' : 'false');
      });
    }

    md.querySelectorAll<HTMLButtonElement>('[data-day]').forEach((btn) =>
      btn.addEventListener('click', () => render(btn.dataset.day!))
    );
  });

  // ============ 02 · MATERIAL MARKETING — finish picker ============
  type MkFinish = { price: string; s1: string; s2: string; s3: string; s4: string; wght: number; scrBg: string; scrAccent: string; caption: string; };
  const mkData: Record<string, MkFinish> = {
    Obsidian:  { price: '899', s1: '50',  s2: '6.7', s3: '24', s4: '256', wght: 900, scrBg: '#1a1a1a', scrAccent: '#e07b3c', caption: 'Night city' },
    Porcelain: { price: '899', s1: '50',  s2: '6.7', s3: '24', s4: '256', wght: 400, scrBg: '#f0ece5', scrAccent: '#5b7c99', caption: 'Morning light' },
    Bay:       { price: '949', s1: '50',  s2: '6.7', s3: '26', s4: '512', wght: 700, scrBg: '#1c2e3d', scrAccent: '#7ab8d4', caption: 'Open water' },
    Rose:      { price: '849', s1: '48',  s2: '6.3', s3: '22', s4: '128', wght: 300, scrBg: '#2d1a1a', scrAccent: '#c66b5a', caption: 'Golden hour' },
  };
  document.querySelectorAll<HTMLElement>('[data-mk]').forEach((mk) => {
    const device = mk.querySelector<HTMLElement>('[data-device]');
    const finName = mk.querySelector<HTMLElement>('[data-fin-name]');
    const price = mk.querySelector<HTMLElement>('[data-price]');
    const s1 = mk.querySelector<HTMLElement>('[data-s1]');
    const s2 = mk.querySelector<HTMLElement>('[data-s2]');
    const s3 = mk.querySelector<HTMLElement>('[data-s3]');
    const s4 = mk.querySelector<HTMLElement>('[data-s4]');
    const head = mk.querySelector<HTMLElement>('.mk__head');
    const scrPhoto = mk.querySelector<HTMLElement>('[data-scr-photo]');
    const scrCap = mk.querySelector<HTMLElement>('[data-scr-cap]');
    const chips = Array.from(mk.querySelectorAll<HTMLButtonElement>('[data-fin]'));
    let currentWght = 800;
    const apply = (btn: HTMLButtonElement, animate: boolean) => {
      chips.forEach((c) => { c.classList.toggle('is-on', c === btn); });
      const name = btn.dataset.fin!;
      const hex = btn.dataset.hex!;
      if (device) device.style.setProperty('--dev', hex);
      if (finName) finName.textContent = name;
      const d = mkData[name];
      if (d) {
        if (price) price.textContent = d.price;
        if (s1) s1.textContent = d.s1;
        if (s2) s2.textContent = d.s2;
        if (s3) s3.textContent = d.s3;
        if (s4) s4.textContent = d.s4;
        if (scrPhoto) { scrPhoto.style.background = d.scrBg; scrPhoto.style.setProperty('--sa', d.scrAccent); }
        if (scrCap) scrCap.textContent = d.caption;
        // swing the wordmark across the weight axis on finish change
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (head && animate && !reduced) {
          const from = currentWght;
          const to = d.wght;
          head.style.transition = 'none';
          head.style.fontVariationSettings = `'wght' ${from}`;
          requestAnimationFrame(() => {
            head.style.transition = 'font-variation-settings 0.5s cubic-bezier(0.25,0.46,0.45,0.94)';
            head.style.fontVariationSettings = `'wght' ${to}`;
          });
        } else if (head) {
          head.style.fontVariationSettings = `'wght' ${d.wght}`;
        }
        currentWght = d.wght;
      }
    };
    chips.forEach((c) => c.addEventListener('click', () => apply(c, true)));
    const first = chips.find((c) => c.classList.contains('is-on')) || chips[0];
    if (first) apply(first, false);
  });

  // ============ 03 · MATERIAL ANALYTICS DASHBOARD — date range ============
  type Metric = { users: string; rev: string; sess: string; dur: string; bounce: string; ret: string; conv: string;
    du: string; dr: string; ds: string; dd: string; dbounce: string; dret: string; dconv: string;
    up: boolean[]; spark: number[];
    rows: [string, string, string][]; };
  const dashData: Record<string, Metric> = {
    '7d': {
      users: '128,402', rev: '$94,210', sess: '312,860', dur: '4:38', bounce: '34.2%', ret: '68.9%', conv: '2,841',
      du: '▲ 12.4%', dr: '▲ 8.1%', ds: '▼ 2.3%', dd: '▲ 0.9%', dbounce: '▼ 1.8%', dret: '▲ 3.2%', dconv: '▲ 5.9%',
      up: [true, true, false, true, false, true, true],
      spark: [12, 18, 14, 22, 19, 27, 31],
      rows: [['Organic search', '48,120', '38.4%'], ['Direct', '31,540', '25.2%'], ['Referral', '22,910', '18.3%'], ['Social', '14,200', '11.3%']],
    },
    '28d': {
      users: '512,940', rev: '$381,620', sess: '1,248,300', dur: '4:51', bounce: '31.6%', ret: '71.4%', conv: '11,340',
      du: '▲ 9.7%', dr: '▲ 11.2%', ds: '▲ 4.0%', dd: '▲ 1.6%', dbounce: '▼ 4.4%', dret: '▲ 5.7%', dconv: '▲ 8.2%',
      up: [true, true, true, true, false, true, true],
      spark: [20, 16, 24, 21, 28, 26, 33],
      rows: [['Organic search', '196,420', '39.1%'], ['Direct', '124,880', '24.9%'], ['Referral', '88,610', '17.6%'], ['Social', '61,300', '12.2%']],
    },
    '90d': {
      users: '1,604,210', rev: '$1,142,900', sess: '3,981,540', dur: '4:29', bounce: '36.8%', ret: '65.2%', conv: '34,120',
      du: '▲ 6.2%', dr: '▲ 5.4%', ds: '▼ 1.1%', dd: '▼ 0.7%', dbounce: '▲ 2.6%', dret: '▼ 2.1%', dconv: '▲ 4.1%',
      up: [true, true, false, false, true, false, true],
      spark: [14, 19, 17, 23, 20, 18, 25],
      rows: [['Organic search', '624,800', '37.8%'], ['Direct', '402,110', '24.3%'], ['Referral', '301,540', '18.2%'], ['Social', '214,900', '13.0%']],
    },
  };
  document.querySelectorAll<HTMLElement>('[data-dash]').forEach((dash) => {
    const q = (s: string) => dash.querySelector(s) as HTMLElement | null;
    const mUsers = q('[data-m-users]'), mRev = q('[data-m-rev]'), mSess = q('[data-m-sess]'), mDur = q('[data-m-dur]');
    const mBounce = q('[data-m-bounce]'), mRet = q('[data-m-ret]'), mConv = q('[data-m-conv]');
    const dUsers = q('[data-d-users]'), dRev = q('[data-d-rev]'), dSess = q('[data-d-sess]'), dDur = q('[data-d-dur]');
    const dBounce = q('[data-d-bounce]'), dRet = q('[data-d-ret]'), dConv = q('[data-d-conv]');
    const poly = dash.querySelector<SVGPolylineElement>('[data-poly]');
    const rows = q('[data-rows]');
    const deltas = [dUsers, dRev, dSess, dDur, dBounce, dRet, dConv];
    const sparkPts = (vals: number[]) => {
      const max = Math.max(...vals), min = Math.min(...vals);
      const span = Math.max(1, max - min);
      return vals.map((v, i) => {
        const x = (i / (vals.length - 1)) * 120;
        const y = 34 - ((v - min) / span) * 30;
        return `${x.toFixed(1)},${y.toFixed(1)}`;
      }).join(' ');
    };
    const apply = (key: string, animate = false) => {
      const d = dashData[key];
      if (!d) return;
      if (mUsers) {
        mUsers.textContent = d.users;
        // exercise wght axis on the feature metric
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (animate && !reduced) {
          mUsers.style.transition = 'none';
          mUsers.style.fontVariationSettings = "'wght' 200";
          requestAnimationFrame(() => {
            mUsers.style.transition = 'font-variation-settings 0.6s cubic-bezier(0.34,1.56,0.64,1)';
            mUsers.style.fontVariationSettings = "'wght' 800";
          });
        }
      }
      if (mRev) mRev.textContent = d.rev;
      if (mSess) mSess.textContent = d.sess;
      if (mDur) mDur.textContent = d.dur;
      if (mBounce) mBounce.textContent = d.bounce;
      if (mRet) mRet.textContent = d.ret;
      if (mConv) mConv.textContent = d.conv;
      const dtexts = [d.du, d.dr, d.ds, d.dd, d.dbounce, d.dret, d.dconv];
      deltas.forEach((el, i) => {
        if (!el) return;
        el.textContent = dtexts[i];
        el.classList.toggle('dash__delta--up', d.up[i]);
        el.classList.toggle('dash__delta--down', !d.up[i]);
      });
      if (poly) poly.setAttribute('points', sparkPts(d.spark));
      if (rows) {
        rows.replaceChildren();
        d.rows.forEach((r) => {
          const tr = document.createElement('tr');
          const t0 = document.createElement('td'); t0.textContent = r[0];
          const t1 = document.createElement('td'); t1.className = 'num'; t1.textContent = r[1];
          const t2 = document.createElement('td'); t2.className = 'num pct'; t2.textContent = r[2];
          tr.append(t0, t1, t2);
          rows.appendChild(tr);
        });
      }
    };
    dash.querySelectorAll<HTMLButtonElement>('[data-rng]').forEach((btn) =>
      btn.addEventListener('click', () => {
        dash.querySelectorAll('[data-rng]').forEach((b) => {
          const on = b === btn;
          b.classList.toggle('is-on', on);
          b.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        apply(btn.dataset.rng!, true);
      })
    );
    apply('7d', false);
  });
</script>

