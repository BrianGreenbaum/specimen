---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;
---
<div class="iu" style={`--fam:${fam}`}>
  <!-- 01 — realistic interactive terminal -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Terminal — a real shell session</span></figcaption>
    <div class="iu__scene">
      <div class="term" data-term>
        <div class="term__chrome">
          <div class="iu__dots"><i style="background:#ff5f57"></i><i style="background:#febc2e"></i><i style="background:#28c840"></i></div>
          <span class="term__title">brian@specimen — zsh</span>
        </div>
        <div class="term__body" data-term-body>
          <p><span class="c">~/specimen</span> <span class="p">❯</span> whoami</p>
          <p class="o">brian — typographer, occasional shell tourist</p>
          <p><span class="c">~/specimen</span> <span class="p">❯</span> <span class="cur">█</span></p>
        </div>
        <div class="term__cmds">
          <span class="label">Try:</span>
          <button data-cmd="npm run build">npm run build</button>
          <button data-cmd="git status">git status</button>
          <button data-cmd="ls fonts/">ls fonts/</button>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Click a command — Plex Mono at real code sizes.</p>
  </figure>

  <!-- 02 — code editor -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Code — syntax in the editor</span></figcaption>
    <div class="iu__scene">
      <div class="editor">
        <div class="editor__tabs"><span class="is-on">specimen.ts</span><span>theme.css</span></div>
        <div class="editor__code">
          <ol>
            <li><span class="kw">export</span> <span class="kw">const</span> <span class="fn">render</span> = <span class="pn">(</span>glyph<span class="pn">)</span> => <span class="pn">{`{`}</span></li>
            <li>  <span class="kw">const</span> m = <span class="fn">measure</span><span class="pn">(</span><span class="st">'Inter'</span>, glyph<span class="pn">)</span>;</li>
            <li>  <span class="cm">// baseline, x-height, cap — all real</span></li>
            <li>  <span class="kw">return</span> <span class="pn">{`{`}</span> x: m.xHeight, cap: m.capHeight <span class="pn">{`}`}</span>;</li>
            <li><span class="pn">{`}`}</span>;</li>
            <li>&nbsp;</li>
            <li><span class="cm">// man &amp; machine, set in mono</span></li>
            <li><span class="fn">console</span>.<span class="fn">log</span><span class="pn">(</span><span class="st">`0 != O`</span><span class="pn">)</span>;</li>
          </ol>
        </div>
      </div>
    </div>
  </figure>
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-term]').forEach((term) => {
    const body = term.querySelector('[data-term-body]') as HTMLElement;
    const out: Record<string, string[]> = {
      'npm run build': ['▸ building 22 pages…', '✓ 12 specimens · 8 eras', '◆ done in 0.42s'],
      'git status': ['On branch main', 'nothing to commit, working tree clean'],
      'ls fonts/': ['inter  fraunces  bodoni-moda  besley', 'jost  cinzel  eb-garamond  …'],
    };
    term.querySelectorAll<HTMLButtonElement>('[data-cmd]').forEach((b) =>
      b.addEventListener('click', () => {
        const cmd = b.dataset.cmd!;
        const cur = body.querySelector('.cur')?.closest('p');
        if (cur) cur.remove();
        const mk = (html: boolean, cls: string, text: string) => {
          const p = document.createElement('p');
          if (cls) p.className = cls;
          p.textContent = text;
          return p;
        };
        const line = document.createElement('p');
        const c = document.createElement('span'); c.className = 'c'; c.textContent = '~/specimen';
        const pr = document.createElement('span'); pr.className = 'p'; pr.textContent = '❯';
        line.append(c, document.createTextNode(' '), pr, document.createTextNode(' ' + cmd));
        body.appendChild(line);
        (out[cmd] || ['…']).forEach((o) => body.appendChild(mk(false, 'o', o)));
        const next = document.createElement('p');
        const c2 = document.createElement('span'); c2.className = 'c'; c2.textContent = '~/specimen';
        const pr2 = document.createElement('span'); pr2.className = 'p'; pr2.textContent = '❯';
        const cur2 = document.createElement('span'); cur2.className = 'cur'; cur2.textContent = '█';
        next.append(c2, document.createTextNode(' '), pr2, document.createTextNode(' '), cur2);
        body.appendChild(next);
        body.scrollTop = body.scrollHeight;
      })
    );
  });
</script>

<style>
  .iu__item { margin: 0; }
  .iu__hint { margin-top: var(--sp-2); color: var(--fg-3); }

  .term { font-family: var(--fam); }
  .term__chrome { display: flex; align-items: center; gap: 0.7rem; padding: 0.6rem 0.9rem; background: color-mix(in srgb, var(--fg) 8%, var(--bg)); border-bottom: 1px solid var(--line); }
  .term__title { font-size: 12px; color: var(--fg-3); margin-inline: auto; }
  .term__body { padding: 1rem 1.1rem; font-size: 13px; line-height: 1.7; height: 260px; overflow-y: auto; }
  .term__body p { white-space: pre-wrap; word-break: break-word; }
  .term .c { color: var(--accent); }
  .term .p { color: #2ecc71; }
  .term .o { color: var(--fg-2); }
  .term .cur { animation: blink 1.1s steps(1) infinite; }
  @keyframes blink { 50% { opacity: 0; } }
  .term__cmds { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; padding: 0.7rem 1.1rem; border-top: 1px solid var(--line); }
  .term__cmds button { font-family: var(--fam); font-size: 12px; color: var(--fg-2); border: 1px solid var(--line); border-radius: 4px; padding: 0.3rem 0.6rem; transition: all 0.18s var(--ease); }
  .term__cmds button:hover { border-color: var(--accent); color: var(--accent); }

  .editor { font-family: var(--fam); }
  .editor__tabs { display: flex; gap: 0; border-bottom: 1px solid var(--line); background: color-mix(in srgb, var(--fg) 4%, var(--bg)); }
  .editor__tabs span { font-size: 12px; color: var(--fg-3); padding: 0.6rem 1rem; border-right: 1px solid var(--line); }
  .editor__tabs span.is-on { color: var(--fg); background: var(--bg); border-bottom: 2px solid var(--accent); }
  .editor__code { padding: 0.8rem 0; font-size: 13px; line-height: 1.7; }
  .editor__code ol { counter-reset: l; }
  .editor__code li { counter-increment: l; padding-left: 3.4rem; position: relative; white-space: pre; }
  .editor__code li::before { content: counter(l); position: absolute; left: 0; width: 2.6rem; text-align: right; color: var(--fg-3); opacity: 0.5; }
  .editor .kw { color: var(--accent); }
  .editor .fn { color: #4aa3ff; }
  .editor .st { color: #2ecc71; }
  .editor .cm { color: var(--fg-3); font-style: italic; }
  .editor .pn { color: var(--fg-2); }

  @container (max-width: 600px) {
    .term__body { height: 200px; font-size: 12px; }
    .editor__code { font-size: 11.5px; }
  }
</style>
