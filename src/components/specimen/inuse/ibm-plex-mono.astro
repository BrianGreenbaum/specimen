  .mon__k { color: var(--term-dim); font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; }
  .mon__stat b { font-size: 20px; font-weight: 600; letter-spacing: 0.01em; font-variant-numeric: tabular-nums; }
  .mon__stat b.hot { color: var(--term-amber); }
  .mon__spark { font-size: 13px; letter-spacing: -0.5px; min-height: 1.1em; }
  /* distinct per-metric spark colour */
