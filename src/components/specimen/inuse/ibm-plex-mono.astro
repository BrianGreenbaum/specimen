  .ide__branch { border-right: none !important; color: var(--ide-blue) !important; }

  .ide__main { counter-reset: ln; }
  .ide__code { margin: 0; padding: 0.7rem 0; font-size: 13px; line-height: 1.65; overflow-x: auto; counter-reset: ln; }
  .ide__code[hidden] { display: none; }
