  .pass__stubrows > div { display: flex; flex-direction: column; gap: 0.5cqi; }
  .pass__stub .pass__k { color: #8b94a3; }
  .pass__stub .pass__v { font-size: 3.4cqi; }
  .pass__seq { margin-top: auto; font-size: 2.4cqi; letter-spacing: 0.1em; color: #8b94a3; }

  /* ============================================================
     05 — SORTABLE LEDGER (theme tokens, real px)
     ============================================================ */
  .led { background: var(--bg); }
  .led__bar { display: flex; justify-content: space-between; align-items: baseline; padding: 0.85rem 1rem; border-bottom: 1px solid var(--line); }
  .led__title { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--fg-3); }
  .led__sum { font-size: 14px; font-weight: 600; color: var(--accent); font-variant-numeric: tabular-nums; }
  .led__table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
  .led__table th { text-align: left; color: var(--fg-3); font-weight: 500; font-size: 10.5px; letter-spacing: 0.1em; padding: 0.6rem 0.7rem; border-bottom: 1px solid var(--fg); cursor: pointer; user-select: none; white-space: nowrap; }
  .led__table th:hover { color: var(--fg); }
  .led__table th.num { text-align: right; }
  .led__table th[data-active]::after { content: ' ↓'; color: var(--accent); }
  .led__table th[data-active='asc']::after { content: ' ↑'; }
  .led__table td { padding: 0.55rem 0.7rem; border-bottom: 1px solid var(--line-soft); }
  .led__table .num { text-align: right; font-variant-numeric: tabular-nums; }
  .led__table .dim { color: var(--fg-3); }
  .led__table .strong { color: var(--fg); font-weight: 600; }
  .led__table .u { color: var(--fg-3); font-size: 0.82em; margin-left: 1px; }
  .led__table .hot { color: #e0533d; }
  .led__table tbody tr { transition: background 0.15s var(--ease); will-change: transform; }
  .led__table tbody tr:hover { background: color-mix(in srgb, var(--accent) 8%, transparent); }
  .led__table td:first-child { color: var(--fg); }

  /* ---------------- responsive ---------------- */
  @container (max-width: 640px) {
    .mon { font-size: 12px; }
    .mon__stat b { font-size: 17px; }
    .ide__code .ln { padding-left: 3.6rem; }
    .ascii__art { font-size: 11px; line-height: 1.3; }
    .pass__city b { font-size: 9.5cqi; }
  }
