  .pass__barcode { height: 7cqi; margin-top: 1cqi; background-image: repeating-linear-gradient(90deg, #15181d 0 0.6cqi, transparent 0.6cqi 1cqi, #15181d 1cqi 1.3cqi, transparent 1.3cqi 2.1cqi, #15181d 2.1cqi 3.1cqi, transparent 3.1cqi 3.7cqi); }

  .pass__stub { position: relative; background: #15181d; color: #f4f1ea; padding: 5cqi 3cqi 4cqi; display: flex; flex-direction: column; gap: 3.4cqi; }
