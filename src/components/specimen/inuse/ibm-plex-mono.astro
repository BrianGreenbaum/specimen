  .ide__code .ln::before { content: counter(ln); position: absolute; left: 0; width: 2.2rem; text-align: right; color: var(--ide-dim); }
  .ide__code .ln::after { content: attr(data-g); position: absolute; left: 2.7rem; width: 1ch; color: var(--ide-dim); }
  .ide__code .ln.add { background: rgba(63,185,80,0.12); }
  .ide__code .ln.add::after { color: var(--ide-green); }
  .ide__code .ln.del { background: rgba(248,81,73,0.12); }
