  .ide__tokens { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.55rem; }
  .ide__tokens .tok { display: inline-flex; flex-direction: column; align-items: center; min-width: 2.1ch; padding: 0.15rem 0.3rem; border-radius: 4px; border: 1px solid var(--ide-line); background: var(--ide-bg); line-height: 1.2; }
  .ide.ide--alt .ide__tokens .tok b { font-feature-settings: 'ss01' 1, 'ss02' 1, 'zero' 1; }
  .ide__tokens .tok b { font-size: 14px; font-weight: 600; }
  .ide__tokens .tok i { font-style: normal; font-size: 8px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ide-dim); margin-top: 1px; }
  .ide__tokens .tok--ambig { border-color: var(--ide-kw); }
  .ide__tokens .tok--ambig b { color: var(--ide-kw); }
  .ide__tokens .tok--ambig i { color: var(--ide-kw); }
