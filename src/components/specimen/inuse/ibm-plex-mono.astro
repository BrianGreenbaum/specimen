---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// Ledger rows for the sortable table (scene 05). Real, plausible infra spend.
const ledger = [
  { svc: 'compute/api-gateway',   reg: 'us-east-1', req: 4820114, p99: 182, err: 0.03, usd: 12480.55 },
  { svc: 'storage/object-store',  reg: 'eu-west-1', req: 1009388, p99: 41,  err: 0.00, usd: 8210.10 },
  { svc: 'queue/event-bus',       reg: 'us-east-1', req: 9930017, p99: 9,   err: 0.12, usd: 3076.40 },
  { svc: 'db/primary-cluster',    reg: 'us-west-2', req: 884201,  p99: 7,   err: 0.01, usd: 19942.00 },
  { svc: 'edge/cdn',              reg: 'global',    req: 41200900,p99: 23,   err: 0.04, usd: 6588.73 },
  { svc: 'ml/inference',          reg: 'us-east-1', req: 220841,  p99: 940,  err: 0.21, usd: 24105.88 },
];
---
<div class="iu" style={`--fam:${fam}`}>
  <!-- 01 — INTERACTIVE REAL-SCALE UI: live monitoring terminal -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Observability — a live monitoring terminal</span></figcaption>
    <div class="iu__scene">
      <div class="mon" data-mon>
        <div class="mon__chrome">
          <div class="iu__dots"><i style="background:#ff5f57"></i><i style="background:#febc2e"></i><i style="background:#28c840"></i></div>
          <span class="mon__title">plexctl top — region us-east-1</span>
          <span class="mon__live" data-live><i></i> LIVE</span>
        </div>

        <div class="mon__grid">
          <div class="mon__stat"><span class="mon__k">req/s</span><b data-stat="rps">—</b><span class="mon__spark" data-spark="rps"></span></div>
          <div class="mon__stat"><span class="mon__k">p99 ms</span><b data-stat="p99">—</b><span class="mon__spark" data-spark="p99"></span></div>
          <div class="mon__stat"><span class="mon__k">err %</span><b data-stat="err">—</b><span class="mon__spark" data-spark="err"></span></div>
          <div class="mon__stat"><span class="mon__k">cpu %</span><b data-stat="cpu">—</b><span class="mon__spark" data-spark="cpu"></span></div>
        </div>

        <table class="mon__procs">
          <thead><tr><th>PID</th><th>NODE</th><th class="r">CONN</th><th class="r">RSS</th><th class="bar">LOAD</th></tr></thead>
          <tbody data-procs>
            <tr><td>00412</td><td>api-7f9c</td><td class="r" data-conn>1842</td><td class="r" data-rss>318M</td><td class="bar"><i data-load style="width:62%"></i></td></tr>
            <tr><td>00871</td><td>api-3b2d</td><td class="r" data-conn>1190</td><td class="r" data-rss>402M</td><td class="bar"><i data-load style="width:41%"></i></td></tr>
            <tr><td>01093</td><td>edge-0a1e</td><td class="r" data-conn>9930</td><td class="r" data-rss>96M</td><td class="bar"><i data-load style="width:78%"></i></td></tr>
            <tr><td>01556</td><td>db-c0re</td><td class="r" data-conn>0064</td><td class="r" data-rss>1.2G</td><td class="bar"><i data-load style="width:23%"></i></td></tr>
          </tbody>
        </table>

        <div class="mon__log" data-log></div>

        <form class="mon__cli" data-cli>
          <span class="mon__prompt">us-east-1 <b>❯</b></span>
          <input data-cli-input type="text" spellcheck="false" autocomplete="off" placeholder="try: scale 6 · drain api-7f9c · status" aria-label="terminal command" />
        </form>
      </div>
    </div>
    <p class="iu__hint label">Live counters realign on the fixed-advance grid every tick. Type <b>scale 6</b>, <b>drain api-7f9c</b>, or <b>status</b> and hit enter.</p>
  </figure>

  <!-- 02 — code editor: switchable tabs, ss-alternate toggle, live tokenizing REPL -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Code — editor, tabs, alternates & a live tokenizer</span></figcaption>
    <div class="iu__scene">
      <div class="ide" data-ide>
        <div class="ide__tabs" role="tablist" aria-label="open files">
          <button class="is-on" role="tab" aria-selected="true" data-tab="ts">tokenizer.ts<i>●</i></button>
          <button role="tab" aria-selected="false" data-tab="css">theme.css</button>
          <button role="tab" aria-selected="false" data-tab="md">README.md</button>
          <button class="ide__alt" data-alt aria-pressed="false" title="Toggle ss01/ss02 stylistic alternates (a g y · digits)">ss<sub>01</sub></button>
          <span class="ide__branch">⎇ main</span>
        </div>

        <div class="ide__main">
          <!-- tokenizer.ts -->
          <pre class="ide__code" data-pane="ts"><code><span class="ln add" data-g="+"><span class="kw">export</span> <span class="kw">function</span> <span class="fn">tokenize</span><span class="pn">(</span><span class="vr">src</span>: <span class="ty">string</span><span class="pn">)</span><span class="pn">:</span> <span class="ty">Token</span><span class="pn">[]</span> <span class="pn">{`{`}</span></span>
<span class="ln"  >  <span class="kw">const</span> <span class="vr">out</span><span class="pn">:</span> <span class="ty">Token</span><span class="pn">[]</span> = <span class="pn">[]</span>;</span>
<span class="ln"  >  <span class="kw">for</span> <span class="pn">(</span><span class="kw">const</span> <span class="vr">ch</span> <span class="kw">of</span> <span class="vr">src</span><span class="pn">)</span> <span class="pn">{`{`}</span></span>
<span class="ln del" data-g="-">    <span class="cm">// 'O' and '0', 'l' and '1' used to collide</span></span>
<span class="ln add" data-g="+">    <span class="vr">out</span>.<span class="fn">push</span><span class="pn">(</span><span class="pn">{`{`}</span> <span class="vr">ch</span>, <span class="vr">kind</span>: <span class="fn">classify</span><span class="pn">(</span><span class="vr">ch</span><span class="pn">)</span> <span class="pn">{`}`}</span><span class="pn">)</span>;</span>
<span class="ln"  >  <span class="pn">{`}`}</span></span>
<span class="ln"  >  <span class="kw">return</span> <span class="vr">out</span>;</span>
<span class="ln"  ><span class="pn">{`}`}</span></span></code></pre>

          <!-- theme.css -->
          <pre class="ide__code" data-pane="css" hidden><code><span class="ln"  ><span class="sel">:root</span> <span class="pn">{`{`}</span></span>
<span class="ln"  >  <span class="prop">--mono</span>: <span class="st">'IBM Plex Mono'</span>, <span class="vr">monospace</span>;</span>
<span class="ln"  >  <span class="prop">--ch</span>: <span class="num2">0.6</span><span class="unit">ch</span>;  <span class="cm">/* one cell wide */</span></span>
<span class="ln"  >  <span class="prop">--ink</span>: <span class="hex">#0a0e15</span>;</span>
<span class="ln"  ><span class="pn">{`}`}</span></span>
<span class="ln"  ><span class="sel">code</span> <span class="pn">{`{`}</span> <span class="prop">font-feature-settings</span>: <span class="st">'zero'</span> <span class="num2">1</span>; <span class="pn">{`}`}</span></span></code></pre>

          <!-- README.md -->
          <pre class="ide__code ide__code--md" data-pane="md" hidden><code><span class="ln"  ><span class="h1"># plex-tokenizer</span></span>
<span class="ln"  ></span>
<span class="ln"  >A lexer set in a face where <span class="code">0</span> never</span>
<span class="ln"  >reads as <span class="code">O</span>, nor <span class="code">1</span> as <span class="code">l</span> or <span class="code">I</span>.</span>
<span class="ln"  ></span>
<span class="ln"  ><span class="bul">-</span> deterministic per-character pass</span>
<span class="ln"  ><span class="bul">-</span> <span class="bold">zero</span> ambiguity by construction</span></code></pre>
        </div>

        <div class="ide__repl">
          <p class="ide__replcmd"><span class="p">›</span> tokenize(<span class="st">"l1 O0 Il"</span>).length</p>
          <p class="ide__replout" data-repl-seed>8</p>
          <form class="ide__replform" data-repl>
            <span class="p">›</span>
            <span class="ide__replpre">tokenize(<span class="st">"</span></span>
            <input data-repl-input type="text" spellcheck="false" autocomplete="off" value="l1 O0 Il" aria-label="tokenizer input" />
            <span class="ide__replpre"><span class="st">"</span>)</span>
          </form>
          <div class="ide__tokens" data-tokens aria-live="polite"></div>
        </div>

        <div class="ide__status">
          <span class="ide__stat-l" data-status-l>TypeScript · UTF-8 · LF</span>
          <span class="ide__stat-r">Ln 5, Col 42 · <i class="add">+3</i> <i class="del">−1</i></span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Switch files, toggle <b>ss01/ss02</b> alternates, and type into the tokenizer — each char is tagged, with <b>0 O</b> / <b>1 l I</b> flagged in colour.</p>
  </figure>

  <!-- 03 — ASCII / box-drawing system diagram with a routed packet -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">ASCII — a box-drawing architecture diagram</span></figcaption>
    <div class="iu__scene">
      <div class="ascii" data-ascii>
        <div class="ascii__head"><span>infra/topology.txt</span><span data-ascii-status>UTF-8 · routing…</span></div>
        <div class="ascii__scroll">
<pre class="ascii__art" data-art aria-label="System architecture rendered in box-drawing characters">        ┌─────────────┐        ┌─────────────┐
        │   CLIENT    │        │   CLIENT    │
        │  390 × 844  │        │ 1440 × 900  │
        └──────┬──────┘        └──────┬──────┘
               │                      │
               └──────────┬───────────┘
                          ▼
                 ╔═════════════════╗
                 ║   EDGE / CDN    ║   ◀── cache hit 94.2%
                 ╚════════╤════════╝
                          │
              ┌───────────┼───────────┐
              ▼           ▼           ▼
        ┌───────┐   ┌───────┐   ┌───────┐
        │ api-1 │   │ api-2 │   │ api-3 │
        └───┬───┘   └───┬───┘   └───┬───┘
            └───────────┼───────────┘
                        ▼
                 ┌──────────────┐
                 │  EVENT BUS   │──▶ ◇ workers ×12
                 └──────┬───────┘
                        ▼
              ┌─────────────────┐
              │  db/primary     │  ●─○ replica
              └─────────────────┘</pre>
        </div>
      </div>
    </div>
    <p class="iu__hint label">A request packet steps cell-by-cell down the rules — every junction and arrow snaps to the grid, impossible in a proportional face.</p>
  </figure>

  <!-- 04 — boarding pass / ticket with figure-style toggle -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Ticket — a monospaced boarding pass</span></figcaption>
    <div class="iu__scene iu__scene--portrait" style="--card-ar: 5 / 3;">
      <div class="iu__poster pass" data-pass>
        <div class="pass__main">
          <div class="pass__brand">
            <span class="pass__logo">▣ PLEX AIR</span>
            <button class="pass__fig" data-fig aria-pressed="false" title="Swap default (lining) ↔ ss02 figures">DEFAULT FIGURES</button>
          </div>
          <div class="pass__route">
            <div class="pass__city"><b>SFO</b><span>San Francisco</span></div>
            <div class="pass__plane">✈</div>
            <div class="pass__city pass__city--r"><b>AMS</b><span>Amsterdam</span></div>
          </div>
          <div class="pass__rows">
            <div><span class="pass__k">PASSENGER</span><span class="pass__v">ABBINK / MIKE</span></div>
            <div><span class="pass__k">FLIGHT</span><span class="pass__v pass__num">IB 0170</span></div>
            <div><span class="pass__k">DATE</span><span class="pass__v pass__num">06 JUN 2026</span></div>
            <div><span class="pass__k">GATE</span><span class="pass__v pass__num">A10</span></div>
            <div><span class="pass__k">BOARD</span><span class="pass__v pass__num">11:05</span></div>
            <div><span class="pass__k">SEAT</span><span class="pass__v pass__num">21C</span></div>
          </div>
          <div class="pass__barcode" aria-hidden="true"></div>
        </div>
        <div class="pass__stub">
          <div class="pass__perf" aria-hidden="true"></div>
          <span class="pass__logo">▣ PLEX AIR</span>
          <div class="pass__stubrows">
            <div><span class="pass__k">SFO → AMS</span></div>
            <div><span class="pass__k">SEAT</span><span class="pass__v pass__num">21C</span></div>
            <div><span class="pass__k">GATE</span><span class="pass__v pass__num">A10</span></div>
            <div><span class="pass__k">SEQ</span><span class="pass__v pass__num">0042</span></div>
          </div>
          <div class="pass__seq pass__num">0170 · 21C · 06JUN</div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Tap <b>DEFAULT FIGURES</b> to swap lining → ss02 across every tabular field — fixed advances keep gates, times and codes on perfect columns either way.</p>
  </figure>

  <!-- 05 — sortable financial ledger (tabular figures realign, FLIP) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">05</span><span class="label">Data — a sortable cost ledger</span></figcaption>
    <div class="iu__scene">
      <div class="led">
        <div class="led__bar"><span class="led__title">spend · last 24h</span><span class="led__sum">Σ $74,403.66</span></div>
        <table class="led__table" data-led>
          <thead>
            <tr>
              <th data-sort="svc">SERVICE</th>
              <th data-sort="reg">REGION</th>
              <th data-sort="req" class="num">REQUESTS</th>
              <th data-sort="p99" class="num">P99</th>
              <th data-sort="err" class="num">ERR%</th>
              <th data-sort="usd" class="num" data-active="desc">USD</th>
            </tr>
          </thead>
          <tbody>
            {ledger.map((r) => (
              <tr data-svc={r.svc} data-reg={r.reg} data-req={r.req} data-p99={r.p99} data-err={r.err} data-usd={r.usd}>
                <td>{r.svc}</td>
                <td class="dim">{r.reg}</td>
                <td class="num">{r.req.toLocaleString('en-US')}</td>
                <td class="num">{r.p99}<span class="u">ms</span></td>
                <td class={`num ${r.err > 0.1 ? 'hot' : ''}`}>{r.err.toFixed(2)}</td>
                <td class="num strong">{r.usd.toLocaleString('en-US', { minimumFractionDigits: 2 })}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
    <p class="iu__hint label">Sort any column — rows animate to their new rank and tabular figures keep every digit on the same vertical rail.</p>
  </figure>
</div>

<script>
  const REDUCE = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ---- 01 live monitoring terminal ----
  document.querySelectorAll<HTMLElement>('[data-mon]').forEach((mon) => {
    const stat = (k: string) => mon.querySelector<HTMLElement>(`[data-stat="${k}"]`)!;
    const spark = (k: string) => mon.querySelector<HTMLElement>(`[data-spark="${k}"]`)!;
    const log = mon.querySelector<HTMLElement>('[data-log]')!;
    const procs = mon.querySelector<HTMLElement>('[data-procs]')!;

    const hist: Record<string, number[]> = { rps: [], p99: [], err: [], cpu: [] };
    const SPARK = '▁▂▃▄▅▆▇█';
    let nodes = 4;
    const drained = new Set<string>();

    const padL = (s: string, n: number) => (s.length >= n ? s : ' '.repeat(n - s.length) + s);
    const renderSpark = (k: string) => {
      const a = hist[k];
      const lo = Math.min(...a), hi = Math.max(...a);
      spark(k).textContent = a.map((v) => SPARK[Math.round(((v - lo) / (hi - lo || 1)) * 7)]).join('');
    };

    let t = 0;
    const tick = () => {
      t++;
      const rps = Math.round(18000 + Math.sin(t / 3) * 4200 + Math.random() * 1800);
      const p99 = Math.round(60 + Math.abs(Math.sin(t / 5)) * 90 + Math.random() * 20);
      const err = +Math.max(0, 0.04 + Math.sin(t / 7) * 0.05 + (Math.random() - 0.5) * 0.03).toFixed(2);
      const cpu = Math.round(34 + Math.abs(Math.sin(t / 4)) * 40 + Math.random() * 8);
      const vals: Record<string, number> = { rps, p99, err, cpu };
      for (const k of Object.keys(vals)) { hist[k].push(vals[k]); if (hist[k].length > 18) hist[k].shift(); }
      stat('rps').textContent = rps.toLocaleString('en-US');
      stat('p99').textContent = String(p99);
      stat('err').textContent = err.toFixed(2);
      stat('cpu').textContent = String(cpu);
      stat('err').classList.toggle('hot', err > 0.08);
      stat('p99').classList.toggle('hot', p99 > 130);
      (['rps', 'p99', 'err', 'cpu'] as const).forEach(renderSpark);

      // process table jitter — tabular figures realign each tick
      procs.querySelectorAll('tr').forEach((tr, i) => {
        const conn = tr.querySelector<HTMLElement>('[data-conn]')!;
        const load = tr.querySelector<HTMLElement>('[data-load]')!;
        const base = [1842, 1190, 9930, 64][i];
        const node = tr.children[1].textContent || '';
        const isDrain = drained.has(node);
        const off = Math.round((Math.random() - 0.4) * base * 0.18);
        const next = isDrain ? 0 : Math.max(0, base + off);
        conn.textContent = padL(String(next), 5).replace(/ /g, '0').slice(-5);
        load.style.width = (isDrain ? 2 : Math.min(98, 20 + Math.random() * 75)) + '%';
        tr.classList.toggle('is-drain', isDrain);
      });
    };

    const addLog = (level: string, msg: string) => {
      const now = new Date();
      const ts = [now.getHours(), now.getMinutes(), now.getSeconds()].map((n) => String(n).padStart(2, '0')).join(':');
      const p = document.createElement('p');
      const t1 = document.createElement('span'); t1.className = 't'; t1.textContent = ts;
      const t2 = document.createElement('span'); t2.className = level.trim().toLowerCase(); t2.textContent = level;
      p.append(t1, document.createTextNode(' '), t2, document.createTextNode(' ' + msg));
      log.appendChild(p);
      while (log.children.length > 6) log.removeChild(log.firstChild!);
      log.scrollTop = log.scrollHeight;
    };

    // CLI
    const cli = mon.querySelector<HTMLFormElement>('[data-cli]')!;
    const input = mon.querySelector<HTMLInputElement>('[data-cli-input]')!;
    cli.addEventListener('submit', (e) => {
      e.preventDefault();
      const raw = input.value.trim(); input.value = '';
      if (!raw) return;
      addLog('CMD  ', '❯ ' + raw);
      const [cmd, arg] = raw.split(/\s+/);
      if (cmd === 'scale' && arg && +arg > 0) {
        nodes = Math.min(24, +arg);
        addLog('INFO ', `autoscale: desired=${nodes} — provisioning…`);
      } else if (cmd === 'drain' && arg) {
        drained.add(arg);
        addLog('WARN ', `draining ${arg} — connections → 0`);
      } else if (cmd === 'status') {
        addLog('INFO ', `nodes=${nodes} drained=${drained.size} region=us-east-1`);
      } else if (cmd === 'clear') {
        log.replaceChildren();
      } else {
        addLog('ERR  ', `unknown command: ${cmd}`);
      }
    });

    // seed numeric history + 6 seed log lines so the static state is rich
    for (let i = 0; i < 18; i++) tick();
    addLog('INFO ', 'health check ok — 4/4 nodes ready');
    addLog('INFO ', 'autoscale: target=4 desired=4');
    addLog('INFO ', 'cache warm — 94.2% hit ratio');
    addLog('WARN ', 'p99 above target on edge-0a1e');
    addLog('INFO ', 'checkpoint flushed to db/primary');
    addLog('INFO ', 'gc: pause 1.4ms · heap 332M');

    if (!REDUCE) {
      setInterval(tick, 1100);
      setInterval(() => {
        const msgs: [string, string][] = [
          ['INFO ', 'cache warm — 94.2% hit ratio'],
          ['INFO ', `gc: pause 1.4ms · heap ${Math.round(300 + Math.random() * 80)}M`],
          ['WARN ', 'p99 above target on edge-0a1e'],
          ['INFO ', 'checkpoint flushed to db/primary'],
        ];
        const m = msgs[Math.floor(Math.random() * msgs.length)];
        addLog(m[0], m[1]);
      }, 2600);
    } else {
      mon.querySelector('[data-live]')?.setAttribute('hidden', '');
    }
  });

  // ---- 02 IDE: tabs, ss-alternate toggle, live tokenizer ----
  document.querySelectorAll<HTMLElement>('[data-ide]').forEach((ide) => {
    // tabs
    const tabs = Array.from(ide.querySelectorAll<HTMLButtonElement>('[data-tab]'));
    const panes = Array.from(ide.querySelectorAll<HTMLElement>('[data-pane]'));
    const statusL = ide.querySelector<HTMLElement>('[data-status-l]')!;
    const STATUS: Record<string, string> = {
      ts: 'TypeScript · UTF-8 · LF', css: 'CSS · UTF-8 · LF', md: 'Markdown · UTF-8 · LF',
    };
    tabs.forEach((tab) => tab.addEventListener('click', () => {
      const key = tab.dataset.tab!;
      tabs.forEach((x) => { x.classList.toggle('is-on', x === tab); x.setAttribute('aria-selected', String(x === tab)); });
      panes.forEach((p) => p.toggleAttribute('hidden', p.dataset.pane !== key));
      statusL.textContent = STATUS[key] ?? statusL.textContent;
    }));

    // ss01/ss02 stylistic alternates
    const alt = ide.querySelector<HTMLButtonElement>('[data-alt]')!;
    alt.addEventListener('click', () => {
      const on = ide.classList.toggle('ide--alt');
      alt.setAttribute('aria-pressed', String(on));
      alt.replaceChildren(document.createTextNode('ss'), Object.assign(document.createElement('sub'), { textContent: on ? '02' : '01' }));
    });

    // live tokenizer: classify each char, flag ambiguous code glyphs
    const replForm = ide.querySelector<HTMLFormElement>('[data-repl]')!;
    const replInput = ide.querySelector<HTMLInputElement>('[data-repl-input]')!;
    const tokensEl = ide.querySelector<HTMLElement>('[data-tokens]')!;
    const seedOut = ide.querySelector<HTMLElement>('[data-repl-seed]')!;
    const AMBIG = new Set(['0', 'O', '1', 'l', 'I']);
    const classify = (ch: string) => {
      if (ch === ' ') return 'space';
      if (AMBIG.has(ch)) return 'ambig';
      if (/[0-9]/.test(ch)) return 'digit';
      return 'alpha';
    };
    const render = () => {
      const src = replInput.value;
      tokensEl.replaceChildren();
      for (const ch of src) {
        const k = classify(ch);
        const chip = document.createElement('span');
        chip.className = 'tok tok--' + k;
        const g = document.createElement('b');
        g.textContent = ch === ' ' ? '␣' : ch;
        const tag = document.createElement('i');
        tag.textContent = k;
        chip.append(g, tag);
        tokensEl.appendChild(chip);
      }
      seedOut.textContent = String([...src].length);
    };
    replForm.addEventListener('submit', (e) => e.preventDefault());
    replInput.addEventListener('input', render);
    render();
  });

  // ---- 03 ASCII: route a packet cell-by-cell down the rule edges ----
  document.querySelectorAll<HTMLElement>('[data-ascii]').forEach((root) => {
    const art = root.querySelector<HTMLElement>('[data-art]')!;
    const status = root.querySelector<HTMLElement>('[data-ascii-status]')!;
    const base = art.textContent ?? '';
    const lines = base.split('\n');
    // characters that form the routable connective tissue
    const PATH = new Set(['│', '┬', '┼', '▼', '╤', '┌', '┐', '└', '┘', '─', '├', '┤']);
    // build a vertical spine of cells (col,row) the packet travels: follow the
    // central column downward, picking connective glyphs.
    const spine: Array<[number, number]> = [];
    for (let r = 0; r < lines.length; r++) {
      const ln = lines[r];
      // find a connective char near the centre to trace the main trunk
      let best = -1, bestDist = Infinity;
      const mid = 26;
      for (let c = 0; c < ln.length; c++) {
        if (PATH.has(ln[c])) {
          const d = Math.abs(c - mid);
          if (d < bestDist) { bestDist = d; best = c; }
        }
      }
      if (best >= 0 && bestDist <= 12) spine.push([best, r]);
    }

    if (REDUCE || spine.length === 0) {
      status.textContent = 'UTF-8 · box-drawing';
      return;
    }

    let i = 0;
    const renderAt = (idx: number) => {
      const frag = document.createDocumentFragment();
      const lit = spine[idx];
      lines.forEach((ln, r) => {
        if (lit && r === lit[1]) {
          const c = lit[0];
          frag.append(document.createTextNode(ln.slice(0, c)));
          const hot = document.createElement('span');
          hot.className = 'ascii__hot';
          hot.textContent = ln[c];
          frag.append(hot, document.createTextNode(ln.slice(c + 1)));
        } else {
          frag.append(document.createTextNode(ln));
        }
        if (r < lines.length - 1) frag.append(document.createTextNode('\n'));
      });
      art.replaceChildren(frag);
    };
    renderAt(0);
    setInterval(() => { i = (i + 1) % spine.length; renderAt(i); status.textContent = `UTF-8 · routing ${i + 1}/${spine.length}`; }, 240);
  });

  // ---- 04 boarding pass: swap lining ↔ ss02 figures ----
  document.querySelectorAll<HTMLElement>('[data-pass]').forEach((pass) => {
    const btn = pass.querySelector<HTMLButtonElement>('[data-fig]')!;
    btn.addEventListener('click', () => {
      const on = pass.classList.toggle('pass--ss02');
      btn.setAttribute('aria-pressed', String(on));
      btn.textContent = on ? 'ss02 FIGURES' : 'DEFAULT FIGURES';
    });
  });

  // ---- 05 sortable ledger with FLIP ----
  document.querySelectorAll<HTMLElement>('[data-led]').forEach((table) => {
    const tbody = table.querySelector('tbody')!;
    const nums = new Set(['req', 'p99', 'err', 'usd']);
    table.querySelectorAll<HTMLElement>('[data-sort]').forEach((th) =>
      th.addEventListener('click', () => {
        const key = th.dataset.sort!;
        const wasAsc = th.dataset.active === 'asc';
        table.querySelectorAll('th').forEach((x) => x.removeAttribute('data-active'));
        const asc = !wasAsc;
        th.dataset.active = asc ? 'asc' : 'desc';
        const rows = Array.from(tbody.querySelectorAll('tr'));

        // FLIP: record first positions
        const first = new Map<HTMLElement, number>();
        rows.forEach((r) => first.set(r, r.getBoundingClientRect().top));

        rows.sort((a, b) => {
          let av: number | string, bv: number | string;
          if (nums.has(key)) { av = +a.dataset[key]!; bv = +b.dataset[key]!; }
          else { av = a.dataset[key]!; bv = b.dataset[key]!; }
          return (av < bv ? -1 : av > bv ? 1 : 0) * (asc ? 1 : -1);
        });
        rows.forEach((r) => tbody.appendChild(r));

        if (REDUCE) return;
        // invert + play
        rows.forEach((r) => {
          const delta = first.get(r)! - r.getBoundingClientRect().top;
          if (!delta) return;
          r.style.transition = 'none';
          r.style.transform = `translateY(${delta}px)`;
        });
        requestAnimationFrame(() => {
          rows.forEach((r) => {
            r.style.transition = 'transform 0.42s cubic-bezier(.22,.61,.36,1)';
            r.style.transform = '';
          });
        });
      })
    );
  });
</script>

<style>
  .iu__item { margin: 0; }
