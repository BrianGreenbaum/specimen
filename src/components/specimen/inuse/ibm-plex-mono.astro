    .mon__procs .bar { display: none; }
    .mon__procs th:last-child, .mon__procs td:last-child { display: none; }
    /* keep diagram legible: hold a real px floor and let the scroll container pan */
    .ascii__art { font-size: 10.5px; }
    .led__table th:nth-child(2), .led__table td:nth-child(2) { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .mon__live i { animation: none; }
    .mon__procs .bar i { transition: none; }
    .led__table tbody tr { transition: none; }
  }
</style>
