    background: var(--ide-bg); color: var(--ide-fg); font-size: 13px;
  }
  /* ss01/ss02 stylistic alternates on the live code */
  .ide.ide--alt .ide__code { font-feature-settings: 'ss01' 1, 'ss02' 1, 'zero' 1; }
  .ide__tabs { display: flex; align-items: stretch; background: var(--ide-bg2); border-bottom: 1px solid var(--ide-line); font-size: 12px; }
  .ide__tabs button, .ide__tabs span { display: flex; align-items: center; gap: 0.4rem; color: var(--ide-dim); padding: 0.55rem 0.95rem; border-right: 1px solid var(--ide-line); }
  .ide__tabs button { background: transparent; border-top: none; border-bottom: none; border-left: none; font: inherit; cursor: pointer; }
  .ide__tabs button[role="tab"].is-on { color: var(--ide-fg); background: var(--ide-bg); }
  .ide__tabs button[role="tab"].is-on i { color: var(--ide-blue); font-size: 9px; font-style: normal; }
  .ide__alt { margin-left: auto; color: var(--ide-dim); letter-spacing: 0.06em; }
