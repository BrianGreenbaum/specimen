  .ide__code .kw { color: var(--ide-kw); }
  .ide__code .fn { color: var(--ide-fn); }
  .ide__code .st { color: var(--ide-st); }
  .ide__code .cm { color: var(--ide-cm); font-style: italic; }
  .ide__code .ty { color: var(--ide-ty); }
  .ide__code .vr { color: var(--ide-vr); }
  .ide__code .pn { color: var(--ide-dim); }
  /* css/md token colours */
  .ide__code .sel { color: var(--ide-ty); }
  .ide__code .prop { color: var(--ide-blue); }
  .ide__code .num2 { color: var(--ide-st); }
  .ide__code .unit { color: var(--ide-kw); }
  .ide__code .hex { color: var(--ide-st); }
  .ide__code--md { line-height: 1.8; }
  .ide__code .h1 { color: var(--ide-fn); font-weight: 600; }
  .ide__code .bul { color: var(--ide-kw); }
  .ide__code .bold { color: var(--ide-fg); font-weight: 600; }
  .ide__code .code { color: var(--ide-st); background: rgba(110,118,129,0.18); padding: 0 0.25em; border-radius: 3px; }

  .ide__repl { border-top: 1px solid var(--ide-line); background: var(--ide-bg2); padding: 0.6rem 1rem; font-size: 12.5px; line-height: 1.7; }
  .ide__repl .p { color: var(--ide-green); }
  .ide__replcmd { color: var(--ide-fg); }
  .ide__replout { color: var(--ide-blue); }
  .ide__replform { display: flex; align-items: center; gap: 0.35rem; color: var(--ide-fg); flex-wrap: wrap; }
  .ide__replpre { color: var(--ide-dim); white-space: pre; }
  .ide__replpre .st { color: var(--ide-st); }
  .ide__repl input { background: rgba(110,118,129,0.14); border: 1px solid var(--ide-line); border-radius: 4px; color: var(--ide-st); font-family: var(--fam); font-size: 12.5px; padding: 0.1rem 0.4rem; outline: none; width: 11ch; }
  .ide__repl input:focus { border-color: var(--ide-blue); }
