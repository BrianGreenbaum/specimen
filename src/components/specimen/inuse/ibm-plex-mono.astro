  }
  .mon__chrome { display: flex; align-items: center; gap: 0.7rem; padding: 0.55rem 0.85rem; background: var(--term-bg2); border-bottom: 1px solid var(--term-line); }
  .mon__title { color: var(--term-dim); font-size: 12px; margin-inline: auto; }
