---
import type { CollectionEntry } from 'astro:content';
import BrandScene from '../BrandScene.astro';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;
---
<div class="iu" style={`--fam:${fam}`}>
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Poster — a Bauhaus composition</span></figcaption>
    <div class="iu__scene scene-sq">
      <div class="iu__poster bau">
        <span class="bau__circle" aria-hidden="true"></span>
        <span class="bau__tri" aria-hidden="true"></span>
        <span class="bau__bar" aria-hidden="true"></span>
        <span class="bau__year">1919—2026</span>
        <h3 class="bau__head">AUS<br/>STELL<br/>UNG</h3>
        <span class="bau__foot">die neue typografie · halle 7</span>
      </div>
    </div>
  </figure>

  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Brand — a modernist identity sheet</span></figcaption>
    <div class="iu__scene brand-scene">
      <BrandScene font={font} variant="grid" />
    </div>
  </figure>
</div>

<style>
  .iu__item { margin: 0; }
  .scene-sq { aspect-ratio: 4 / 5; max-width: 460px; }
  .brand-scene { aspect-ratio: 16 / 9; }

  .bau { background: var(--bg); overflow: hidden; padding: 5cqi; }
  .bau__circle { position: absolute; width: 34cqi; height: 34cqi; border-radius: 50%; background: var(--accent); top: 6cqi; right: 6cqi; }
  .bau__tri { position: absolute; width: 0; height: 0; border-left: 14cqi solid transparent; border-right: 14cqi solid transparent; border-bottom: 24cqi solid var(--fg); bottom: 16cqi; right: 10cqi; opacity: 0.9; }
  .bau__bar { position: absolute; width: 60cqi; height: 4cqi; background: var(--accent); left: -10cqi; bottom: 30cqi; transform: rotate(-24deg); }
  .bau__year { position: relative; font-size: 3cqi; letter-spacing: 0.2em; color: var(--fg-2); }
  .bau__head { position: relative; font-size: 22cqi; line-height: 0.86; font-weight: 700; letter-spacing: -0.02em; margin-top: 4cqi; color: var(--fg); }
  .bau__foot { position: absolute; bottom: 5cqi; left: 5cqi; font-size: 2.6cqi; letter-spacing: 0.1em; color: var(--fg-2); }
</style>
