---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// Restaurant menu data (scene 04, interactive reservation/menu UI — real device scale)
const menu = {
  entrées: [
    { name: 'Oysters & Mignonette', detail: 'Belon · cucumber · finger lime',        price: '24' },
    { name: 'Burrata di Andria',    detail: 'heirloom tomato · basil oil · sea salt', price: '21' },
    { name: 'Steak Tartare',        detail: 'hand-cut · cured yolk · sourdough',      price: '26' },
  ],
  plats: [
    { name: 'Turbot, Beurre Blanc', detail: 'leek · champagne · caviar',              price: '52' },
    { name: 'Canard à l’Orange',    detail: 'aged duck · bitter orange · endive',     price: '46' },
    { name: 'Risotto al Tartufo',   detail: 'carnaroli · black truffle · parmigiano', price: '38' },
  ],
  desserts: [
    { name: 'Soufflé au Chocolat',  detail: 'Valrhona · crème anglaise',              price: '18' },
    { name: 'Tarte Tatin',          detail: 'caramelised apple · crème fraîche',      price: '16' },
    { name: 'Affogato',             detail: 'espresso · vanilla · amaretto',          price: '14' },
  ],
};
const courses = Object.keys(menu) as (keyof typeof menu)[];

// Boutique lookbook (scene 05, interactive hover-reveal hero)
const pieces = [
  { id: 'I',   name: 'La Robe Noire',  detail: 'Silk crêpe, bias cut',    price: '2,850' },
  { id: 'II',  name: 'Cape Monceau',   detail: 'Double wool, hand-felled', price: '3,400' },
  { id: 'III', name: 'Soie Blanche',   detail: 'Charmeuse, draped',        price: '1,980' },
];
---
<div class="iu" style={`--fam:${fam}`}>

  <!-- 01 — FASHION / CULTURE MAGAZINE COVER -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Magazine — the culture cover</span></figcaption>
    <div class="iu__scene iu__scene--portrait">
      <div class="iu__poster cover" data-reveal data-reveal-cover>
        <div class="cover__top">
          <span class="cover__no">Issue 19</span>
          <span class="cover__season">Spring 2026</span>
          <span class="cover__price">$14</span>
        </div>
        <div class="cover__mast">
          <h3 class="cover__word" data-cover-word>Mode</h3>
          <span class="cover__amp" aria-hidden="true">&amp;</span>
          <h3 class="cover__word cover__word--it" data-cover-word>Manière</h3>
        </div>
        <div class="cover__lines">
          <p class="cover__feat">The Return of<br />the <em>Hairline</em></p>
          <ul class="cover__list">
            <li>Forty pages on couture &amp; the new restraint</li>
            <li>Tilda Swinton, in her own words</li>
            <li><span class="cover__plus">Plus</span> a season in Parma</li>
          </ul>
        </div>
        <div class="cover__foot">
          <span class="cover__bar" aria-hidden="true">
            {Array.from({ length: 26 }).map((_, i) => (<i style={`width:${(i % 3) + 1}px`}></i>))}
          </span>
          <span class="cover__byline">Photograph — Paolo Roversi</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Roman and true italic share the masthead; the cover lines rise in on scroll.</p>
  </figure>

  <!-- 02 — RESTAURANT IDENTITY / HOSPITALITY (giant contrast-revealing monogram) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Identity — restaurant &amp; hospitality mark</span></figcaption>
    <div class="iu__scene scene-16">
      <div class="iu__poster maison" data-reveal data-reveal-rule>
        <!-- LEFT: a giant initial cropped at the bowl so the thick-stem→hairline-serif
             transition is the entire image. Annotation sits in its own caption strip
             below the crop so it can never clip. -->
        <div class="maison__crop">
          <span class="maison__glyph" aria-hidden="true">C</span>
          <span class="maison__tag">Specimen — the initial, drawn large</span>
        </div>
        <!-- RIGHT: the actual identity, supporting type set against the giant letter. -->
        <div class="maison__id">
          <div class="maison__est">
            <span>Restaurant</span>
            <span class="maison__dot"></span>
            <span>est. 1921</span>
          </div>
          <div class="maison__name">
            <h3 class="maison__word">Crillon</h3>
            <span class="maison__sub">Hôtel &amp; Table — Place de la Concorde</span>
          </div>
          <div class="maison__foot">
            <span>Déjeuner &amp; dîner</span>
            <span class="maison__sep">·</span>
            <span>Paris VIII<sup>e</sup></span>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">The mark is the face itself — a cropped initial whose thick stem falls to a hairline bracketed serif, the identity set beside it.</p>
  </figure>

  <!-- 03 — EDITORIAL FEATURE OPENER: roman vs the true italic -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Editorial — feature opener, roman vs italic</span></figcaption>
    <div class="iu__scene scene-43">
      <div class="iu__poster spread">
        <div class="spread__rail">
          <span class="spread__folio">Essay · 072</span>
          <span class="spread__sec">On Contrast</span>
        </div>
        <div class="spread__main">
          <span class="spread__kicker">The thick & the thin</span>
          <h3 class="spread__head">
            A letter drawn to <span class="spread__it">vanish</span>
          </h3>
          <p class="spread__deck">How the Didone serif taught the page to whisper and shout in a single line.</p>
          <div class="spread__body">
            <p><span class="spread__drop">B</span>y the 1790s the press had finally caught the eye — paper smoother, ink blacker, the burin sharper. Firmin Didot in Paris and Bodoni in Parma let the contrast run riot: heavy stems beside hairlines fine enough to cut.</p>
            <p>Two centuries on, the same drama still reads as one thing only — pure luxury, set large on a cover. The thinner the stroke, the louder the couture. <em>The italic, meanwhile, leans into the curve and keeps the secret.</em></p>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">The roman headline anchors; one word swaps to the true italic — the family’s second voice.</p>
  </figure>

  <!-- 04 — INTERACTIVE: restaurant menu + reservation UI (real device scale) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Menu &amp; reservation UI (real scale, interactive)</span></figcaption>
    <div class="iu__scene">
      <div class="iu__device carte" data-carte>
        <div class="iu__chrome">
          <div class="iu__dots"><i></i><i></i><i></i></div>
          <span class="iu__addr">crillon.paris/la-carte</span>
        </div>
        <header class="carte__head">
          <span class="carte__logo">Crillon</span>
          <nav class="carte__tabs" aria-label="Menu sections">
            {courses.map((c, i) => (
              <button class={i === 0 ? 'is-on' : ''} data-course={c}>{c}</button>
            ))}
          </nav>
        </header>
        <div class="carte__panel">
          {courses.map((c, i) => (
            <ul class={`carte__list${i === 0 ? ' is-on' : ''}`} data-panel={c}>
              {menu[c].map((d) => (
                <li class="dish">
                  <div class="dish__row">
                    <span class="dish__name">{d.name}</span>
                    <span class="dish__dots" aria-hidden="true"></span>
                    <span class="dish__price">{d.price}</span>
                  </div>
                  <span class="dish__detail">{d.detail}</span>
                </li>
              ))}
            </ul>
          ))}
        </div>
        <div class="carte__resa">
          <span class="carte__resa-h">Réservez</span>
          <div class="carte__party">
            <span class="carte__plabel">Table for</span>
            <div class="carte__steps" data-party>
              <button data-step="-1" aria-label="Fewer guests">–</button>
              <span class="carte__count" data-count>2</span>
              <button data-step="1" aria-label="More guests">+</button>
            </div>
          </div>
          <button class="carte__book" data-book>Book — <span data-book-n>2</span> guests</button>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Switch courses, set your party size — the booking line restates it in display italic.</p>
  </figure>

  <!-- 05 — INTERACTIVE: boutique e-commerce editorial hero, hover-reveal -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">05</span><span class="label">Boutique hero — editorial e-commerce (interactive)</span></figcaption>
    <div class="iu__scene">
      <div class="iu__device shop" data-shop>
        <div class="iu__chrome">
          <div class="iu__dots"><i></i><i></i><i></i></div>
          <span class="iu__addr">atelier-crillon.com/collection</span>
        </div>
        <header class="shop__head">
          <span class="shop__logo">Atelier</span>
          <nav class="shop__nav"><span>Collection</span><span>Atelier</span><span class="shop__bag">Bag · 0</span></nav>
        </header>
        <div class="shop__stage" data-stage>
          <span class="shop__ghost" data-ghost>01</span>
          <div class="shop__lockup">
            <span class="shop__no" data-no>Look 01</span>
            <h4 class="shop__name" data-name>La Robe Noire</h4>
            <span class="shop__detail" data-detail>Silk crêpe, bias cut</span>
            <span class="shop__price" data-price>$2,850</span>
          </div>
        </div>
        <div class="shop__thumbs" data-thumbs>
          {pieces.map((p, i) => (
            <button
              class={`thumb${i === 0 ? ' is-on' : ''}`}
              data-look={String(i)}
              data-name={p.name} data-detail={p.detail} data-price={p.price} data-id={p.id}
            >
              <span class="thumb__no">{p.id}</span>
              <span class="thumb__name">{p.name}</span>
            </button>
          ))}
        </div>
      </div>
    </div>
    <p class="iu__hint label">Hover or tap a look — the display name cross-fades and the giant ghost numeral scales in.</p>
  </figure>

</div>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ---- 01 + 02: scroll-reveal (kinetic rise / hairline draw) ----
  if (!reduce && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (ents) => ents.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); } }),
      { threshold: 0.35 }
    );
    document.querySelectorAll('[data-reveal-cover],[data-reveal-rule]').forEach((el) => io.observe(el));
  } else {
    document.querySelectorAll('[data-reveal-cover],[data-reveal-rule]').forEach((el) => el.classList.add('is-in'));
  }

  // ---- 04: restaurant menu tabs + party stepper + reservation line ----
  document.querySelectorAll<HTMLElement>('[data-carte]').forEach((root) => {
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-course]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-panel]'));
    tabs.forEach((t) =>
      t.addEventListener('click', () => {
        tabs.forEach((x) => x.classList.remove('is-on'));
        t.classList.add('is-on');
        const c = t.dataset.course!;
        panels.forEach((p) => p.classList.toggle('is-on', p.dataset.panel === c));
      })
    );

    const count = root.querySelector<HTMLElement>('[data-count]')!;
    const bookN = root.querySelector<HTMLElement>('[data-book-n]')!;
    let party = 2;
    const render = () => { count.textContent = String(party); bookN.textContent = String(party); };
    root.querySelectorAll<HTMLButtonElement>('[data-step]').forEach((b) =>
      b.addEventListener('click', () => {
        party = Math.min(8, Math.max(1, party + Number(b.dataset.step)));
        render();
      })
    );
    render();
  });

  // ---- 05: boutique look switcher (hover + click), cross-fade display name ----
  document.querySelectorAll<HTMLElement>('[data-shop]').forEach((root) => {
    const stage = root.querySelector<HTMLElement>('[data-stage]')!;
    const ghost = root.querySelector<HTMLElement>('[data-ghost]')!;
    const no = root.querySelector<HTMLElement>('[data-no]')!;
    const name = root.querySelector<HTMLElement>('[data-name]')!;
    const detail = root.querySelector<HTMLElement>('[data-detail]')!;
    const price = root.querySelector<HTMLElement>('[data-price]')!;
    const thumbs = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-look]'));

    let active = 0;
    const set = (i: number) => {
      if (i === active) return;
      active = i;
      const t = thumbs[i];
      thumbs.forEach((x) => x.classList.toggle('is-on', x === t));
      stage.classList.remove('is-swap'); void stage.offsetWidth; stage.classList.add('is-swap');
      ghost.textContent = t.dataset.id!;
      no.textContent = `Look ${String(i + 1).padStart(2, '0')}`;
      name.textContent = t.dataset.name!;
      detail.textContent = t.dataset.detail!;
      price.textContent = `$${t.dataset.price!}`;
    };
    thumbs.forEach((t, i) => {
      t.addEventListener('click', () => set(i));
      t.addEventListener('pointerenter', () => { if (!reduce) set(i); });
    });
  });
</script>

<style>
  .iu__item { margin: 0; }
  .iu__hint { margin-top: var(--sp-2); color: var(--fg-3); }
  .iu__hint code { font-family: var(--font-mono); font-size: 0.85em; color: var(--fg-2); }
  .scene-16 { aspect-ratio: 16 / 9; }
  .scene-43 { aspect-ratio: 4 / 3; }
  .iu__scene * { font-family: var(--fam); }

  /* ============================================================
     01 — CULTURE COVER
     High-contrast display serif at masthead scale: roman + true italic
     sharing the title. Accent reserved to a SINGLE small mark (issue no.).
     ============================================================ */
  .cover { --card-ar: 3 / 4; background: var(--bg); display: flex; flex-direction: column; padding: 5.5cqi 5.5cqi 4.5cqi; }
  .cover__top {
    display: flex; justify-content: space-between; align-items: baseline;
    font-family: var(--font-mono); font-size: 2.4cqi; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--fg-3); border-bottom: 1px solid var(--line); padding-bottom: 3cqi;
  }
  .cover__no { color: var(--accent); }
  .cover__season { letter-spacing: 0.18em; }
  .cover__mast { display: flex; flex-direction: column; align-items: center; margin: 7cqi 0 4cqi; line-height: 0.82; }
  .cover__word { font-size: 26cqi; line-height: 0.8; color: var(--fg); margin: 0; letter-spacing: -0.01em; }
  .cover__word--it { font-style: italic; letter-spacing: 0; }
  .cover__amp { font-style: italic; font-size: 9cqi; color: var(--accent); line-height: 1; margin: 0.4cqi 0; }
  .cover__lines { display: flex; flex-direction: column; gap: 3.6cqi; margin-top: auto; }
  .cover__feat { font-size: 7.2cqi; line-height: 0.98; color: var(--fg); margin: 0; letter-spacing: -0.01em; }
  .cover__feat em { font-style: italic; color: var(--fg); }
  .cover__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1.7cqi; max-width: 78%; }
  .cover__list li {
    font-family: var(--fam); font-style: italic; font-size: 3.2cqi; line-height: 1.22; color: var(--fg-2);
    padding-left: 4.4cqi; position: relative;
  }
  .cover__list li::before {
    content: ''; position: absolute; left: 0; top: 0.62em; width: 2.8cqi; height: 1px; background: var(--line);
  }
  .cover__plus { font-family: var(--font-mono); font-style: normal; font-size: 1.9cqi; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); margin-right: 0.4em; }
  .cover__foot {
    display: flex; align-items: flex-end; justify-content: space-between; gap: 3cqi;
    margin-top: 5cqi; padding-top: 3cqi; border-top: 1px solid var(--line);
  }
  .cover__bar { display: flex; align-items: flex-end; gap: 2px; height: 7cqi; }
  .cover__bar i { background: var(--fg-3); height: 100%; }
  .cover__byline { font-family: var(--font-mono); font-size: 2.1cqi; letter-spacing: 0.1em; text-transform: uppercase; color: var(--fg-3); text-align: right; }

  /* kinetic reveal: masthead + lines rise in */
  @media (prefers-reduced-motion: no-preference) {
    .cover.is-in .cover__word, .cover.is-in .cover__amp,
    .cover.is-in .cover__feat, .cover.is-in .cover__list li {
      animation: cover-rise 0.7s var(--ease) both;
    }
    @keyframes cover-rise { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: none; } }
    .cover.is-in .cover__word--it { animation-delay: 0.08s; }
    .cover.is-in .cover__amp { animation-delay: 0.05s; }
    .cover.is-in .cover__feat { animation-delay: 0.18s; }
    .cover.is-in .cover__list li:nth-child(1) { animation-delay: 0.26s; }
    .cover.is-in .cover__list li:nth-child(2) { animation-delay: 0.32s; }
    .cover.is-in .cover__list li:nth-child(3) { animation-delay: 0.38s; }
  }

  /* ============================================================
     02 — RESTAURANT / HOSPITALITY IDENTITY
     The mark IS the typeface: a giant initial cropped so the thick-stem→
     hairline bracketed-serif transition fills the frame, annotated, with the
     identity set tiny beside it. Extreme size jump = unmistakably DM Serif Display.
     ============================================================ */
  .maison {
    background: var(--bg); display: grid; grid-template-columns: 42% 1fr;
    align-items: stretch; gap: 0; overflow: hidden;
  }

  /* --- the cropped contrast specimen --- */
  .maison__crop {
    position: relative; overflow: hidden; border-right: 1px solid var(--line);
    background: color-mix(in srgb, var(--accent) 9%, var(--bg)); display: block;
  }
  .maison__glyph {
    position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);
    font-size: 78cqi; line-height: 1;
    /* the thick stem→hairline drama rendered in the accent for a luxe foil */
    color: color-mix(in srgb, var(--accent) 78%, var(--fg));
    letter-spacing: 0;
  }
  /* annotation lives in its own strip pinned to the foot of the crop — never clips */
  .maison__tag {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 2cqi 4cqi; font-family: var(--font-mono); font-size: 1.7cqi;
    letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent);
    border-top: 1px solid color-mix(in srgb, var(--accent) 26%, transparent);
    background: color-mix(in srgb, var(--bg) 64%, transparent);
    backdrop-filter: blur(2px);
  }

  /* --- the identity, set against the giant letter --- */
  .maison__id {
    display: flex; flex-direction: column; justify-content: space-between;
    padding: 6cqi 6cqi 5cqi;
  }
  .maison__est {
    display: flex; align-items: center; gap: 1.6cqi;
    font-family: var(--font-mono); font-size: 1.9cqi; letter-spacing: 0.22em; text-transform: uppercase; color: var(--fg-3);
  }
  .maison__dot { width: 0.6cqi; height: 0.6cqi; border-radius: 50%; background: var(--accent); }
  .maison__name { display: flex; flex-direction: column; gap: 1.6cqi; margin: auto 0; }
  .maison__word { font-size: 17cqi; line-height: 0.84; color: var(--fg); margin: 0; letter-spacing: -0.01em; }
  .maison__sub { font-size: 2.9cqi; line-height: 1.25; font-style: italic; color: var(--fg-2); max-width: 40cqi; }
  .maison__foot {
    display: flex; align-items: baseline; gap: 1.4cqi; flex-wrap: wrap;
    font-family: var(--font-mono); font-size: 1.7cqi; letter-spacing: 0.16em; text-transform: uppercase; color: var(--fg-3);
  }
  .maison__sep { color: var(--accent); }
  .maison__foot sup { font-size: 0.7em; }

  /* reveal: the giant glyph slides up into the crop; tag fades after */
  @media (prefers-reduced-motion: no-preference) {
    .maison .maison__glyph { transform: translate(-50%, calc(-50% + 8cqi)); opacity: 0; }
    .maison .maison__tag { opacity: 0; }
    .maison.is-in .maison__glyph { animation: maison-glyph 0.8s var(--ease) both; }
    .maison.is-in .maison__tag { animation: maison-mark 0.5s var(--ease) 0.3s both; }
    @keyframes maison-glyph { from { transform: translate(-50%, calc(-50% + 8cqi)); opacity: 0; } to { transform: translate(-50%, -50%); opacity: 1; } }
    @keyframes maison-mark { from { opacity: 0; } to { opacity: 1; } }
  }

  /* ============================================================
     03 — EDITORIAL FEATURE OPENER (roman vs the true italic)
     Big roman headline; one word in the true italic. Accent = rail folio.
     ============================================================ */
  .spread { background: var(--bg); display: grid; grid-template-columns: 13% 1fr; gap: 4cqi; padding: 5cqi; }
  .spread__rail { display: flex; flex-direction: column; justify-content: space-between; border-right: 1px solid var(--line); padding-right: 3cqi; }
  .spread__folio { font-family: var(--font-mono); font-size: 1.9cqi; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); }
  .spread__sec { font-family: var(--font-mono); font-size: 1.9cqi; letter-spacing: 0.16em; text-transform: uppercase; color: var(--fg-3); writing-mode: vertical-rl; }
  .spread__main { grid-column: 2; display: flex; flex-direction: column; min-height: 0; }
  .spread__kicker { font-family: var(--font-mono); font-size: 2cqi; letter-spacing: 0.16em; text-transform: uppercase; color: var(--fg-3); }
  .spread__head { font-size: 13cqi; line-height: 0.92; color: var(--fg); margin: 1.5cqi 0 0; letter-spacing: -0.015em; }
  .spread__it { font-style: italic; color: var(--fg); }
  .spread__deck { font-size: 3.2cqi; line-height: 1.2; font-style: italic; color: var(--fg-2); max-width: 80%; margin: 3cqi 0 0; }
  .spread__body { columns: 2; column-gap: 4cqi; font-size: 2.1cqi; line-height: 1.55; color: var(--fg-2); margin-top: 3.5cqi; }
  .spread__body p { margin: 0 0 0.9em; }
  .spread__body em { font-style: italic; color: var(--fg); }
  .spread__drop { float: left; font-size: 10cqi; line-height: 0.66; padding: 0.06em 0.12em 0 0; color: var(--fg); }

  /* ============================================================
     04 — RESTAURANT MENU + RESERVATION UI (real px, interactive)
     ============================================================ */
  .carte { font-size: 14px; line-height: 1.45; background: var(--bg); }
  .carte__head { display: flex; align-items: center; gap: 1rem; padding: 1rem 1.2rem 0.85rem; border-bottom: 1px solid var(--line); }
  .carte__logo { font-size: 26px; line-height: 1; color: var(--fg); letter-spacing: 0.01em; }
  .carte__tabs { display: flex; gap: 0.2rem; margin-left: auto; }
  .carte__tabs button {
    font-family: var(--fam); font-style: italic; font-size: 16px; color: var(--fg-3);
