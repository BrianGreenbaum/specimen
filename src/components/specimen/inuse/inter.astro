---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// --- 01 · Analytics dashboard (interactive, real device scale) -----------
// Per-tab KPI + chart + table data; tabular figures hold columns on sort.
const tableRows = [
  { src: 'Direct', v: 18420, c: 4.8, r: 92840 },
  { src: 'Organic search', v: 12950, c: 3.1, r: 41200 },
  { src: 'Referral', v: 8310, c: 5.2, r: 38760 },
  { src: 'Social', v: 6740, c: 1.9, r: 12030 },
  { src: 'Email', v: 4980, c: 6.4, r: 28590 },
  { src: 'Affiliates', v: 3120, c: 4.1, r: 19470 },
];

// --- 02 · Mobile banking app — the disambiguation case (real phone scale) -
// The scene's whole argument: on a money screen, 0-vs-O and 1-vs-l-vs-I cannot
// be guessed. Inter's slashed zero ('zero'/cv'01) + tabular figures ('tnum')
// make every account, card and reference ID *unambiguous* at 11–28px on glass.
// Account identifiers are deliberately built from the colliding glyph pairs:
//   0/O · 1/l/I · 5/S · 8/B · 2/Z — so the feature toggle is visibly load-bearing.
const accounts = [
  {
    id: 'everyday', name: 'Everyday', sub: '·· 4471', bal: 4820.55, delta: '+128.40',
    card: '4051  10O8  2BIl  9O5S',     // masked-style full number, glyph-collision heavy
    iban: 'GB29 NW01 5O18 8B2l O5S0 71', // sort/IBAN with O, 0, l, 1, B, 8
    sort: '60-O1-08', ref: 'NWB-2O25-Il5O8',
    tx: [
      ['Transfer to Savings', 'Today · 09:14', -250.0, 'in'],
      ['Apple Store', 'Today · 08:02', -19.0, 'shopping'],
      ['Salary — Northwind Inc', 'Yesterday', 4310.0, 'pay'],
      ['Whole Foods Market', 'Yesterday', -86.42, 'groceries'],
    ] as [string, string, number, string][],
  },
  {
    id: 'savings', name: 'Savings', sub: '·· 9920', bal: 21940.0, delta: '+1,250.00',
    card: '4051  10O8  771O  99ZO', iban: 'GB80 NW01 5O18 99ZO 1O80 44',
    sort: '60-O1-15', ref: 'NWB-2O25-S9ZlO',
    tx: [
      ['Transfer from Everyday', 'Today · 09:14', 250.0, 'in'],
      ['Interest', '1 Jun', 38.21, 'pay'],
      ['Round-ups', '1 Jun', 14.07, 'in'],
      ['Standing order', '28 May', 1000.0, 'in'],
    ] as [string, string, number, string][],
  },
  {
    id: 'travel', name: 'Travel', sub: '·· 1180', bal: 612.30, delta: '−214.60',
    card: '4051  10O8  3B1l  O72S', iban: 'GB15 NW01 5O18 3B1l O72S 60',
    sort: '60-O1-22', ref: 'NWB-2O25-T3B1l',
    tx: [
      ['SNCF — Paris→Lyon', 'Today · 07:48', -58.0, 'travel'],
      ['Le Comptoir', 'Yesterday', -42.5, 'food'],
      ['Hotel Lumière', '3 Jun', -188.0, 'travel'],
      ['Top-up', '2 Jun', 400.0, 'in'],
    ] as [string, string, number, string][],
  },
];
const a0 = accounts[0];
const money = (n: number) =>
  (n < 0 ? '−' : '') + '$' + Math.abs(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

// --- 03 · Command palette (interactive, real device scale) ---------------
const commands = [
  ['Create new document', '⌘N', 'Actions', '◇'],
  ['Open settings…', '⌘,', 'Navigate', '⚙'],
  ['Switch workspace', '⌘K W', 'Navigate', '⇄'],
  ['Invite teammates', '', 'Team', '＋'],
  ['Toggle dark mode', '⌘⇧L', 'Preferences', '◐'],
  ['Export as PDF', '⌘⇧E', 'Actions', '↧'],
  ['Search docs & people', '⌘P', 'Navigate', '⌕'],
  ['Archive project', '', 'Actions', '▢'],
  ['Connect integration', '', 'Team', '⌬'],
  ['View keyboard shortcuts', '?', 'Preferences', '⌨'],
] as [string, string, string, string][];
---
<div class="iu" style={`--fam:${fam}`}>

  <!-- 01 — analytics dashboard (interactive, real device scale) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Product UI — analytics dashboard, real device scale</span></figcaption>
    <div class="iu__scene">
      <div class="iu__device dash" data-dash>
        <div class="dash__chrome">
          <div class="dash__dots"><i></i><i></i><i></i></div>
          <span class="dash__addr">app.northwind.io/analytics</span>
        </div>
        <div class="dash__bar">
          <span class="dash__logo">◆ Northwind</span>
          <nav class="dash__tabs">
            <button class="is-on" data-tab="overview">Overview</button>
            <button data-tab="audience">Audience</button>
            <button data-tab="revenue">Revenue</button>
          </nav>
          <span class="dash__range" data-range>Last 30 days</span>
          <span class="dash__avatar">RA</span>
        </div>
        <div class="dash__body">
          <div class="dash__kpis">
            <div class="dash__kpi"><span class="dash__k">Visitors</span><b data-kpi="v">51,400</b><i class="up" data-trend="v">▲ 12.4%</i></div>
            <div class="dash__kpi"><span class="dash__k">Conversion</span><b data-kpi="c">4.18%</b><i class="up" data-trend="c">▲ 0.6%</i></div>
            <div class="dash__kpi"><span class="dash__k">Revenue</span><b data-kpi="r">$213,420</b><i class="up" data-trend="r">▲ 8.1%</i></div>
            <div class="dash__kpi"><span class="dash__k">Avg. session</span><b data-kpi="s">2m 41s</b><i class="dn" data-trend="s">▼ 0.3%</i></div>
          </div>
          <div class="dash__chart" data-chart aria-hidden="true">
            {[42,60,38,72,55,81,64,90,48,76,58,96,70,84].map((h)=>(<span style={`height:${h}%`}></span>))}
          </div>
          <table class="dash__table" data-table>
            <thead>
              <tr>
                <th data-sort="src">Source</th>
                <th data-sort="v" class="num" data-active="desc">Visitors</th>
                <th data-sort="c" class="num">Conv.</th>
                <th data-sort="r" class="num">Revenue</th>
              </tr>
            </thead>
            <tbody>
              {tableRows.map((r)=>(
                <tr data-v={r.v} data-c={r.c} data-r={r.r}>
                  <td>{r.src}</td>
                  <td class="num">{r.v.toLocaleString()}</td>
                  <td class="num">{r.c.toFixed(1)}%</td>
                  <td class="num">${r.r.toLocaleString()}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Switch tabs and sort the table — Inter's tabular figures keep every number column aligned at 12–13px.</p>
  </figure>

  <!-- 02 — mobile banking app (interactive, real phone scale) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Product UI — mobile banking app, true phone scale</span></figcaption>
    <div class="iu__scene iu__scene--phone">
      <div class="iu__device bank" data-bank>
        <div class="bank__chrome">
          <span class="bank__time">9:41</span>
          <span class="bank__status">
            <svg class="bank__wifi" viewBox="0 0 16 12" aria-hidden="true"><rect x="0" y="8" width="3" height="4" rx="0.6"/><rect x="4" y="5" width="3" height="7" rx="0.6"/><rect x="8" y="2" width="3" height="10" rx="0.6"/><rect x="12" y="0" width="3" height="12" rx="0.6"/></svg>
            <svg class="bank__batt" viewBox="0 0 26 12" aria-hidden="true"><rect x="0.5" y="0.5" width="22" height="11" rx="2.5" fill="none" stroke="currentColor" stroke-width="1"/><rect x="24" y="3.5" width="2" height="5" rx="1" fill="currentColor"/><rect x="2" y="2" width="16" height="8" rx="1" fill="currentColor"/></svg>
          </span>
        </div>
        <div class="bank__head">
          <span class="bank__hello">Good morning, Rasmus</span>
          <span class="bank__bell">◔</span>
        </div>
        <div class="bank__pills" role="tablist">
          {accounts.map((ac, i) => (
            <button class={`bank__pill ${i === 0 ? 'is-on' : ''}`} data-acct={ac.id} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>
              {ac.name}
            </button>
          ))}
        </div>
        <div class="bank__card" data-card>
          <span class="bank__card-label" data-clabel>{a0.name} <i>{a0.sub}</i></span>
          <span class="bank__balance" data-balance>{money(a0.bal)}</span>
          <span class="bank__delta is-up" data-delta>{a0.delta} this month</span>
        </div>

        <!-- the disambiguation moment: account details where 0/O · 1/l/I must not be guessed -->
        <div class="bank__ids" data-ids>
          <div class="bank__ids-top">
            <span class="bank__ids-h">Account &amp; card details</span>
            <button class="bank__toggle" data-dz role="switch" aria-checked="true" aria-label="Slashed zero and disambiguation">
              <span class="bank__toggle-knob"></span>
              <em>Slashed&nbsp;0</em>
            </button>
          </div>
          <dl class="bank__id-grid" data-idgrid>
            <div class="bank__id bank__id--wide"><dt>Card number</dt><dd class="bank__mono" data-id-card>{a0.card}</dd></div>
            <div class="bank__id"><dt>Sort code</dt><dd class="bank__mono" data-id-sort>{a0.sort}</dd></div>
            <div class="bank__id"><dt>Payment ref</dt><dd class="bank__mono" data-id-ref>{a0.ref}</dd></div>
            <div class="bank__id bank__id--wide"><dt>IBAN</dt><dd class="bank__mono" data-id-iban>{a0.iban}</dd></div>
          </dl>
          <p class="bank__id-note" data-dznote>Slashed zero &amp; tabular figures on — 0 vs O, 1 vs l, 8 vs B read at a glance.</p>
        </div>

        <div class="bank__actions">
          <span class="bank__act"><i>↑</i>Send</span>
          <span class="bank__act"><i>↓</i>Request</span>
          <span class="bank__act"><i>⇄</i>Move</span>
          <span class="bank__act"><i>＋</i>Top up</span>
        </div>
        <div class="bank__feed-h">Transactions</div>
        <ul class="bank__feed" data-feed>
          {a0.tx.map((t) => (
            <li class="bank__tx">
              <span class={`bank__tx-ic bank__tx-ic--${t[3]}`}>{t[2] < 0 ? '–' : '+'}</span>
              <span class="bank__tx-main">
                <b>{t[0]}</b>
                <i>{t[1]}</i>
              </span>
              <span class={`bank__tx-amt ${t[2] < 0 ? '' : 'is-in'}`}>{money(t[2])}</span>
            </li>
          ))}
        </ul>
        <div class="bank__nav">
          <span class="is-on">⌂<em>Home</em></span>
          <span>◧<em>Cards</em></span>
          <span>◑<em>Insights</em></span>
          <span>○<em>You</em></span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Tap an account, then toggle <b>Slashed&nbsp;0</b>: the card, sort code, IBAN and reference flip between Inter's default and disambiguation set (<code>'zero'</code>, <code>cv01</code>, <code>'tnum'</code>) — 0 vs O, 1 vs l, 8 vs B stop being a guess.</p>
  </figure>

  <!-- 03 — command palette (interactive, real device scale) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Product UI — command palette, keyboard-driven</span></figcaption>
    <div class="iu__scene cmd-scene">
      <div class="iu__device cmdwrap" data-cmd>
        <div class="cmd__ghost">
          <span class="cmd__ghost-bar"></span>
          <span class="cmd__ghost-bar"></span>
          <span class="cmd__ghost-bar"></span>
          <span class="cmd__ghost-hint">Press <kbd>⌘K</kbd> to open the command palette</span>
        </div>
        <div class="cmd">
          <div class="cmd__search">
            <span class="cmd__search-ic">⌕</span>
            <input class="cmd__input" type="text" value="" placeholder="Type a command or search…" data-input aria-label="Command palette search" />
            <kbd class="cmd__esc">esc</kbd>
          </div>
          <ul class="cmd__list" data-list>
            {commands.map((c, i) => (
              <li class={`cmd__row ${i === 0 ? 'is-active' : ''}`} data-row data-name={c[0].toLowerCase()} data-group={c[2].toLowerCase()}>
                <span class="cmd__row-ic">{c[3]}</span>
                <span class="cmd__row-name">{c[0]}</span>
                <span class="cmd__row-group">{c[2]}</span>
                {c[1] && <kbd class="cmd__row-key">{c[1]}</kbd>}
              </li>
            ))}
          </ul>
          <div class="cmd__foot">
            <span class="cmd__foot-keys"><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
            <span class="cmd__foot-keys"><kbd>↵</kbd> select</span>
            <span class="cmd__foot-count" data-count>{commands.length} results</span>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Type to filter — matched letters highlight, the count updates. The dense 13px UI list is exactly Inter's home turf.</p>
  </figure>

  <!-- 04 — product marketing hero (opsz / weight-axis display) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Marketing — product hero, optical size & weight axis</span></figcaption>
    <div class="iu__scene scene-tall">
      <div class="hero" data-hero>
        <div class="hero__nav">
          <span class="hero__logo">◆ Northwind</span>
          <span class="hero__nav-links"><b>Product</b><b>Pricing</b><b>Docs</b></span>
          <span class="hero__cta">Get started</span>
        </div>
        <div class="hero__body">
          <span class="hero__eyebrow">Northwind OS · v3.0</span>
          <h3 class="hero__head">The workspace<br/>that <span class="hero__em" data-em>disappears.</span></h3>
          <p class="hero__sub">A single, fast surface for docs, data and decisions — set in Inter, the typeface drawn to be invisible on the screens you read all day.</p>
          <div class="hero__row">
            <span class="hero__btn">Start free</span>
            <span class="hero__btn hero__btn--ghost">Watch the demo</span>
          </div>
        </div>
        <div class="hero__strip">
          <span class="hero__stat"><b>180k+</b><i>teams shipping</i></span>
          <span class="hero__stat"><b>99.99%</b><i>uptime SLA</i></span>
          <span class="hero__stat"><b>40ms</b><i>median sync</i></span>
          <span class="hero__stat"><b>SOC 2</b><i>type II audited</i></span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">The headline breathes across Inter's weight axis; tiny caption type stays crisp — the same family, two optical worlds.</p>
  </figure>
</div>

<script id="inter-bank-data" type="application/json" set:html={JSON.stringify(accounts)} is:inline></script>

<script>
  // ============ 01 · DASHBOARD ============
  document.querySelectorAll<HTMLElement>('[data-dash]').forEach((dash) => {
    const ranges: Record<string, string> = { overview: 'Last 30 days', audience: 'Last 30 days', revenue: 'Last quarter' };
    const kpis: Record<string, [string, string, string, string, string]> = {
      // [visitors, conv, revenue, session, trendVisitors]
      overview: ['51,400', '4.18%', '$213,420', '2m 41s', '▲ 12.4%'],
      audience: ['38,910', '3.04%', '$148,210', '3m 12s', '▲ 5.2%'],
      revenue: ['51,400', '5.92%', '$402,880', '4m 06s', '▲ 18.7%'],
    };
    const order = ['v', 'c', 'r', 's'];
    dash.querySelectorAll<HTMLButtonElement>('[data-tab]').forEach((b) =>
      b.addEventListener('click', () => {
        const key = b.dataset.tab!;
        dash.querySelectorAll('[data-tab]').forEach((x) => x.classList.remove('is-on'));
        b.classList.add('is-on');
        const vals = kpis[key] || kpis.overview;
        order.forEach((k, i) => {
          const el = dash.querySelector(`[data-kpi="${k}"]`);
          if (el) el.textContent = vals[i];
        });
        const tv = dash.querySelector('[data-trend="v"]');
        if (tv) tv.textContent = vals[4];
        const range = dash.querySelector('[data-range]');
        if (range) range.textContent = ranges[key] || 'Last 30 days';
        const bars = dash.querySelectorAll<HTMLElement>('[data-chart] span');
        bars.forEach((s, i) => {
          const seed = Math.sin(key.length * 3.7 + i * 1.3);
          s.style.height = Math.round(34 + (seed + 1) * 31) + '%';
        });
      })
    );

    // sortable table
    const table = dash.querySelector('[data-table]') as HTMLTableElement;
    const tbody = table.querySelector('tbody')!;
    let activeKey = 'v';
    let asc = false;
    function sortBy(key: string) {
      if (key === activeKey) asc = !asc;
      else { activeKey = key; asc = false; }
      table.querySelectorAll('th').forEach((x) => x.removeAttribute('data-active'));
      const th = table.querySelector(`[data-sort="${key}"]`);
      if (th) th.setAttribute('data-active', asc ? 'asc' : 'desc');
      const rows = Array.from(tbody.querySelectorAll('tr'));
      rows.sort((ra, rb) => {
        const av = key === 'src' ? ra.children[0].textContent! : +ra.dataset[key]!;
        const bv = key === 'src' ? rb.children[0].textContent! : +rb.dataset[key]!;
        return (av < bv ? -1 : av > bv ? 1 : 0) * (asc ? 1 : -1);
      });
      rows.forEach((r) => tbody.appendChild(r));
    }
    table.querySelectorAll<HTMLElement>('[data-sort]').forEach((th) =>
      th.addEventListener('click', () => sortBy(th.dataset.sort!))
    );
  });

  // ============ 02 · BANKING APP ============
  type Acct = {
    id: string; name: string; sub: string; bal: number; delta: string;
    card: string; iban: string; sort: string; ref: string;
    tx: [string, string, number, string][];
  };
  const bankIsland = document.getElementById('inter-bank-data');
  let accts: Acct[] = [];
  try { accts = bankIsland ? JSON.parse(bankIsland.textContent || '[]') : []; } catch { accts = []; }
  const byId: Record<string, Acct> = {};
  accts.forEach((a) => (byId[a.id] = a));
  const fmtMoney = (n: number) =>
    (n < 0 ? '−' : '') + '$' + Math.abs(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  document.querySelectorAll<HTMLElement>('[data-bank]').forEach((bank) => {
    if (!accts.length) return;
    const q = (s: string) => bank.querySelector(s) as HTMLElement | null;
    const clabel = q('[data-clabel]')!, balance = q('[data-balance]')!, delta = q('[data-delta]')!;
    const feed = q('[data-feed]')!;
    const idGrid = q('[data-idgrid]');
    const idCard = q('[data-id-card]'), idSort = q('[data-id-sort]');
    const idIban = q('[data-id-iban]'), idRef = q('[data-id-ref]');
    const dzBtn = q('[data-dz]') as HTMLButtonElement | null;
    const dzNote = q('[data-dznote]');

    function render(id: string) {
      const a = byId[id];
      if (!a) return;
      if (idCard) idCard.textContent = a.card;
      if (idSort) idSort.textContent = a.sort;
      if (idIban) idIban.textContent = a.iban;
      if (idRef) idRef.textContent = a.ref;
      clabel.replaceChildren();
      clabel.append(document.createTextNode(a.name + ' '));
      const sub = document.createElement('i');
      sub.textContent = a.sub;
      clabel.append(sub);
      balance.textContent = fmtMoney(a.bal);
      const up = !a.delta.startsWith('−');
      delta.textContent = a.delta + ' this month';
      delta.classList.toggle('is-up', up);
      delta.classList.toggle('is-dn', !up);

      feed.replaceChildren();
      a.tx.forEach((t) => {
        const li = document.createElement('li');
        li.className = 'bank__tx';
        const ic = document.createElement('span');
        ic.className = `bank__tx-ic bank__tx-ic--${t[3]}`;
        ic.textContent = t[2] < 0 ? '–' : '+';
        const main = document.createElement('span');
        main.className = 'bank__tx-main';
        const name = document.createElement('b');
        name.textContent = t[0];
        const when = document.createElement('i');
        when.textContent = t[1];
        main.append(name, when);
        const amt = document.createElement('span');
        amt.className = 'bank__tx-amt' + (t[2] < 0 ? '' : ' is-in');
        amt.textContent = fmtMoney(t[2]);
        li.append(ic, main, amt);
        feed.appendChild(li);
      });

      bank.querySelectorAll('[data-acct]').forEach((p) => {
        const on = (p as HTMLElement).dataset.acct === id;
        p.classList.toggle('is-on', on);
        p.setAttribute('aria-selected', on ? 'true' : 'false');
      });
    }

    bank.querySelectorAll<HTMLButtonElement>('[data-acct]').forEach((btn) =>
      btn.addEventListener('click', () => render(btn.dataset.acct!))
    );

    // disambiguation toggle: flip Inter's 'zero'/cv01 (slashed zero) + 'tnum'
    if (dzBtn && idGrid) {
      const setDz = (on: boolean) => {
        idGrid.classList.toggle('is-plain', !on);
        dzBtn.setAttribute('aria-checked', on ? 'true' : 'false');
        dzBtn.classList.toggle('is-off', !on);
        if (dzNote) {
          dzNote.textContent = on
            ? 'Slashed zero & tabular figures on — 0 vs O, 1 vs l, 8 vs B read at a glance.'
            : 'Defaults: dotted/oval zero, proportional digits — the colliding glyphs are a guess.';
        }
      };
      dzBtn.addEventListener('click', () =>
        setDz(dzBtn.getAttribute('aria-checked') !== 'true')
      );
    }
  });

  // ============ 03 · COMMAND PALETTE ============
  document.querySelectorAll<HTMLElement>('[data-cmd]').forEach((wrap) => {
    const input = wrap.querySelector('[data-input]') as HTMLInputElement;
    const list = wrap.querySelector('[data-list]') as HTMLElement;
    const count = wrap.querySelector('[data-count]') as HTMLElement;
    const rows = Array.from(wrap.querySelectorAll<HTMLElement>('[data-row]'));
    const names = rows.map((r) => r.querySelector('.cmd__row-name')!.textContent || '');

    function highlight(rowName: HTMLElement, label: string, query: string) {
      rowName.replaceChildren();
      if (!query) { rowName.textContent = label; return; }
      const idx = label.toLowerCase().indexOf(query.toLowerCase());
      if (idx < 0) { rowName.textContent = label; return; }
      rowName.append(document.createTextNode(label.slice(0, idx)));
      const mark = document.createElement('mark');
      mark.textContent = label.slice(idx, idx + query.length);
      rowName.append(mark);
      rowName.append(document.createTextNode(label.slice(idx + query.length)));
    }

    function filter() {
      const q = input.value.trim().toLowerCase();
      let shown = 0;
      let firstActive = false;
      rows.forEach((row, i) => {
        const hay = (row.dataset.name || '') + ' ' + (row.dataset.group || '');
        const ok = !q || hay.includes(q);
        row.classList.toggle('is-hidden', !ok);
        row.classList.remove('is-active');
        const nameEl = row.querySelector('.cmd__row-name') as HTMLElement;
        highlight(nameEl, names[i], q);
        if (ok) {
          shown++;
          if (!firstActive) { row.classList.add('is-active'); firstActive = true; }
        }
      });
      count.textContent = `${shown} result${shown === 1 ? '' : 's'}`;
    }
    input.addEventListener('input', filter);

    // arrow-key navigation among visible rows
    input.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowDown' && e.key !== 'ArrowUp') return;
      e.preventDefault();
      const vis = rows.filter((r) => !r.classList.contains('is-hidden'));
      if (!vis.length) return;
      let cur = vis.findIndex((r) => r.classList.contains('is-active'));
      vis.forEach((r) => r.classList.remove('is-active'));
      cur = e.key === 'ArrowDown' ? (cur + 1) % vis.length : (cur - 1 + vis.length) % vis.length;
      vis[cur].classList.add('is-active');
      vis[cur].scrollIntoView({ block: 'nearest' });
    });

    rows.forEach((row) =>
      row.addEventListener('mouseenter', () => {
        rows.forEach((r) => r.classList.remove('is-active'));
        row.classList.add('is-active');
      })
    );
  });
</script>

