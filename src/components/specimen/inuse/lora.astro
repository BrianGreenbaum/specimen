  .smv__mark { margin: 0.25em 0 0; font-size: clamp(48px, 7.4cqi, 96px); line-height: 1; font-weight: 600; font-variation-settings: 'wght' 600; letter-spacing: -0.01em; }
  .smv__sub { margin-top: 0.7em; font-size: clamp(10px, 1.1cqi, 14px); letter-spacing: 0.32em; text-indent: 0.32em; color: var(--cream-dim); }
