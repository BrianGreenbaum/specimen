  .smv__tinru { font-size: clamp(19px, 2.6cqi, 34px); line-height: 1.05; font-weight: 600; font-variation-settings: 'wght' 600; }
  .smv__tinen { margin-top: 0.45em; font-size: clamp(9.5px, 1cqi, 12.5px); letter-spacing: 0.2em; text-transform: uppercase; color: var(--gall-soft); }
  .smv__tinrule { width: 56%; border-top: 1px solid color-mix(in srgb, var(--gall) 30%, transparent); margin: clamp(0.55rem, 1.3cqi, 1rem) 0; }
