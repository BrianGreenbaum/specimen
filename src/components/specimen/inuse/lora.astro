---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// ── The sequence ─────────────────────────────────────────────────────────────
// LORA IS A SCREEN SERIF WITH A RUSSIAN PASSPORT AND A BRUSH IN ITS PAST —
// five acts about one novel in translation. The all-type jacket of FIREFLY
// (01, night ink) → the translation journal that prints the Tyutchev it
// descends from (02, cream paper) → the tea merchant who advertises in the
// journal's back matter (03, lacquer red) → the practice sheet of the hand
// that lettered the labels (04, ruled cream) → the reader where you, the
// reader, hold the pen yourself (05, theme tokens, real px). Night → paper →
// lacquer → paper → screen; the rust accent is the one ink carried through.
//
// Honesty ledger — verified against the fontsource latin/cyrillic woff2s
// (fontTools, fvar + GSUB):
// · VARIABLE: wght 400–700 only. No opsz, no slnt, no width. TRUE ITALIC
//   loaded at the same axis range (wght-italic.css, all subsets).
// · GSUB liga: f+i → fi and f+l → fl ONLY. No ffi/ffl/Th sorts — never
//   claimed. "Firefly" carries both real ligatures in one word.
// · frac: precomposed ½ ¼ ¾ only — acts use exactly those three.
// · tnum / pnum are real (default figures are proportional LINING — no
//   oldstyle story is ever told). calt exists; no specific claim made.
// · Cyrillic ships first-class (Cyreal is a Cyrillic-first foundry) and
//   loads via unicode-range — Tyutchev, the tea house and the wordmark
//   are live text in the same family, roman and italic.

// ── 02 · Tyutchev, «Silentium!» (1830, public domain) ───────────────────────
// Facing-page translation; the English is set fresh for this artifact.
// Both texts set FLUSH LEFT from the gutter outward, as Modern Poetry in
// Translation and the thick journals set parallel verse — the verso/recto
// asymmetry is carried by roman vs italic, not by mirrored alignment.
// glue(): no breath before an em dash — a dash never opens a wrapped line,
// so the verse's left edge stays optically clean at every width.
const glue = (s: string) => s.replace(/ —/gu, '\u00A0—');
const silentium: { ru: string; en: string }[] = [
  { ru: 'Молчи, скрывайся и таи',           en: 'Be silent, hide yourself, conceal' },
  { ru: 'И чувства и мечты свои —',          en: 'the feelings and the dreams you feel;' },
  { ru: 'Пускай в душевной глубине',         en: 'deep in the spirit let them rise' },
  { ru: 'Встают и заходят оне',              en: 'like stars that climb the evening skies,' },
  { ru: 'Безмолвно, как звезды в ночи, —',   en: 'silent, before the night is stirred:' },
  { ru: 'Любуйся ими — и молчи.',            en: 'delight in them — and not a word.' },
  { ru: 'Как сердцу высказать себя?',        en: 'How can the heart declare its whole?' },
  { ru: 'Другому как понять тебя?',          en: 'How can another know your soul,' },
  { ru: 'Поймёт ли он, чем ты живёшь?',      en: 'or guess what quickens you, and why?' },
  { ru: 'Мысль изречённая есть ложь.',       en: 'A thought, once spoken, is a lie.' },
  { ru: 'Взрывая, возмутишь ключи, —',       en: 'Stir up the springs and they run blurred:' },
  { ru: 'Питайся ими — и молчи.',            en: 'drink at their source — and not a word.' },
];

// ── 03 · the tea tins — every net weight is a REAL precomposed fraction ─────
const tins = [
  { id: 'caravan', ru: 'Караванъ',  en: 'Russian Caravan', frac: '1/2', funt: 'фунта', price: '380',
    steep: 'four minutes, just off the boil — the smoky black for the long evening chapter.' },
  { id: 'ivan',    ru: 'Иванъ-чай', en: 'Willow Herb',     frac: '1/4', funt: 'фунта', price: '240',
    steep: 'seven minutes, water well rested — the meadow herb the engravers drank at dusk.' },
  { id: 'garden',  ru: 'Садовый',   en: 'Garden Green',    frac: '3/4', funt: 'фунта', price: '520',
    steep: 'two minutes, eighty degrees — a green picked before the morning proofs.' },
];

// ── 04 · the practice lines, split server-side so every letter is a span ────
const line1 = 'written, not engineered';
const line2 = 'the pen survives the pixel';
const split = (s: string) => Array.from(s);
---

<div class="iu lr" style={`--fam:${fam}`}>

  <!-- ════════════════════════════════════════════════════════════════════
       01 · ILLUSTRATION & COMMERCIAL — the all-type literary jacket.
       Reference: the contemporary Knopf school of all-type covers (the
       Janet Hansen / Alex Merto lineage) — no photograph, the title set
       so the type IS the picture. "Firefly" carries Lora's two real
       ligatures (fi, fl) in a single display word; the back cover gives
       the Russian original, «Светлячок», in the same family.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Commercial — the all-type jacket, in the Knopf school</span></figcaption>
    <div class="iu__scene jkt">
      <div class="jkt__flat">
        <section class="jkt__back" aria-label="Back cover">
          <p class="jkt__orig">first published in Russian as</p>
          <span class="jkt__origtitle">светлячок</span>
          <p class="jkt__quote"><em>&ldquo;A novel about everything a letter can carry &mdash; Sorokina writes the way ink dries: slowly, and for good.&rdquo;</em></p>
          <span class="jkt__quotesrc">&mdash; The Common Reader</span>
          <p class="jkt__blurb">In the last summer of the dacha, a translator inherits a shoebox of her grandmother&rsquo;s unsent letters &mdash; and begins, against every instruction, to answer them. Vera Sorokina&rsquo;s celebrated novel arrives in English at last, in Daria Anders&rsquo;s luminous translation.</p>
          <div class="jkt__isbnrow">
            <div class="jkt__isbn">
              <i class="jkt__bars" aria-hidden="true"></i>
              <span class="jkt__isbnnum">ISBN 978-1-913 408-22-7</span>
            </div>
            <span class="jkt__price">$28 &middot; &pound;22</span>
          </div>
        </section>
        <section class="jkt__spine" aria-label="Spine">
          <span class="jkt__sptext"><em>firefly</em> &mdash; Vera Sorokina</span>
          <span class="jkt__spmark">M</span>
        </section>
        <section class="jkt__front" aria-label="Front cover">
          <i class="jkt__sheen" aria-hidden="true"></i>
          <span class="jkt__house">Marginalia Editions</span>
          <div class="jkt__titleblock">
            <h3 class="jkt__title"><span class="jkt__tl">fire</span><span class="jkt__tl jkt__tl--2">fly</span></h3>
            <span class="jkt__anovel">a novel</span>
          </div>
          <div class="jkt__authorblock">
            <div class="jkt__authorcol">
              <span class="jkt__author">Vera Sorokina</span>
              <span class="jkt__trans"><em>translated from the Russian by Daria Anders</em></span>
            </div>
            <p class="jkt__pull"><em>&ldquo;A translation that reads like a confession.&rdquo;</em><span class="jkt__pullsrc">&mdash; The Paris Review</span></p>
          </div>
        </section>
      </div>
    </div>
    <p class="iu__hint label">No image, no ornament — the contemporary all-type literary jacket in the Hansen/Merto lineage: the axis broken, the title flush left and stacked so the word splits at its own ligatures. Set lowercase, <em>fire</em> and <em>fly</em> each close a real cast ligature — the <em>fi</em> on one line, the <em>fl</em> on the other — and Lora&rsquo;s brushed terminals become the picture. The back cover answers at equal voice: the Russian original, <em>светлячок</em>, at display size in the same italic. A slow spot-gloss catches the shelf light (still under reduced motion).</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       02 · EDITORIAL — the facing-page translation journal.
       Reference: the Russian "thick journal" (толстый журнал) tradition —
       Sovremennik, Novy Mir, the literary monthlies — crossed with the
       facing-page parallel text of the translation journals (Modern
       Poetry in Translation). Tyutchev's Silentium! (1830), Cyrillic
       verso, English recto — BOTH flush left from the gutter outward,
       as MPT sets parallel text; roman-verso/italic-recto carries the
       asymmetry. Hover or tap a line and its twin lights up. The
       masthead's « hangs (optical margin alignment) and em dashes are
       glued to their words so no dash ever dents a column's left edge.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click='[data-pl="3"]'>
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Editorial — a facing-page translation journal, after the Russian thick monthlies</span></figcaption>
    <div class="iu__scene slv">
      <div class="slv__spread" data-slv>
        <header class="slv__band">
          <span class="slv__mast"><span class="slv__hang">&laquo;</span>СЛОВО&raquo; &middot; THE WORD</span>
          <span class="slv__tag"><em>a journal of translation</em></span>
          <span class="slv__issue">кн. <span class="num">214</span> &middot; лѣто / summer <span class="num">2026</span></span>
        </header>
        <div class="slv__pages">
          <section class="slv__page slv__page--ru" lang="ru">
            <span class="slv__runhead">Ф. И. Тютчевъ</span>
            <h3 class="slv__poemtitle">Silentium!</h3>
            <span class="slv__year num">1830</span>
            <div class="slv__poem">
              {silentium.map((l, i) => (
                <span class={`slv__ln${i === 9 ? ' is-lit' : ''}${i === 6 ? ' slv__ln--stanza' : ''}`} data-pl={i} tabindex="0">{glue(l.ru)}</span>
              ))}
            </div>
            <span class="slv__folio num">86</span>
          </section>
          <section class="slv__page slv__page--en" lang="en">
            <span class="slv__runhead">Fyodor Tyutchev</span>
            <h3 class="slv__poemtitle slv__poemtitle--en"><em>Silentium!</em></h3>
            <span class="slv__year slv__year--en"><em>translated by Daria Anders</em></span>
            <div class="slv__poem slv__poem--en">
              {silentium.map((l, i) => (
                <span class={`slv__ln${i === 9 ? ' is-lit' : ''}${i === 6 ? ' slv__ln--stanza' : ''}`} data-pl={i} tabindex="0"><em>{glue(l.en)}</em></span>
              ))}
            </div>
            <span class="slv__folio slv__folio--r num">87</span>
          </section>
        </div>
        <footer class="slv__foot">
          <span>в этом номерѣ: о романѣ &laquo;Светлячок&raquo; Веры Сорокиной, стр. <span class="num">44</span></span>
          <span class="slv__foot--r">advertisement overleaf &middot; Самоваръ, чайный домъ</span>
        </footer>
      </div>
    </div>
    <p class="iu__hint label">The толстый журнал — the Russian thick monthly that serialized a literature — crossed with the facing-page convention of the translation journals: Tyutchev&rsquo;s <em>Silentium!</em> in Cyrillic on the verso, the English in true italic on the recto, both set flush left from the gutter outward as Modern Poetry in Translation sets parallel text — roman against italic is the asymmetry, and alignment carries it. Hover, tap, or tab to any line and its twin lights on the facing page — the translator&rsquo;s reading made visible. The masthead&rsquo;s opening guillemet hangs into the margin, em dashes stay glued to their words, and the famous tenth line arrives pre-lit.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       03 · BRANDING & IDENTITY — the tea merchant's label system.
       Reference: the Moscow tea-merchant lineage — Perlov's tea house on
       Myasnitskaya, 1896 — re-set in the contemporary warm-serif rebrand
       current (the post-Chobani turn back to humanist serifs). The hard
       sign is kept the way «Коммерсантъ» keeps it: heritage worn live.
       Every net weight is one of Lora's three real precomposed fractions.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click='[data-tin="ivan"]'>
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Branding — the tea merchant&rsquo;s counter, Perlov lineage, warm-serif current</span></figcaption>
    <div class="iu__scene smv">
      <div class="smv__shop" data-smv>
        <div class="smv__ident">
          <span class="smv__est">основано въ Москвѣ &middot; <span class="num">1896</span></span>
          <h3 class="smv__mark"><em>Самоваръ</em></h3>
          <span class="smv__sub">ЧАЙНЫЙ ДОМЪ &middot; TEA MERCHANTS</span>
          <p class="smv__creed"><em>The hard sign stays. A house that has poured tea through three alphabets&rsquo; reforms does not redraw its name for the fourth.</em></p>
          <dl class="smv__facts">
            <div><dt>blends in the book</dt><dd class="num">217</dd></div>
            <div><dt>samovars on the wall</dt><dd class="num">31</dd></div>
            <div><dt>years at the counter</dt><dd class="num">130</dd></div>
          </dl>
          <span class="smv__addr">Мясницкая, <span class="num">19</span> &middot; Moscow</span>
        </div>
        <div class="smv__counter">
          <span class="smv__shelf-label">сегодня на прилавкѣ &middot; on the counter today</span>
          <div class="smv__tins" role="group" aria-label="Choose a tin">
            {tins.map((t, i) => (
              <button class={`smv__tin${i === 0 ? ' is-picked' : ''}`} type="button" data-tin={t.id} data-steep={t.steep} data-name={`${t.ru} · ${t.en}`} data-frac={t.frac} data-price={t.price} aria-pressed={i === 0 ? 'true' : 'false'}>
                <i class="smv__lid" aria-hidden="true"></i>
                <span class="smv__tinru"><em>{t.ru}</em></span>
                <span class="smv__tinen">{t.en}</span>
                <span class="smv__tinrule" aria-hidden="true"></span>
                <span class="smv__tinwt"><b class="frac">{t.frac}</b> {t.funt}</span>
                <span class="smv__tinprice num">{t.price} руб.</span>
              </button>
            ))}
          </div>
          <div class="smv__ticket" aria-live="polite">
            <span class="smv__tk-head">чекъ &middot; the counter ticket</span>
            <span class="smv__tk-line"><b data-tk-name><em>Караванъ &middot; Russian Caravan</em></b></span>
            <span class="smv__tk-row"><span class="frac" data-tk-frac>1/2</span> фунта &middot; <span class="num" data-tk-price>380</span> руб. &middot; brewed <span data-tk-steep>four minutes, just off the boil — the smoky black for the long evening chapter.</span></span>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">The journal&rsquo;s back-matter advertiser, given the full identity: a Moscow tea house in the Perlov lineage, redrawn in today&rsquo;s warm-serif current. The wordmark keeps the pre-reform hard sign the way «Коммерсантъ» does — heritage as a living glyph, not pastiche. Every net weight on the labels is one of the three fractions actually cast in this font — ½, ¼, ¾ — and the prices align because <em>tnum</em> is real. Pick a tin and the counter ticket rewrites itself.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       04 · INTERACTIVE & EXPERIMENTAL — the pressure sheet.
       Reference: Edward Johnston, "Writing & Illuminating, & Lettering"
       (1906) — the ruled broad-nib practice sheets every calligraphic
       serif descends from — rebuilt as an instrument: the pointer is the
       pen, Lora's single wght axis (400–700) is the ink pressure. With
       the pen lifted (or motion reduced) the sheet shows a graded stroke,
       400 to 700 across the line — complete without a cursor.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Experimental — the pressure sheet, after Johnston&rsquo;s broad-nib exercises</span></figcaption>
    <div class="iu__scene prs">
      <div class="prs__sheet" data-prs>
        <header class="prs__head">
          <span class="prs__plate">PLATE VII &middot; OF PRESSURE</span>
          <span class="prs__lesson"><em>after the practice sheets of</em> Writing &amp; Illuminating, &amp; Lettering, <span class="num">1906</span></span>
          <span class="prs__gauge">pressure <b class="num" data-prs-out>700</b> <i>of</i> <b class="num">700</b></span>
        </header>
        <div class="prs__line prs__line--roman" data-prs-line aria-label={line1}>
          <span class="prs__rules" aria-hidden="true"><i class="prs__r prs__r--asc"></i><i class="prs__r prs__r--x"></i><i class="prs__r prs__r--base"></i><i class="prs__r prs__r--desc"></i></span>
          <span class="prs__word" aria-hidden="true">
            {split(line1).map((ch) => ch === ' ' ? <span class="prs__sp">&nbsp;</span> : <span class="prs__ch" data-ch>{ch}</span>)}
          </span>
          <span class="prs__handlabel">the roman hand</span>
        </div>
        <div class="prs__line prs__line--italic" data-prs-line aria-label={line2}>
          <span class="prs__rules" aria-hidden="true"><i class="prs__r prs__r--asc"></i><i class="prs__r prs__r--x"></i><i class="prs__r prs__r--base"></i><i class="prs__r prs__r--desc"></i></span>
          <span class="prs__word prs__word--it" aria-hidden="true">
            {split(line2).map((ch) => ch === ' ' ? <span class="prs__sp">&nbsp;</span> : <span class="prs__ch" data-ch>{ch}</span>)}
          </span>
          <span class="prs__handlabel"><em>the italic hand — a true cursive, not a slant</em></span>
        </div>
        <footer class="prs__foot">
          <span>one axis, honestly: wght <span class="num">400</span>&ndash;<span class="num">700</span> — nothing here the file cannot do</span>
          <span class="prs__foot--r"><em>draw across the line; the letters swell where the pen presses</em></span>
        </footer>
      </div>
    </div>
    <p class="iu__hint label">Johnston&rsquo;s 1906 manual taught the broad nib on ruled sheets — ascender, waist, base and descender lines — and every calligraphic serif, Lora included, descends from that classroom. Here the sheet is rebuilt as an instrument: move the pen across either line and each letter takes the pressure of your stroke, swelling through the real 400–700 weight axis and falling off like ink. Lift the pen — or prefer reduced motion — and the sheet rests as a graded stroke, light to full, still a complete plate.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       05 · WEB & APP UI — the reader, at true device scale.
       Reference: the reader-mode current (Safari Reader, Instapaper,
       Pocket) — the strain of the web Lora was literally drawn for, and
       where it remains one of the most-set serifs alive. The typography
       panel hands the pen from act 04 to the reader: the weight slider
       IS the pressure, now in the user's hand.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item" data-shoot-click="[data-size='20']">
    <figcaption class="iu__cap"><span class="index-num">05</span><span class="label">Web UI — reader mode at real device scale, live controls</span></figcaption>
    <div class="iu__scene rdr-scene">
      <div class="iu__device rdr" data-rdr>
        <div class="iu__chrome">
          <div class="iu__dots"><i></i><i></i><i></i></div>
          <span class="iu__addr">slovo.press/notes/a-thought-once-spoken</span>
        </div>
        <div class="rdr__top">
          <span class="rdr__logo">Слово<em>/notes</em></span>
          <div class="rdr__progress" aria-hidden="true"><i data-prog style="width:8%"></i></div>
          <button class="rdr__aA" type="button" data-panel-btn aria-expanded="true" aria-label="Typography settings"><span class="rdr__aAs">A</span><span class="rdr__aAb">A</span></button>
        </div>
        <div class="rdr__panel" data-panel>
          <div class="rdr__prow">
            <span class="rdr__plab">weight</span>
            <input type="range" min="400" max="700" step="1" value="400" data-wght aria-label="Body weight, 400 to 700" />
            <b class="rdr__pval num" data-wout>400</b>
          </div>
          <div class="rdr__prow">
            <span class="rdr__plab">size</span>
            <div class="rdr__seg" role="group" aria-label="Body size">
              <button class="is-on" type="button" data-size="16" aria-pressed="true">16</button>
              <button type="button" data-size="18" aria-pressed="false">18</button>
              <button type="button" data-size="20" aria-pressed="false">20</button>
            </div>
            <span class="rdr__plab rdr__plab--r">features</span>
            <div class="rdr__chips">
              <button class="is-on" type="button" data-feat="liga" aria-pressed="true">fi fl ligatures</button>
              <button type="button" data-feat="tnum" aria-pressed="false">tabular figures</button>
            </div>
          </div>
        </div>
        <article class="rdr__body" data-art>
          <p class="rdr__kicker">Notes from the journal &middot; translation</p>
          <h4 class="rdr__head">A thought, once spoken</h4>
          <p class="rdr__byline"><em>Daria Anders on translating Tyutchev</em> &middot; <span class="num">9</span> June <span class="num">2026</span></p>
          <p class="rdr__lede">Tyutchev warns the translator off in his own tenth line — <span lang="ru">«Мысль изречённая есть ложь»</span>, a thought once spoken is a lie — and every English version of <em>Silentium!</em> begins by deciding how big a liar it is willing to be.</p>
          <p>Mine settles for roughly <span class="frac">3/4</span> of his syllables and all of his refusal. What the meter loses, the letterform carries: this page is set in the same face as the journal, a serif drawn for the screen with a brush in its memory, and at sixteen pixels the flicker of the pen — the softened terminals, the firm bracketed feet — is what keeps two thousand words feeling written rather than rendered.</p>
          <blockquote class="rdr__quote"><em>A translation is a reading you can no longer take back.</em></blockquote>
          <p>The fitting test is below: the draft ledger, where the versions sit in columns. Switch the figures to tabular and the ledger snaps to the grid; loosen them and each numeral takes only the room it needs — both cuts live in this one file.</p>
          <table class="rdr__ledger">
            <caption>the draft ledger</caption>
            <tbody>
              <tr><th scope="row">draft <span class="num">1</span> — literal</th><td class="rdr__fig">1,914</td><td class="rdr__fig">words</td></tr>
              <tr><th scope="row">draft <span class="num">4</span> — metrical</th><td class="rdr__fig">1,107</td><td class="rdr__fig">words</td></tr>
              <tr><th scope="row">draft <span class="num">11</span> — printed</th><td class="rdr__fig">2,041</td><td class="rdr__fig">words</td></tr>
            </tbody>
          </table>
          <p>Tyutchev wrote his six-line stanzas at a desk by candlelight; you are reading them by the light of the screen itself. The instrument has changed twice. The instruction has not: delight in them — and not a word.</p>
        </article>
      </div>
    </div>
    <p class="iu__hint label">The reader-mode current — Safari Reader, Instapaper, Pocket — is the room Lora was drawn for, and this one runs at true interface scale: a 16-pixel column you can actually drive. The weight slider is act 04&rsquo;s pen handed to the reader — the same live 400–700 axis; the size control re-leads the column honestly at 16/18/20; the feature chips close the <em>fi fl</em> ligatures and snap the draft ledger to tabular figures. The progress bar tracks your real scroll through the essay.</p>
  </figure>

</div>

<script>
  // ── 02 · facing-page line pairing ─────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-slv]').forEach((spread) => {
    const lines = Array.from(spread.querySelectorAll<HTMLElement>('[data-pl]'));
    const light = (idx: string) => {
      lines.forEach((l) => l.classList.toggle('is-lit', l.dataset.pl === idx));
    };
    lines.forEach((l) => {
      const idx = l.dataset.pl!;
      l.addEventListener('pointerenter', () => light(idx));
      l.addEventListener('focus', () => light(idx));
      l.addEventListener('click', () => light(idx));
    });
  });

  // ── 03 · the counter ticket ───────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-smv]').forEach((shop) => {
    const tkName = shop.querySelector<HTMLElement>('[data-tk-name]')!;
    const tkFrac = shop.querySelector<HTMLElement>('[data-tk-frac]')!;
    const tkPrice = shop.querySelector<HTMLElement>('[data-tk-price]')!;
    const tkSteep = shop.querySelector<HTMLElement>('[data-tk-steep]')!;
    const tinsEls = Array.from(shop.querySelectorAll<HTMLButtonElement>('[data-tin]'));
    tinsEls.forEach((tin) => {
      tin.addEventListener('click', () => {
        tinsEls.forEach((t) => { t.classList.remove('is-picked'); t.setAttribute('aria-pressed', 'false'); });
        tin.classList.add('is-picked');
        tin.setAttribute('aria-pressed', 'true');
        // tkName keeps its <em>; write into it, not over it
        (tkName.firstElementChild ?? tkName).textContent = tin.dataset.name!;
        tkFrac.textContent = tin.dataset.frac!;
        tkPrice.textContent = tin.dataset.price!;
        tkSteep.textContent = tin.dataset.steep!;
      });
    });
  });

  // ── 04 · the pressure sheet ───────────────────────────────────────────────
  // Resting state (and reduced-motion state): a graded stroke, 400 → 700
  // across each line. With a pointer down/over: Gaussian pressure around
  // the pen, reads batched before writes, one rAF in flight at a time.
  document.querySelectorAll<HTMLElement>('[data-prs]').forEach((sheet) => {
    const out = sheet.querySelector<HTMLElement>('[data-prs-out]');
    const lines = Array.from(sheet.querySelectorAll<HTMLElement>('[data-prs-line]'));
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

    const ramp = () => {
      lines.forEach((line) => {
        const chars = Array.from(line.querySelectorAll<HTMLElement>('[data-ch]'));
        const n = Math.max(1, chars.length - 1);
        chars.forEach((c, i) => {
          c.style.fontVariationSettings = `'wght' ${Math.round(400 + 300 * (i / n))}`;
        });
      });
      if (out) out.textContent = '700';
    };
    ramp();
    document.fonts?.ready.then(ramp);
    if (reduce) return;

    let raf = 0;
    let px = 0;
    const press = () => {
      raf = 0;
      let peak = 400;
      lines.forEach((line) => {
        const chars = Array.from(line.querySelectorAll<HTMLElement>('[data-ch]'));
        // reads first…
        const centers = chars.map((c) => {
          const r = c.getBoundingClientRect();
          return r.left + r.width / 2;
        });
        const sigma = Math.max(48, line.getBoundingClientRect().width * 0.055);
        // …then writes
        chars.forEach((c, i) => {
          const w = Math.round(400 + 300 * Math.exp(-((px - centers[i]) ** 2) / (2 * sigma * sigma)));
          if (w > peak) peak = w;
          c.style.fontVariationSettings = `'wght' ${w}`;
        });
      });
      if (out) out.textContent = String(peak);
    };
    sheet.addEventListener('pointermove', (e) => {
      px = e.clientX;
      if (!raf) raf = requestAnimationFrame(press);
    });
    sheet.addEventListener('pointerleave', () => {
      if (raf) cancelAnimationFrame(raf);
      raf = 0;
      ramp();
    });
  });

  // ── 05 · the reader ───────────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-rdr]').forEach((rdr) => {
    const art = rdr.querySelector<HTMLElement>('[data-art]')!;
    const panel = rdr.querySelector<HTMLElement>('[data-panel]')!;
    const panelBtn = rdr.querySelector<HTMLButtonElement>('[data-panel-btn]')!;
    const wght = rdr.querySelector<HTMLInputElement>('[data-wght]')!;
    const wout = rdr.querySelector<HTMLElement>('[data-wout]')!;
    const prog = rdr.querySelector<HTMLElement>('[data-prog]')!;
    const feats: Record<string, boolean> = { liga: true, tnum: false };

    const apply = () => {
      art.style.fontVariationSettings = `'wght' ${wght.value}`;
      art.style.fontFeatureSettings = `'liga' ${feats.liga ? 1 : 0}, 'tnum' ${feats.tnum ? 1 : 0}`;
    };
    wght.addEventListener('input', () => { wout.textContent = wght.value; apply(); });

    rdr.querySelectorAll<HTMLButtonElement>('[data-size]').forEach((b) => {
      b.addEventListener('click', () => {
        rdr.querySelectorAll('[data-size]').forEach((o) => { o.classList.remove('is-on'); o.setAttribute('aria-pressed', 'false'); });
        b.classList.add('is-on');
        b.setAttribute('aria-pressed', 'true');
        art.style.fontSize = `${b.dataset.size}px`;
      });
    });

    rdr.querySelectorAll<HTMLButtonElement>('[data-feat]').forEach((b) => {
      b.addEventListener('click', () => {
        const f = b.dataset.feat!;
        feats[f] = !feats[f];
        b.classList.toggle('is-on', feats[f]);
        b.setAttribute('aria-pressed', String(feats[f]));
        apply();
      });
    });

    panelBtn.addEventListener('click', () => {
      const open = panel.hasAttribute('hidden');
      if (open) panel.removeAttribute('hidden'); else panel.setAttribute('hidden', '');
      panelBtn.setAttribute('aria-expanded', String(open));
    });

    art.addEventListener('scroll', () => {
      const max = art.scrollHeight - art.clientHeight;
      prog.style.width = `${max > 0 ? Math.max(8, Math.round((art.scrollTop / max) * 100)) : 8}%`;
    }, { passive: true });

    apply();
  });
</script>

