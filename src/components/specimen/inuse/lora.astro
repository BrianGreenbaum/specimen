  .smv__facts dt { font-size: clamp(9px, 0.95cqi, 11.5px); letter-spacing: 0.12em; text-transform: uppercase; color: var(--cream-dim); }
  .smv__facts dd { margin: 0; font-size: clamp(22px, 2.9cqi, 38px); font-weight: 700; font-variation-settings: 'wght' 700; line-height: 1; }
  .smv__addr { margin-top: auto; padding-top: clamp(1rem, 2.2cqi, 1.8rem); font-size: clamp(11px, 1.2cqi, 15px); font-style: italic; color: var(--cream-dim); }

