---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// E-commerce lookbook data (scene 05, interactive)
const looks = [
  { id: 'LB-01', name: 'Soie Noire', cat: 'gowns',  price: '4,200',  detail: 'Silk-faille column gown',     tag: 'Atelier' },
  { id: 'LB-02', name: 'Hauteville', cat: 'coats',  price: '6,850',  detail: 'Wool-cashmere opera coat',    tag: '' },
  { id: 'LB-03', name: 'Verre Brisé',cat: 'gowns',  price: '5,400',  detail: 'Crystal-pleated bias dress', tag: '' },
  { id: 'LB-04', name: 'Monceau',    cat: 'coats',  price: '3,990',  detail: 'Belted gabardine trench',     tag: '' },
  { id: 'LB-05', name: 'Lumière',    cat: 'jewels', price: '12,000', detail: 'Pavé diamond collar',         tag: '' },
  { id: 'LB-06', name: 'Étoile',     cat: 'jewels', price: '2,750',  detail: 'Baguette drop earrings',      tag: '' },
];
---
<div class="iu" style={`--fam:${fam}`}>
  <!-- 01 — fashion magazine cover -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Magazine — the fashion cover</span></figcaption>
    <div class="iu__scene iu__scene--portrait">
      <div class="iu__poster cover" data-bloom>
        <div class="cover__paper" aria-hidden="true"></div>
        <div class="cover__inner">
          <div class="cover__top">
            <span class="cover__logo">Vol. <span class="cover__fig">XI</span></span>
            <span class="cover__season">Le numéro d’automne</span>
            <span class="cover__price"><span class="cover__fig">€12</span></span>
          </div>
          <h3 class="cover__masthead" data-bloom-word>MODA</h3>
          <span class="cover__strap">Paris — Milano — New York</span>
          <div class="cover__lines">
            <span class="cover__feat">The Architecture<br/>of <em>Elegance</em></span>
            <span class="cover__sub">Couture cut in forty-eight hairlines — and the new minimalism in fine jewellery</span>
          </div>
          <div class="cover__foot">
            <span class="cover__barcode" aria-hidden="true">
              {Array.from({length:34}).map((_,i)=>(<i style={`width:${(i%5)+1}px`}></i>))}
            </span>
            <span class="cover__plus">Saint&nbsp;Laurent <em>at sixty</em> <span class="cover__pg">p.&nbsp;<span class="cover__fig">112</span></span></span>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Hover the masthead — the optical-size axis blooms the hairlines razor-thin.</p>
  </figure>

  <!-- 02 — luxury brand identity / packaging -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Brand — maison identity system</span></figcaption>
    <div class="iu__scene scene16">
      <div class="iu__poster maison" data-breathe>
        <div class="maison__hero">
          <span class="maison__estd">Parfumeur — Paris — fondée <span class="maison__fig">1804</span></span>
          <h3 class="maison__word" data-breathe-word>Bellecour</h3>
          <span class="maison__sub">Eau de parfum &amp; soins rares</span>
        </div>
        <div class="maison__sys" aria-label="identity system">
          <div class="maison__mono">
            <span class="maison__monocap">B</span>
            <span class="maison__monoyear"><span class="maison__fig">18</span>·<span class="maison__fig">04</span></span>
          </div>
          <div class="maison__card">
            <span class="maison__cardname">Crème de Soie</span>
            <span class="maison__cardrule" aria-hidden="true"></span>
            <span class="maison__cardmeta"><i>Nº&nbsp;<span class="maison__fig">7</span></i> &middot; <span class="maison__fig">50</span>&nbsp;ml</span>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">A logotype and its monogram + label lockups — the wordmark breathes the opsz axis, hairlines swelling and vanishing.</p>
  </figure>

  <!-- 03 — perfume bottle, type wrapped via SVG textPath -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Packaging — engraved flacon (SVG textPath)</span></figcaption>
    <div class="iu__scene iu__scene--portrait">
      <div class="iu__poster flacon" data-flacon>
        <svg class="flacon__svg" viewBox="0 0 360 460" role="img" aria-label="Noir Absolu eau de parfum flacon with engraved typography">
          <defs>
            <linearGradient id="bm-glass" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0" stop-color="var(--g-edge)"/>
              <stop offset="0.18" stop-color="var(--g-mid)"/>
              <stop offset="0.5" stop-color="var(--g-face)"/>
              <stop offset="0.82" stop-color="var(--g-mid)"/>
              <stop offset="1" stop-color="var(--g-edge)"/>
            </linearGradient>
            <linearGradient id="bm-cap" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0" stop-color="var(--c-edge)"/>
              <stop offset="0.5" stop-color="var(--c-face)"/>
              <stop offset="1" stop-color="var(--c-edge)"/>
            </linearGradient>
            <linearGradient id="bm-plate" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="var(--p-top)"/>
              <stop offset="1" stop-color="var(--p-bot)"/>
            </linearGradient>
            <!-- arched legend over the plate -->
            <path id="bm-arc" d="M 116 196 C 150 178 210 178 244 196" fill="none" />
            <!-- base curve -->
            <path id="bm-base" d="M 120 300 C 152 312 208 312 240 300" fill="none" />
          </defs>

          <!-- cap / stopper -->
          <g class="flacon__cap">
            <rect x="150" y="20" width="60" height="14" rx="2" fill="url(#bm-cap)"/>
            <rect x="156" y="34" width="48" height="40" rx="2" fill="url(#bm-cap)"/>
            <line class="flacon__caphi" x1="166" y1="38" x2="166" y2="70"/>
          </g>
          <!-- collar -->
          <rect class="flacon__collar" x="146" y="74" width="68" height="10" rx="2"/>

          <!-- glass body: faceted shoulders -->
          <path class="flacon__glass"
            d="M 100 84 L 260 84 C 270 84 278 92 282 104 L 300 168
               C 304 182 306 196 306 212 L 306 400
               C 306 426 286 442 256 442 L 104 442
               C 74 442 54 426 54 400 L 54 212
               C 54 196 56 182 60 168 L 78 104
               C 82 92 90 84 100 84 Z"/>
          <!-- inner refraction highlight -->
          <path class="flacon__refract"
            d="M 96 110 C 86 150 84 220 84 300 C 84 370 88 410 104 426"/>
          <!-- liquid line -->
          <line class="flacon__fill" x1="64" y1="356" x2="296" y2="356"/>

          <!-- engraved label plate -->
          <rect class="flacon__plate" x="92" y="176" width="176" height="156" rx="4" fill="url(#bm-plate)"/>
          <rect class="flacon__plateframe" x="100" y="184" width="160" height="140" rx="2"/>

          <!-- engraved type on the plate -->
          <text class="flacon__arc"><textPath href="#bm-arc" startOffset="50%" text-anchor="middle">LE NOUVEAU PARFUM</textPath></text>
          <text class="flacon__noir"   x="180" y="246" text-anchor="middle">Noir</text>
          <line class="flacon__hair" x1="150" y1="258" x2="210" y2="258" />
          <text class="flacon__absolu" x="180" y="290" text-anchor="middle">Absolu</text>
          <text class="flacon__base"><textPath href="#bm-base" startOffset="50%" text-anchor="middle">EAU DE PARFUM · 100 ML</textPath></text>
        </svg>
        <span class="flacon__house">Bellecour · Paris · <span class="flacon__fig">1804</span></span>
      </div>
    </div>
    <p class="iu__hint label">Live SVG <code>textPath</code> engraves the legend onto the glass plate — it re-draws on hover.</p>
  </figure>

  <!-- 04 — editorial masthead / feature opener -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Editorial — the feature opener</span></figcaption>
    <div class="iu__scene scene43">
      <div class="iu__poster spread" data-bloom>
        <div class="spread__rail">
          <span class="spread__folio">Feature</span>
          <span class="spread__sec">Style · <span class="spread__fig">064</span></span>
        </div>
        <div class="spread__main">
          <span class="spread__kicker">On the vanishing stroke</span>
          <h3 class="spread__head" data-bloom-word>The <em>Hairline</em></h3>
          <p class="spread__deck">Two hundred years it took to make a letter this thin — and a single press season to make it the loudest thing on a page.</p>
          <div class="spread__body">
            <p><span class="spread__drop">B</span>y the 1790s the press had finally caught the eye: paper smoother, ink blacker, steel sharper. Bodoni let the contrast run riot — heavy stems beside hairlines fine enough to cut, finished with flat serifs snapped on at a perfect right angle.</p>
            <p>Two centuries on, the same drama still reads as one thing only: pure luxury, set large on a fashion page. The thinner the stroke, the louder the couture — and the more a face like this one earns its place above the fold.</p>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Hover the headline — opsz drives the hairlines to their finest, over a two-column drop-cap body.</p>
  </figure>

  <!-- 05 — INTERACTIVE: e-commerce lookbook with live optical-size slider -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">05</span><span class="label">Product UI — couture lookbook (real scale, interactive)</span></figcaption>
    <div class="iu__scene">
      <div class="iu__device shop" data-shop>
        <div class="iu__chrome">
          <div class="iu__dots"><i></i><i></i><i></i></div>
          <span class="iu__addr">bellecour.paris/lookbook/automne</span>
        </div>
        <header class="shop__head">
          <span class="shop__logo">Bellecour</span>
          <nav class="shop__filters" aria-label="Filter collection">
            <button class="is-on" data-filter="all">All</button>
            <button data-filter="gowns">Gowns</button>
            <button data-filter="coats">Coats</button>
            <button data-filter="jewels">Jewels</button>
          </nav>
          <span class="shop__bag">Bag · <span class="shop__fig">0</span></span>
        </header>

        <div class="shop__opsz">
          <span class="shop__opsz-lead">Drag to set the optical size of the hero</span>
          <label class="shop__opsz-ctrl" for="opsz-bm">
            <input id="opsz-bm" type="range" min="11" max="96" value="96" step="1" data-opsz />
            <span class="shop__opsz-val"><span data-opsz-val>96</span>&nbsp;pt</span>
          </label>
        </div>

        <div class="shop__grid" data-grid>
          {looks.map((l, i)=>{
            const hero = i === 0;
            return (
            <article class={`card${hero ? ' card--hero' : ''}`} data-cat={l.cat}>
              <div class="card__img" aria-hidden="true">
                <span class="card__ghost">£{l.price}</span>
                {hero
                  ? <span class="card__hero-word" data-opsz-type>{l.name}</span>
                  : <span class="card__big">{l.name}</span>}
                {l.tag && <span class="card__tag">{l.tag}</span>}
              </div>
              <div class="card__meta">
                <h4 class="card__name">{l.name}</h4>
                <span class="card__detail">{l.detail}</span>
                <div class="card__row">
                  <span class="card__price">£{l.price}</span>
                  <span class="card__id">{l.id}</span>
                </div>
              </div>
            </article>
          );})}
        </div>
      </div>
    </div>
    <p class="iu__hint label">Filter the collection, then drag the optical-size axis — the contrast blooms live on the hero gown.</p>
  </figure>
</div>

<script>
  // ---- Scene 05: filter + live optical-size axis on hero word ----
  document.querySelectorAll<HTMLElement>('[data-shop]').forEach((shop) => {
    const grid = shop.querySelector('[data-grid]') as HTMLElement;
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.card'));
    shop.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach((b) =>
      b.addEventListener('click', () => {
        shop.querySelectorAll('[data-filter]').forEach((x) => x.classList.remove('is-on'));
        b.classList.add('is-on');
        const f = b.dataset.filter!;
        cards.forEach((c) => {
          const show = f === 'all' || c.dataset.cat === f;
          c.classList.toggle('is-hidden', !show);
        });
      })
    );

    const slider = shop.querySelector('[data-opsz]') as HTMLInputElement;
    const val = shop.querySelector('[data-opsz-val]') as HTMLElement;
    const heads = shop.querySelectorAll<HTMLElement>('[data-opsz-type]');
    const apply = () => {
      const v = slider.value;
      val.textContent = v;
      heads.forEach((h) => (h.style.fontVariationSettings = `'opsz' ${v}, 'wght' 500`));
    };
    slider.addEventListener('input', apply);
    apply();
  });

  // ---- Scenes 01 + 04: pointer-driven opsz bloom on a masthead/headline ----
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduce) {
    document.querySelectorAll<HTMLElement>('[data-bloom]').forEach((scene) => {
      const word = scene.querySelector<HTMLElement>('[data-bloom-word]');
      if (!word) return;
      const rest = getComputedStyle(word).getPropertyValue('--opsz').trim() || '72';
      scene.addEventListener('pointerenter', () => word.style.setProperty('--opsz', '96'));
      scene.addEventListener('pointerleave', () => word.style.setProperty('--opsz', rest));
    });
  }
</script>

<style>
  .iu__item { margin: 0; }
  .iu__hint { margin-top: var(--sp-2); color: var(--fg-3); }
  .iu__hint code { font-family: var(--font-mono); font-size: 0.85em; color: var(--fg-2); }
  .scene16 { aspect-ratio: 16 / 9; }
  .scene43 { aspect-ratio: 4 / 3; }
  .iu__scene * { font-family: var(--fam); }

  /* oldstyle figures everywhere a number reads as set text, not UI */
  .cover__fig, .maison__fig, .flacon__fig, .spread__fig {
    font-feature-settings: 'onum' 1; font-variation-settings: 'opsz' 14;
  }

  /* ============================================================
     01 — FASHION COVER
     A printed cover with a real paper/photo surface: tonal vignette
     atmosphere behind the type, true editorial hierarchy, folio chrome.
     opsz blooms on hover. RED reserved to a single small mark.
     ============================================================ */
  .cover {
    --card-ar: 3 / 4; background: var(--bg); overflow: hidden;
    display: block; isolation: isolate;
  }
  /* the "photograph": a soft tonal field that gives the cover a surface */
  .cover__paper {
    position: absolute; inset: 0; z-index: 0;
    background:
      radial-gradient(120% 80% at 50% 8%, color-mix(in srgb, var(--fg) 12%, transparent), transparent 60%),
      radial-gradient(90% 70% at 78% 78%, color-mix(in srgb, var(--accent) 14%, transparent), transparent 62%),
      linear-gradient(180deg, color-mix(in srgb, var(--fg) 6%, var(--bg)) 0%, var(--bg) 48%, var(--bg-2) 100%);
  }
  /* faint paper tooth */
  .cover__paper::after {
    content: ''; position: absolute; inset: 0; opacity: 0.5; mix-blend-mode: overlay;
    background-image: repeating-linear-gradient(0deg, transparent 0 3px, color-mix(in srgb, var(--fg) 4%, transparent) 3px 4px);
  }
  .cover__inner {
    position: relative; z-index: 1; height: 100%;
    display: flex; flex-direction: column; padding: 4.4cqi 5cqi 4cqi;
  }
  .cover__top {
    display: flex; justify-content: space-between; align-items: baseline;
    font-size: 2.3cqi; letter-spacing: 0.16em; text-transform: uppercase; color: var(--fg-2);
  }
  .cover__logo { color: var(--fg-2); }
  .cover__price { color: var(--accent); }
  .cover__season { font-style: italic; letter-spacing: 0.02em; text-transform: none; color: var(--fg-3); }
  .cover__masthead {
    --opsz: 78;
    font-size: 33cqi; line-height: 0.78; text-align: center;
    font-weight: 900; letter-spacing: -0.02em; margin: 3.2cqi 0 0; color: var(--fg);
    font-variation-settings: 'opsz' var(--opsz), 'wght' 900;
    transition: font-variation-settings 0.6s var(--ease);
    text-shadow: 0 2cqi 5cqi color-mix(in srgb, var(--bg) 60%, transparent);
  }
  .cover__strap {
    display: block; text-align: center; margin-top: 0.4cqi;
    font-size: 2.2cqi; letter-spacing: 0.42em; text-transform: uppercase; color: var(--fg-3);
    padding-left: 0.42em;
  }
  .cover__lines { margin-top: auto; max-width: 70%; }
  .cover__feat {
    display: block; font-size: 8.4cqi; line-height: 0.96; color: var(--fg);
    font-style: normal; font-weight: 600; letter-spacing: -0.015em;
    font-variation-settings: 'opsz' 60, 'wght' 600;
  }
  .cover__feat em { font-style: italic; font-weight: 400; color: var(--fg); font-variation-settings: 'opsz' 60, 'wght' 400; }
  .cover__sub {
    display: block; margin-top: 2cqi; font-size: 3cqi; line-height: 1.24;
    font-style: italic; color: var(--fg-2); max-width: 34ch;
  }
  .cover__foot {
    display: flex; align-items: flex-end; justify-content: space-between; gap: 3cqi;
    margin-top: 4cqi; padding-top: 2.2cqi; border-top: 1px solid var(--line);
  }
  .cover__barcode { display: flex; align-items: flex-end; gap: 1.5px; height: 6.5cqi; opacity: 0.7; }
  .cover__barcode i { background: var(--fg-2); height: 100%; }
  .cover__plus { font-size: 2.5cqi; letter-spacing: 0.02em; color: var(--fg-2); text-align: right; font-style: italic; }
  .cover__plus em { color: var(--fg); font-weight: 600; font-style: normal; }
  .cover__pg { color: var(--fg-3); }

  /* ============================================================
     02 — MAISON IDENTITY SYSTEM
     A logotype plus a resolved monogram + product-label lockup,
     arranged as an identity sheet (not a single mark in a void).
     No flanking-rule cliché. Wordmark breathes the opsz axis.
     ============================================================ */
  .maison {
    background: var(--bg);
    display: grid; grid-template-columns: 1.55fr 1fr; align-items: stretch;
    padding: 5.5cqi 6cqi;
  }
  .maison__hero {
    display: flex; flex-direction: column; justify-content: center;
    border-right: 1px solid var(--line); padding-right: 5cqi;
  }
  .maison__estd {
    font-size: 2cqi; letter-spacing: 0.34em; text-transform: uppercase; color: var(--fg-3);
    padding-left: 0.34em;
  }
  .maison__word {
    --opsz: 78;
    font-size: 14.5cqi; line-height: 0.9; font-weight: 500; letter-spacing: 0.005em; color: var(--fg);
    font-variation-settings: 'opsz' var(--opsz), 'wght' 500; margin: 2.2cqi 0 1.6cqi;
  }
  .maison__sub {
    font-size: 2.6cqi; letter-spacing: 0.06em; font-style: italic; color: var(--fg-2);
  }
  .maison__sys {
    display: flex; flex-direction: column; justify-content: center; gap: 4cqi;
    padding-left: 5cqi;
  }
  .maison__mono {
    display: flex; flex-direction: column; align-items: center; gap: 0.6cqi;
    border: 1px solid var(--line); padding: 3cqi 3cqi 2.4cqi;
  }
  .maison__monocap {
    font-size: 12cqi; line-height: 0.85; font-weight: 700; color: var(--fg);
    font-variation-settings: 'opsz' 80, 'wght' 700;
  }
  .maison__monoyear {
    font-size: 1.8cqi; letter-spacing: 0.3em; text-transform: uppercase; color: var(--fg-3); padding-left: 0.3em;
  }
  .maison__card {
    display: flex; flex-direction: column; align-items: center; gap: 1.4cqi; text-align: center;
  }
  .maison__cardname { font-size: 4.4cqi; line-height: 1; color: var(--fg); font-style: italic; font-variation-settings: 'opsz' 40, 'wght' 500; }
  .maison__cardrule { width: 60%; height: 1px; background: var(--line); }
  .maison__cardmeta { font-size: 2cqi; letter-spacing: 0.16em; text-transform: uppercase; color: var(--fg-3); }
  .maison__cardmeta i { font-style: italic; text-transform: none; letter-spacing: 0.04em; color: var(--accent); }

  @media (prefers-reduced-motion: no-preference) {
    .maison__word { animation: bm-breathe 5s var(--ease) infinite; }
    @keyframes bm-breathe {
      0%, 100% { font-variation-settings: 'opsz' 30, 'wght' 500; }
      50%      { font-variation-settings: 'opsz' 96, 'wght' 500; }
    }
  }

  /* ============================================================
     03 — FLACON: type engraved onto a recognizable luxury flacon
     Faceted glass body w/ refraction + liquid line, real cap + collar,
     an engraved label plate carrying the lockup. Legible engrave type.
     ============================================================ */
  .flacon {
    --card-ar: 3 / 4; background: var(--bg);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 4cqi 4cqi 3cqi; position: relative;
    /* glass + cap + plate tones (theme-derived) */
    --g-edge: color-mix(in srgb, var(--fg) 4%, var(--bg-2));
    --g-mid:  color-mix(in srgb, var(--fg) 9%, var(--bg-2));
    --g-face: color-mix(in srgb, var(--fg) 16%, var(--bg-2));
    --c-edge: color-mix(in srgb, var(--fg) 8%, var(--bg));
    --c-face: color-mix(in srgb, var(--fg) 22%, var(--bg-2));
    --p-top:  color-mix(in srgb, var(--fg) 90%, var(--bg));
    --p-bot:  color-mix(in srgb, var(--fg) 78%, var(--bg));
  }
  .flacon__svg { width: 92%; height: auto; display: block; }

  .flacon__glass { fill: url(#bm-glass); stroke: color-mix(in srgb, var(--fg) 22%, transparent); stroke-width: 1; }
  .flacon__refract { fill: none; stroke: color-mix(in srgb, var(--fg) 28%, transparent); stroke-width: 3; stroke-linecap: round; opacity: 0.5; }
  .flacon__fill { stroke: color-mix(in srgb, var(--fg) 14%, transparent); stroke-width: 1; }
  .flacon__cap rect { stroke: color-mix(in srgb, var(--fg) 18%, transparent); stroke-width: 0.75; }
  .flacon__caphi { stroke: color-mix(in srgb, var(--bg) 70%, var(--fg)); stroke-width: 1.5; opacity: 0.4; }
  .flacon__collar { fill: url(#bm-cap); stroke: color-mix(in srgb, var(--fg) 18%, transparent); stroke-width: 0.75; }

  /* engraved label plate: light plate, dark engraved type (looks pressed) */
  .flacon__plate { stroke: color-mix(in srgb, var(--fg) 30%, transparent); stroke-width: 0.5; }
  .flacon__plateframe { fill: none; stroke: color-mix(in srgb, var(--bg) 55%, transparent); stroke-width: 1; }

  .flacon__svg text { fill: var(--bg); }
  .flacon__arc  { font-size: 9px; letter-spacing: 3.5px; fill: color-mix(in srgb, var(--bg) 70%, var(--fg)); }
  .flacon__base { font-size: 8.5px; letter-spacing: 3px; fill: color-mix(in srgb, var(--bg) 70%, var(--fg)); }
  .flacon__hair { stroke: color-mix(in srgb, var(--bg) 60%, var(--fg)); stroke-width: 0.75; }
  .flacon__noir {
    font-size: 44px; font-weight: 900; fill: var(--bg);
