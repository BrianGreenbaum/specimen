---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// Act 01 — graded showings, after the Manuale Tipografico (Parma, 1818).
// Each body restarts the Catilinarian text, as specimen plates always have.
// Sizes are cqi with px floors; optical sizing is automatic, so each rung
// genuinely carries the opsz the punchcutter would have cut for that body.
const showings = [
  { corpo: 'Canone',    size: 'max(8.6cqi, 27px)',  text: 'Quousque tandem' },
  { corpo: 'Palestina', size: 'max(6.2cqi, 21px)',  text: 'Quousque tandem abutere,' },
  { corpo: 'Parangone', size: 'max(4.5cqi, 16px)',  text: 'Quousque tandem abutere, Catilina,' },
  { corpo: 'Testo',     size: 'max(3.3cqi, 13px)',  text: 'Quousque tandem abutere, Catilina, patientia' },
  { corpo: 'Lettura',   size: 'max(2.5cqi, 11px)',  text: 'Quousque tandem abutere, Catilina, patientia nostra? quamdiu nos' },
  { corpo: 'Filosofia', size: 'max(1.95cqi, 10px)', text: 'Quousque tandem abutere, Catilina, patientia nostra? quamdiu nos etiam furor iste tuus eludet?' },
  { corpo: 'Testino',   size: 'max(1.55cqi, 9px)',  text: 'Quousque tandem abutere, Catilina, patientia nostra? quamdiu nos etiam furor iste tuus eludet? quem ad finem sese effrenata iactabit audacia? nihilne te nocturnum praesidium Palati, nihil urbis vigiliae, nihil timor populi commovent?' },
];

// Act 04 — product data for the maison's shop.
const fabrics = [
  { id: 'lana',     name: 'Lana doppiata',  price: '2.450' },
  { id: 'cammello', name: 'Cammello',       price: '2.890' },
  { id: 'cashmere', name: 'Cashmere nero',  price: '3.400' },
];
const sizes = [38, 40, 42, 44, 46, 48];

// Act 05 — the weight instrument. Server-rendered at the reduced-motion
// resting state: an ascending scale 400→900 across the six capitals.
const lensWord = 'MILANO'.split('').map((ch, i) => ({ ch, w: 400 + i * 100 }));
---
<div class="iu" style={`--fam:${fam}`}>

  <!-- ============================================================
       01 — ILLUSTRATION & COMMERCIAL
       A specimen plate after Bodoni's own Manuale Tipografico
       (Parma, "Presso la Vedova", 1818): the same text re-set at
       every body, each size a different cut. The variable opsz axis
       performs exactly that, automatically, as the plate scales.
       ============================================================ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Illustration &amp; commercial — a plate after the <em>Manuale Tipografico</em>, Parma 1818</span></figcaption>
    <div class="iu__scene mp" data-plate>
      <div class="mp__sheet">
        <p class="mp__series" data-reveal>Manuale Tipografico</p>
        <p class="mp__author" data-reveal style="--reveal-delay:80ms">del cavaliere Giambattista Bodoni · volume primo</p>
        <span class="mp__rule mp__rule--dbl" aria-hidden="true"></span>
        <div class="mp__ladder">
          {showings.map((s, i) => (
            <div class="mp__row" data-reveal style={`--reveal-delay:${140 + i * 70}ms`}>
              <span class="mp__corpo">{s.corpo}</span>
              <p class="mp__line" style={`font-size:${s.size}`}>{s.text}</p>
              <span class="mp__measure" data-measure aria-hidden="true"></span>
            </div>
          ))}
        </div>
        <span class="mp__rule" aria-hidden="true"></span>
        <p class="mp__place" data-reveal style="--reveal-delay:680ms">Parma</p>
        <p class="mp__imprint" data-reveal style="--reveal-delay:740ms">presso la vedova · <span class="mp__yr">MDCCCXVIII</span></p>
      </div>
    </div>
    <p class="iu__hint label">Bodoni cut every body as a different design — sturdier hairlines small, razor ones large. Optical sizing is automatic here, so each rung truly changes cut; hover a showing and the margin gives its modern measure, <code>px · opsz</code>. Shrink the page and watch the whole plate re-cut itself.</p>
  </figure>

  <!-- ============================================================
       02 — EDITORIAL
       The type-only fashion cover: Alexander Liberman's postwar
       Vogue masthead logic, and Vogue Italia's April 2020 cover —
       the issue that ran with no photograph at all.
       ============================================================ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Editorial — the type-only cover, after Liberman&rsquo;s <em>Vogue</em> and <em>Vogue Italia</em>, April 2020</span></figcaption>
    <div class="iu__scene cv">
      <div class="cv__in">
        <div class="cv__top">
          <span class="cv__ed">Milano · le collezioni</span>
          <span class="cv__date">gennaio 2026 · n. 481</span>
          <span class="cv__price">€ 15</span>
        </div>
        <h3 class="cv__mast" data-mast>MODA</h3>
        <p class="cv__strap">il numero senza fotografie</p>
        <div class="cv__low">
          <div class="cv__feat-w">
            <p class="cv__feat">Il nero<br/><em>assoluto</em></p>
            <p class="cv__deck">Quaranta pagine di couture raccontate soltanto in lettere — perché quest&rsquo;anno l&rsquo;immagine più forte è una parola.</p>
          </div>
          <ul class="cv__more">
            <li><em>Sull&rsquo;orlo</em> — la gonna a matita torna al ginocchio</li>
            <li><em>L&rsquo;intervista</em> — l&rsquo;ultima sarta di via Monte Napoleone</li>
            <li><em>Il guardaroba</em> — dodici capi, bianco e nero</li>
            <li><em>Parma, 1818</em> — il punzone che inventò il lusso</li>
          </ul>
        </div>
        <div class="cv__foot">
          <span class="cv__barcode" aria-hidden="true">
            {Array.from({ length: 32 }).map((_, i) => (<i style={`width:${(i % 5) + 1}px`}></i>))}
          </span>
          <span class="cv__issn">ISSN 2531-419X · Poste Italiane S.p.A. — sped. abb. post.</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">The masthead is wght 900 at opsz 96 — the hairlines at their thinnest. Hover it and the optical axis falls to 56: the same letters, re-cut for a smaller body. Select the cover lines; even the selection runs house red.</p>
  </figure>

  <!-- ============================================================
       03 — BRANDING & IDENTITY
       A Milanese maison in the line of Valentino's Bodoni wordmark
       (spaced Didone capitals, since 1968): mark, monogram, woven
       label, hangtag — one family from corpo 96 down to the size tag.
       ============================================================ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Branding &amp; identity — a Milanese maison, in the line of Valentino&rsquo;s Bodoni wordmark</span></figcaption>
    <div class="iu__scene id">
      <div class="id__in">
        <header class="id__head">
          <span>Lamberti · identità di marca</span>
          <span>maison fondata a Milano, 1953</span>
        </header>
        <div class="id__sheet">
          <div class="id__wm-row">
            <div class="id__wm" tabindex="0">
              <span class="id__g id__g--cap" aria-hidden="true"><i>maiuscole · opsz 96</i></span>
              <p class="id__word">LAMBERTI</p>
              <span class="id__g id__g--base" aria-hidden="true"><i>linea di base · wght 500</i></span>
              <p class="id__city">MILANO</p>
              <p class="id__ann">spazieggiatura +0.32em — la ricetta di via Condotti, 1968</p>
            </div>
          </div>
          <div class="id__apps">
            <div class="id__app id__app--mono">
              <span class="id__oval"><b>L</b></span>
              <p class="id__ann">monogramma · wght 600</p>
            </div>
            <div class="id__app id__app--label">
              <div class="id__woven">
                <span class="id__woven-mark">LAMBERTI</span>
                <span class="id__woven-city">milano</span>
                <span class="id__woven-rule" aria-hidden="true"></span>
                <span class="id__woven-meta">lana vergine 100% · made in Italy</span>
                <span class="id__woven-size">taglia 42</span>
              </div>
              <p class="id__ann">etichetta tessuta · corpo 8</p>
            </div>
            <div class="id__app id__app--tag">
              <div class="id__tag">
                <span class="id__tag-hole" aria-hidden="true"></span>
                <span class="id__tag-name">Cappotto <em>Aurelia</em></span>
                <span class="id__tag-meta">disegno n. 7 · autunno inverno</span>
                <span class="id__tag-price">€ 2.450</span>
              </div>
              <p class="id__ann">cartellino · cifre allineate</p>
            </div>
          </div>
        </div>
        <p class="id__foot">Fig. 2 — Marchio, monogramma, etichetta e cartellino: una sola famiglia, dal corpo 96 al corpo 8.</p>
      </div>
    </div>
    <p class="iu__hint label">Spaced Didone capitals have signed Italian fashion since Valentino reset its mark in Bodoni. Hover or focus the wordmark and the spec drawing surfaces — cap line, baseline, tracking. The woven label runs the same family at an 8&nbsp;px-equivalent body, on the low end of the optical axis.</p>
  </figure>

  <!-- ============================================================
       04 — WEB & APP UI
       The maison online, in the contemporary current of typographic
       luxury commerce (The Row, Khaite): a product page at real px,
       fully user-driven, the whole interface set in the Didone —
       which the opsz axis makes honestly possible at 13 px.
       ============================================================ -->
  <figure class="iu__item" data-shoot-click='[data-size="42"]'>
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Web &amp; app UI — the maison online, after The Row&rsquo;s typographic commerce (real px, interactive)</span></figcaption>
    <div class="iu__scene">
      <div class="iu__device pd" data-pd>
        <div class="iu__chrome">
          <div class="iu__dots"><i></i><i></i><i></i></div>
          <span class="iu__addr">lamberti-milano.com/donna/capospalla/cappotto-aurelia</span>
        </div>
        <header class="pd__head">
          <span class="pd__brand">L A M B E R T I</span>
          <nav class="pd__nav" aria-label="Sezioni">
            <a href="#in-use" class="is-on" aria-current="page">Donna</a><a href="#in-use">Uomo</a><a href="#in-use">Sfilate</a><a href="#in-use">Atelier</a>
          </nav>
          <span class="pd__bag">Borsa (<b class="pd__num" data-bag>0</b>)</span>
        </header>
        <div class="pd__main">
          <div class="pd__visual">
            <span class="pd__season">autunno · inverno 2026</span>
            <span class="pd__ghost" aria-hidden="true">L</span>
            <p class="pd__vname"><em>Aurelia</em></p>
            <p class="pd__vsub" data-vsub>cappotto in lana doppiata — disegno n. 7</p>
          </div>
          <div class="pd__info">
            <p class="pd__crumb">Donna / Capospalla</p>
            <h4 class="pd__name">Cappotto Aurelia</h4>
            <p class="pd__price"><span class="pd__num" data-price>2.450</span> €</p>
            <div class="pd__group" role="group" aria-label="Tessuto">
              <p class="pd__k">Tessuto</p>
              <div class="pd__fabs">
                {fabrics.map((f, i) => (
                  <button class={i === 0 ? 'is-on' : ''} data-fab={f.id} data-fprice={f.price} data-fname={f.name} aria-pressed={i === 0 ? 'true' : 'false'}>{f.name}</button>
                ))}
              </div>
            </div>
            <div class="pd__group" role="group" aria-label="Taglia italiana">
              <p class="pd__k">Taglia <span class="pd__kk">(IT)</span></p>
              <div class="pd__sizes">
                {sizes.map((s) => (
                  <button class="pd__size" data-size={s} aria-pressed="false"><span class="pd__num">{s}</span></button>
                ))}
              </div>
              <p class="pd__note" data-note>Seleziona una taglia — vestibilità regolare, consigliamo la taglia abituale.</p>
            </div>
            <button class="pd__add" data-add disabled>Seleziona una taglia</button>
            <p class="pd__ok" data-ok hidden>Aggiunto alla borsa — spedito dall&rsquo;atelier di Milano in 2–4 giorni.</p>
            <div class="pd__accs">
              <details class="pd__acc">
                <summary>Dettagli e composizione</summary>
                <p>Lana doppiata italiana, fodera in cupro. Doppiopetto, manica a <span class="pd__frac">3/4</span>, martingala. Disegno n. 7 dell&rsquo;archivio, ridisegnato per questa stagione.</p>
              </details>
              <details class="pd__acc">
                <summary>Spedizione e resi</summary>
                <p>Spedizione da Milano in 2–4 giorni lavorativi. Reso gratuito entro 30 giorni; confezione al tessuto inclusa.</p>
              </details>
            </div>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Every word of the interface is Bodoni Moda, down to the 13&nbsp;px fine print — <code>font-optical-sizing:&nbsp;auto</code> drops the axis toward opsz&nbsp;13 and thickens the hairlines, so a Didone can genuinely run a store. Choose a cloth and a size; the bag keeps count in tabular figures, and the ¾ in the details is a live <code>frac</code>.</p>
  </figure>

  <!-- ============================================================
       05 — INTERACTIVE & EXPERIMENTAL
       MILANO as an instrument: pointer-reactive weight, in the
       current of DIA Studio's kinetic identities. Each capital is
       re-weighed live on the real 400–900 axis, with its value read
       out beneath — and the true italic is drawn at every weight.
       ============================================================ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click='[data-cut="corsivo"]'>
    <figcaption class="iu__cap"><span class="index-num">05</span><span class="label">Interactive &amp; experimental — <em>MILANO</em>, a weight-axis instrument after DIA&rsquo;s kinetic type</span></figcaption>
    <div class="iu__scene kn" data-kn>
      <div class="kn__bar">
        <span class="kn__k">strumento · asse wght 400–900</span>
        <div class="kn__cuts" role="group" aria-label="Tondo o corsivo">
          <button class="is-on" data-cut="tondo" aria-pressed="true">Tondo</button>
          <button data-cut="corsivo" aria-pressed="false">Corsivo</button>
        </div>
      </div>
      <div class="kn__stage" data-stage>
        {lensWord.map((l) => (
          <span class="kn__l">
            <b style={`font-variation-settings:'opsz' 96, 'wght' ${l.w}`}>{l.ch}</b>
            <i class="kn__w" data-w>{l.w}</i>
          </span>
        ))}
      </div>
      <p class="kn__foot">sei capitali, un solo file — il peso segue il puntatore</p>
    </div>
    <p class="iu__hint label">Move the pointer across the word — each capital is re-weighed live on the real variable axis, its value read out beneath, hairlines holding steady while the stems thunder to 900. Switch to the <em>corsivo</em>: a true italic, drawn at every weight. With motion off, the word rests as a 400→900 scale.</p>
  </figure>

</div>

<script>
  // ---- 01: live measures in the plate margin (px + the opsz auto applies) ----
  document.querySelectorAll<HTMLElement>('[data-plate]').forEach((plate) => {
    const rows = Array.from(plate.querySelectorAll<HTMLElement>('.mp__row'));
    const measure = () => rows.forEach((row) => {
      const line = row.querySelector('.mp__line') as HTMLElement;
      const note = row.querySelector('[data-measure]') as HTMLElement;
      const px = parseFloat(getComputedStyle(line).fontSize);
      const opsz = Math.round(Math.min(96, Math.max(6, px)));
      note.textContent = `${Math.round(px)} px · opsz ${opsz}`;
    });
    measure();
    window.addEventListener('resize', measure);
  });

  // ---- 02: hover re-cuts the masthead to a smaller optical body ----
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll<HTMLElement>('[data-mast]').forEach((m) => {
      m.addEventListener('pointerenter', () => m.style.setProperty('--opsz', '56'));
      m.addEventListener('pointerleave', () => m.style.setProperty('--opsz', '96'));
    });
  }

  // ---- 04: fabric, size, bag ----
  document.querySelectorAll<HTMLElement>('[data-pd]').forEach((pd) => {
    const price = pd.querySelector('[data-price]') as HTMLElement;
    const vsub = pd.querySelector('[data-vsub]') as HTMLElement;
    const note = pd.querySelector('[data-note]') as HTMLElement;
    const add = pd.querySelector('[data-add]') as HTMLButtonElement;
    const ok = pd.querySelector('[data-ok]') as HTMLElement;
    const bag = pd.querySelector('[data-bag]') as HTMLElement;
    let size: string | null = null;
    let count = 0;

    pd.querySelectorAll<HTMLButtonElement>('[data-fab]').forEach((b) =>
      b.addEventListener('click', () => {
        pd.querySelectorAll('[data-fab]').forEach((x) => { x.classList.remove('is-on'); x.setAttribute('aria-pressed', 'false'); });
        b.classList.add('is-on'); b.setAttribute('aria-pressed', 'true');
        price.textContent = b.dataset.fprice!;
        vsub.textContent = `cappotto in ${b.dataset.fname!.toLowerCase()} — disegno n. 7`;
        ok.hidden = true;
      })
    );

    pd.querySelectorAll<HTMLButtonElement>('[data-size]').forEach((b) =>
      b.addEventListener('click', () => {
        pd.querySelectorAll('[data-size]').forEach((x) => { x.classList.remove('is-on'); x.setAttribute('aria-pressed', 'false'); });
        b.classList.add('is-on'); b.setAttribute('aria-pressed', 'true');
        size = b.dataset.size!;
        note.textContent = `Taglia ${size} — disponibile, spedita dall’atelier di Milano.`;
        add.disabled = false;
        add.textContent = 'Aggiungi alla borsa';
        ok.hidden = true;
      })
    );

    add.addEventListener('click', () => {
      if (!size) return;
      count += 1;
      bag.textContent = String(count);
      ok.hidden = false;
      add.textContent = 'Aggiungine un’altra';
    });
  });

  // ---- 05: the weight instrument ----
  document.querySelectorAll<HTMLElement>('[data-kn]').forEach((kn) => {
    const stage = kn.querySelector('[data-stage]') as HTMLElement;
    const letters = Array.from(stage.querySelectorAll<HTMLElement>('.kn__l'));
    let italic = false;

    const setW = (el: HTMLElement, w: number) => {
      const b = el.querySelector('b') as HTMLElement;
      const out = el.querySelector('[data-w]') as HTMLElement;
      const v = Math.round(w);
      // the italic file carries wght only — never claim opsz on it
      b.style.fontVariationSettings = italic ? `'wght' ${v}` : `'opsz' 96, 'wght' ${v}`;
      out.textContent = String(v);
    };
    const baseline = () => letters.forEach((el, i) => setW(el, 400 + i * 100));

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    kn.querySelectorAll<HTMLButtonElement>('[data-cut]').forEach((btn) =>
      btn.addEventListener('click', () => {
        italic = btn.dataset.cut === 'corsivo';
        stage.classList.toggle('is-italic', italic);
        kn.querySelectorAll('[data-cut]').forEach((x) => {
          x.classList.toggle('is-on', x === btn);
          x.setAttribute('aria-pressed', x === btn ? 'true' : 'false');
        });
        if (reduce) baseline();
      })
    );

    if (reduce) return; // the word rests as the 400→900 scale

    let mx: number | null = null;
    let t = Math.PI / 2;
    stage.addEventListener('pointermove', (e) => {
      const r = stage.getBoundingClientRect();
      mx = (e.clientX - r.left) / r.width;
    });
    stage.addEventListener('pointerleave', () => { mx = null; });

    const tick = () => {
      t += 0.014;
      letters.forEach((el, i) => {
        let w: number;
        if (mx === null) {
          w = 650 + 250 * Math.sin(t + i * 0.85); // slow autonomous swell
        } else {
          const c = (i + 0.5) / letters.length;
          const d = Math.abs(c - mx);
          w = 400 + 500 * Math.max(0, 1 - d * 3.1);
        }
        setW(el, w);
      });
      requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  });
</script>

<style>
  /* The sequence: paper / ink / paper / interface / ink. One red thread runs
     through all five surfaces; the gap is tightened so the cuts read as beats. */
  .iu { gap: clamp(3rem, 8vh, 6rem); }
  .iu__item { margin: 0; }
  .iu__hint { margin-top: var(--sp-2); color: var(--fg-3); }
  .iu__hint code { font-family: var(--font-mono); font-size: 0.85em; color: var(--fg-2); }
  .iu__scene * { font-family: var(--fam); }

  /* print surfaces (intentional, self-declared) */
  .mp, .id { --pp: #f2ebdc; --pp-2: #eee5d2; --ink: #1c1611; --ink-2: #5d5240; --red: #ae2336; }
  .cv, .kn { --blk: #0b0a09; --cream: #f2ece1; --cream-2: #b6ad9c; --cream-3: #837a6b; --red: #e8384f; }

  /* ============================================================
     01 — THE MANUALE PLATE (cream, bleed)
     ============================================================ */
  .mp { background: linear-gradient(180deg, var(--pp) 0%, var(--pp-2) 100%); color: var(--ink); }
  .mp::after { /* paper tooth */
    content: ''; position: absolute; inset: 0; pointer-events: none; opacity: 0.35; mix-blend-mode: multiply;
    background-image: repeating-linear-gradient(0deg, transparent 0 3px, rgba(92, 74, 50, 0.05) 3px 4px);
  }
  .mp__sheet {
    width: min(72cqi, 920px); margin-inline: auto; text-align: center;
    padding: clamp(2.6rem, 6cqi, 5rem) 0 clamp(2.2rem, 5cqi, 4rem);
  }
  .mp__series {
    font-size: max(3.4cqi, 21px); letter-spacing: 0.3em; text-transform: uppercase;
    font-weight: 500; margin: 0 0 0 0.3em; font-variation-settings: 'wght' 500;
  }
  .mp__author {
    margin: 0.9em 0 0 0.26em; font-size: max(1.5cqi, 11px); letter-spacing: 0.26em; text-transform: uppercase; color: var(--ink-2);
  }
  .mp__rule { display: block; width: 38%; height: 1px; background: var(--ink); opacity: 0.55; margin: 2.2em auto; }
  .mp__rule--dbl { box-shadow: 0 3px 0 -2px var(--ink); margin-bottom: 2.6em; }
  .mp__ladder { display: flex; flex-direction: column; gap: 1.6em; }
  .mp__row { position: relative; }
  .mp__corpo {
    display: block; font-size: max(1.05cqi, 9px); letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--red); margin: 0 0 0.65em 0.3em;
  }
  .mp__line { margin: 0; line-height: 1.16; text-wrap: balance; }
  .mp__measure {
    position: absolute; left: 100%; top: 0.2em; margin-left: 2.4cqi; white-space: nowrap;
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.06em; color: var(--red);
    opacity: 0; transition: opacity 0.25s var(--ease);
  }
  @media (hover: hover) { .mp__row:hover .mp__measure { opacity: 1; } }
  .mp__place { margin: 0; font-size: max(2.6cqi, 17px); letter-spacing: 0.5em; text-transform: uppercase; padding-left: 0.5em; }
  .mp__imprint { margin: 0.8em 0 0 0.3em; font-size: max(1.3cqi, 10px); letter-spacing: 0.3em; text-transform: uppercase; color: var(--ink-2); }
