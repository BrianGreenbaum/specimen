---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// --- 01 · Mission-control telemetry console (interactive, real device scale) --
// Three flight phases the operator can switch; tabular telemetry re-streams,
// subsystem toggles flip state, gauges re-arm. The canonical Space Grotesk use.
const phases = [
  {
    id: 'ascent', name: 'ASCENT', met: '+00:02:41', live: true,
    vehicle: 'ARTEMIS-VII', stage: 'STAGE I BURN',
    telem: [
      ['ALT', '38.42', 'km'],
      ['VEL', '1.94', 'km/s'],
      ['DYN.Q', '34.1', 'kPa'],
      ['THR', '98.6', '%'],
      ['PITCH', '74.2', '°'],
      ['LOX', '71.3', '%'],
    ] as [string, string, string][],
    subs: [
      ['GUIDANCE', 'NOMINAL', 'ok'],
      ['PROPULSION', 'NOMINAL', 'ok'],
      ['TELEMETRY', 'LOCKED', 'ok'],
      ['RANGE SAFE', 'ARMED', 'warn'],
    ] as [string, string, string][],
    gauges: [['CHAMBER', 78], ['TURBO', 64], ['HYDRAULIC', 91]] as [string, number][],
  },
  {
    id: 'meco', name: 'MECO', met: '+00:08:52', live: true,
    vehicle: 'ARTEMIS-VII', stage: 'STAGE SEP',
    telem: [
      ['ALT', '188.07', 'km'],
      ['VEL', '7.61', 'km/s'],
      ['DYN.Q', '00.0', 'kPa'],
      ['THR', '00.0', '%'],
      ['PITCH', '02.8', '°'],
      ['LOX', '04.2', '%'],
    ] as [string, string, string][],
    subs: [
      ['GUIDANCE', 'NOMINAL', 'ok'],
      ['PROPULSION', 'CUTOFF', 'warn'],
      ['TELEMETRY', 'LOCKED', 'ok'],
      ['RANGE SAFE', 'SAFED', 'ok'],
    ] as [string, string, string][],
    gauges: [['CHAMBER', 4], ['TURBO', 0], ['HYDRAULIC', 88]] as [string, number][],
  },
  {
    id: 'orbit', name: 'ORBIT', met: '+01:24:17', live: true,
    vehicle: 'ARTEMIS-VII', stage: 'LEO INSERTION',
    telem: [
      ['ALT', '412.80', 'km'],
      ['VEL', '7.66', 'km/s'],
      ['DYN.Q', '00.0', 'kPa'],
      ['THR', '00.0', '%'],
      ['INC', '51.64', '°'],
      ['PWR', '99.1', '%'],
    ] as [string, string, string][],
    subs: [
      ['GUIDANCE', 'NOMINAL', 'ok'],
      ['SOLAR ARRAY', 'DEPLOYED', 'ok'],
      ['TELEMETRY', 'LOCKED', 'ok'],
      ['THERMAL', 'NOMINAL', 'ok'],
    ] as [string, string, string][],
    gauges: [['BATTERY', 99], ['COMMS', 96], ['ATTITUDE', 100]] as [string, number][],
  },
];
const p0 = phases[0];

// --- 03 · Crypto / on-chain trading terminal (interactive, real px) ----------
const markets = [
  ['SOL', 'Solana', '148.92', '+6.41', 1],
  ['ETH', 'Ethereum', '3,412.08', '+2.18', 1],
  ['BTC', 'Bitcoin', '67,940.50', '+0.94', 1],
  ['AVAX', 'Avalanche', '38.17', '-1.62', -1],
  ['LINK', 'Chainlink', '18.44', '+3.07', 1],
  ['ARB', 'Arbitrum', '1.082', '-2.94', -1],
] as [string, string, string, string, number][];

// order book: [price, size] for asks (desc) and bids (desc)
const asks = [
  ['149.12', '184.2'], ['149.08', '402.6'], ['149.03', '96.1'],
  ['148.99', '658.0'], ['148.95', '221.7'],
] as [string, string][];
const bids = [
  ['148.90', '512.4'], ['148.86', '143.9'], ['148.81', '870.3'],
  ['148.77', '305.5'], ['148.72', '64.8'],
] as [string, string][];

// --- 04 · Deep-space science data-viz editorial -----------------------------
const exoplanets = [
  ['KEPLER-442 b', '1,206', '2.34', '112.3', 0.84],
  ['TRAPPIST-1 e', '40.7', '0.92', '6.10', 0.71],
  ['PROXIMA b', '4.24', '1.27', '11.19', 0.62],
  ['TOI-700 d', '101.4', '1.19', '37.42', 0.69],
  ['LHS 1140 b', '48.9', '1.73', '24.74', 0.58],
] as [string, string, string, string, number][];
---
<div class="iu" style={`--fam:${fam}`}>

  <!-- 01 — INTERACTIVE mission-control telemetry console (real device scale) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Product UI — flight-control telemetry, real device scale</span></figcaption>
    <div class="iu__scene iu__scene--console">
      <div class="mc" data-mc>
        <div class="mc__bar">
          <span class="mc__logo"><i class="mc__diamond"></i>RANGE&nbsp;CONTROL</span>
          <span class="mc__vehicle" data-vehicle>{p0.vehicle}</span>
          <span class="mc__met"><span class="mc__met-k">MET</span><span data-met>{p0.met}</span></span>
        </div>

        <div class="mc__phases" role="tablist">
          {phases.map((ph, i) => (
            <button class={`mc__phase ${i === 0 ? 'is-on' : ''}`} data-phase={ph.id} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>
              <span class="mc__phase-i">T{i + 1}</span>
              <span class="mc__phase-n">{ph.name}</span>
            </button>
          ))}
        </div>

        <div class="mc__body">
          <div class="mc__telem" data-telem>
            <div class="mc__telem-h"><span data-stage>{p0.stage}</span><span class="mc__strip" data-strip>● STREAMING</span></div>
            <div class="mc__readout">
              {p0.telem.map((t) => (
                <div class="mc__cell" data-cell>
                  <span class="mc__cell-k" data-ck>{t[0]}</span>
                  <span class="mc__cell-v"><b data-cv>{t[1]}</b><i data-cu>{t[2]}</i></span>
                </div>
              ))}
            </div>
            <div class="mc__gauges" data-gauges>
              {p0.gauges.map((g) => (
                <div class="mc__gauge" data-gauge>
                  <span class="mc__gauge-top"><span data-gk>{g[0]}</span><b data-gv>{g[1]}%</b></span>
                  <span class="mc__gauge-track"><i data-gfill style={`width:${g[1]}%`}></i></span>
                </div>
              ))}
            </div>
          </div>

          <div class="mc__side">
            <span class="mc__side-h">SUBSYSTEMS</span>
            <div class="mc__subs" data-subs>
              {p0.subs.map((s) => (
                <button class={`mc__sub mc__sub--${s[2]}`} data-sub data-state={s[2]}>
                  <span class="mc__sub-led"></span>
                  <span class="mc__sub-n" data-sn>{s[0]}</span>
                  <span class="mc__sub-s" data-ss>{s[1]}</span>
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Switch flight phase (T1–T3) — the tabular telemetry re-streams and gauges re-arm. Tap a subsystem to acknowledge it. Tall, narrow figures hold their columns like a countdown clock.</p>
  </figure>

  <!-- 02 — techy product / brand poster, kinetic variable weight + stylistic-set reveal -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Brand — product launch wall, kinetic wght axis + ss01/02/03</span></figcaption>
    <div class="iu__scene scene16">
      <div class="halt" data-halt>
        <div class="halt__grid" aria-hidden="true"></div>
        <div class="halt__top">
          <span class="halt__mark"><i class="halt__diamond"></i>HALT&nbsp;LABS</span>
          <span class="halt__ver">REV&nbsp;0.9 · 2026</span>
        </div>
        <span class="halt__kicker">EDGE COMPUTE FOR THE ORBITAL AGE</span>
        <h3 class="halt__head">
          <span class="halt__word" data-flux style="--d:0s">gravity</span>
          <span class="halt__word halt__word--accent" data-flux style="--d:-2.6s">signal</span>
        </h3>
        <p class="halt__sub">An edge runtime that streams telemetry from anywhere with a horizon — set in Space&nbsp;Grotesk&rsquo;s alternate <b class="halt__alt">a g t</b>.</p>
        <div class="halt__foot">
          <button class="halt__chip" data-ss-toggle type="button" aria-pressed="true">
            <span class="halt__chip-dot" aria-hidden="true"></span>STYLISTIC&nbsp;SETS&nbsp;<b data-ss-state>ON</b>
          </button>
          <span class="halt__meta">SS01·alt&nbsp;a&nbsp; SS02·single-storey&nbsp;g&nbsp; SS03·alt&nbsp;t</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">The two display words breathe across the full 300–700 weight axis, phase-offset. Toggle the stylistic sets to swap in Space Grotesk&rsquo;s signature alternate a, single-storey g and cut t &mdash; the detail that makes the poster unmistakably this face.</p>
  </figure>

  <!-- 03 — INTERACTIVE crypto / on-chain trading terminal (own dark surface, real px) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Product UI — on-chain trading terminal, live tape</span></figcaption>
    <div class="iu__scene iu__scene--console">
      <div class="trade" data-trade>
        <div class="trade__bar">
          <span class="trade__logo">◈ HELION</span>
          <span class="trade__net"><i class="trade__dot"></i>MAINNET</span>
          <span class="trade__gas">GAS <b data-gas>14</b> gwei</span>
        </div>
        <div class="trade__watch" data-watch role="tablist">
          {markets.map((mk, i) => (
            <button class={`trade__tk ${i === 0 ? 'is-on' : ''} ${mk[4] > 0 ? 'is-up' : 'is-dn'}`} data-mkt={mk[0]} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>
              <span class="trade__tk-sym">{mk[0]}</span>
              <span class="trade__tk-px" data-px>{mk[2]}</span>
              <span class="trade__tk-ch" data-ch>{mk[3]}%</span>
            </button>
          ))}
        </div>
        <div class="trade__body">
          <div class="trade__chart-wrap">
            <div class="trade__quote">
              <span class="trade__pair" data-pair>SOL / USDC</span>
              <span class="trade__last" data-last>148.92</span>
              <span class="trade__delta is-up" data-delta>+6.41%</span>
            </div>
            <svg class="trade__chart" viewBox="0 0 300 90" preserveAspectRatio="none" aria-hidden="true">
              <polyline class="trade__spark" data-spark points="" fill="none" />
              <polyline class="trade__sparkfill" data-sparkfill points="" />
            </svg>
            <div class="trade__btns">
              <button class="trade__buy">BUY</button>
              <button class="trade__sell">SELL</button>
            </div>
          </div>
          <div class="trade__book">
            <div class="trade__book-h"><span>PRICE</span><span>SIZE</span></div>
            <div class="trade__asks">
              {asks.map((a) => (
                <div class="trade__lvl trade__lvl--ask"><i class="trade__depth" style={`width:${Math.min(100, +a[1] / 9)}%`}></i><span class="trade__lp">{a[0]}</span><span class="trade__ls">{a[1]}</span></div>
              ))}
            </div>
            <div class="trade__spread"><span data-spread>SPREAD 0.02 · 0.013%</span></div>
            <div class="trade__bids">
              {bids.map((b) => (
                <div class="trade__lvl trade__lvl--bid"><i class="trade__depth" style={`width:${Math.min(100, +b[1] / 9)}%`}></i><span class="trade__lp">{b[0]}</span><span class="trade__ls">{b[1]}</span></div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Pick a market — the pair, last price, sparkline and book re-key live; the tape flickers like a ticker. Tabular figures keep every price column flush.</p>
  </figure>

  <!-- 04 — deep-space science data-viz editorial -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Editorial — exoplanet survey, data-viz spread</span></figcaption>
    <div class="iu__scene scene-tall">
      <div class="exo">
        <div class="exo__head">
          <span class="exo__issue">VOL. XII · DEEP FIELD SURVEY</span>
          <h3 class="exo__title">THE HABITABLE<br/>SHORTLIST</h3>
          <p class="exo__deck">Five rocky worlds in the circumstellar comfort zone, ranked by an Earth-Similarity Index drawn from radius, insolation and orbital geometry.</p>
        </div>
        <div class="exo__chart" data-exo>
          <div class="exo__chart-h"><span>WORLD</span><span class="exo__num">DIST&nbsp;ly</span><span class="exo__num">R⊕</span><span class="exo__num">PERIOD&nbsp;d</span><span class="exo__esi">ESI</span></div>
          {exoplanets.map((e) => (
            <div class="exo__row">
              <span class="exo__name">{e[0]}</span>
              <span class="exo__num">{e[1]}</span>
              <span class="exo__num">{e[2]}</span>
              <span class="exo__num">{e[3]}</span>
              <span class="exo__esi">
                <i class="exo__bar" data-bar style={`--v:${e[4]}`}></i>
                <b>{e[4].toFixed(2)}</b>
              </span>
            </div>
          ))}
        </div>
        <div class="exo__foot">
          <span>SOURCE · ARCHIVE DR4</span>
          <span class="exo__foot-note">ESI 1.00 = EARTH</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">A data spread: display gothic headline over tabular survey figures, the ESI bars drawing in on reveal.</p>
  </figure>
</div>

<script id="sg-mc-data" type="application/json" set:html={JSON.stringify(phases)} is:inline></script>
<script id="sg-mkt-data" type="application/json" set:html={JSON.stringify({ markets, asks, bids })} is:inline></script>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ===== 01 · mission-control phase switching + subsystem ack =====
  type Phase = {
    id: string; name: string; met: string; live: boolean; vehicle: string; stage: string;
    telem: [string, string, string][];
    subs: [string, string, string][];
    gauges: [string, number][];
  };
  const mcIsland = document.getElementById('sg-mc-data');
  let phases: Phase[] = [];
  try { phases = mcIsland ? JSON.parse(mcIsland.textContent || '[]') : []; } catch { phases = []; }
  const phaseById: Record<string, Phase> = {};
  phases.forEach((p) => (phaseById[p.id] = p));

  document.querySelectorAll<HTMLElement>('[data-mc]').forEach((mc) => {
    if (!phases.length) return;
    const q = (s: string) => mc.querySelector(s) as HTMLElement | null;
    const vehicle = q('[data-vehicle]')!, met = q('[data-met]')!, stage = q('[data-stage]')!;
    const cells = Array.from(mc.querySelectorAll('[data-cell]'));
    const gauges = Array.from(mc.querySelectorAll('[data-gauge]'));
    const subsWrap = q('[data-subs]')!;

    function render(id: string) {
      const p = phaseById[id];
      if (!p) return;
      vehicle.textContent = p.vehicle;
      met.textContent = p.met;
      stage.textContent = p.stage;

      cells.forEach((cell, i) => {
        const t = p.telem[i];
        if (!t) { (cell as HTMLElement).style.display = 'none'; return; }
        (cell as HTMLElement).style.display = '';
        (cell.querySelector('[data-ck]') as HTMLElement).textContent = t[0];
        (cell.querySelector('[data-cv]') as HTMLElement).textContent = t[1];
        (cell.querySelector('[data-cu]') as HTMLElement).textContent = t[2];
      });

      gauges.forEach((g, i) => {
        const gd = p.gauges[i];
        if (!gd) { (g as HTMLElement).style.display = 'none'; return; }
        (g as HTMLElement).style.display = '';
        (g.querySelector('[data-gk]') as HTMLElement).textContent = gd[0];
        (g.querySelector('[data-gv]') as HTMLElement).textContent = gd[1] + '%';
        (g.querySelector('[data-gfill]') as HTMLElement).style.width = gd[1] + '%';
      });

      subsWrap.replaceChildren();
      p.subs.forEach((s) => {
        const btn = document.createElement('button');
        btn.className = `mc__sub mc__sub--${s[2]}`;
        btn.setAttribute('data-sub', '');
        btn.setAttribute('data-state', s[2]);
        const led = document.createElement('span'); led.className = 'mc__sub-led';
        const n = document.createElement('span'); n.className = 'mc__sub-n'; n.textContent = s[0];
        const st = document.createElement('span'); st.className = 'mc__sub-s'; st.textContent = s[1];
        btn.append(led, n, st);
        wireSub(btn);
        subsWrap.appendChild(btn);
      });

      mc.querySelectorAll('[data-phase]').forEach((t) => {
        const on = (t as HTMLElement).dataset.phase === id;
        t.classList.toggle('is-on', on);
        t.setAttribute('aria-selected', on ? 'true' : 'false');
      });
    }

    function wireSub(btn: HTMLElement) {
      btn.addEventListener('click', () => {
        const ss = btn.querySelector('[data-ss]') as HTMLElement;
        if (btn.dataset.state === 'warn') {
          btn.dataset.state = 'ok';
          btn.classList.remove('mc__sub--warn');
          btn.classList.add('mc__sub--ok');
          ss.textContent = 'ACK';
        } else {
          btn.dataset.state = 'warn';
          btn.classList.remove('mc__sub--ok');
          btn.classList.add('mc__sub--warn');
          ss.textContent = 'CHECK';
        }
      });
    }
    mc.querySelectorAll<HTMLElement>('[data-sub]').forEach(wireSub);

    mc.querySelectorAll<HTMLButtonElement>('[data-phase]').forEach((btn) =>
      btn.addEventListener('click', () => render(btn.dataset.phase!))
    );

    // subtle live jitter on telemetry (reduced-motion: static)
    if (!reduce) {
      const jitter = () => {
        cells.forEach((cell) => {
          const vEl = cell.querySelector('[data-cv]') as HTMLElement;
          const base = parseFloat(vEl.textContent || '0');
          if (!isFinite(base) || base === 0) return;
          const drift = base * (1 + (Math.random() - 0.5) * 0.0016);
          const dec = (vEl.textContent || '').includes('.') ? (vEl.textContent!.split('.')[1]?.length || 2) : 0;
          vEl.textContent = drift.toFixed(dec);
        });
      };
      setInterval(jitter, 1200);
    }
  });

  // ===== 02 · HALT poster — stylistic-set (ss01/ss02/ss03) live toggle =====
  document.querySelectorAll<HTMLElement>('[data-halt]').forEach((halt) => {
    const btn = halt.querySelector('[data-ss-toggle]') as HTMLButtonElement | null;
    const state = halt.querySelector('[data-ss-state]') as HTMLElement | null;
    if (!btn) return;
    btn.addEventListener('click', () => {
      const off = halt.toggleAttribute('data-ss-off');
      btn.setAttribute('aria-pressed', off ? 'false' : 'true');
      if (state) state.textContent = off ? 'OFF' : 'ON';
    });
  });

  // ===== 03 · crypto terminal market switching + live tape =====
  type Mkt = [string, string, string, string, number];
  const mktIsland = document.getElementById('sg-mkt-data');
  let mdata: { markets: Mkt[]; asks: [string, string][]; bids: [string, string][] } =
    { markets: [], asks: [], bids: [] };
  try { mdata = mktIsland ? JSON.parse(mktIsland.textContent || '{}') : mdata; } catch {}
  const mktById: Record<string, Mkt> = {};
  mdata.markets.forEach((m) => (mktById[m[0]] = m));

  // deterministic-ish sparkline generator per symbol
  function spark(sym: string, up: boolean): number[] {
    let seed = 0;
    for (const c of sym) seed += c.charCodeAt(0);
    const pts: number[] = [];
    let v = 45;
    for (let i = 0; i < 32; i++) {
      seed = (seed * 9301 + 49297) % 233280;
      const r = seed / 233280;
      v += (r - 0.5) * 14 + (up ? 0.5 : -0.5);
      v = Math.max(10, Math.min(80, v));
      pts.push(v);
    }
    return pts;
  }

  document.querySelectorAll<HTMLElement>('[data-trade]').forEach((tr) => {
    if (!mdata.markets || !mdata.markets.length) return;
    const q = (s: string) => tr.querySelector(s) as HTMLElement | null;
    const pair = q('[data-pair]')!, last = q('[data-last]')!, delta = q('[data-delta]')!;
    const spreadEl = q('[data-spread]')!;
    const sparkEl = tr.querySelector('[data-spark]') as unknown as SVGPolylineElement;
    const fillEl = tr.querySelector('[data-sparkfill]') as unknown as SVGPolylineElement;

    function draw(sym: string) {
      const m = mktById[sym];
      if (!m) return;
      const up = m[4] > 0;
      pair.textContent = `${m[0]} / USDC`;
      last.textContent = m[2];
      delta.textContent = (up ? '+' : '') + m[3] + '%';
      delta.classList.toggle('is-up', up);
      delta.classList.toggle('is-dn', !up);
      const ys = spark(sym, up);
      const stepX = 300 / (ys.length - 1);
      const pts = ys.map((y, i) => `${(i * stepX).toFixed(1)},${(90 - y).toFixed(1)}`).join(' ');
      sparkEl.setAttribute('points', pts);
      fillEl.setAttribute('points', `0,90 ${pts} 300,90`);
      tr.dataset.dir = up ? 'up' : 'dn';
      // re-trigger the draw animation
      if (!reduce) {
        sparkEl.style.animation = 'none';
        // eslint-disable-next-line @typescript-eslint/no-unused-expressions
        sparkEl.getBoundingClientRect();
        sparkEl.style.animation = '';
      }
    }

    draw('SOL');
    tr.querySelectorAll<HTMLButtonElement>('[data-mkt]').forEach((btn) =>
      btn.addEventListener('click', () => {
        tr.querySelectorAll('[data-mkt]').forEach((b) => {
          b.classList.remove('is-on');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('is-on');
        btn.setAttribute('aria-selected', 'true');
        draw(btn.dataset.mkt!);
      })
    );

    // live gas + faint price tape flicker (reduced-motion: static)
    if (!reduce) {
      const gas = q('[data-gas]');
      setInterval(() => {
        if (gas) gas.textContent = String(8 + Math.floor(Math.random() * 22));
      }, 2600);
    }
  });

  // ===== 04 · exoplanet ESI bars draw in on reveal =====
  if (!reduce && 'IntersectionObserver' in window) {
    document.querySelectorAll<HTMLElement>('[data-exo]').forEach((exo) => {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((en) => {
          if (en.isIntersecting) { exo.classList.add('is-in'); io.disconnect(); }
        });
      }, { threshold: 0.3 });
      io.observe(exo);
    });
  } else {
    document.querySelectorAll<HTMLElement>('[data-exo]').forEach((e) => e.classList.add('is-in'));
  }
</script>

<style>
  .iu__item { margin: 0; }
  .iu__hint { margin-top: var(--sp-2); color: var(--fg-3); }
  .iu * { font-family: var(--fam); }

  /* shared scene framing — matches InUse.astro / inter.astro */
  .iu__scene {
    container-type: inline-size;
    position: relative;
    border: clamp(22px, 3.4vw, 44px) solid var(--bg-2);
    outline: 1px solid var(--line);
    overflow: hidden;
    aspect-ratio: 16 / 9;
