---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;
---
<div class="iu" style={`--fam:${fam}`}>
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Poster — mission control</span></figcaption>
    <div class="iu__scene scene16">
      <div class="iu__poster mission" data-mission>
        <div class="ms-top"><span>◤ ORBITAL DYNAMICS</span><span data-clock>T‑00:00:08</span></div>
        <h3 class="ms-head">LAUNCH<br/>WINDOW</h3>
        <div class="ms-grid">
          <div><span class="ms-k">ALT</span><b>412.8 km</b></div>
          <div><span class="ms-k">VEL</span><b>7.66 km/s</b></div>
          <div><span class="ms-k">INC</span><b>51.6°</b></div>
          <div><span class="ms-k">FUEL</span><b>98.2%</b></div>
        </div>
        <div class="ms-foot"><span>PAD 39A · LEO INSERTION</span><span class="ms-go">● GO</span></div>
      </div>
    </div>
  </figure>

  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Sleeve — a record cover</span></figcaption>
    <div class="iu__scene scene-sq iu__scene--portrait">
      <div class="iu__poster sleeve">
        <div class="sl-rings" aria-hidden="true"><span></span><span></span><span></span></div>
        <span class="sl-side">SIDE A · 33⅓</span>
        <h3 class="sl-title">Frequencies<br/>from Orbit</h3>
        <span class="sl-artist">THE SECOND STAGE</span>
      </div>
    </div>
  </figure>
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-mission]').forEach((m) => {
    const clock = m.querySelector('[data-clock]') as HTMLElement;
    let t = 8;
    const tick = () => {
      t = t <= 0 ? 8 : t - 1;
      clock.textContent = `T‑00:00:${String(t).padStart(2, '0')}`;
    };
    setInterval(tick, 1000);
  });
</script>

<style>
  .iu__item { margin: 0; }
  .scene16 { aspect-ratio: 16 / 9; }
  .scene-sq { --card-ar: 1 / 1; }

  .mission { background: var(--bg); color: var(--fg); padding: 5cqi; display: flex; flex-direction: column; }
  .ms-top { display: flex; justify-content: space-between; font-size: 2.6cqi; letter-spacing: 0.1em; color: var(--accent); }
  .ms-top [data-clock] { font-feature-settings: 'tnum'; }
  .ms-head { font-size: 17cqi; line-height: 0.86; font-weight: 700; letter-spacing: -0.02em; margin: 2cqi 0 auto; }
  .ms-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2cqi; border-top: 1px solid var(--line); padding-top: 3cqi; }
  .ms-grid div { display: flex; flex-direction: column; gap: 0.6cqi; }
  .ms-k { font-size: 2.2cqi; letter-spacing: 0.1em; color: var(--fg-3); }
  .ms-grid b { font-size: 3.6cqi; font-feature-settings: 'tnum'; }
  .ms-foot { display: flex; justify-content: space-between; align-items: center; margin-top: 3cqi; font-size: 2.6cqi; letter-spacing: 0.08em; color: var(--fg-2); }
  .ms-go { color: var(--accent); font-weight: 700; }

  .sleeve { background: var(--fg); color: var(--bg); overflow: hidden; padding: 6cqi; display: flex; flex-direction: column; }
  .sl-rings { position: absolute; top: 50%; left: 50%; transform: translate(-30%, -50%); }
  .sl-rings span { position: absolute; border: 1px solid var(--accent); border-radius: 50%; opacity: 0.5; }
  .sl-rings span:nth-child(1) { width: 60cqi; height: 60cqi; margin: -30cqi; }
  .sl-rings span:nth-child(2) { width: 42cqi; height: 42cqi; margin: -21cqi; }
  .sl-rings span:nth-child(3) { width: 24cqi; height: 24cqi; margin: -12cqi; background: var(--accent); }
  .sl-side { position: relative; font-size: 2.6cqi; letter-spacing: 0.2em; }
  .sl-title { position: relative; font-size: 13cqi; line-height: 0.9; font-weight: 700; margin-top: auto; }
  .sl-artist { position: relative; font-size: 2.8cqi; letter-spacing: 0.25em; color: var(--accent); margin-top: 2cqi; }
</style>
