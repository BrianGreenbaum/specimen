---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// ── The sequence ─────────────────────────────────────────────────────────────
// FRAUNCES MISBEHAVES ON PURPOSE — and the misbehaviour is on sliders.
// Five acts trace the wonk from instrument to ancestry to shelf to page to
// checkout: the dark inkwell where you play the axes by hand (01) → the 1896
// Arts & Crafts broadside the genre descends from (02) → the Bahian chocolate
// shelf where Fraunces actually lives today (03) → the food quarterly that is
// its contemporary editorial habitat (04) → the bakery storefront where the
// 9 pt text cut earns its keep at 13 px (05). Surfaces: theme dark → aged
// cream → vermilion/green/cocoa (the poster's vermilion ink handed off to the
// first wrapper) → white-cream paper → back to the site surface, a quiet beat.
//
// Honesty notes — verified against the loaded fontsource latin-full woff2s
// (fontTools, normal + italic):
// · VARIABLE: wght 100–900 · opsz 9–144 · SOFT 0–100 · WONK 0–1. All four are
//   performed below; every font-variation-settings line sets all four.
// · GSUB is ONLY liga (fi fl ff) + rvrn; GPOS kern. The frontmatter's claims
//   of dlig / onum / frac / sups are NOT in this subset — never set here.
//   Figures are lining-only; every act is composed accordingly.
// · WONK alternates (via rvrn): h m n s & (+ñ). Wonk is only ever staged on
//   words that actually contain those glyphs — "humming", the broadside "&",
//   "Leite & Mel".
// · True italic is loaded (full-italic.css) and used at deck/pull-quote sizes.

// Act 01 — the inkwell's word. Every wonk-bearing letter Fraunces owns is in
// "humming": h m m n lean when WONK = 1. Initial state is a left→right ink
// ramp so the composition is complete before (or without) any pointer.
const INK_WORD = 'humming';
const inkLetters = INK_WORD.split('').map((ch, i, arr) => {
  const t = i / (arr.length - 1);
  return { ch, soft: Math.round(t * 100), wght: 340 + Math.round(t * 380) };
});

// Act 03 — the FAVA identity rule: the darker the bar, the heavier and the
// inkier the type. Crisp 70 → soft 55 → molten 85.
const bars = [
  { pct: '70', flavor: 'Bahia Intenso',  origin: 'Fazenda Riachuelo',  field: 'verm',  wght: 400, soft: 0   },
  { pct: '55', flavor: 'Leite & Mel',    origin: 'Leite da serra',     field: 'green', wght: 560, soft: 55  },
  { pct: '85', flavor: 'Torrado Escuro', origin: 'Colheita tardia',    field: 'cocoa', wght: 800, soft: 100 },
];
---

<div class="iu fr" style={`--fam:${fam}`}>

  <!-- ════════════════════════════════════════════════════════════════════
       01 · INTERACTIVE & EXPERIMENTAL — "humming", a four-axis inkwell.
       Reference: DIA Studio's pointer-reactive kinetic identities — type as
       an instrument the visitor plays. The pointer is a wet brush: proximity
       floods each letter's SOFT and wght; one switch throws WONK and the
       h m m n lean over. Without a pointer (or with reduced motion) the word
       holds a composed left→right ink ramp.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Interactive — the inkwell: four variable axes under your pointer</span></figcaption>
    <div class="iu__scene ink" data-ink>
      <div class="ink__hud">
        <span class="ink__tag">Fraunces · wght 100–900 · SOFT 0–100</span>
        <span class="ink__read" data-ink-read>SOFT 100 · WGHT 720</span>
      </div>
      <h3 class="ink__word" aria-label={INK_WORD}>
        {inkLetters.map((l) => (
          <span
            class="ink__l"
            aria-hidden="true"
            data-soft={l.soft}
            data-wght={l.wght}
            style={`font-variation-settings:'wght' ${l.wght}, 'opsz' 144, 'SOFT' ${l.soft}, 'WONK' 1`}
          >{l.ch}</span>
        ))}
      </h3>
      <div class="ink__foot">
        <button type="button" class="ink__wonk" data-wonk aria-pressed="true">
          <span class="ink__knob" aria-hidden="true"></span>
          <span>WONK · on — the h, m &amp; n lean</span>
        </button>
        <span class="ink__note">an old-style that misbehaves on purpose</span>
      </div>
    </div>
    <p class="iu__hint label">Move across the word — the ink follows your pointer. Throw the switch to straighten the letters back up.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       02 · ILLUSTRATION & COMMERCIAL — the ancestry: an Arts & Crafts
       Exhibition Society broadside, London, 1896. Reference: the Society's
       fifth exhibition at the New Gallery, Regent Street (the Kelmscott
       year — Morris died that October); jobbing composition printed by the
       Chiswick Press. Fraunces descends from exactly this romanticised
       Old Style. One motion idea: as the sheet scrolls into view the press
       comes up to pressure — SOFT floods the ampersand and the title line,
       the over-inked hand-press impression arriving live.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Commercial — an 1896 exhibition broadside, the genre Fraunces descends from</span></figcaption>
    <div class="iu__scene pst" data-pst>
      <div class="pst__sheet">
        <p class="pst__row pst__venue">The New Gallery &middot; 121 Regent Street &middot; London W.</p>
        <p class="pst__row pst__pre">the fifth exhibition of the society of</p>
        <h3 class="pst__row pst__main" data-pst-main>ARTS<span class="pst__amp" data-pst-amp>&amp;</span>CRAFTS</h3>
        <p class="pst__row pst__sub">hand-wrought metal &middot; printed books &middot; tapestry &amp; honest furniture</p>
        <p class="pst__row pst__it">comprising work from the Kelmscott Press, shown in memoriam William Morris</p>
        <div class="pst__rule" aria-hidden="true"><i></i><b>*&#8201;*&#8201;*</b><i></i></div>
        <p class="pst__row pst__terms">Open daily from October 1896 &middot; ten of the clock till dusk</p>
        <p class="pst__row pst__terms pst__terms--b">Admission one shilling &middot; season ticket five shillings &middot; catalogue sixpence</p>
        <p class="pst__row pst__imprint">Printed for the Society by the Chiswick Press, Took&rsquo;s Court, Chancery Lane, E.C.</p>
      </div>
    </div>
    <p class="iu__hint label">Watch the sheet arrive — the ampersand takes the most ink, the way a hand-press always over-inks the biggest sort.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       03 · BRANDING & IDENTITY — FAVA, bean-to-bar chocolate, Salvador da
       Bahia. Reference: the post-2019 wonky-serif CPG wave that Fraunces
       itself ignited — and its documented Brazilian adoption (Zimbardi has
       watched it cover packaging and national campaigns back home). The
       identity is a SYSTEM, not a logo: the darker the chocolate, the
       heavier the weight and the wetter the SOFT axis. Crisp 70 → soft 55 →
       molten 85. Hovering a bar melts its numeral. The first wrapper takes
       the broadside's vermilion ink as its field — the handoff.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed fr-snug">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Branding — FAVA bean-to-bar: weight and SOFT graded to cacao percentage</span></figcaption>
    <div class="iu__scene shelfscene">
      <div class="shelf">
        {bars.map((b) => (
          <div class={`bar bar--${b.field}`} tabindex="0" style={`--bw:${b.wght}; --bs:${b.soft}; --bw2:${Math.min(b.wght + 80, 900)}`}>
            <p class="bar__brand">FAVA<span>cacau de origem</span></p>
            <p class="bar__pct"><span class="bar__num">{b.pct}</span><span class="bar__sym">%</span></p>
            <p class="bar__flavor">{b.flavor}</p>
            <p class="bar__origin">{b.origin}</p>
            <p class="bar__foot"><span>60 g</span><span>colheita 2025</span><span>Salvador, BA</span></p>
          </div>
        ))}
      </div>
    </div>
    <p class="iu__hint label">One rule makes the identity: 70% sets crisp and regular, 85% sets black and molten. Hover a bar and it melts a little further.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       04 · EDITORIAL — The Skillet, a food quarterly. Reference: The
       Gourmand's appetite-led feature openers — vast light serif headline,
       italic deck, patient text columns. This is the opsz story told as
       editorial fact: the headline at the 144 display cut blooms open as the
       spread enters view; the columns sit in the 9 pt text cut and just
       read. True italics carry the deck and the pull quote.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Editorial — a food quarterly opener in the Gourmand manner; one outline, 9 pt to 144 pt</span></figcaption>
    <div class="iu__scene mag" data-mag>
      <div class="mag__spread">
        <header class="mag__folio">
          <span>The Skillet &mdash; a quarterly of appetites</span>
          <span>No. 12 &middot; Autumn 2026</span>
        </header>
        <div class="mag__head">
          <p class="mag__kicker">Kitchen Doctrine</p>
          <h3 class="mag__hl" data-mag-hl>In Praise of<br />Burnt Butter</h3>
          <p class="mag__deck">On beurre noisette, the bravest of the easy luxuries &mdash; and why the best cooks let it go one shade past comfortable.</p>
          <p class="mag__byline">By Marina Duarte &middot; photographs set entirely in type</p>
        </div>
        <div class="mag__body">
          <div class="mag__col">
            <p><span class="mag__drop">T</span>he butter is not burnt, of course. It is taken to the breath before burning &mdash; the milk solids toasted to the colour of a hazelnut shell, the foam gone quiet, the smell suddenly enormous. French kitchens call it beurre noisette and treat it as a sauce; the rest of us should treat it as a doctrine.</p>
            <p>Doctrine, because it asks for the one thing home cooks are talked out of: nerve. Pull the pan at golden and you have warm butter. Wait &mdash; four seconds, maybe five &mdash; and you have something with a past.</p>
          </div>
          <div class="mag__col mag__col--b">
            <blockquote class="mag__pull">&ldquo;Let it go one shade past comfortable. That is where the flavour lives.&rdquo;</blockquote>
            <p>Spoon it over white fish, fold it through madeleine batter, or do the truly luxurious thing and eat it on toast with salt. The whole technique costs ninety seconds and a moment of courage.</p>
          </div>
        </div>
        <footer class="mag__folio mag__folio--ft">
          <span>64</span>
          <span class="mag__ft-it">beurre noisette, continued</span>
          <span>65</span>
        </footer>
      </div>
    </div>
    <p class="iu__hint label">The headline blooms from the text cut to the 144 pt display cut as the spread arrives &mdash; the same outline, contrast turned up.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       05 · WEB & APP UI — Hearth, a neighbourhood-bakery storefront at real
       device pixels. Reference: the type-led DTC storefronts of the
       post-2019 wonky-serif wave — the commercial genre Fraunces created.
       The point made at 13 px: the opsz 9 text cut calms the contrast and
       raises the x-height, so the same family that swaggers upstairs sets
       working UI labels here. Size, schedule, and quantity all drive a live
       total; the basket actually counts.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">05</span><span class="label">Web UI — a bakery storefront at true device scale; the 9 pt text cut on duty at 13 px</span></figcaption>
    <div class="iu__scene shopwrap">
      <div class="shop" data-shop>
        <header class="shop__bar">
          <span class="shop__logo">Hearth</span>
          <nav class="shop__nav" aria-label="Shop sections">
            <a class="is-here" href="#0">Breads</a><a href="#0">Pastry</a><a href="#0">Pantry</a>
          </nav>
          <span class="shop__cart">Basket &middot; <b data-cart>0</b></span>
        </header>
        <div class="shop__main">
          <div class="shop__hero">
            <p class="shop__kicker">Daily loaf &middot; No. 04</p>
            <h4 class="shop__name">Burnt&#8209;Honey Sourdough</h4>
            <p class="shop__desc">Dark, blistered crust; an open crumb sweetened with honey taken one shade past caution. Levain, stoneground T85, thirty&#8209;six&#8209;hour cold proof.</p>
            <p class="shop__meta">Baked Wednesday to Sunday in Greenpoint &middot; sold out most days by noon</p>
          </div>
          <div class="shop__panel">
            <div class="shop__group" role="group" aria-label="Loaf size">
              <span class="shop__lbl">Size</span>
              <div class="shop__opts">
                <button type="button" class="shop__opt is-on" data-size="9" aria-pressed="true">800 g <b>$9</b></button>
                <button type="button" class="shop__opt" data-size="14" aria-pressed="false">1.4 kg <b>$14</b></button>
              </div>
            </div>
            <div class="shop__group" role="group" aria-label="Schedule">
              <span class="shop__lbl">Schedule</span>
              <div class="shop__opts">
                <button type="button" class="shop__opt is-on" data-plan="1" aria-pressed="true">One&#8209;off</button>
                <button type="button" class="shop__opt" data-plan="0.9" aria-pressed="false">Weekly <b>&minus;10%</b></button>
                <button type="button" class="shop__opt" data-plan="0.95" aria-pressed="false">Fortnightly <b>&minus;5%</b></button>
              </div>
            </div>
            <div class="shop__group" role="group" aria-label="Quantity">
              <span class="shop__lbl">Quantity</span>
              <div class="shop__qty">
                <button type="button" data-qty="-1" aria-label="One loaf fewer">&minus;</button>
                <b data-qty-out>1</b>
                <button type="button" data-qty="1" aria-label="One loaf more">+</button>
              </div>
            </div>
            <div class="shop__row">
              <span class="shop__total" data-total>$9.00</span>
              <button type="button" class="shop__add" data-add>Add to basket</button>
            </div>
            <p class="shop__fine">Subscriptions pause anytime. First delivery Saturday; loaves travel in paper, never plastic.</p>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Pick a size and a schedule, count up the loaves &mdash; the total keeps pace and the basket actually fills.</p>
  </figure>

</div>

<script>
  const fvs = (w: number, o: number, s: number, k: number) =>
    `'wght' ${w}, 'opsz' ${o}, 'SOFT' ${s}, 'WONK' ${k}`;
  const motionOK = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;

  // ── 01 · the inkwell ──────────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-ink]').forEach((scene) => {
    const letters = [...scene.querySelectorAll<HTMLElement>('.ink__l')];
    const read = scene.querySelector<HTMLElement>('[data-ink-read]')!;
    const wonkBtn = scene.querySelector<HTMLButtonElement>('[data-wonk]')!;
    let wonk = 1;

    const base = () => {
      letters.forEach((l) => {
        l.style.fontVariationSettings = fvs(+l.dataset.wght!, 144, +l.dataset.soft!, wonk);
      });
      read.textContent = 'SOFT 100 · WGHT 720';
    };

    if (motionOK) {
      let raf = 0;
      const paint = (x: number, y: number) => {
        const rect = scene.getBoundingClientRect();
        const reach = Math.max(rect.width, rect.height) * 0.22;
        let best = 0, bs = 0, bw = 0;
        letters.forEach((l) => {
          const r = l.getBoundingClientRect();
          const dx = x - (r.left + r.width / 2);
          const dy = y - (r.top + r.height / 2);
          const g = Math.exp(-((dx * dx + dy * dy) / (reach * reach)));
          const s = Math.round(g * 100);
          const w = Math.round(340 + g * 420);
          l.style.fontVariationSettings = fvs(w, 144, s, wonk);
          if (g > best) { best = g; bs = s; bw = w; }
        });
        read.textContent = `SOFT ${bs} · WGHT ${bw}`;
      };
      scene.addEventListener('pointermove', (e) => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => paint(e.clientX, e.clientY));
      });
      scene.addEventListener('pointerleave', () => { cancelAnimationFrame(raf); base(); });
    }

    wonkBtn.addEventListener('click', () => {
      wonk = wonk ? 0 : 1;
      wonkBtn.setAttribute('aria-pressed', String(!!wonk));
      const label = wonkBtn.querySelector('span:last-child');
      if (label) label.textContent = wonk ? 'WONK · on — the h, m & n lean' : 'WONK · off — standing up straight';
      base();
    });

    base();
  });

  // ── 02 + 04 · arrive-in-view states (press pressure / opsz bloom) ─────────
  // Default CSS is the FINAL state, so the acts are complete without JS or
  // with reduced motion. Under no-preference we arm the pre-state, then let
  // an IntersectionObserver release it once.
  if (motionOK) {
    const watch: Array<[string, string]> = [['[data-pst]', 'pst--pre'], ['[data-mag]', 'mag--pre']];
    watch.forEach(([sel, cls]) => {
      document.querySelectorAll<HTMLElement>(sel).forEach((el) => {
        el.classList.add(cls);
        const io = new IntersectionObserver((entries) => {
          entries.forEach((en) => {
            if (en.isIntersecting) { el.classList.remove(cls); io.disconnect(); }
          });
        }, { threshold: 0.45 });
        io.observe(el);
      });
    });
  }

  // ── 05 · the storefront ───────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-shop]').forEach((shop) => {
    const total = shop.querySelector<HTMLElement>('[data-total]')!;
    const qtyOut = shop.querySelector<HTMLElement>('[data-qty-out]')!;
    const cart = shop.querySelector<HTMLElement>('[data-cart]')!;
    const add = shop.querySelector<HTMLButtonElement>('[data-add]')!;
    let price = 9, plan = 1, qty = 1, basket = 0;

    const sum = () => { total.textContent = `$${(price * plan * qty).toFixed(2)}`; };
    const pick = (btns: NodeListOf<HTMLButtonElement>, on: HTMLButtonElement) => {
      btns.forEach((b) => { b.classList.toggle('is-on', b === on); b.setAttribute('aria-pressed', String(b === on)); });
    };

    const sizes = shop.querySelectorAll<HTMLButtonElement>('[data-size]');
    sizes.forEach((b) => b.addEventListener('click', () => { price = +b.dataset.size!; pick(sizes, b); sum(); }));

    const plans = shop.querySelectorAll<HTMLButtonElement>('[data-plan]');
    plans.forEach((b) => b.addEventListener('click', () => { plan = +b.dataset.plan!; pick(plans, b); sum(); }));

    shop.querySelectorAll<HTMLButtonElement>('[data-qty]').forEach((b) =>
      b.addEventListener('click', () => { qty = Math.min(6, Math.max(1, qty + +b.dataset.qty!)); qtyOut.textContent = String(qty); sum(); }));

    let flash = 0;
    add.addEventListener('click', () => {
      basket += qty;
      cart.textContent = String(basket);
      add.textContent = 'Added ✓';
      add.classList.add('did');
      clearTimeout(flash);
      flash = window.setTimeout(() => { add.textContent = 'Add to basket'; add.classList.remove('did'); }, 1200);
    });

    sum();
  });
</script>

<style>
  /* ── stack rhythm: the handoffs ─────────────────────────────────────────
     Tighter overall beat than the default; the broadside hands its vermilion
     ink straight to the first FAVA wrapper, so that junction is snugger. */
  .iu { gap: clamp(3.25rem, 8vh, 5.5rem); }
  .fr-snug { margin-top: calc(-1 * clamp(0.75rem, 3vh, 2.25rem)); }
  .iu__hint { margin-top: var(--sp-2); color: var(--fg-3); }
  .iu__scene * { font-family: var(--fam); }

  /* ════ 01 · THE INKWELL ════════════════════════════════════════════════ */
  .ink {
    background: var(--bg);
    display: flex; flex-direction: column; justify-content: space-between;
    min-height: clamp(420px, 72vh, 680px);
    padding: clamp(1.25rem, 3.2cqi, 2.6rem) clamp(1.1rem, 4cqi, 4rem);
    cursor: crosshair;
  }
  .ink__hud {
    display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--fg-3);
  }
  .ink__read { color: var(--accent); font-variant-numeric: tabular-nums; }
  .ink__word {
    margin: auto 0; display: flex; justify-content: center; align-items: baseline;
    font-size: clamp(64px, 18.5cqi, 280px); line-height: 0.9; color: var(--fg);
    letter-spacing: -0.035em; font-weight: 400; user-select: none;
  }
  .ink__l { display: inline-block; }
  .ink__foot { display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .ink__wonk {
    display: inline-flex; align-items: center; gap: 0.6rem;
    border: 1px solid var(--accent); border-radius: 100px;
    padding: 0.4rem 0.85rem 0.4rem 0.4rem; cursor: pointer; background: transparent;
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--accent);
  }
  .ink__knob { width: 14px; height: 14px; border-radius: 50%; background: var(--accent); flex: none; }
  .ink__wonk[aria-pressed='false'] { border-color: var(--line); color: var(--fg-3); }
  .ink__wonk[aria-pressed='false'] .ink__knob { background: var(--fg-3); }
  .ink__note {
    font-style: italic; color: var(--fg-2); font-size: clamp(13px, 1.2cqi, 16px);
    font-variation-settings: 'wght' 400, 'opsz' 30, 'SOFT' 0, 'WONK' 0;
  }
  @media (prefers-reduced-motion: no-preference) {
    .ink__l { transition: font-variation-settings 0.32s var(--ease-out, ease-out); }
    .ink__wonk { transition: border-color 0.25s var(--ease), color 0.25s var(--ease); }
  }
  /* NOTE: .ink is itself the queried container — only descendants recompose. */
  @container (max-width: 560px) {
    .ink__word {
      flex-direction: column; align-items: center; margin: 1.75rem 0 2rem;
      font-size: 23cqi; line-height: 0.82; letter-spacing: 0;
    }
    .ink__foot { flex-direction: column; align-items: flex-start; gap: 0.8rem; }
  }

  /* ════ 02 · THE BROADSIDE (cream paper, vermilion + black ink) ═════════ */
  .pst {
    --paper: #ece0c4; --inkc: #221610; --verm: #b8401e;
    background: var(--paper); color: var(--inkc);
    display: grid; place-items: center;
    padding: clamp(2.5rem, 7cqi, 6.5rem) clamp(1.1rem, 5cqi, 4rem);
  }
  .pst__sheet {
    width: 100%; max-width: 920px; text-align: center;
    display: flex; flex-direction: column; gap: clamp(0.8rem, 2cqi, 1.6rem);
  }
  .pst__row { margin: 0; }
  .pst__venue {
    font-size: clamp(11px, 1.35cqi, 17px); letter-spacing: 0.34em; text-transform: uppercase;
    font-variation-settings: 'wght' 540, 'opsz' 40, 'SOFT' 0, 'WONK' 0;
    border-block: 2px solid var(--inkc); padding: 0.55em 0;
  }
  .pst__pre {
