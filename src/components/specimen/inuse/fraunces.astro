---
import type { CollectionEntry } from 'astro:content';
import BrandScene from '../BrandScene.astro';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;
---
<div class="iu" style={`--fam:${fam}`}>
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Show card — an Arts &amp; Crafts bill</span></figcaption>
    <div class="iu__scene scene-sq iu__scene--portrait">
      <div class="iu__poster showcard">
        <span class="sc__badge sc__badge--1">Est. 1899</span>
        <span class="sc__badge sc__badge--2">Honk!</span>
        <p class="sc__small">THE ROYCROFT GUILD PRESENTS</p>
        <h3 class="sc__head">A Marvellous<br/><em>Evening</em> of Type</h3>
        <p class="sc__sub">with curious letters &amp; soft, wonky serifs</p>
        <span class="sc__foot">Saturday · Half past Eight</span>
      </div>
    </div>
  </figure>

  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Brand — a modernist lockup</span></figcaption>
    <div class="iu__scene brand-scene">
      <BrandScene font={font} variant="stack" />
    </div>
  </figure>
</div>

<style>
  .iu__item { margin: 0; }
  .brand-scene { aspect-ratio: 16 / 9; }
  .scene-sq { --card-ar: 4 / 5; }

  .showcard { background: var(--bg); color: var(--fg); display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 6cqi; gap: 2cqi; }
  .sc__badge { position: absolute; font-weight: 700; border-radius: 50%; display: grid; place-items: center; transform: rotate(-12deg); }
  .sc__badge--1 { background: var(--accent); color: var(--accent-contrast); width: 18cqi; height: 18cqi; font-size: 3cqi; top: 5cqi; right: 5cqi; }
  .sc__badge--2 { background: var(--fg); color: var(--bg); width: 14cqi; height: 14cqi; font-size: 3.4cqi; bottom: 6cqi; left: 5cqi; transform: rotate(10deg); font-style: italic; }
  .sc__small { font-size: 2.6cqi; letter-spacing: 0.2em; color: var(--fg-2); }
  .sc__head { font-size: 13cqi; line-height: 0.95; font-weight: 600; }
  .sc__head em { font-style: italic; color: var(--accent); }
  .sc__sub { font-size: 3.4cqi; font-style: italic; color: var(--fg-2); }
  .sc__foot { font-size: 2.8cqi; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); margin-top: 1cqi; }
</style>
