---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// ============================================================
// UNBOUNDED — rounded geometric variable display (wght 200–900)
// Roman Shchupak, 2022. Screen-native, brand-forward.
// Scenes lean into ROUNDED geometry and the full wght range.
// NO italic. openType: liga, tnum, frac only.
// ============================================================

// --- 02 · Music streaming UI (interactive, real device scale) ---------------
const albums = [
  {
    id: 'a1', artist: 'KODE9', title: 'Black Sun', genre: 'ELECTRONIC', year: '2012',
    tracks: [
      { n: 1, t: 'Black Sun', dur: '6:18', plays: '2.4M' },
      { n: 2, t: 'Neon Skyline', dur: '5:42', plays: '1.8M' },
      { n: 3, t: 'Sine Channel', dur: '4:57', plays: '3.1M' },
      { n: 4, t: 'Subtone', dur: '7:03', plays: '980K' },
      { n: 5, t: 'The Grid', dur: '5:29', plays: '1.2M' },
    ],
    hue: 260,
  },
  {
    id: 'a2', artist: 'OBJEKT', title: 'Flatland', genre: 'TECHNO', year: '2014',
    tracks: [
      { n: 1, t: 'Agnes Apparatus', dur: '6:51', plays: '1.9M' },
      { n: 2, t: 'Needle & Thread', dur: '8:12', plays: '2.7M' },
      { n: 3, t: 'Dogma', dur: '7:44', plays: '1.4M' },
      { n: 4, t: 'Agnes Apparatus II', dur: '5:33', plays: '880K' },
      { n: 5, t: 'Flatland', dur: '9:02', plays: '3.6M' },
    ],
    hue: 310,
  },
  {
    id: 'a3', artist: 'BURIAL', title: 'Untrue', genre: 'DUBSTEP', year: '2007',
    tracks: [
      { n: 1, t: 'Archangel', dur: '5:06', plays: '8.2M' },
      { n: 2, t: 'Near Dark', dur: '4:43', plays: '6.4M' },
      { n: 3, t: 'Ghost Hardware', dur: '5:38', plays: '5.9M' },
      { n: 4, t: 'Endorphin', dur: '4:52', plays: '4.7M' },
      { n: 5, t: 'Shell of Light', dur: '6:01', plays: '5.1M' },
    ],
    hue: 195,
  },
];
const a0 = albums[0];

// --- 04 · Weight ladder for identity scene -----------------------------------
const steps = [
  { w: 200, l: 'ExtraLight' },
  { w: 300, l: 'Light' },
  { w: 400, l: 'Regular' },
  { w: 500, l: 'Medium' },
  { w: 600, l: 'SemiBold' },
  { w: 700, l: 'Bold' },
  { w: 800, l: 'ExtraBold' },
  { w: 900, l: 'Black' },
];
---

<div class="iu" style={`--fam:${fam}`}>

  <!-- 01 — BRAND LAUNCH POSTER · kinetic wght 200↔900, rounded geometry dramatised -->
  <figure class="iu__item">
    <figcaption class="iu__cap">
      <span class="index-num">01</span>
      <span class="label">Poster — brand launch, kinetic wght 200→900</span>
    </figcaption>
    <div class="iu__scene scene16">
      <div class="lnch" data-lnch>
        <div class="lnch__bg" aria-hidden="true">
          <div class="lnch__orb lnch__orb--1"></div>
          <div class="lnch__orb lnch__orb--2"></div>
        </div>
        <header class="lnch__top">
          <span class="lnch__mark"><span class="lnch__dot"></span>RADIUS&nbsp;STUDIO</span>
          <span class="lnch__meta">EST. 2024</span>
        </header>
        <div class="lnch__hero">
          <span class="lnch__ghost" aria-hidden="true">R</span>
          <span class="lnch__pre">INTRODUCING</span>
          <h3 class="lnch__head">
            <span class="lnch__word" data-flux style="--d:0s">ROUND</span>
            <span class="lnch__word lnch__word--accent" data-flux style="--d:-2.2s">WORLD</span>
          </h3>
          <p class="lnch__tagline" aria-hidden="true">GEOMETRY&nbsp;IS&nbsp;EVERYTHING</p>
          <p class="lnch__deck">A branding system built for the screen era. Every form softened, every edge earned.</p>
        </div>
        <footer class="lnch__foot">
          <span class="lnch__cta">EXPLORE &rarr;</span>
          <span class="lnch__wt" aria-hidden="true">wght&nbsp;<b data-wlabel>900</b></span>
        </footer>
      </div>
    </div>
    <p class="iu__hint label">Two display words drive Unbounded&rsquo;s full 200&rarr;900 wght axis in a phase-offset breathe &mdash; counters opening at ExtraLight, crushing into circular mass at Black. The readout tracks live.</p>
  </figure>

  <!-- 02 — INTERACTIVE music streaming UI (real device scale) -->
  <figure class="iu__item">
    <figcaption class="iu__cap">
      <span class="index-num">02</span>
      <span class="label">Product UI &mdash; music streaming app, real device scale</span>
    </figcaption>
    <div class="iu__scene iu__scene--console">
      <div class="strm" data-strm>
        <div class="strm__bar">
          <span class="strm__logo">&#9673; ORBIT</span>
          <div class="strm__tabs" role="tablist">
            {albums.map((a, i) => (
              <button
                class={`strm__tab ${i === 0 ? 'is-on' : ''}`}
                data-album={a.id} role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
              >{a.artist}</button>
            ))}
          </div>
          <span class="strm__status"><i class="strm__dot"></i>LIVE</span>
        </div>

        {albums.map((a, ai) => (
          <div class={`strm__panel ${ai === 0 ? 'is-on' : ''}`} data-panel={a.id} style={`--ahue:${a.hue}`}>
            <div class="strm__hero">
              <div class="strm__art" aria-hidden="true">
                <span class="strm__art-letter">{a.artist[0]}</span>
                <div class="strm__art-ring strm__art-ring--1"></div>
                <div class="strm__art-ring strm__art-ring--2"></div>
              </div>
              <div class="strm__meta">
                <span class="strm__genre">{a.genre} &middot; {a.year}</span>
                <h4 class="strm__title">{a.title}</h4>
                <span class="strm__artist">{a.artist}</span>
                <div class="strm__controls">
                  <button class="strm__btn strm__btn--prev" aria-label="Previous">&#9664;</button>
                  <button class="strm__btn strm__btn--play is-playing" data-play aria-label="Play/Pause">&#9646;&#9646;</button>
                  <button class="strm__btn strm__btn--next" aria-label="Next">&#9654;</button>
                </div>
              </div>
            </div>
            <div class="strm__list">
              <div class="strm__list-h">
                <span>#</span><span>TITLE</span>
                <span class="strm__plays-h">PLAYS</span>
                <span>TIME</span>
              </div>
              {a.tracks.map((tr, ti) => (
                <button
                  class={`strm__row ${ai === 0 && ti === 0 ? 'is-playing' : ''}`}
                  data-track={ti}
                  data-key={`${a.id}|${ti}`}
                  data-title={tr.t}
                  data-dur={tr.dur}
                  data-artist={a.artist}
                  aria-pressed={ai === 0 && ti === 0 ? 'true' : 'false'}
                >
                  <span class="strm__tn">{tr.n}</span>
                  <span class="strm__tt">{tr.t}</span>
                  <span class="strm__tp">{tr.plays}</span>
                  <span class="strm__td">{tr.dur}</span>
                </button>
              ))}
            </div>
          </div>
        ))}

        <div class="strm__now">
          <span class="strm__now-artist" data-nartist>{a0.artist}</span>
          <span class="strm__now-title" data-ntitle>{a0.tracks[0].t}</span>
          <div class="strm__progress">
            <div class="strm__prog-bar">
              <i class="strm__prog-fill" data-fill></i>
            </div>
            <span class="strm__prog-t" data-elapsed>1:42</span>
            <span class="strm__prog-t strm__prog-t--dur" data-dur>{a0.tracks[0].dur}</span>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Switch artist (KODE9 / OBJEKT / BURIAL) to change album. Tap a track row to select it &mdash; the now-playing bar updates. Unbounded Black drives the album title at display scale; tabular figures keep play counts and times flush.</p>
  </figure>

  <!-- 03 — KINETIC EDITORIAL · pointer/idle drives the wght axis -->
  <figure class="iu__item">
    <figcaption class="iu__cap">
      <span class="index-num">03</span>
      <span class="label">Kinetic editorial &mdash; pointer drives the weight axis</span>
    </figcaption>
    <div class="iu__scene scene16">
      <div class="kn" data-kn>
        <span class="kn__bg-letter" data-kbg aria-hidden="true">G</span>
        <div class="kn__hud" aria-hidden="true">
          <span class="kn__hud-l">WGHT</span>
          <span class="kn__hud-v" data-kreadout>400</span>
          <span class="kn__hud-r">200 &harr; 900</span>
        </div>
        <div class="kn__stack">
          <span class="kn__w kn__w--0" data-kw>BOLD</span>
          <span class="kn__w kn__w--1" data-kw>ROUND</span>
          <span class="kn__w kn__w--2" data-kw>FREE</span>
        </div>
        <p class="kn__cap">Move left&ndash;right. Each word lags the last &mdash; rounded counters open at 200, collapse at Black 900.</p>
      </div>
    </div>
    <p class="iu__hint label">Move the pointer left&rarr;right (or scrub on touch) across the scene. The three words ripple through the full 200&ndash;900 wght axis &mdash; the rounded geometry is most visible at the extremes. Without a pointer, the words breathe on their own.</p>
  </figure>

  <!-- 04 — CONTEMPORARY IDENTITY · wordmark + full weight ladder -->
  <figure class="iu__item">
    <figcaption class="iu__cap">
      <span class="index-num">04</span>
      <span class="label">Identity &mdash; contemporary wordmark system</span>
    </figcaption>
    <div class="iu__scene scene-tall">
      <div class="wm" data-wm>
        <div class="wm__bg" aria-hidden="true">
          <div class="wm__ring wm__ring--1"></div>
          <div class="wm__ring wm__ring--2"></div>
          <div class="wm__ring wm__ring--3"></div>
        </div>
        <header class="wm__top">
          <span class="wm__idx">IDENTITY SYSTEM</span>
          <span class="wm__ver">V 1.0 &middot; 2024</span>
        </header>
        <div class="wm__center">
          <div class="wm__primary">
            <span class="wm__kicker">PRIMARY MARK &mdash; UNBOUNDED BLACK</span>
            <h3 class="wm__mark" data-wmark>RADIUS</h3>
            <span class="wm__sub">Rounded &middot; Geometric &middot; Display</span>
          </div>
          <div class="wm__lockup">
            <span class="wm__lock-light">RADIUS</span>
            <span class="wm__lock-divider" aria-hidden="true"></span>
            <span class="wm__lock-heavy">STUDIO</span>
          </div>
          <div class="wm__scale">
            <span class="wm__scale-h">WEIGHT RANGE &middot; 200 &mdash; 900</span>
            <div class="wm__steps">
              {steps.map((s) => (
                <div class="wm__step">
                  <span
                    class="wm__step-w"
                    style={`font-variation-settings:'wght' ${s.w};font-weight:${s.w}`}
                  >Gg</span>
                  <span class="wm__step-n">{s.w}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
        <footer class="wm__foot">
          <span>UNBOUNDED &middot; R. SHCHUPAK &middot; 2022</span>
          <span class="wm__pal">
            <i class="wm__swatch" style="--c:var(--accent)"></i>
            <i class="wm__swatch" style="--c:var(--fg)"></i>
            <i class="wm__swatch" style="--c:var(--fg-3)"></i>
          </span>
        </footer>
      </div>
    </div>
    <p class="iu__hint label">The wordmark breathes from ExtraLight 200 to Black 900 &mdash; Unbounded&rsquo;s rounded counters opening and closing. The weight ladder shows Gg at every instance, making the rounded geometry shift visible across the full range.</p>
  </figure>

</div>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ===== 01 · Brand poster — live wght readout tracking the CSS animation =====
  document.querySelectorAll<HTMLElement>('[data-lnch]').forEach((lnch) => {
    const wLabel = lnch.querySelector('[data-wlabel]') as HTMLElement | null;
    if (!wLabel) return;

    if (reduce) {
      lnch.querySelectorAll<HTMLElement>('[data-flux]').forEach((w, i) => {
        w.style.fontVariationSettings = `'wght' ${i === 0 ? 700 : 900}`;
      });
      wLabel.textContent = '900';
      return;
    }

    const startMs = performance.now();
    let raf = 0;
    function tick() {
      const t = (performance.now() - startMs) / 1000;
      const p0 = 0.5 + 0.5 * Math.sin(t * (Math.PI / 6));
      const p1 = 0.5 + 0.5 * Math.sin((t + 2.2) * (Math.PI / 6));
      const w0 = Math.round(200 + p0 * 700);
      const w1 = Math.round(200 + p1 * 700);
      wLabel.textContent = String(Math.max(w0, w1));
      raf = requestAnimationFrame(tick);
    }
    raf = requestAnimationFrame(tick);

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((ents) => {
        ents.forEach((en) => {
          if (en.isIntersecting) { if (!raf) raf = requestAnimationFrame(tick); }
          else { cancelAnimationFrame(raf); raf = 0; }
        });
      }, { threshold: 0.05 });
      io.observe(lnch);
    }
  });

  // ===== 02 · Music streaming UI =====
  document.querySelectorAll<HTMLElement>('[data-strm]').forEach((strm) => {
    const nArtist = strm.querySelector('[data-nartist]') as HTMLElement | null;
    const nTitle = strm.querySelector('[data-ntitle]') as HTMLElement | null;
    const durEl = strm.querySelector('[data-dur]') as HTMLElement | null;
    const fillEl = strm.querySelector('[data-fill]') as HTMLElement | null;
    const elapsedEl = strm.querySelector('[data-elapsed]') as HTMLElement | null;

    let progressPct = 0.28;
    let totalSecs = 378; // default first track
    let playInterval = 0;

    function parseTime(dur: string): number {
      const parts = dur.split(':');
      return parseInt(parts[0]) * 60 + parseInt(parts[1] || '0');
    }

    function startProgress() {
      if (reduce) return;
      clearInterval(playInterval);
      playInterval = window.setInterval(() => {
        progressPct = Math.min(1, progressPct + 0.004);
        if (fillEl) fillEl.style.width = (progressPct * 100) + '%';
        if (elapsedEl) {
          const elapsed = Math.round(progressPct * totalSecs);
          elapsedEl.textContent = `${Math.floor(elapsed / 60)}:${String(elapsed % 60).padStart(2, '0')}`;
        }
        if (progressPct >= 1) { progressPct = 0; clearInterval(playInterval); }
      }, 200);
    }

    function selectTrack(row: HTMLButtonElement) {
      const title = row.dataset.title || '';
      const dur = row.dataset.dur || '0:00';
      const artist = row.dataset.artist || '';
      if (nArtist) nArtist.textContent = artist;
      if (nTitle) nTitle.textContent = title;
      if (durEl) durEl.textContent = dur;
      totalSecs = parseTime(dur);
      progressPct = 0;
      if (fillEl) fillEl.style.width = '0%';
      // update row states
      strm.querySelectorAll<HTMLButtonElement>('[data-track]').forEach((r) => {
        const same = r.dataset.key === row.dataset.key;
        r.classList.toggle('is-playing', same);
        r.setAttribute('aria-pressed', same ? 'true' : 'false');
      });
      startProgress();
    }

    strm.querySelectorAll<HTMLButtonElement>('[data-album]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.album!;
        strm.querySelectorAll('[data-album]').forEach((b) => {
          b.classList.remove('is-on');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('is-on');
        btn.setAttribute('aria-selected', 'true');
        strm.querySelectorAll('[data-panel]').forEach((p) => {
          (p as HTMLElement).classList.toggle('is-on', (p as HTMLElement).dataset.panel === id);
        });
        // auto-play first track of new album
        const first = strm.querySelector<HTMLButtonElement>(`[data-panel="${id}"] [data-track="0"]`);
        if (first) selectTrack(first);
      });
    });

    strm.querySelectorAll<HTMLButtonElement>('[data-track]').forEach((row) => {
      row.addEventListener('click', () => selectTrack(row));
    });

    strm.querySelectorAll<HTMLButtonElement>('[data-play]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const playing = btn.classList.toggle('is-playing');
        btn.textContent = playing ? '▊▊' : '▶';
        if (playing) startProgress();
        else clearInterval(playInterval);
      });
    });

    startProgress();
  });

  // ===== 03 · Kinetic editorial — pointer drives wght =====
  document.querySelectorAll<HTMLElement>('[data-kn]').forEach((kn) => {
    const words = Array.from(kn.querySelectorAll<HTMLElement>('[data-kw]'));
    const readout = kn.querySelector('[data-kreadout]') as HTMLElement | null;
    const bgLetter = kn.querySelector('[data-kbg]') as HTMLElement | null;
    const MIN = 200, MAX = 900;

    let target = 0.5;
    let pointerActive = false;
    const cur = words.map(() => 0.5);
    let bgCur = 0.5;

    function apply() {
      words.forEach((w, i) => {
        const wght = Math.round(MIN + cur[i] * (MAX - MIN));
        w.style.fontVariationSettings = `'wght' ${wght}`;
      });
      if (readout) readout.textContent = String(Math.round(MIN + cur[0] * (MAX - MIN)));
      // bg letter uses inverted weight so it contrasts the words
      if (bgLetter) {
        const bgWght = Math.round(MIN + (1 - bgCur) * (MAX - MIN));
        bgLetter.style.fontVariationSettings = `'wght' ${bgWght}`;
      }
    }

    kn.addEventListener('pointermove', (e) => {
      const rect = kn.getBoundingClientRect();
      target = Math.min(1, Math.max(0, (e.clientX - rect.left) / rect.width));
      pointerActive = true;
    });
    kn.addEventListener('pointerleave', () => { pointerActive = false; });

    if (reduce) {
      cur.forEach((_, i) => (cur[i] = 0.7 - i * 0.15));
      bgCur = 0.5;
      apply();
      return;
    }

    let raf = 0;
    function tick(ts: number) {
      if (!pointerActive) {
        target = 0.5 + 0.45 * Math.sin(ts / 1000 * 0.6);
      }
      cur.forEach((v, i) => {
        const ease = Math.max(0.04, 0.14 - i * 0.035);
        cur[i] = v + (target - v) * ease;
      });
      bgCur = bgCur + (target - bgCur) * 0.06;
      apply();
      raf = requestAnimationFrame(tick);
    }
    raf = requestAnimationFrame(tick);

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((ents) => {
        ents.forEach((en) => {
          if (en.isIntersecting) { if (!raf) raf = requestAnimationFrame(tick); }
          else { cancelAnimationFrame(raf); raf = 0; }
        });
      }, { threshold: 0.05 });
      io.observe(kn);
    }
  });
</script>

<style>
  .iu__item { margin: 0; }
  .iu__hint { margin-top: var(--sp-2); color: var(--fg-3); }
  .iu * { font-family: var(--fam); }

  /* shared scene framing */
  .iu__scene {
    container-type: inline-size;
    position: relative;
    border: clamp(22px, 3.4vw, 44px) solid var(--bg-2);
    outline: 1px solid var(--line);
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--bg-2);
  }
  .iu__scene * { font-family: var(--fam); }
  .scene16 { aspect-ratio: 16 / 9; }
  .scene-tall { aspect-ratio: 4 / 5; }
  @container (min-width: 720px) { .scene-tall { aspect-ratio: 5 / 7; } }

  .iu__scene--console { aspect-ratio: 16 / 10; padding: 0; }
  @media (max-width: 680px) { .iu__scene--console { aspect-ratio: 9 / 16; } }

  /* ============================================================
     01 · BRAND LAUNCH POSTER (kinetic variable weight)
     ============================================================ */
  .lnch {
    position: absolute; inset: 0; background: var(--bg); color: var(--fg);
    padding: 4cqi 5cqi 4cqi; display: flex; flex-direction: column; overflow: hidden;
  }
  .lnch__bg {
    position: absolute; inset: 0; pointer-events: none; overflow: hidden;
  }
  .lnch__orb {
    position: absolute; border-radius: 50%;
    filter: blur(55px); opacity: 0.4;
  }
  .lnch__orb--1 {
    width: 50cqi; height: 50cqi; top: -18cqi; right: -12cqi;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 80%, transparent) 0%, transparent 70%);
  }
  .lnch__orb--2 {
    width: 32cqi; height: 32cqi; bottom: -10cqi; left: 3cqi;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 35%, transparent) 0%, transparent 70%);
  }

  .lnch__top, .lnch__hero, .lnch__foot { position: relative; }
  .lnch__top {
    display: flex; justify-content: space-between; align-items: center; flex: none;
    font-size: 2cqi; letter-spacing: 0.2em; text-transform: uppercase; color: var(--fg-2);
  }
  .lnch__mark {
    display: inline-flex; align-items: center; gap: 1.6cqi;
    font-weight: 700; color: var(--fg); font-size: 2.2cqi;
  }
  .lnch__dot { width: 1.9cqi; height: 1.9cqi; border-radius: 50%; background: var(--accent); flex: none; }
  .lnch__meta { color: var(--fg-3); font-feature-settings: 'tnum'; }

  .lnch__hero { flex: 1; display: flex; flex-direction: column; justify-content: center; position: relative; }
  .lnch__ghost {
    position: absolute; right: -2cqi; top: 50%; transform: translateY(-48%);
    font-size: 52cqi; line-height: 1; font-weight: 200;
    font-variation-settings: 'wght' 200;
    color: transparent;
    -webkit-text-stroke: 1px color-mix(in srgb, var(--accent) 22%, transparent);
    text-stroke: 1px color-mix(in srgb, var(--accent) 22%, transparent);
    letter-spacing: -0.04em; pointer-events: none; user-select: none;
    text-transform: uppercase; z-index: 0;
  }
  .lnch__pre {
    display: block; font-size: 2.2cqi; font-weight: 600; letter-spacing: 0.28em;
    text-transform: uppercase; color: var(--accent); margin-bottom: 1.6cqi;
    position: relative;
  }
  .lnch__head {
    display: flex; flex-direction: column; gap: 0; line-height: 0.86;
    margin: 0; text-transform: uppercase; position: relative;
  }
  .lnch__word {
    font-size: 14cqi; font-weight: 900; letter-spacing: -0.02em;
    font-variation-settings: 'wght' 900;
    white-space: nowrap;
  }
  .lnch__word--accent { color: var(--accent); }
  .lnch__tagline {
    font-size: 2.5cqi; font-weight: 200; letter-spacing: 0.36em;
    font-variation-settings: 'wght' 200;
    text-transform: uppercase; color: var(--fg-3);
    margin: 1.8cqi 0 0; position: relative;
  }
