---
import type { CollectionEntry } from 'astro:content';
import BrandScene from '../BrandScene.astro';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;
---
<div class="iu" style={`--fam:${fam}`}>
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Invitation — the wedding suite</span></figcaption>
    <div class="iu__scene invite-scene">
      <div class="iu__poster invite">
        <span class="inv__eyebrow">together with their families</span>
        <p class="inv__pre">request the pleasure of your company at the marriage of</p>
        <h3 class="inv__names">Eleanor<span class="inv__amp"> &amp; </span>Auguste</h3>
        <div class="inv__rule" aria-hidden="true"><span>✦</span></div>
        <p class="inv__detail">the twelfth of September · half past four<br/>The Old Print Works · Birmingham</p>
        <span class="inv__rsvp">Black Tie · Reply by August</span>
      </div>
    </div>
  </figure>

  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Brand — a couture logotype</span></figcaption>
    <div class="iu__scene brand-scene">
      <BrandScene font={font} variant="wordmark" />
    </div>
  </figure>
</div>

<style>
  .iu__item { margin: 0; }
  .brand-scene { aspect-ratio: 16 / 9; }
  .invite-scene { aspect-ratio: 4 / 5; max-width: 460px; }

  .invite { background: var(--bg); color: var(--fg); display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 2.4cqi; padding: 7cqi 6cqi; }
  .inv__eyebrow { font-size: 2.6cqi; letter-spacing: 0.28em; text-transform: uppercase; color: var(--accent); }
  .inv__pre { font-size: 3.2cqi; font-style: italic; color: var(--fg-2); max-width: 78%; }
  .inv__names { font-size: 16cqi; line-height: 0.95; font-weight: 500; }
  .inv__amp { font-style: italic; color: var(--accent); }
  .inv__rule { display: flex; align-items: center; gap: 2cqi; width: 44%; color: var(--accent); }
  .inv__rule::before, .inv__rule::after { content: ''; flex: 1; height: 1px; background: currentColor; opacity: 0.5; }
  .inv__detail { font-size: 3cqi; line-height: 1.7; color: var(--fg-2); }
  .inv__rsvp { font-size: 2.2cqi; letter-spacing: 0.2em; text-transform: uppercase; color: var(--fg-3); margin-top: 1cqi; }
</style>
