---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// ── The sequence ─────────────────────────────────────────────────────────────
// A DISPLAY GARAMOND ONLY LIVES ABOVE A CERTAIN SIZE — five acts about that law.
// Night-green commerce (01) → the cream wedding table it actually rules (02) →
// the slow-living magazine that tells the astronomer's story (03) → back to the
// night for the instrument that PROVES the law (04) → and the wedding gone
// digital, the face's real modern habitat (05). Cream ↔ deep green alternate;
// the proof-marker's red appears only as warning ink (02's proof, 04's
// forbidden zone).
//
// Honesty notes — verified against the fontsource latin woff2s (fontTools):
// · STATIC family. No fvar, no axes. Weights 300–700 roman; ITALIC IS LOADED
//   ONLY AT 400 & 600 (Layout.astro) — no other italic weight is ever set.
// · GSUB: calt ccmp dnom frac liga lnum locl numr tnum (+pnum italic only).
//   NO dlig / onum / sups / smcp / swsh in this build — never claimed below,
//   even though the frontmatter lists some. The mdx is wrong; the file rules.
// · DEFAULT FIGURES ARE PROPORTIONAL OLD-STYLE — 3 5 7 9 truly hang (yMin
//   −276 vs −13 overshoot elsewhere). `lnum` maps to .lf lining alternates,
//   `tnum` makes them tabular. That pair is the only figures story told.
// · `liga` (on by default) carries T_T, T_h, g_g and the full f-set
//   (ff fi fl ffi ffl fft fb fh fk ft …) — Th, TT, ffl are performed large.
// · `frac` is real (1/2 → ½ in act 02's menu).
// · mark/mkmk + the flamboyantly tall accents: é è used at display size.

// ── Act 04 — Fournier's bodies (Manuel Typographique, 1764) ─────────────────
// Names + conventional point equivalents. THE FULL TABLE: Fournier's Table des
// Proportions does not stop at Gros Canon — it continues through Double Canon
// (56) to Grosse Nonpareille (96), the true end of the table (Manuel, ch. XVII,
// cf. jacques-andre.fr's digitization), and bodies that large were truly cast.
// The instrument's law therefore hangs on 96, not 44: the letter outruns the
// WHOLE 1764 scale. Positions on the rail are computed live in JS because the
// rail's ceiling adapts to the viewport (the instrument never lies).
const bodies = [
  { pt: 6,  name: 'Nonpareille',        label: true,  cls: '' },
  { pt: 12, name: 'Cicéro',             label: true,  cls: '' },
  { pt: 14, name: 'Saint-Augustin',     label: false, cls: '' },
  { pt: 18, name: 'Gros Romain',        label: false, cls: '' },
  { pt: 22, name: 'Gros Parangon',      label: false, cls: '' },
  { pt: 28, name: 'Petit Canon',        label: true,  cls: '' },
  { pt: 44, name: 'Gros Canon',         label: false, cls: '' },
  { pt: 56, name: 'Double Canon',       label: true,  cls: 'cgi__tick--tight' },
  { pt: 96, name: 'Grosse Nonpareille', label: true,  cls: 'cgi__tick--wrap' },
];

// ── Act 05 — supper choices ──────────────────────────────────────────────────
const suppers = [
  { id: 'mer',    dish: 'Loup de mer en croûte de sel',  note: 'fenouil confit, beurre blanc',  card: 'le loup de mer' },
  { id: 'boeuf',  dish: 'Filet de bœuf, jus au thym',    note: 'pommes de terre écrasées',      card: 'le filet de bœuf' },
  { id: 'potager',dish: 'Légumes du potager',            note: 'artichauts en barigoule',       card: 'les légumes du potager' },
];
---

<div class="iu cg" style={`--fam:${fam}`}>

  <!-- ════════════════════════════════════════════════════════════════════
       01 · ILLUSTRATION & COMMERCIAL — the perfume launch page.
       Reference: the Draeger Frères lineage — the Paris luxury printers
       who pressed the catalogues and announcement pages of Hermès and
       Lanvin — type-as-the-picture, no photograph, one ligature doing the
       work of an image. The ffl of L'Effleurement is a single glyph
       reaching across three letters; the scent's italic ghost lifts off
       the word like vapour.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Commercial — a perfume launch page, in the Draeger Frères lineage</span></figcaption>
    <div class="iu__scene cgp">
      <div class="cgp__in" lang="fr">
        <header class="cgp__top">
          <span class="cgp__house">AUBIER &amp; CIE</span>
          <span class="cgp__trade">parfumeurs · Paris &amp; Grasse</span>
          <span class="cgp__since"><em>depuis</em> 1893</span>
        </header>
        <div class="cgp__hero">
          <span class="cgp__over">le nouveau parfum</span>
          <h3 class="cgp__word">
            <span class="cgp__ghost" aria-hidden="true">L&rsquo;Effleurement</span>
            <span class="cgp__ink">L&rsquo;E<span class="cgp__ffl">ffl<i class="cgp__fflnote" aria-hidden="true">un seul caract&egrave;re &mdash; one sort, three letters</i></span>eurement</span>
          </h3>
          <span class="cgp__under">EXTRAIT DE PARFUM</span>
        </div>
        <div class="cgp__pyr" aria-label="La pyramide olfactive">
          <p class="cgp__pnote cgp__pnote--1"><span>notes de t&ecirc;te</span>bergamote, feuille de figuier</p>
          <p class="cgp__pnote cgp__pnote--2"><span>notes de c&oelig;ur</span>iris pallida, h&eacute;liotrope</p>
          <p class="cgp__pnote cgp__pnote--3"><span>notes de fond</span>santal, encens, musc blanc</p>
        </div>
        <p class="cgp__claim">Trois gouttes au creux du poignet, &agrave; la nuit tomb&eacute;e&nbsp;— il ne parle qu&rsquo;une fois, et jamais &agrave; voix haute.</p>
        <footer class="cgp__foot">
          <span>30&nbsp;ml &middot; flacon n&ordm;&nbsp;3, verre souffl&eacute; &agrave; Biot</span>
          <span class="cgp__flacon" aria-hidden="true">
            <i class="cgp__fl-stopper"></i>
            <i class="cgp__fl-neck"></i>
            <b class="cgp__fl-body">n&ordm;&thinsp;3</b>
          </span>
          <span>imprim&eacute; &agrave; Paris par Draeger&nbsp;Fr&egrave;res</span>
        </footer>
      </div>
    </div>
    <p class="iu__hint label">No photograph — in the manner of the great Paris luxury printers, the type is the picture. The <em>ffl</em> of <em>L&rsquo;Effleurement</em> is one ligature reaching across three letters — traced beneath the word, one cell per letter, so the single sort is seen rather than asserted. The pyramid steps the italic through three sizes, t&ecirc;te to fond, as the Draeger catalogues did; its ghost rises off the word like vapour, opening its letter-fit as it lifts (and holds still under reduced motion). The flacon in the imprint is drawn from hairline rules — the maison&rsquo;s own mark.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       02 · BRANDING & IDENTITY — the engraved wedding suite.
       Reference: the engraver's social-stationery etiquette codified by
       Crane & Co. — dates spelled out to the last letter, the reply card's
       "M ___" line — because the wedding world is where Cormorant actually
       lives (the mdx says so). The couple's cipher is the face's own T_T
       ligature; toggle the proof and the engraver circles the evidence
       in red.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click="[data-proof-btn]">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Branding — the wedding suite, set to the engraver&rsquo;s etiquette</span></figcaption>
    <div class="iu__scene cgs-scene">
      <div class="cgs" data-suite data-proof="off">
        <div class="cgs__bench">
          <span class="cgs__benchlabel">Atelier de gravure &middot; la suite compl&egrave;te</span>
          <button class="cgs__prooftab" type="button" data-proof-btn aria-pressed="false">
            <span class="cgs__tab-off">&Eacute;preuve &middot; see the engraver&rsquo;s proof</span>
            <span class="cgs__tab-on">Bon &agrave; tirer &middot; back to fair copy</span>
          </button>
        </div>
        <div class="cgs__lay">
          <div class="cgs__card cgs__invite">
            <span class="cgs__reg" aria-hidden="true"></span>
            <span class="cgs__axis" aria-hidden="true"></span>
            <span class="cgs__cipher" aria-label="cipher of the couple">TT</span>
            <p class="cgs__line cgs__small">Together with their families</p>
            <p class="cgs__name"><span class="cgs__ring" data-n="1">Th</span>&eacute;r&egrave;se Aubier</p>
            <p class="cgs__amp">and</p>
            <p class="cgs__name">Th<span class="cgs__ring cgs__ring--acc" data-n="2">&eacute;</span>odore Maraval</p>
            <p class="cgs__line">request the pleasure of your company<br/>at their marriage</p>
            <p class="cgs__date"><span class="cgs__ring cgs__ring--wide" data-n="3">Saturday, the twentieth of June<br/>two thousand twenty-six</span><br/>at half past four in the afternoon</p>
            <p class="cgs__place">Domaine de la Cormoraie &middot; Grasse</p>
            <p class="cgs__docket" aria-hidden="true">1 &middot; the T&middot;h tied, cast as one sort&ensp;&mdash;&ensp;2 &middot; the accent flies above the cap line&ensp;&mdash;&ensp;3 &middot; figures spelled out, per etiquette</p>
            <span class="cgs__bat" aria-hidden="true">BON &Agrave; TIRER &mdash; &eacute;preuve n&ordm; 2</span>
          </div>
          <div class="cgs__card cgs__menu" lang="fr">
            <span class="cgs__chead">Le D&icirc;ner</span>
            <ul class="cgs__courses">
              <li><b>Loup de mer en cro&ucirc;te de sel</b><i>fenouil confit, beurre blanc</i></li>
              <li><b>Filet de b&oelig;uf, jus au thym</b><i>pommes de terre &eacute;cras&eacute;es</i></li>
              <li><b>Vacherin aux fraises des bois</b><i>une <span class="cgs__ring cgs__ring--frac" data-n="4"><span class="cgs__frac">1/2</span></span> mesure de Chartreuse</i></li>
            </ul>
            <span class="cgs__wines">vins du domaine &mdash; blanc 2019 &middot; rouge 2015</span>
            <span class="cgs__docket cgs__docket--menu" aria-hidden="true">4 &middot; the &frac12; is cut as one fraction (frac), not stacked by hand</span>
          </div>
          <div class="cgs__pair">
            <div class="cgs__card cgs__placecard">
              <span class="cgs__pname">Th&eacute;a Maraval</span>
              <span class="cgs__ptable">Table <span class="cgs__ring cgs__ring--pc" data-n="5">3</span></span>
              <span class="cgs__docket cgs__docket--pc" aria-hidden="true">5 &middot; the 3 hangs below the line, as cast</span>
            </div>
            <div class="cgs__card cgs__reply">
              <span class="cgs__chead cgs__chead--sm">La R&eacute;ponse</span>
              <p class="cgs__rline">The favour of a reply is requested<br/>before the first of May</p>
              <p class="cgs__mline">M<span aria-hidden="true"></span></p>
              <p class="cgs__rchoice"><em>accepts with pleasure</em> &middot; <em>declines with regret</em></p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Cormorant&rsquo;s true habitat — the wedding suite — held to Crane&rsquo;s engraver&rsquo;s etiquette: the date spelled out to the last letter, the reply card&rsquo;s bare <em>M</em> line. The cipher is the face&rsquo;s own <em>TT</em> ligature, the names carry the tied <em>Th</em>, and the only figures on the table hang below the line, as cast. The proof opens itself once as the suite enters view — the engraver audits the whole table, five marks across three cards, the cut <em>&frac12;</em> and the hanging <em>3</em> included; the red stamp on the bench hands it back to fair copy.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       03 · EDITORIAL — the slow-living profile.
       Reference: the Kinfolk / Cereal school of slow editorial (Ouur,
       Copenhagen) — hairline rules, air as material, light display serif,
       a profile of the person whose hands made the thing. The subject is
       the literal truth from this font's story: an astronomer who draws
       type at night. Hanging figures are the default; a chip in the
       colophon flips them to lining (lnum) live.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item" data-shoot-click="[data-fig-btn]">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Editorial — a slow-living profile, in the Kinfolk school</span></figcaption>
    <div class="iu__scene cge" data-mag>
      <header class="cge__band">
        <span class="cge__pub">DEMEURE</span>
        <span class="cge__tag"><em>a quarterly of the slow crafts</em></span>
        <span class="cge__issue">Midsummer &middot; n&ordm; <span class="cge__fig">21</span></span>
      </header>
      <div class="cge__grid">
        <div class="cge__main">
          <span class="cge__kicker">HANDS</span>
          <h3 class="cge__head">The Astronomer<br/><em>of the Small Hours</em></h3>
          <p class="cge__deck">By day, Christian Thalmann studies the sky. At night, when the house goes quiet, he draws the Garamond that metal could never print.</p>
          <div class="cge__body">
            <p><span class="cge__drop">Q</span>uietly, in the slivers of time left over from research and parenthood, the Garamond he wanted began to appear — conceived, drawn, spaced, kerned and produced by one person, then given away to anyone who asks. Faithful revivals already served the book page, where Garamond is exquisite at twelve point. His complaint was the other end of the scale: enlarged to a headline, the old cuts turn clumpy, their forms still braced against spreading ink.</p>
            <p>Cormorant is the answer. The serifs are filed to needles, the counters squeezed scandalously small, the accents drawn tall enough to graze the line above. Every one of those moves would be suicide in metal at six point; on a sharp screen at a hundred, they are the whole point.</p>
          </div>
        </div>
        <aside class="cge__side">
          <div class="cge__giant" aria-label="Folio numeral set at display size — old-style figures hang below the baseline">
            <span class="cge__giantrow" aria-hidden="true"><span class="cge__giantfig cge__fig">85</span><i class="cge__giantrule"></i></span>
            <span class="cge__giantlab">folio &middot; enlarged to the size that breaks the old cuts &mdash; the 8 stands on the baseline, the 5 hangs through it; the footnote below stands its figures up</span>
          </div>
          <blockquote class="cge__quote"><p>&ldquo;Distil the essence of Garamond, free it from metal&nbsp;&mdash; and let it bloom.&rdquo;</p><cite>the brief he set himself, <span class="cge__fig">2015</span></cite></blockquote>
          <dl class="cge__file">
            <div><dt>The face</dt><dd>Cormorant Garamond</dd></div>
            <div><dt>The hand</dt><dd>Christian Thalmann, Catharsis Fonts</dd></div>
            <div><dt>The cut</dt><dd>five weights &middot; two true italics</dd></div>
            <div><dt>The licence</dt><dd>SIL Open Font, <span class="cge__fig">2015</span></dd></div>
          </dl>
        </aside>
      </div>
      <footer class="cge__colo">
        <span class="cge__folio">pages <span class="cge__fig">84</span>&nbsp;&mdash;&nbsp;<span class="cge__fig">85</span></span>
        <button class="cge__figbtn" type="button" data-fig-btn aria-pressed="false">
          <span class="cge__fb-ast" aria-hidden="true">*</span>
          <span class="cge__fb-off">the figures of this page hang below the line, as cast &mdash; press to stand them up (lnum)</span>
          <span class="cge__fb-on">the figures stand as lining alternates (lnum) &mdash; press to let them hang again</span>
        </button>
      </footer>
    </div>
    <p class="iu__hint label">The Kinfolk school — hairline rules, air as material, a light serif doing the talking — telling this face&rsquo;s own true story, and taking the one display risk the school allows: the folio enlarged to headline size, enacting the article&rsquo;s thesis on the very page that argues it. The <em>Th</em> of the headline is one tied glyph; the drop cap is the famous flowing-tailed Q. Every numeral hangs below the line because old-style figures are this font&rsquo;s default — the folio&rsquo;s baseline is drawn clear across the sidebar, so the 8 visibly stands on it and the 5 hangs through it; press the asterisked footnote in the colophon and <em>lnum</em> stands them all up live, the giant <em>85</em> included.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       04 · INTERACTIVE & EXPERIMENTAL — the scale of bodies, run off the table.
       Reference: Pierre-Simon Fournier's Table des Proportions (Manuel
       Typographique, 1764) — the first standardized scale of type bodies,
       running Nonpareille (6) through Double Canon (56) to Grosse
       Nonpareille (96) — rebuilt as an instrument and run PAST its own end.
       Drag the rail: below Cicéro the prover's red declares the letter
       forbidden; past Grosse Nonpareille the letter leaves the entire 1764
       table behind.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click="[data-body='6']">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Experimental — the scale of bodies, after Fournier, run off the end of his table</span></figcaption>
    <div class="iu__scene cgi">
      <div class="cgi__in" data-inst>
        <header class="cgi__top">
          <span class="cgi__title">LA TAILLE</span>
          <span class="cgi__ref"><em>an instrument after Fournier&rsquo;s</em> Table des Proportions, <span class="cgi__lf">1764</span></span>
          <span class="cgi__law">the table ends at Grosse Nonpareille, <span class="cgi__lf">96</span> &middot; this letter outruns it</span>
        </header>
        <div class="cgi__stage">
          <span class="cgi__reticle" aria-hidden="true"></span>
          <span class="cgi__word" data-word>souffle</span>
        </div>
        <div class="cgi__read">
          <span class="cgi__pt"><b data-pt>120</b><i>pt</i></span>
          <span class="cgi__body-name" data-body-name>&mdash; past Grosse Nonpareille</span>
          <p class="cgi__verdict" data-verdict data-zone="bloom">En fleur. Past Grosse Nonpareille — the end of Fournier&rsquo;s entire table. The scale itself runs out; the serifs come to their points and the counters dare to close. The only country this letter was drawn for.</p>
        </div>
        <div class="cgi__railwrap">
          <div class="cgi__ticks" data-ticks>
            {bodies.map((b) => (
              <button class={`cgi__tick${b.label ? ' cgi__tick--named' : ''}${b.cls ? ` ${b.cls}` : ''}`} type="button" data-body={b.pt} title={`${b.name} · ${b.pt} pt`}>
                <i aria-hidden="true"></i>
                {b.label && <span>{b.name}<b class="cgi__lf">{b.pt}</b></span>}
              </button>
            ))}
            <span class="cgi__beyond" data-beyond aria-hidden="true"><i></i><span>hors table &middot; past Grosse Nonpareille, off the 1764 scale</span></span>
          </div>
          <input class="cgi__rail" type="range" min="0" max="1000" step="1" value="912" data-rail aria-label="Type size, from Nonpareille to beyond metal" />
          <div class="cgi__zones" aria-hidden="true"><i class="cgi__zone-red" data-zone-red></i></div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Fournier&rsquo;s 1764 scale of bodies — Nonpareille through Double Canon to Grosse Nonpareille, <em>96</em>, where the table simply stops — rebuilt as an instrument and run off its own end, the inverse of the 1592 sheet two rooms over. Drag the rail (its ceiling adapts honestly to your viewport, and always clears the table&rsquo;s end): below Cic&eacute;ro the prover&rsquo;s red declares the letter forbidden — counters flood, hairlines fall below the pixel — and past Grosse Nonpareille the letter leaves the entire scale behind. The readout&rsquo;s figures stand up and align because <em>lnum</em> and <em>tnum</em> are real in this file.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       05 · WEB & APP UI — the wedding website's RSVP, live at real px.
       Reference: the contemporary wedding-web current (Zola, Minted,
       Squarespace), where Cormorant Garamond is — measurably — the house
       serif of the entire industry. The same wedding as act 02, gone
       digital: type a name and watch the place card engrave itself.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item" data-shoot-click="[data-send]">
    <figcaption class="iu__cap"><span class="index-num">05</span><span class="label">Web UI — the wedding website&rsquo;s RSVP, live at real scale</span></figcaption>
    <div class="iu__scene">
      <div class="iu__device cgr" data-rsvp>
        <div class="iu__chrome">
          <div class="iu__dots"><i></i><i></i><i></i></div>
          <span class="iu__addr">lacormoraie.fr/juin/rsvp</span>
        </div>
        <header class="cgr__head">
          <span class="cgr__cipher" aria-hidden="true">TT</span>
          <span class="cgr__names">Th&eacute;r&egrave;se <em>&amp;</em> Th&eacute;odore</span>
          <nav class="cgr__nav" aria-label="Wedding site">
            <a>Le week-end</a><a>Voyage</a><a>La liste</a><a class="is-here" aria-current="page">RSVP</a>
          </nav>
        </header>
        <div class="cgr__split">
          <form class="cgr__form" data-form>
            <h4 class="cgr__ftitle">R&eacute;ponse</h4>
            <p class="cgr__fsub"><em>by the first of May, s&rsquo;il vous pla&icirc;t</em></p>
            <label class="cgr__lab" for="cgr-name">Your name, as it should be set</label>
            <input class="cgr__input" id="cgr-name" type="text" value="Th&eacute;a Maraval" autocomplete="off" spellcheck="false" data-name />
            <p class="cgr__fnote"><em>engraved as typed &mdash; try Th&eacute;a, Th&eacute;odore, Joffrey, or Steffi</em></p>
            <span class="cgr__lab">Will you join us?</span>
            <div class="cgr__seg" role="group" aria-label="Attendance">
              <button class="is-on" type="button" data-yes aria-pressed="true">With pleasure</button>
              <button type="button" data-no aria-pressed="false">With regret</button>
            </div>
            <span class="cgr__lab">Choose your supper</span>
            <div class="cgr__menu" role="radiogroup" aria-label="Supper">
              {suppers.map((s, i) => (
                <label class="cgr__dish">
                  <input type="radio" name="cgr-supper" value={s.id} checked={i === 0} data-dish={s.card} />
                  <span class="cgr__dishname">{s.dish}</span>
                  <span class="cgr__dishnote"><em>{s.note}</em></span>
                </label>
              ))}
            </div>
            <button class="cgr__send" type="button" data-send>Seal the reply</button>
          </form>
          <div class="cgr__sealed" data-sealed hidden>
            <div class="cgr__bigcard" aria-label="The engraved place card">
              <span class="cgr__bigcipher" aria-hidden="true">TT</span>
              <span class="cgr__bigname" data-echo-name>Th&eacute;a Maraval</span>
              <span class="cgr__bigtable cgr__seal-yes">Table <span class="cgr__os">3</span> &middot; beneath the lindens</span>
              <span class="cgr__bigdish cgr__seal-yes" data-card-dish>le loup de mer</span>
              <span class="cgr__bigregret cgr__seal-no"><em>we will drink your share &mdash; you will be missed</em></span>
            </div>
            <p class="cgr__sealline"><span class="cgr__seal-yes">Sealed &mdash; the card goes to the engraver; the cellar has been warned.</span><span class="cgr__seal-no">Sealed, with a sigh.</span></p>
            <button class="cgr__again" type="button" data-again>amend the reply</button>
          </div>
          <aside class="cgr__side">
            <div class="cgr__card" aria-label="Place card preview">
              <span class="cgr__ccipher" aria-hidden="true">TT</span>
              <span class="cgr__cname" data-card-name>Th&eacute;a Maraval</span>
              <span class="cgr__ctable">Table <span class="cgr__os">3</span></span>
              <span class="cgr__cdish" data-card-dish>le loup de mer</span>
            </div>
            <div class="cgr__sched">
              <span class="cgr__schedhead">Le programme &middot; samedi</span>
              <ul>
                <li><span>c&eacute;r&eacute;monie, beneath the lindens</span><i class="cgr__lead" aria-hidden="true"></i><b class="cgr__lf">16.30</b></li>
                <li><span>ap&eacute;ritif on the terrace</span><i class="cgr__lead" aria-hidden="true"></i><b class="cgr__lf">18.00</b></li>
                <li><span>supper &amp; toasts</span><i class="cgr__lead" aria-hidden="true"></i><b class="cgr__lf">20.00</b></li>
                <li><span>brandy, for the brave</span><i class="cgr__lead" aria-hidden="true"></i><b class="cgr__lf">00.30</b></li>
              </ul>
            </div>
          </aside>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Cormorant is, demonstrably, the house serif of the wedding web (the Zola / Minted / Squarespace current) — so here is that artifact done properly, at true interface scale. Type a name and the place card engraves itself live; seal the reply and the card is rendered writ large — the engraving idea completing on screen, hairlines at display size inside the interface itself. The programme&rsquo;s times stand up and align (<em>lnum&nbsp;tnum</em>); the cards keep the hanging defaults.</p>
  </figure>

</div>

<script>
  // ── 02 · the engraver's proof ─────────────────────────────────────────────
  // The proof opens ITSELF once, the first time the suite enters the viewport —
  // the act's best idea should not hide behind a link. A state change, not
  // motion (transitions are already stilled under prefers-reduced-motion).
  document.querySelectorAll<HTMLElement>('[data-suite]').forEach((suite) => {
    const btn = suite.querySelector<HTMLButtonElement>('[data-proof-btn]')!;
    const set = (on: boolean) => {
      suite.dataset.proof = on ? 'on' : 'off';
      btn.setAttribute('aria-pressed', String(on));
    };
    btn.addEventListener('click', () => set(suite.dataset.proof !== 'on'));
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        io.disconnect();
        if (suite.dataset.proof !== 'on') set(true);
      });
    }, { threshold: 0.4 });
    io.observe(suite);
  });

  // ── 03 · hanging ↔ lining figures ────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-mag]').forEach((mag) => {
    const btn = mag.querySelector<HTMLButtonElement>('[data-fig-btn]')!;
    btn.addEventListener('click', () => {
      const on = mag.classList.toggle('is-lining');
      btn.setAttribute('aria-pressed', String(on));
    });
  });

  // ── 04 · the instrument ───────────────────────────────────────────────────
  // pt maps exponentially along the rail: pt = 6 · (max/6)^(v/1000).
  // The ceiling adapts to the word's measured width so the readout NEVER
  // claims a size the stage can't truly show.
  document.querySelectorAll<HTMLElement>('[data-inst]').forEach((inst) => {
    const word = inst.querySelector<HTMLElement>('[data-word]')!;
    const rail = inst.querySelector<HTMLInputElement>('[data-rail]')!;
    const ptOut = inst.querySelector<HTMLElement>('[data-pt]')!;
    const bodyName = inst.querySelector<HTMLElement>('[data-body-name]')!;
    const verdict = inst.querySelector<HTMLElement>('[data-verdict]')!;
    const beyond = inst.querySelector<HTMLElement>('[data-beyond]')!;
    const zoneRed = inst.querySelector<HTMLElement>('[data-zone-red]')!;
    const ticks = Array.from(inst.querySelectorAll<HTMLButtonElement>('[data-body]'));

    const MIN = 6;
    let MAX = 160;
    let emW = 4; // word width in em, measured

    const NAMES: [number, string][] = [
      [6, 'Nonpareille'], [12, 'Cicéro'], [14, 'Saint-Augustin'], [18, 'Gros Romain'],
      [22, 'Gros Parangon'], [28, 'Petit Canon'], [44, 'Gros Canon'],
      [56, 'Double Canon'], [96, 'Grosse Nonpareille'],
    ];
    const nearName = (pt: number) => {
      if (pt > 96) return '— past Grosse Nonpareille';
      let best = NAMES[0];
      for (const n of NAMES) if (Math.abs(n[0] - pt) < Math.abs(best[0] - pt)) best = n;
      return `≈ ${best[1]}`;
    };
    const VERDICTS = {
      red: 'Interdit. At the bodies of the book the counters flood and the hairlines fall below the pixel — set a book Garamond here, never this one.',
      dim: 'Survivable, joyless. These are the bodies the old cuts were braced for; Cormorant keeps its needles sheathed and waits.',
      grand: 'Les grands corps. Gros Canon, Double Canon, Grosse Nonpareille — the table runs all the way to 96, and the founders truly cast these giants. The needles begin to show; metal still owns the names.',
      bloom: 'En fleur. Past Grosse Nonpareille — the end of Fournier’s entire table. The scale itself runs out; the serifs come to their points and the counters dare to close. The only country this letter was drawn for.',
    };

    const toPt = (v: number) => MIN * Math.pow(MAX / MIN, v / 1000);
    const toV = (pt: number) => Math.round(1000 * Math.log(pt / MIN) / Math.log(MAX / MIN));
    const pos = (pt: number) => (100 * Math.log(pt / MIN)) / Math.log(MAX / MIN);

    const apply = () => {
      const pt = Math.round(toPt(+rail.value));
      word.style.fontSize = `${pt}pt`;
      ptOut.textContent = String(pt);
      bodyName.textContent = nearName(pt);
      const zone = pt < 12 ? 'red' : pt < 44 ? 'dim' : pt <= 96 ? 'grand' : 'bloom';
      if (verdict.dataset.zone !== zone) {
        verdict.dataset.zone = zone;
        verdict.textContent = VERDICTS[zone as keyof typeof VERDICTS];
      }
      inst.dataset.zone = zone;
    };

    const layout = () => {
      // measure the word at a known size, derive the honest ceiling.
      // 'souffle' carries the ffl at full size; where a narrow viewport can't
      // honestly clear the table's end (96), 'été' — two flying accents —
      // takes over, so the whole 1764 scale stays provable on every screen.
      const avail = (word.parentElement as HTMLElement).clientWidth * 0.96;
      const prev = word.style.fontSize;
      word.style.fontSize = '100px';
      const fit = (txt: string) => {
        if (word.textContent !== txt) word.textContent = txt;
        emW = word.scrollWidth / 100;
        return Math.max(48, Math.min(160, Math.floor((avail * 3) / (emW * 4) / 1.02)));
      };
      MAX = fit('souffle');
      if (MAX < 110) MAX = fit('été');
      word.style.fontSize = prev;
      // place the ticks; hide those past the ceiling
      ticks.forEach((t) => {
        const pt = +t.dataset.body!;
        t.style.left = `${pos(pt)}%`;
        t.hidden = pt > MAX;
      });
      const end = pos(96);
      beyond.hidden = end > 98;
      beyond.style.left = `${end}%`;
      beyond.style.width = `${100 - end}%`;
      zoneRed.style.width = `${pos(12)}%`;
      apply();
    };

    ticks.forEach((t) =>
      t.addEventListener('click', () => {
        rail.value = String(toV(+t.dataset.body!));
        apply();
      })
    );
    rail.addEventListener('input', apply);
    new ResizeObserver(layout).observe(inst);
    document.fonts?.ready.then(layout);
    layout();
  });

  // ── 05 · the RSVP ─────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-rsvp]').forEach((rsvp) => {
    const nameIn = rsvp.querySelector<HTMLInputElement>('[data-name]')!;
    const cardName = rsvp.querySelector<HTMLElement>('[data-card-name]')!;
    const cardDishes = Array.from(rsvp.querySelectorAll<HTMLElement>('[data-card-dish]'));
    const echoes = Array.from(rsvp.querySelectorAll<HTMLElement>('[data-echo-name]'));
    const form = rsvp.querySelector<HTMLElement>('[data-form]')!;
    const sealed = rsvp.querySelector<HTMLElement>('[data-sealed]')!;
    const yes = rsvp.querySelector<HTMLButtonElement>('[data-yes]')!;
    const no = rsvp.querySelector<HTMLButtonElement>('[data-no]')!;
    let attending = true;

    const reflectName = () => {
      const v = nameIn.value.trim() || 'A. Guest';
      cardName.textContent = v;
      echoes.forEach((e) => (e.textContent = v));
    };
    nameIn.addEventListener('input', reflectName);

    [yes, no].forEach((b) =>
      b.addEventListener('click', () => {
        attending = b === yes;
        yes.classList.toggle('is-on', attending);
        no.classList.toggle('is-on', !attending);
        yes.setAttribute('aria-pressed', String(attending));
        no.setAttribute('aria-pressed', String(!attending));
        rsvp.classList.toggle('is-regret', !attending);
      })
    );

    rsvp.querySelectorAll<HTMLInputElement>('[data-dish]').forEach((r) =>
      r.addEventListener('change', () => {
        if (r.checked) cardDishes.forEach((d) => (d.textContent = r.dataset.dish!));
      })
    );

    rsvp.querySelector<HTMLButtonElement>('[data-send]')!.addEventListener('click', () => {
      reflectName();
      form.hidden = true;
      sealed.hidden = false;
      rsvp.classList.add('is-sent');
    });
    rsvp.querySelector<HTMLButtonElement>('[data-again]')!.addEventListener('click', () => {
      sealed.hidden = true;
      form.hidden = false;
      rsvp.classList.remove('is-sent');
    });
  });
</script>

<style>
  /* ── the stack: paced tighter than default; night ↔ cream alternation ──── */
  .cg { gap: clamp(3.25rem, 8vh, 5.75rem); }
  .iu__hint { margin-top: var(--sp-2); color: var(--fg-3); }
  .iu__hint em { font-style: italic; }
  .iu__scene { font-family: var(--fam); }
  .iu__scene :is(button, input, a) { font-family: inherit; }
  .iu__scene .iu__addr { font-family: var(--font-mono); }
  .iu__scene ::selection { background: color-mix(in srgb, var(--accent) 26%, transparent); }

  /* the night surfaces (01 & 04) declare themselves fully — both modes */
  .cgp, .cgi { --nt: #16241b; --nt-2: #1e3126; --cream: #f0e7d3; --cream-dim: #b3ab92; --red: #d4674a; }

  /* ════════════════════════════════════════════════════════════════════
     01 · L'EFFLEUREMENT — type as the picture, on the night field
     ════════════════════════════════════════════════════════════════════ */
  .cgp {
    background: radial-gradient(120% 95% at 50% 0%, var(--nt-2) 0%, var(--nt) 62%, #101a13 100%);
    color: var(--cream);
  }
  .cgp__in {
    max-width: 1240px; margin-inline: auto; min-height: clamp(520px, 78vh, 760px);
    display: flex; flex-direction: column;
    padding: clamp(1.6rem, 3.4cqi, 3.2rem) clamp(1.2rem, 4.5cqi, 4.5rem) clamp(1.6rem, 3.2cqi, 3rem);
  }
  .cgp__top {
    display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;
    padding-bottom: clamp(0.8rem, 1.6cqi, 1.4rem); border-bottom: 1px solid #f0e7d326;
  }
  .cgp__house { font-size: clamp(13px, 1.5cqi, 20px); font-weight: 500; letter-spacing: 0.3em; text-indent: 0.3em; }
  .cgp__trade { font-size: clamp(11px, 1.15cqi, 15px); font-style: italic; color: var(--cream-dim); }
  .cgp__since { font-size: clamp(11px, 1.2cqi, 16px); color: var(--cream-dim); }
  .cgp__since em { font-style: italic; }

  .cgp__hero { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding-block: clamp(1rem, 3cqi, 3rem); }
  .cgp__over { font-size: clamp(13px, 1.7cqi, 23px); font-style: italic; color: var(--cream-dim); }
  .cgp__word { position: relative; margin: 0.05em 0 0; display: grid; line-height: 1.04; font-weight: 400; font-style: italic; font-size: clamp(46px, 11.4cqi, 162px); letter-spacing: 0.002em; }
  .cgp__ink { grid-area: 1 / 1; white-space: nowrap; }
  /* the ghost is lifted out of the grid so its opening letter-fit never
     reflows the ink beneath it */
  .cgp__ghost { position: absolute; left: 50%; top: 0; transform: translateX(-50%); white-space: nowrap; opacity: 0; color: var(--cream); pointer-events: none; }
  @media (prefers-reduced-motion: no-preference) {
    .cgp__ghost { animation: cgp-vapor 9s var(--ease) infinite; }
    @keyframes cgp-vapor {
      0%, 18% { opacity: 0; letter-spacing: 0.002em; transform: translateX(-50%); }
      45% { opacity: 0.3; }
      78%, 100% { opacity: 0; letter-spacing: 0.013em; transform: translateX(-50%) translateY(-13%) scale(1.015); }
    }
  }

  /* the act's focal idea, staged: the f_f_l span traced as one sort of
     three letters — a hairline rule divided into three cells beneath it,
     with the engraver's sidenote */
  .cgp__ffl { position: relative; }
  .cgp__ffl::before {
    content: ''; position: absolute; left: -0.1em; right: 0.005em; bottom: -0.068em; height: 0.055em;
    border-bottom: 1px solid #f0e7d38c;
    background:
      linear-gradient(#f0e7d38c, #f0e7d38c) 0 100% / 1px 100% no-repeat,
      linear-gradient(#f0e7d38c, #f0e7d38c) 33.4% 100% / 1px 100% no-repeat,
      linear-gradient(#f0e7d38c, #f0e7d38c) 66.7% 100% / 1px 100% no-repeat,
      linear-gradient(#f0e7d38c, #f0e7d38c) 100% 100% / 1px 100% no-repeat;
    pointer-events: none;
  }
  .cgp__fflnote {
    /* the +offset is in container units: this element's own em is tiny, the
       ligature's em is huge — cqi tracks the word's cqi-driven size */
    position: absolute; left: 50%; top: calc(100% + 1.25cqi); transform: translateX(-50%);
    font-size: clamp(9.5px, 1cqi, 13.5px); font-style: italic; font-weight: 400; line-height: 1;
    letter-spacing: 0.03em; white-space: nowrap; color: var(--cream-dim);
  }
  .cgp__under { margin-top: clamp(2rem, 3.9cqi, 3.7rem); font-size: clamp(11px, 1.25cqi, 17px); letter-spacing: 0.46em; text-indent: 0.46em; color: var(--cream-dim); }

  /* the pyramid — Draeger catalogue furniture: the italic stepped through
     three sizes, tête to fond */
  .cgp__pyr { display: flex; flex-direction: column; align-items: center; gap: clamp(0.4rem, 0.9cqi, 0.8rem); margin: 0 auto clamp(1.5rem, 3cqi, 2.8rem); text-align: center; }
  .cgp__pnote { margin: 0; font-style: italic; line-height: 1.25; color: var(--cream); }
  .cgp__pnote span { color: var(--cream-dim); }
  .cgp__pnote span::after { content: '\2002\2014\2002'; color: var(--cream-dim); }
  .cgp__pnote--1 { font-size: clamp(12.5px, 1.45cqi, 19px); }
  .cgp__pnote--2 { font-size: clamp(14.5px, 1.85cqi, 25px); }
  .cgp__pnote--3 { font-size: clamp(17px, 2.35cqi, 32px); }

  .cgp__claim {
    margin: 0 auto clamp(1.2rem, 2.6cqi, 2.4rem); max-width: 44ch; text-align: center;
    font-size: clamp(14px, 1.65cqi, 22px); line-height: 1.5; font-style: italic; color: var(--cream);
  }
  .cgp__foot {
    display: flex; justify-content: space-between; align-items: center; gap: 1rem;
    padding-top: clamp(0.8rem, 1.5cqi, 1.3rem); border-top: 1px solid #f0e7d326;
    font-size: clamp(11px, 1.15cqi, 15px); color: var(--cream-dim);
  }
  /* the maison's mark: a flacon drawn entirely from hairline rules, nº 3 on
     its belly — Draeger pages carried the house device, never a dingbat */
  .cgp__flacon { display: flex; flex-direction: column; align-items: center; gap: 3px; }
  .cgp__fl-stopper { width: 11px; border-top: 1px solid #f0e7d3a0; }
  .cgp__fl-neck { width: 7px; height: 6px; border-left: 1px solid #f0e7d3a0; border-right: 1px solid #f0e7d3a0; }
  .cgp__fl-body {
    width: 36px; height: 34px; border: 1px solid #f0e7d3a0;
    display: grid; place-items: center;
    font-weight: 400; font-style: italic; font-size: 13.5px; color: var(--cream);
  }

  /* ════════════════════════════════════════════════════════════════════
     02 · THE WEDDING SUITE — cream cards on the engraver's linen
     ════════════════════════════════════════════════════════════════════ */
  /* the suite declares its daylight fully: linen table, cream stock, iron-gall
     ink, the engraver's red — intentional in both site modes */
  .cgs-scene { background: #e2d9c2; }
  .cgs {
    --linen: #e2d9c2; --stock: #f9f4e6; --ink: #2b2316; --soft: #7c7058;
    --green: #36513f; --proof-red: #a23524;
    background:
      repeating-linear-gradient(0deg, transparent 0 5px, #2b231608 5px 6px),
      repeating-linear-gradient(90deg, transparent 0 5px, #2b231605 5px 6px),
      var(--linen);
    color: var(--ink);
    padding: clamp(1.4rem, 3cqi, 2.6rem) clamp(1rem, 4cqi, 4rem) clamp(1.8rem, 3.6cqi, 3.4rem);
  }
  .cgs__bench {
    max-width: 1180px; margin: 0 auto clamp(1.1rem, 2.2cqi, 1.8rem);
    display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;
  }
  .cgs__benchlabel { font-size: clamp(11px, 1.2cqi, 14px); letter-spacing: 0.26em; text-transform: uppercase; color: var(--soft); }
  /* the proof tab is a red stamp on the bench, not a shy italic link */
  .cgs__prooftab {
    font-size: clamp(10.5px, 1.1cqi, 13px); letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--proof-red); background: transparent;
    border: 1px solid #a23524aa; padding: 0.5em 1em; cursor: pointer;
    transform: rotate(-1.4deg);
  }
  .cgs__prooftab:hover { background: #a2352414; border-color: var(--proof-red); }
  .cgs__tab-on { display: none; }
  .cgs[data-proof='on'] .cgs__tab-off { display: none; }
  .cgs[data-proof='on'] .cgs__tab-on { display: inline; }

  .cgs__lay {
    max-width: 1180px; margin-inline: auto;
    display: grid; grid-template-columns: minmax(0, 54%) 1fr;
    grid-template-rows: 1fr auto;
    gap: clamp(1rem, 2.4cqi, 2.2rem); align-items: stretch;
  }
  .cgs__card {
    background: var(--stock); color: var(--ink);
    box-shadow: 0 16px 30px -18px rgba(43, 35, 22, 0.55), 0 2px 6px rgba(43, 35, 22, 0.12);
    container-type: inline-size;
  }

  /* the invitation */
  .cgs__invite {
    position: relative; text-align: center;
    padding: 9cqi 7cqi 8cqi;
  }
  /* the cipher is the T_T sort; its joined crossbar carries the kern — what
     we tune optically is its fit against the line below */
  .cgs__cipher { display: block; font-size: 11.6cqi; line-height: 0.88; color: var(--green); font-weight: 400; }
  .cgs__small { font-size: 3.2cqi; letter-spacing: 0.12em; margin: 4.4cqi 0 0; }
  .cgs__name { margin: 3.2cqi 0 0; font-size: 9cqi; line-height: 1.1; font-style: italic; font-weight: 400; }
  .cgs__amp { margin: 1.2cqi 0 0; font-size: 3.7cqi; font-style: italic; color: var(--soft); }
  .cgs__name + .cgs__amp + .cgs__name { margin-top: 1.2cqi; }
  .cgs__line { margin: 4.4cqi 0 0; font-size: 3.5cqi; line-height: 1.5; letter-spacing: 0.04em; }
  /* the bottom third holds its rhythm: the date block sits close against the
     place line, leading tightened to the invitation's beat */
  .cgs__date { margin: 3cqi 0 0; font-size: 3.5cqi; line-height: 1.42; letter-spacing: 0.04em; }
  .cgs__place { margin: 2.6cqi 0 0; font-size: 3.2cqi; letter-spacing: 0.2em; text-transform: uppercase; color: var(--green); }

  /* the proof: axis, registration, stamp, red rings — snap on, no theatrics */
  .cgs__axis, .cgs__reg, .cgs__bat { opacity: 0; pointer-events: none; transition: opacity 0.3s var(--ease); }
  .cgs__axis { position: absolute; inset: 4cqi 50% 4cqi auto; width: 0; border-left: 1px dashed #a2352480; }
  .cgs__reg { position: absolute; inset: 2.4cqi; }
  .cgs__reg::before, .cgs__reg::after {
    content: ''; position: absolute; width: 4cqi; height: 4cqi;
    border: 1px solid #a23524aa;
  }
  .cgs__reg::before { top: 0; left: 0; border-right: 0; border-bottom: 0; }
  .cgs__reg::after { bottom: 0; right: 0; border-left: 0; border-top: 0; }
  .cgs__bat {
    position: absolute; top: 4.4cqi; right: 4.6cqi; transform: rotate(6deg);
    font-size: 2.5cqi; letter-spacing: 0.18em; color: var(--proof-red);
    border: 1px solid #a23524aa; padding: 0.9cqi 1.6cqi;
  }
  .cgs__ring { position: relative; }
  .cgs__ring::before {
    content: ''; position: absolute; inset: -0.1em -0.16em -0.18em;
    border: 1.5px solid var(--proof-red); border-radius: 50%;
    opacity: 0; transition: opacity 0.3s var(--ease); pointer-events: none;
  }
  /* the engraver's numbered marks, keyed to the docket below */
  .cgs__ring::after {
    content: attr(data-n); position: absolute; top: -0.62em; right: -0.85em;
    font-size: 0.42em; font-style: italic; font-weight: 500; line-height: 1;
    color: var(--proof-red); opacity: 0; transition: opacity 0.3s var(--ease); pointer-events: none;
  }
  .cgs__ring--acc::before { inset: auto -0.16em; top: -0.42em; height: 0.7em; }
  .cgs__ring--acc::after { top: -1.15em; right: -0.5em; }
  .cgs__ring--wide { display: inline-block; }
  .cgs__ring--wide::before { inset: -0.2em -1.1em; border-radius: 3em / 1.7em; }
  .cgs__ring--wide::after { font-size: 0.8em; top: 0.1em; right: -1.9em; }
  /* the audit reaches every card: 4 — the menu's cut fraction; 5 — the place
     card's hanging 3 (the ring drops below the baseline with it) */
  .cgs__ring--frac::before { inset: -0.2em -0.24em; }
  .cgs__ring--frac::after { font-size: 0.72em; top: -1.1em; right: -1.1em; }
  .cgs__ring--pc::before { inset: -0.12em -0.22em -0.4em; }
  .cgs__ring--pc::after { font-size: 0.5em; top: -0.8em; right: -1em; }
  .cgs__docket {
    margin: 4.6cqi 0 0; font-size: 2.8cqi; line-height: 1.55; font-style: italic;
    color: var(--proof-red); opacity: 0; transition: opacity 0.3s var(--ease);
  }
  .cgs__docket--menu { display: block; margin-top: 3.2cqi; font-size: 3cqi; }
  .cgs__docket--pc { display: block; margin-top: 2.8cqi; font-size: 3.6cqi; line-height: 1.4; }
  .cgs[data-proof='on'] :is(.cgs__axis, .cgs__reg, .cgs__bat, .cgs__docket) { opacity: 1; }
  .cgs[data-proof='on'] .cgs__ring::before, .cgs[data-proof='on'] .cgs__ring::after { opacity: 1; }
  @media (prefers-reduced-motion: reduce) {
    .cgs__axis, .cgs__reg, .cgs__bat, .cgs__docket, .cgs__ring::before, .cgs__ring::after { transition: none; }
  }

  /* the right-hand column: menu over the small pair */
  .cgs__menu { text-align: center; padding: 7cqi 8cqi 6.5cqi; display: flex; flex-direction: column; justify-content: center; }
  .cgs__chead { display: block; font-size: 8cqi; font-style: italic; color: var(--green); line-height: 1; }
  .cgs__courses { list-style: none; margin: 5cqi 0 0; padding: 0; }
  .cgs__courses li { padding: 3.4cqi 0; border-top: 1px solid #2b231620; display: flex; flex-direction: column; gap: 0.9cqi; }
  .cgs__courses li:first-child { border-top: 0; padding-top: 0; }
  .cgs__courses b { font-weight: 500; font-size: 4.2cqi; line-height: 1.15; }
  .cgs__courses i { font-style: italic; font-size: 3.3cqi; color: var(--soft); }
  .cgs__frac { font-feature-settings: 'frac' 1; font-style: normal; }
  .cgs__wines { display: block; margin-top: 4.4cqi; padding-top: 3.4cqi; border-top: 1px solid #2b231620; font-size: 3.1cqi; letter-spacing: 0.12em; color: var(--soft); }

  .cgs__pair { min-width: 0; }
  .cgs__pair { display: grid; grid-template-columns: 1fr 1.4fr; gap: clamp(1rem, 2.4cqi, 2.2rem); margin-top: clamp(1rem, 2.4cqi, 2.2rem); align-items: stretch; }
  .cgs__placecard { display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 9cqi 5cqi; }
  .cgs__pname { font-size: 16.5cqi; font-style: italic; line-height: 1.1; }
  .cgs__ptable { margin-top: 4.5cqi; font-size: 7.2cqi; letter-spacing: 0.14em; color: var(--green); }
  .cgs__reply { text-align: center; padding: 7cqi 6cqi; display: flex; flex-direction: column; justify-content: center; }
  .cgs__chead--sm { font-size: 10.5cqi; }
  .cgs__rline { margin: 4.6cqi 0 0; font-size: 4.7cqi; line-height: 1.5; letter-spacing: 0.04em; }
  .cgs__mline { margin: 5cqi auto 0; font-size: 6cqi; font-style: italic; display: flex; align-items: baseline; gap: 1.4cqi; justify-content: center; width: 78%; }
  .cgs__mline span { flex: 1; border-bottom: 1px solid #2b231655; }
  .cgs__rchoice { margin: 4.6cqi 0 0; font-size: 4.3cqi; color: var(--soft); }
  .cgs__rchoice em { font-style: italic; }

  /* grid placement: invitation spans, menu + pair stack beside it */
  .cgs__invite { grid-row: 1 / span 2; }
  .cgs__menu { grid-column: 2; }
  .cgs__pair { grid-column: 2; margin-top: 0; }

  /* ════════════════════════════════════════════════════════════════════
     03 · DEMEURE — the Kinfolk school, on theme tokens (both modes)
     ════════════════════════════════════════════════════════════════════ */
  .cge { background: var(--bg-2); color: var(--fg); padding: clamp(1.6rem, 4cqi, 3.6rem) clamp(1.2rem, 4.5cqi, 4.2rem) clamp(1.4rem, 3cqi, 2.6rem); }
  .cge__band {
    display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;
    padding-bottom: clamp(0.7rem, 1.4cqi, 1.2rem); border-bottom: 1px solid var(--line);
  }
  .cge__pub { font-size: clamp(15px, 1.8cqi, 24px); font-weight: 500; letter-spacing: 0.34em; text-indent: 0.34em; }
  .cge__tag { font-size: clamp(11px, 1.2cqi, 15px); color: var(--fg-3); }
  .cge__tag em { font-style: italic; }
  .cge__issue { font-size: clamp(11px, 1.2cqi, 15px); color: var(--fg-2); }

  .cge__grid {
    display: grid; grid-template-columns: 1fr minmax(220px, 30%);
    gap: clamp(1.4rem, 3.4cqi, 3.4rem);
    padding-block: clamp(1.4rem, 3cqi, 2.8rem);
  }
  .cge__kicker { font-size: clamp(11px, 1.15cqi, 14px); letter-spacing: 0.32em; color: var(--accent); }
  .cge__head { margin: 0.45em 0 0; font-size: clamp(34px, 6.2cqi, 86px); line-height: 1.02; font-weight: 300; letter-spacing: 0.002em; }
  .cge__head em { font-style: italic; font-weight: 400; }
  .cge__deck {
    margin: clamp(0.9rem, 1.8cqi, 1.6rem) 0 0; max-width: 52ch;
    font-size: clamp(15px, 1.75cqi, 23px); line-height: 1.42; font-style: italic; color: var(--fg-2);
  }
  .cge__body {
    columns: 2; column-gap: clamp(1.4rem, 3cqi, 2.8rem);
    margin-top: clamp(1.1rem, 2.4cqi, 2.2rem); padding-top: clamp(1rem, 2cqi, 1.8rem);
    border-top: 1px solid var(--line);
    /* the school's own text setting: ~16px, regular, generous leading —
       never a mid-gray 500 slab */
    font-size: clamp(15.5px, 1.15cqi, 16px); font-weight: 400; line-height: 1.7; color: var(--fg);
  }
  .cge__body p { margin: 0 0 0.9em; }
  .cge__drop { float: left; font-size: 4.6em; line-height: 0.74; font-weight: 300; padding: 0.04em 0.1em 0 0; color: var(--fg); }

  .cge__side { display: flex; flex-direction: column; gap: clamp(1.2rem, 2.6cqi, 2.4rem); padding-top: 0; }
  /* the one display risk the school allows: the folio at headline size.
     The baseline is a DRAWN GRID FACT: the underline (skip-ink off) runs
     beneath the digits and a flex filler extends the same 1.5px rule to the
     sidebar's far edge — the 8 stands on it, the old-style 5 hangs through
     it, and under lnum the 5 stands up onto it. */
  .cge__giant { display: flex; flex-direction: column; gap: 0.7rem; }
  .cge__giantrow {
    display: flex; align-items: baseline; width: 100%;
    /* clear the overflowing descender (line-height 0.7) before the label */
    margin-bottom: clamp(36px, 5cqi, 64px);
  }
  .cge__giantfig {
    font-size: clamp(118px, 16.5cqi, 212px); line-height: 0.7; font-weight: 300;
    letter-spacing: -0.015em; color: var(--fg);
    text-decoration: underline; text-decoration-thickness: 1.5px;
    text-decoration-color: var(--fg-3); text-underline-offset: 0.012em;
    text-decoration-skip-ink: none;
  }
  .cge__giantrule {
    flex: 1; height: 1.5px; background: var(--fg-3);
    /* sit the filler's rule exactly on the underline: baseline-aligned flex
       items hang from their bottom margin edge */
    font-size: clamp(118px, 16.5cqi, 212px);
    margin-bottom: calc(-0.012em - 1.5px);
  }
  .cge__giantlab {
    font-size: clamp(10.5px, 1.05cqi, 13px); letter-spacing: 0.18em; line-height: 1.6;
    text-transform: uppercase; color: var(--fg-3); max-width: 26em;
  }
  .cge__quote { margin: 0; border: 0; }
  .cge__quote p {
    margin: 0; font-size: clamp(19px, 2.3cqi, 31px); line-height: 1.28; font-style: italic; font-weight: 400;
    text-indent: -0.42em; /* hang the opening quote */
    color: var(--fg);
  }
  .cge__quote cite { display: block; margin-top: 0.8em; font-size: clamp(11.5px, 1.2cqi, 15px); font-style: normal; color: var(--fg-3); }
  .cge__file { margin: 0; padding-top: clamp(0.9rem, 1.8cqi, 1.5rem); border-top: 1px solid var(--line); }
  .cge__file div { display: grid; grid-template-columns: 7.5em 1fr; gap: 1em; padding: 0.42em 0; border-bottom: 1px solid var(--line-soft); }
  .cge__file dt { font-size: clamp(10.5px, 1.05cqi, 13px); letter-spacing: 0.22em; text-transform: uppercase; color: var(--fg-3); align-self: baseline; }
  .cge__file dd { margin: 0; font-size: clamp(12.5px, 1.25cqi, 16px); font-weight: 500; color: var(--fg-2); }

  .cge__colo {
    display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;
    padding-top: clamp(0.7rem, 1.4cqi, 1.2rem); border-top: 1px solid var(--line);
  }
  .cge__folio { font-size: clamp(11px, 1.2cqi, 15px); color: var(--fg-3); letter-spacing: 0.08em; }
  /* the toggle is typeset as the page's own footnote convention — an
     asterisked italic colophon line, not a chip */
  .cge__figbtn {
    font-size: clamp(11.5px, 1.2cqi, 14.5px); font-style: italic; color: var(--fg-3);
    background: transparent; border: 0; padding: 0; cursor: pointer; text-align: right;
  }
  .cge__fb-ast { font-style: normal; color: var(--accent); margin-right: 0.4em; }
  .cge__figbtn:hover { color: var(--fg); }
  .cge__fb-on { display: none; }
  .cge.is-lining .cge__fb-off { display: none; }
  .cge.is-lining .cge__fb-on { display: inline; }
  /* the live figures: hanging by default (the font's truth); lnum stands them up */
  .cge.is-lining .cge__fig { font-feature-settings: 'lnum' 1; }

  /* ════════════════════════════════════════════════════════════════════
     04 · LA TAILLE — the instrument, on the night field again (bookend)
     ════════════════════════════════════════════════════════════════════ */
  .cgi {
    background: radial-gradient(120% 100% at 50% 100%, var(--nt-2) 0%, var(--nt) 60%, #101a13 100%);
    color: var(--cream);
  }
  .cgi__in {
    max-width: 1240px; margin-inline: auto;
    display: flex; flex-direction: column;
    padding: clamp(1.4rem, 3cqi, 2.8rem) clamp(1.2rem, 4.5cqi, 4.5rem) clamp(2rem, 4cqi, 3.6rem);
  }
  .cgi__top {
    display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;
    padding-bottom: clamp(0.7rem, 1.4cqi, 1.2rem); border-bottom: 1px solid #f0e7d326;
  }
  .cgi__title { font-size: clamp(13px, 1.5cqi, 20px); font-weight: 500; letter-spacing: 0.32em; text-indent: 0.32em; }
  .cgi__ref { font-size: clamp(11px, 1.2cqi, 15px); color: var(--cream-dim); }
  .cgi__ref em { font-style: italic; }
  .cgi__law { font-size: clamp(11px, 1.15cqi, 14.5px); font-style: italic; color: var(--cream-dim); }
  .cgi__lf { font-feature-settings: 'lnum' 1, 'tnum' 1; font-style: normal; }

  .cgi__stage {
    position: relative;
    min-height: clamp(190px, 34vh, 330px);
    display: grid; place-items: center; overflow: clip;
  }
  .cgi__stage > * { grid-area: 1 / 1; }
  /* the instrument's reticle: the stage is a measuring glass, so the letter
     is pinned even when the forbidden sizes shrink it to a speck */
  .cgi__reticle {
    position: relative; place-self: center; width: min(46cqi, 380px); aspect-ratio: 1;
    border: 1px solid #f0e7d31c; border-radius: 50%; pointer-events: none;
  }
  .cgi__reticle::before, .cgi__reticle::after {
    content: ''; position: absolute; background: #f0e7d322;
  }
  .cgi__reticle::before { left: 50%; top: -7%; bottom: -7%; width: 1px; }
  .cgi__reticle::after { top: 50%; left: -7%; right: -7%; height: 1px; }
  [data-inst][data-zone='red'] .cgi__reticle { border-color: color-mix(in srgb, var(--red) 36%, transparent); }
  [data-inst][data-zone='red'] .cgi__reticle::before,
  [data-inst][data-zone='red'] .cgi__reticle::after { background: color-mix(in srgb, var(--red) 30%, transparent); }
  .cgi__word { font-style: italic; font-weight: 400; line-height: 1; white-space: nowrap; color: var(--cream); transition: color 0.3s var(--ease); }
  [data-inst][data-zone='red'] .cgi__word { color: var(--cream-dim); }

  .cgi__read {
    display: flex; align-items: baseline; gap: clamp(0.9rem, 2.4cqi, 2rem);
    padding-top: clamp(0.6rem, 1.4cqi, 1.2rem); border-top: 1px solid #f0e7d326;
  }
  .cgi__pt b { font-size: clamp(40px, 5.4cqi, 76px); font-weight: 300; font-feature-settings: 'lnum' 1, 'tnum' 1; letter-spacing: 0.01em; }
  .cgi__pt i { font-style: italic; font-size: clamp(15px, 1.7cqi, 23px); color: var(--cream-dim); margin-left: 0.18em; }
  .cgi__body-name { font-size: clamp(13px, 1.5cqi, 20px); font-style: italic; color: var(--cream-dim); white-space: nowrap; }
  .cgi__verdict {
    margin: 0 0 0 auto; max-width: 46ch; text-align: right;
    font-size: clamp(12px, 1.3cqi, 16.5px); line-height: 1.42; font-style: italic; color: var(--cream-dim);
  }
  .cgi__verdict[data-zone='red'] { color: var(--red); }
  .cgi__verdict[data-zone='grand'] { color: var(--cream); }
  .cgi__verdict[data-zone='bloom'] { color: #a9c3a0; }

  .cgi__railwrap { position: relative; margin-top: clamp(1.6rem, 3.4cqi, 3rem); padding-top: 4.75rem; }
  .cgi__rail {
    -webkit-appearance: none; appearance: none; width: 100%; height: 2px; display: block;
    background: #f0e7d340; border-radius: 2px; cursor: ew-resize; position: relative; z-index: 2;
  }
  .cgi__rail::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none; width: 14px; height: 26px; border-radius: 3px;
    background: var(--cream); border: 1px solid #101a13; cursor: ew-resize;
    box-shadow: 0 2px 8px rgba(0,0,0,0.5);
  }
  .cgi__rail::-moz-range-thumb { width: 14px; height: 26px; border: 1px solid #101a13; border-radius: 3px; background: var(--cream); cursor: ew-resize; }
  .cgi__zones { position: absolute; left: 0; right: 0; bottom: 0; height: 2px; z-index: 1; }
  .cgi__zone-red { position: absolute; left: 0; top: 0; height: 100%; background: color-mix(in srgb, var(--red) 70%, transparent); }

  .cgi__ticks { position: absolute; inset: 0 0 0 0; pointer-events: none; }
  .cgi__tick {
    position: absolute; bottom: -1px; transform: translateX(-50%);
    display: flex; flex-direction: column-reverse; align-items: center; gap: 0.45rem;
    background: transparent; border: 0; padding: 0; cursor: pointer; pointer-events: auto;
    color: var(--cream-dim);
  }
  .cgi__tick i { display: block; width: 1px; height: 12px; background: #f0e7d366; }
  .cgi__tick--named i { height: 18px; background: #f0e7d3aa; }
  .cgi__tick span {
    font-size: clamp(10px, 1.05cqi, 13px); letter-spacing: 0.14em; text-transform: uppercase;
    display: flex; flex-direction: column; align-items: center; gap: 0.1em; white-space: nowrap;
  }
  .cgi__tick span b { font-weight: 400; letter-spacing: 0.04em; }
  .cgi__tick:hover { color: var(--cream); }
  .cgi__tick:first-child { transform: none; align-items: flex-start; }
  /* Grosse Nonpareille's long name breaks to two centred lines so the
     table's true terminus stays readable close to the rail's right edge */
  .cgi__tick--wrap span { white-space: normal; max-width: 7.5em; text-align: center; }
  .cgi__beyond { position: absolute; bottom: -1px; height: 0; }
  .cgi__beyond i { position: absolute; left: 0; right: 0; bottom: 0; display: block; height: 2px; background: linear-gradient(90deg, transparent, #a9c3a0aa); }
  .cgi__beyond span {
    position: absolute; top: 0.85rem; right: 0;
    font-size: clamp(10px, 1.05cqi, 13px); font-style: italic; letter-spacing: 0.06em;
    color: #a9c3a0; white-space: nowrap;
  }

  /* ════════════════════════════════════════════════════════════════════
     05 · THE RSVP — real px, theme tokens; the place card is printed cream
     ════════════════════════════════════════════════════════════════════ */
  .cgr { max-width: 980px; margin-inline: auto; width: 100%; border: 1px solid var(--line); font-size: 15px; line-height: 1.45; background: var(--bg); }
  .cgr__head {
    display: flex; align-items: baseline; gap: 1rem;
    padding: 0.95rem 1.3rem; border-bottom: 1px solid var(--line);
  }
  .cgr__cipher { font-size: 26px; line-height: 1; color: var(--accent); }
  .cgr__names { font-size: 19px; color: var(--fg); white-space: nowrap; }
  .cgr__names em { font-style: italic; color: var(--fg-2); }
  .cgr__nav { margin-left: auto; display: flex; gap: 1.1rem; }
  .cgr__nav a { font-size: 14px; font-style: italic; color: var(--fg-3); cursor: pointer; }
  .cgr__nav a:hover { color: var(--fg); }
  .cgr__nav a.is-here { color: var(--accent); border-bottom: 1px solid var(--accent); font-style: normal; }

  .cgr__split { display: grid; grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr); }
  .cgr__form, .cgr__sealed { padding: 1.4rem 1.5rem 1.5rem; border-right: 1px solid var(--line); min-width: 0; }
  /* the one display moment the genre allows — Réponse at true hairline scale.
     Weight 400: the italic is loaded at 400 & 600 only, so 400 is what the
     browser can honestly draw. */
  .cgr__ftitle { margin: 0; font-size: 52px; font-weight: 400; font-style: italic; line-height: 1; color: var(--fg); }
  .cgr__fsub { margin: 0.4rem 0 1.2rem; font-size: 14.5px; color: var(--fg-3); }
  .cgr__fsub em { font-style: italic; }
  .cgr__lab { display: block; font-size: 11.5px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--fg-3); margin: 1.1rem 0 0.45rem; }
  .cgr__input {
    width: 100%; font-size: 19px; font-style: italic; color: var(--fg);
    background: transparent; border: 0; border-bottom: 1px solid var(--fg-3);
    padding: 0.15rem 0 0.3rem; border-radius: 0; outline-offset: 4px;
  }
  .cgr__input:focus-visible { outline: 1px dotted var(--accent); border-bottom-color: var(--accent); }
  .cgr__fnote { margin: 0.35rem 0 0; font-size: 12.5px; color: var(--fg-3); }
  .cgr__fnote em { font-style: italic; }
  /* the form furniture speaks the engraver's language: hairline-ruled
     choices led by engraver's points, no pills, no rounded chrome */
  .cgr__seg { display: flex; }
  .cgr__seg button {
    display: flex; align-items: baseline; gap: 0.55rem;
    font-size: 15px; font-style: italic; color: var(--fg-3); cursor: pointer;
    background: transparent; border: 0; padding: 0.25rem 0;
    transition: color 0.18s var(--ease);
  }
  .cgr__seg button + button { margin-left: 1.4rem; padding-left: 1.4rem; border-left: 1px solid var(--line); }
  .cgr__seg button::before {
    content: ''; width: 7px; height: 7px; border-radius: 50%; align-self: center;
    border: 1px solid var(--fg-3); transition: background 0.18s var(--ease), border-color 0.18s var(--ease);
  }
  .cgr__seg button:hover { color: var(--fg); }
  .cgr__seg button.is-on { color: var(--fg); }
  .cgr__seg button.is-on::before { background: var(--accent); border-color: var(--accent); }
  .cgr__menu { display: flex; flex-direction: column; }
  .cgr__dish {
    display: grid; grid-template-columns: auto 1fr; grid-template-rows: auto auto;
    column-gap: 0.65rem; align-items: baseline;
    padding: 0.55rem 0.2rem; border-top: 1px solid var(--line-soft); cursor: pointer;
  }
  .cgr__dish:first-child { border-top: 0; }
  /* the radio is an engraver's point, not a platform widget */
  .cgr__dish input {
    grid-row: 1 / span 2; align-self: center; margin: 0; cursor: pointer;
    appearance: none; -webkit-appearance: none;
    width: 7px; height: 7px; border-radius: 50%; border: 1px solid var(--fg-3);
    transition: background 0.18s var(--ease), border-color 0.18s var(--ease);
  }
  .cgr__dish input:checked { background: var(--accent); border-color: var(--accent); }
  .cgr__dish input:focus-visible { outline: 1px dotted var(--accent); outline-offset: 3px; }
  .cgr__dishname { font-size: 16.5px; font-weight: 500; color: var(--fg); }
  .cgr__dishnote { grid-column: 2; font-size: 13px; color: var(--fg-3); }
  .cgr__dishnote em { font-style: italic; }
  /* the seal: a rectangular, letterspaced-caps press — closer to a die stamp
     than a web button */
  .cgr__send {
    margin-top: 1.4rem; font-size: 13px; letter-spacing: 0.26em; text-indent: 0.26em;
    text-transform: uppercase; cursor: pointer;
    color: var(--accent-contrast); background: var(--accent); border: 1px solid var(--accent);
    padding: 0.72rem 1.7rem; border-radius: 0;
    transition: opacity 0.18s var(--ease);
  }
  .cgr__send:hover { opacity: 0.88; }

  /* the payoff: the confirmation IS the place card, writ large — the engraving
     idea completing on screen. Cream stock and iron-gall ink, both site modes. */
  .cgr__sealed { display: flex; flex-direction: column; align-items: flex-start; justify-content: center; gap: 0.85rem; }
  .cgr__sealed[hidden] { display: none; }
  .cgr__bigcard {
    width: 100%; background: #f9f4e6; color: #2b2316; text-align: center;
    padding: 2.4rem 1.4rem 2.2rem;
    box-shadow: 0 18px 34px -18px rgba(43, 35, 22, 0.55), 0 2px 6px rgba(43, 35, 22, 0.14);
  }
  @media (prefers-reduced-motion: no-preference) {
    .cgr__bigcard { animation: cgr-engrave 0.55s var(--ease-out) both; }
    @keyframes cgr-engrave { from { opacity: 0; transform: translateY(10px); } }
  }
  .cgr__bigcipher { display: block; font-size: 30px; line-height: 1; color: #36513f; }
  .cgr__bigname { display: block; margin-top: 0.9rem; font-size: 54px; line-height: 1.04; font-style: italic; font-weight: 400; overflow-wrap: anywhere; }
  .cgr__bigtable { display: block; margin-top: 1rem; font-size: 14.5px; letter-spacing: 0.2em; text-transform: uppercase; color: #36513f; }
  .cgr__bigtable .cgr__os { text-transform: none; letter-spacing: 0.04em; }
  .cgr__bigdish { display: block; margin-top: 0.4rem; font-size: 14px; font-style: italic; color: #7c7058; }
  .cgr__bigregret { margin-top: 1rem; font-size: 15px; color: #7c7058; }
