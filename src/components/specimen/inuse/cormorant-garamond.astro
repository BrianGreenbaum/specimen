---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// ── Scene 05 (interactive boutique lookbook) data ───────────────────────────
const looks = [
  { id: 'AW-01', name: 'Verveine',   cat: 'eau',    price: '210', vol: '100 ml', note: 'Bergamot · Neroli · White Cedar', tag: 'New' },
  { id: 'AW-02', name: 'Foudre',     cat: 'eau',    price: '245', vol: '100 ml', note: 'Black Fig · Vetiver · Ambrette',  tag: '' },
  { id: 'AW-03', name: 'Linceul',    cat: 'extrait',price: '380', vol: '50 ml',  note: 'Oud · Iris · Smoked Leather',     tag: 'Rare' },
  { id: 'AW-04', name: 'Aubépine',   cat: 'eau',    price: '195', vol: '100 ml', note: 'Hawthorn · Mimosa · Soft Musk',   tag: '' },
  { id: 'AW-05', name: 'Sève',       cat: 'extrait',price: '340', vol: '50 ml',  note: 'Galbanum · Tuberose · Sandalwood',tag: '' },
  { id: 'AW-06', name: 'Crépuscule', cat: 'home',   price: '120', vol: '320 g',  note: 'Beeswax · Tonka · Cade Wood',     tag: '' },
];
---
<div class="iu" style={`--fam:${fam}`}>

  <!-- 01 — fashion / luxury magazine cover -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Magazine — the fashion cover</span></figcaption>
    <div class="iu__scene iu__scene--portrait">
      <div class="iu__poster cg-cover" data-cover>
        <div class="cg-cover__top">
          <span class="cg-cover__pub">Lumière</span>
          <span class="cg-cover__no">Numéro <span class="num">21</span> · Automne—Hiver</span>
        </div>

        <div class="cg-cover__hero">
          <span class="cg-cover__over">the architecture of</span>
          <h3 class="cg-cover__masthead">
            <span class="cg-cover__line cg-cover__line--1" data-cover-flip>
              <span class="cg-cover__roman">Light</span><span class="cg-cover__ital">Light</span>
            </span>
            <span class="cg-cover__line cg-cover__line--2"><em>ness</em></span>
          </h3>
        </div>

        <div class="cg-cover__lines">
          <span class="cg-cover__feat">Paris couture, cut from a single hairline — and the slow return of restraint</span>
          <span class="cg-cover__rule" aria-hidden="true"></span>
          <span class="cg-cover__more">Saint Laurent, revisited · The vanishing serif · A winter in greys</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Hover the cover — the display word turns from its roman to its true italic, the one piece of motion a static face can honestly make.</p>
  </figure>

  <!-- 02 — fine-dining tasting menu (italic dish lines, frac fractions, hover pairing) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Hospitality — the tasting menu</span></figcaption>
    <div class="iu__scene iu__scene--portrait">
      <div class="iu__poster cg-menu">
        <header class="cg-menu__head">
          <span class="cg-menu__estd">Maison du Sel · est. MCMXII</span>
          <h3 class="cg-menu__name">Menu <em>Dégustation</em></h3>
          <span class="cg-menu__sub">Quatre services · Printemps</span>
        </header>

        <ol class="cg-menu__list">
          <li class="cg-dish" data-dish>
            <span class="cg-dish__top">
              <span class="cg-dish__name">Oysters &amp; Verjus Granité</span>
              <span class="cg-dish__price num">28</span>
            </span>
            <span class="cg-dish__desc">Fine de claire, green apple, a <span class="num">1½</span>-year cider mignonette</span>
            <span class="cg-dish__pair"><em>Muscadet sur Lie</em> · Loire</span>
          </li>
          <li class="cg-dish" data-dish>
            <span class="cg-dish__top">
              <span class="cg-dish__name">Hand-Dived Scallop</span>
              <span class="cg-dish__price num">36</span>
            </span>
            <span class="cg-dish__desc">Cauliflower, brown butter, a <span class="num">3/4</span> spoon of Oscietra</span>
            <span class="cg-dish__pair"><em>Meursault</em> · Côte de Beaune</span>
          </li>
          <li class="cg-dish" data-dish>
            <span class="cg-dish__top">
              <span class="cg-dish__name">Aged Hereford &amp; Bone Marrow</span>
              <span class="cg-dish__price num">52</span>
            </span>
            <span class="cg-dish__desc">Salsify, <span class="num">21</span>-day rib, a <span class="num">1/2</span> glass of house Syrah</span>
            <span class="cg-dish__pair"><em>Cornas</em> · Northern Rhône</span>
          </li>
          <li class="cg-dish" data-dish>
            <span class="cg-dish__top">
              <span class="cg-dish__name">Tarte Fine aux Pommes</span>
              <span class="cg-dish__price num">18</span>
            </span>
            <span class="cg-dish__desc">Caramel of Calvados, crème double, <span class="num">1/2</span> vanilla pod</span>
            <span class="cg-dish__pair"><em>Coteaux du Layon</em> · Anjou</span>
          </li>
        </ol>

        <footer class="cg-menu__foot">
          <span class="cg-menu__set">Four courses <span class="num">96</span></span>
          <span class="cg-menu__pair-note"><em>with the cellar pairing</em> <span class="num">64</span></span>
        </footer>
      </div>
    </div>
    <p class="iu__hint label">Hover a course to draw out its cellar pairing in true italic; prices fall down a tabular hairline column with real <code>frac</code> fractions.</p>
  </figure>

  <!-- 03 — perfume flacon: tall portrait packaging that exploits the hairline contrast + tall accents -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Brand — the flacon &amp; its label</span></figcaption>
    <div class="iu__scene iu__scene--portrait">
      <div class="iu__poster cg-flacon" data-flacon>
        <div class="cg-flacon__id">
          <span>Aubépine &amp; Cie</span>
          <span class="cg-flacon__dot" aria-hidden="true"></span>
          <span>Grasse</span>
        </div>

        <div class="cg-flacon__stage">
          <div class="cg-flacon__bottle" aria-label="perfume flacon">
            <span class="cg-flacon__cap" aria-hidden="true"></span>
            <div class="cg-flacon__label">
              <span class="cg-flacon__house">Extrait</span>
              <h3 class="cg-flacon__name" data-flacon-word>Linceul</h3>
              <span class="cg-flacon__accent" aria-hidden="true">é</span>
              <span class="cg-flacon__notes"><em>Oud · Iris · Smoked Leather</em></span>
              <span class="cg-flacon__rule" aria-hidden="true"></span>
              <span class="cg-flacon__vol">50 ml <span class="num">℮</span></span>
            </div>
          </div>
        </div>

        <div class="cg-flacon__foot">
          <span>Extrait de Parfum</span>
          <span class="cg-flacon__yr">depuis <span class="num">1911</span></span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">A real label object — the tall, flamboyant accent and razor serifs set against open space, the kind of contrast that only blooms at this size.</p>
  </figure>

  <!-- 04 — editorial feature opener -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Editorial — the feature opener</span></figcaption>
    <div class="iu__scene cg-scene-43">
      <div class="iu__poster cg-spread" data-reveal-cover>
        <div class="cg-spread__rail">
          <span class="cg-spread__folio">Feature · <span class="num">072</span></span>
          <span class="cg-spread__sec">Atelier</span>
        </div>
        <div class="cg-spread__main">
          <span class="cg-spread__kicker">On craft</span>
          <h3 class="cg-spread__head" data-cover-word>The <em>Vanishing</em> Stroke</h3>
          <p class="cg-spread__deck">How a Swiss astronomer filed the Garamond serif to a needle, and let it bloom only at the size of a whisper.</p>
          <div class="cg-spread__body">
            <p><span class="cg-spread__drop">F</span>or four centuries the Garamond serif kept its weight, sturdy enough to survive the spread of ink across damp rag paper. Cormorant takes the opposite vow: it assumes a screen, a fine press, and a generous size — and files every ending to a point.</p>
            <p>The counters close, the contrast runs high, the accents climb tall above the cap line. Set small it would collapse; set large and light it becomes the quietest kind of luxury — the letter that asks to be looked at, never read in a hurry.</p>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Hover the headline — the display weight lightens to a hairline and the italic word leads.</p>
  </figure>

  <!-- 05 — INTERACTIVE boutique lookbook (real px, filter + sort + hover) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">05</span><span class="label">Product UI — boutique lookbook (real scale, interactive)</span></figcaption>
    <div class="iu__scene">
      <div class="iu__device cg-shop" data-shop>
        <div class="iu__chrome">
          <div class="iu__dots"><i></i><i></i><i></i></div>
          <span class="iu__addr">aubepine.paris/collection/automne</span>
        </div>
        <header class="cg-shop__head">
          <span class="cg-shop__logo">Aubépine <em>&amp; Cie</em></span>
          <nav class="cg-shop__filters" aria-label="Filter collection">
            <button class="is-on" data-filter="all">Tout</button>
            <button data-filter="eau">Eau de Parfum</button>
            <button data-filter="extrait">Extrait</button>
            <button data-filter="home">Maison</button>
          </nav>
          <div class="cg-shop__sort">
            <span class="cg-shop__sortlabel">Trier</span>
            <button data-sort aria-pressed="false"><span data-sort-label>Nouveautés</span></button>
          </div>
        </header>

        <div class="cg-shop__grid" data-grid>
          {looks.map((l, i)=>{
            const hero = i === 0;
            return (
            <article class={`cg-card${hero ? ' cg-card--hero' : ''}`} data-cat={l.cat} data-price={l.price} data-id={l.id}>
              <div class="cg-card__img" aria-hidden="true">
                <span class="cg-card__ghost">{l.name.slice(0,1)}</span>
                <span class="cg-card__word">{l.name}</span>
                {l.tag && <span class="cg-card__tag">{l.tag}</span>}
                <span class="cg-card__cta">View · Ajouter</span>
              </div>
              <div class="cg-card__meta">
                <div class="cg-card__row cg-card__row--top">
                  <h4 class="cg-card__name">{l.name}</h4>
                  <span class="cg-card__price num">£{l.price}</span>
                </div>
                <span class="cg-card__note"><em>{l.note}</em></span>
                <div class="cg-card__row cg-card__row--foot">
                  <span class="cg-card__vol">{l.vol}</span>
                  <span class="cg-card__id num">{l.id}</span>
                </div>
              </div>
            </article>
          );})}
        </div>
      </div>
    </div>
    <p class="iu__hint label">Filter by family and re-sort by price — hover any flacon to reveal the live italic note &amp; add-to-bag.</p>
  </figure>

</div>

<script>
  // ── Scene 05: filter + sort + hover lookbook ──────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-shop]').forEach((shop) => {
    const grid = shop.querySelector<HTMLElement>('[data-grid]')!;
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.cg-card'));
    const order = cards.slice();

    let filter = 'all';
    let byPrice = false;

    const relayout = () => {
      // filter
      cards.forEach((c) => {
        const show = filter === 'all' || c.dataset.cat === filter;
        c.classList.toggle('is-hidden', !show);
      });
      // sort (only meaningful re-order; hero keeps its span)
      const visible = (byPrice
        ? order.slice().sort((a, b) => +a.dataset.price! - +b.dataset.price!)
        : order
      );
      visible.forEach((c) => grid.appendChild(c));
    };

    shop.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach((b) =>
      b.addEventListener('click', () => {
        shop.querySelectorAll('[data-filter]').forEach((x) => x.classList.remove('is-on'));
        b.classList.add('is-on');
        filter = b.dataset.filter!;
        relayout();
      })
    );

    const sortBtn = shop.querySelector<HTMLButtonElement>('[data-sort]');
    const sortLabel = shop.querySelector<HTMLElement>('[data-sort-label]');
    sortBtn?.addEventListener('click', () => {
      byPrice = !byPrice;
      sortBtn.setAttribute('aria-pressed', String(byPrice));
      if (sortLabel) sortLabel.textContent = byPrice ? 'Prix · ↑' : 'Nouveautés';
      relayout();
    });
  });
</script>

<style>
  .iu__item { margin: 0; }
  .iu__hint { margin-top: var(--sp-2); color: var(--fg-3); }
  .iu__hint code { font-family: var(--font-mono); font-size: 0.85em; color: var(--fg-2); }
  .cg-scene-43 { aspect-ratio: 4 / 3; }
  /* every glyph in every scene resolves to Cormorant Garamond */
  .iu__scene * { font-family: var(--fam); }
  /* real, tabular figures wherever .num is used */
  .iu__scene .num { font-feature-settings: 'lnum' 1, 'tnum' 1; font-variant-numeric: lining-nums tabular-nums; }

  /* ============================================================
     01 — FASHION COVER
     A confident masthead-led cover. The big word LIGHTNESS breaks across
     two lines; "Light" carries a real roman→italic flip on hover (a static
     face's one honest move). Accent is reserved for the publication mark.
     ============================================================ */
  .cg-cover { --card-ar: 3 / 4; background: var(--bg); display: grid; grid-template-rows: auto 1fr auto; padding: 5cqi 5.5cqi 4.5cqi; }
  .cg-cover__top { display: flex; justify-content: space-between; align-items: baseline; gap: 3cqi; border-bottom: 1px solid var(--line); padding-bottom: 2.6cqi; }
  .cg-cover__pub { font-size: 4.6cqi; font-style: italic; font-weight: 500; letter-spacing: 0; color: var(--accent); line-height: 1; }
  .cg-cover__no { font-size: 2.4cqi; letter-spacing: 0.22em; text-transform: uppercase; color: var(--fg-3); align-self: center; }

  .cg-cover__hero { align-self: center; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .cg-cover__over { font-size: 3.1cqi; font-style: italic; font-weight: 400; letter-spacing: 0.04em; color: var(--fg-3); margin-bottom: 1cqi; }
  .cg-cover__masthead { margin: 0; text-align: center; color: var(--fg); font-weight: 400; line-height: 0.82; }
  .cg-cover__line { display: block; font-size: 30cqi; }
  .cg-cover__line--2 { color: var(--fg-2); }
  .cg-cover__line--2 em { font-style: italic; font-weight: 400; }
  /* roman / italic flip — both glyphs stacked, swapped by opacity */
  .cg-cover__line--1 { position: relative; display: inline-grid; }
  .cg-cover__roman, .cg-cover__ital { grid-area: 1 / 1; transition: opacity 0.5s var(--ease); }
  .cg-cover__ital { font-style: italic; opacity: 0; color: var(--accent); }

  .cg-cover__lines { display: flex; flex-direction: column; gap: 2.4cqi; }
  .cg-cover__feat { font-size: 5.4cqi; line-height: 1.06; color: var(--fg); max-width: 22ch; }
  .cg-cover__rule { height: 1px; background: var(--line); width: 100%; }
  .cg-cover__more { font-size: 2.5cqi; letter-spacing: 0.16em; text-transform: uppercase; color: var(--fg-3); }

  @media (prefers-reduced-motion: no-preference) {
    .cg-cover[data-cover]:hover .cg-cover__roman,
    .cg-cover[data-cover]:focus-within .cg-cover__roman { opacity: 0; }
    .cg-cover[data-cover]:hover .cg-cover__ital,
    .cg-cover[data-cover]:focus-within .cg-cover__ital { opacity: 1; }
  }

  /* ============================================================
     02 — TASTING MENU
     Real hospitality scale: large roman dish names, italic descriptions
     with frac fractions, prices in a tabular hairline column. Hover a
     course to reveal its cellar pairing in true italic.
     ============================================================ */
  .cg-menu { --card-ar: 3 / 4; background: var(--bg); display: flex; flex-direction: column; padding: 6.5cqi 7cqi 5.5cqi; }
  .cg-menu__head { text-align: center; display: flex; flex-direction: column; gap: 1.6cqi; }
  .cg-menu__estd { font-size: 2.2cqi; letter-spacing: 0.3em; text-transform: uppercase; color: var(--fg-3); }
  .cg-menu__name { font-size: 11cqi; line-height: 0.96; font-weight: 400; color: var(--fg); }
  .cg-menu__name em { font-style: italic; font-weight: 400; color: var(--accent); }
  .cg-menu__sub { font-size: 2.6cqi; letter-spacing: 0.26em; text-transform: uppercase; color: var(--fg-2); }

  .cg-menu__list { list-style: none; margin: 5cqi 0 0; padding: 0; display: flex; flex-direction: column; flex: 1; justify-content: space-evenly; width: 100%; }
  .cg-dish { display: flex; flex-direction: column; gap: 0.7cqi; padding: 4.4cqi 0; border-top: 1px solid var(--line-soft); }
  .cg-dish:first-child { border-top: 0; }
  .cg-dish__top { display: flex; align-items: baseline; justify-content: space-between; gap: 2cqi; }
  .cg-dish__name { font-size: 5.2cqi; line-height: 1.0; font-weight: 400; color: var(--fg); transition: color 0.3s var(--ease); }
  .cg-dish__price { font-size: 4.4cqi; font-weight: 400; color: var(--fg-2); font-variant-numeric: tabular-nums lining-nums; flex: none; }
  .cg-dish__desc { font-size: 3.2cqi; line-height: 1.32; color: var(--fg-2); font-style: italic; max-width: 40ch; }
  .cg-dish__desc .num { font-style: normal; font-feature-settings: 'frac' 1; }
  .cg-dish__pair {
    font-size: 2.9cqi; line-height: 1; letter-spacing: 0.02em; color: var(--accent);
    overflow: hidden; max-height: 0; opacity: 0;
    transition: max-height 0.4s var(--ease), opacity 0.3s var(--ease), margin-top 0.4s var(--ease);
    margin-top: 0;
  }
  .cg-dish__pair em { font-style: italic; font-weight: 500; }
  .cg-dish__pair::before { content: '⟡  '; color: var(--fg-3); }

  @media (prefers-reduced-motion: no-preference) {
    .cg-dish[data-dish]:hover .cg-dish__pair,
    .cg-dish[data-dish]:focus-within .cg-dish__pair { max-height: 6cqi; opacity: 1; margin-top: 1.2cqi; }
    .cg-dish[data-dish]:hover .cg-dish__name { color: var(--accent); }
  }
  @media (prefers-reduced-motion: reduce) {
    .cg-dish__pair { max-height: none; opacity: 1; margin-top: 1.2cqi; }
  }

  .cg-menu__foot { display: flex; align-items: baseline; justify-content: space-between; gap: 2cqi; margin-top: 4cqi; padding-top: 3.4cqi; border-top: 1px solid var(--line); font-size: 3.2cqi; color: var(--fg); }
  .cg-menu__set { letter-spacing: 0.02em; }
  .cg-menu__foot .num { color: var(--accent); margin-left: 0.5cqi; font-variant-numeric: tabular-nums lining-nums; }
  .cg-menu__pair-note { color: var(--fg-2); }
  .cg-menu__pair-note em { font-style: italic; }

  /* ============================================================
     03 — FLACON & LABEL
     A tall portrait packaging shot. A real bottle silhouette holds a
     centred label; the giant tall accent (é) is set as a flourish at
     dramatic scale against open cream space. Slow draw-in on the name.
     ============================================================ */
  .cg-flacon { --card-ar: 3 / 4; background: var(--bg-2); display: grid; grid-template-rows: auto 1fr auto; padding: 5cqi 6cqi 4.5cqi; }
  .cg-flacon__id, .cg-flacon__foot { display: flex; align-items: center; justify-content: center; gap: 2.4cqi; font-size: 2.2cqi; letter-spacing: 0.3em; text-transform: uppercase; color: var(--fg-3); }
  .cg-flacon__foot { justify-content: space-between; }
  .cg-flacon__dot { width: 0.6cqi; height: 0.6cqi; border-radius: 50%; background: var(--accent); }
  .cg-flacon__yr .num { color: var(--accent); }

  .cg-flacon__stage { display: grid; justify-items: center; align-items: stretch; min-height: 0; padding: 1.5cqi 0; }
  .cg-flacon__bottle {
    position: relative; width: 78cqi; background: var(--bg);
    border: 1px solid var(--line); box-shadow: 0 3cqi 8cqi -4cqi rgba(0,0,0,0.28);
    padding: 7cqi; display: flex; flex-direction: column; align-items: center; justify-content: center;
  }
  /* the stopper */
  .cg-flacon__cap { position: absolute; top: -4.4cqi; left: 50%; transform: translateX(-50%); width: 22cqi; height: 4.4cqi; background: var(--bg); border: 1px solid var(--line); border-bottom: 0; }
  .cg-flacon__label { display: flex; flex-direction: column; align-items: center; text-align: center; width: 100%; }
  .cg-flacon__house { order: 1; font-size: 2.6cqi; letter-spacing: 0.4em; text-transform: uppercase; color: var(--fg-3); }
  /* the é set as a giant flamboyant flourish above the name — the face's tall accent at dramatic scale */
  .cg-flacon__accent { order: 2; font-size: 17cqi; line-height: 0.62; font-style: italic; color: var(--accent); margin: 3cqi 0 0; }
  .cg-flacon__name { order: 3; font-size: 21cqi; line-height: 0.86; font-weight: 400; color: var(--fg); margin: 0.4cqi 0 0; letter-spacing: 0.005em; }
  .cg-flacon__notes { order: 4; font-size: 3cqi; line-height: 1.3; color: var(--fg-2); margin-top: 3cqi; max-width: 24ch; }
  .cg-flacon__notes em { font-style: italic; font-weight: 400; }
  .cg-flacon__rule { order: 5; width: 20cqi; height: 1px; background: var(--line); margin: 3.4cqi 0 2.8cqi; }
  .cg-flacon__vol { order: 6; font-size: 2.5cqi; letter-spacing: 0.24em; text-transform: uppercase; color: var(--fg-3); }
  .cg-flacon__vol .num { letter-spacing: 0; }

  @media (prefers-reduced-motion: no-preference) {
    .cg-flacon__name { animation: cg-draw 1.4s var(--ease) both; }
    .cg-flacon__accent { animation: cg-accent 1.6s var(--ease) 0.3s both; }
    .cg-flacon__rule { animation: cg-rule 1.1s var(--ease) 0.5s both; transform-origin: center; }
    @keyframes cg-draw { from { opacity: 0; letter-spacing: 0.14em; } to { opacity: 1; letter-spacing: 0.01em; } }
    @keyframes cg-accent { from { opacity: 0; transform: translateY(2cqi); } to { opacity: 1; transform: translateY(0); } }
    @keyframes cg-rule { from { transform: scaleX(0); } to { transform: scaleX(1); } }
  }

  /* ============================================================
     04 — EDITORIAL FEATURE OPENER
     Light display headline, italic lead word; drop-cap two-column body.
     ============================================================ */
  .cg-spread { background: var(--bg); display: grid; grid-template-columns: 13% 1fr; padding: 4.5cqi 5cqi; gap: 4cqi; }
  .cg-spread__rail { display: flex; flex-direction: column; justify-content: space-between; border-right: 1px solid var(--line); padding-right: 3cqi; }
