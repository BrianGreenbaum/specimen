---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;
// Serif text companion (loaded site-wide in Layout.astro).
const serif = "'Libre Baskerville', Georgia, serif";

// VERIFIED against node_modules/@fontsource-variable/archivo (standard subset,
// the one Layout.astro loads): axes wght 100–900 AND wdth 62–125 (upright +
// italic); GSUB carries liga / tnum / pnum / frac (with numr+dnom). Every act
// below performs the two-dimensional wght×wdth space; the tabular and fraction
// features are exercised only where those tags exist.

// --- 01 · Season poster ----------------------------------------------------
const plays = [
  { title: 'JULIUS CAESAR', dates: 'June 18 — July 12', dir: 'dir. Renata Okafor' },
  { title: 'TWELFTH NIGHT', dates: 'July 16 — August 9', dir: 'dir. Sam Brennan' },
  { title: 'THE TEMPEST',   dates: 'August 13 — 30',     dir: 'dir. Lucía Páez' },
];

// --- 02 · Magazine chart ----------------------------------------------------
const rates = [
  { yr: '’19', v: 1.9 }, { yr: '’20', v: 0.6 }, { yr: '’21', v: 0.5 },
  { yr: '’22', v: 2.4 }, { yr: '’23', v: 4.6 }, { yr: '’24', v: 4.9 },
  { yr: '’25', v: 4.2 }, { yr: '’26', v: 3.8 },
];
const rateMax = 5;

// --- 03 · Terminal monitor ---------------------------------------------------
const eq = [
  { sym: 'AAPL',  name: 'APPLE INC',      last: '198.42', chg: '+1.86', pct: '+0.95', vol: '41.2M',  volN: 41.2,  cap: '2.98T', capN: 2.98, pe: '31.4', ytd: '+12.4' },
  { sym: 'MSFT',  name: 'MICROSOFT',      last: '441.07', chg: '-2.31', pct: '-0.52', vol: '18.7M',  volN: 18.7,  cap: '3.28T', capN: 3.28, pe: '36.2', ytd: '+9.8'  },
  { sym: 'NVDA',  name: 'NVIDIA CORP',    last: '132.88', chg: '+4.02', pct: '+3.12', vol: '287.4M', volN: 287.4, cap: '3.27T', capN: 3.27, pe: '62.8', ytd: '+28.1' },
  { sym: 'AMZN',  name: 'AMAZON.COM',     last: '219.55', chg: '+0.74', pct: '+0.34', vol: '33.0M',  volN: 33.0,  cap: '2.28T', capN: 2.28, pe: '41.7', ytd: '+6.2'  },
  { sym: 'GOOGL', name: 'ALPHABET A',     last: '186.30', chg: '-1.12', pct: '-0.60', vol: '21.4M',  volN: 21.4,  cap: '2.29T', capN: 2.29, pe: '24.9', ytd: '+3.5'  },
  { sym: 'META',  name: 'META PLATFORMS', last: '612.74', chg: '+8.91', pct: '+1.48', vol: '12.9M',  volN: 12.9,  cap: '1.55T', capN: 1.55, pe: '28.3', ytd: '+18.9' },
  { sym: 'TSLA',  name: 'TESLA INC',      last: '247.19', chg: '-6.45', pct: '-2.54', vol: '96.3M',  volN: 96.3,  cap: '0.79T', capN: 0.79, pe: '88.6', ytd: '-11.2' },
  { sym: 'JPM',   name: 'JPMORGAN CHASE', last: '234.60', chg: '+0.95', pct: '+0.41', vol: '8.1M',   volN: 8.1,   cap: '0.67T', capN: 0.67, pe: '12.6', ytd: '+14.0' },
];
const govt = [
  { t: 'US 2YR',  px: '99',  fr: '21/32', yld: '4.18', up: false },
  { t: 'US 5YR',  px: '99',  fr: '9/32',  yld: '4.07', up: true  },
  { t: 'US 10YR', px: '98',  fr: '17/32', yld: '4.31', up: false },
  { t: 'US 30YR', px: '95',  fr: '11/32', yld: '4.52', up: false },
];
const fx = [
  { p: 'EUR/USD', v: '1.0842',   up: false },
  { p: 'GBP/USD', v: '1.2918',   up: true  },
  { p: 'USD/JPY', v: '152.40',   up: true  },
  { p: 'USD/ARS', v: '1,187.50', up: false },
];

// --- 04 · Subte signage -----------------------------------------------------
const stations = [
  { id: 'alem',   name: 'LEANDRO N. ALEM',                      sub: 'Salida: Av. Corrientes y L. N. Alem' },
  { id: 'pelle',  name: 'CARLOS PELLEGRINI',                    sub: 'Combinación: Líneas C y D' },
  { id: 'malabia',name: 'MALABIA — OSVALDO PUGLIESE',           sub: 'Salida: Av. Corrientes y Malabia' },
  { id: 'rosas',  name: 'JUAN MANUEL DE ROSAS — VILLA URQUIZA', sub: 'Terminal · Trenes a L. N. Alem' },
];

// --- 05 · Broadside ----------------------------------------------------------
const bill = [
  { txt: 'OMNIBUS·TYPE OF BUENOS AIRES',              basis: 0.060, wght: 700, acc: false },
  { txt: 'ANNOUNCES TO THE TRADE',                    basis: 0.052, wght: 400, acc: false },
  { txt: 'ARCHIVO',                                   basis: 0.200, wght: 900, acc: true  },
  { txt: 'A HIGH-PERFORMANCE GROTESQUE',              basis: 0.060, wght: 600, acc: false },
  { txt: 'NINE WEIGHTS · SIXTY-TWO TO ONE TWENTY-FIVE', basis: 0.038, wght: 500, acc: false },
  { txt: 'EVERY LINE FILLS THE MEASURE',              basis: 0.056, wght: 800, acc: false },
];
---
<div class="iu" style={`--fam:${fam}; --serif:${serif}`}>

  <!-- ============ 01 — ILLUSTRATION & COMMERCIAL ============ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap">
      <span class="index-num">01</span>
      <span class="label">Illustration &amp; commercial — a free-theater season bill, after Paula Scher’s Public Theater identity (Pentagram, 1994–) and its colliding wood-type gothic widths</span>
    </figcaption>
    <div class="iu__scene">
      <div class="cp" data-cp>
        <div class="cp__edge cp__edge--l" aria-hidden="true"><span>FREE FOR ALL</span></div>
        <div class="cp__main">
          <div class="cp__top">
            <span class="cp__brand">THE CIVIC</span>
            <span class="cp__season">SUMMER SEASON · NEW YORK · 2026</span>
          </div>
          <div class="cp__stack">
            <p class="cp__l cp__l--1"><span class="cp__clip"><span class="cp__in" data-reveal>SHAKESPEARE</span></span></p>
            <p class="cp__l cp__l--2">
              <span class="cp__clip"><span class="cp__in cp__in--thin" data-reveal style="--reveal-delay:90ms">IN THE</span></span>
              <span class="cp__clip"><span class="cp__in" data-reveal style="--reveal-delay:180ms">SQUARE</span></span>
            </p>
            <p class="cp__band" data-reveal style="--reveal-delay:280ms">JUNE 18 — AUGUST 30 · EVERY NIGHT · FREE</p>
          </div>
          <div class="cp__list">
            {plays.map((p) => (
              <div class="cp__play">
                <b>{p.title}</b>
                <span>{p.dates}</span>
                <i>{p.dir}</i>
              </div>
            ))}
          </div>
          <p class="cp__imprint">THE CIVIC THEATER OF NEW YORK · POSTER No. 7 OF THE 2026 SEASON · PRINTED IN TWO COLORS BY LONG ACRE LITHO, BROOKLYN · POST NO BILLS</p>
        </div>
        <div class="cp__edge cp__edge--r" aria-hidden="true"><span>NO TICKETS · NO VELVET ROPE · CURTAIN 8 PM</span></div>
      </div>
    </div>
    <p class="iu__hint label">One family does the wood-type case: “IN THE” at width 125 / weight 200 jammed against “SQUARE” at width 62 / weight 900 — Scher’s collision, drawn from a single axis. Lines set themselves as the bill scrolls in.</p>
  </figure>

  <!-- ============ 02 — EDITORIAL ============ -->
  <figure class="iu__item">
    <figcaption class="iu__cap">
      <span class="index-num">02</span>
      <span class="label">Editorial — a business-weekly feature opener, after <em>Bloomberg Businessweek</em> under Richard Turley (2010–14): blunt grotesque headlines over serif text and hard data</span>
    </figcaption>
    <div class="iu__scene">
      <div class="lg">
        <div class="lg__spine" aria-hidden="true"><span>THE LEDGER — JUNE 15–21, 2026 — MARKETS</span></div>
        <div class="lg__page">
          <header class="lg__head">
            <span class="lg__sec">MARKETS</span>
            <span class="lg__rule" aria-hidden="true"></span>
            <span class="lg__folio">THE LEDGER · 47</span>
          </header>
          <h3 class="lg__hed">Cheap money is gone. Markets are still pretending.</h3>
          <p class="lg__deck">Three years after the great repricing, equity multiples have crept back to their 2021 highs — while the cost of capital hasn’t moved an inch. Something has to give.</p>
          <p class="lg__byline">BY ANA FERREYRA · GRAPHICS BY THE LEDGER DESK</p>
          <div class="lg__grid">
            <div class="lg__body">
              <p>The most expensive sentence in finance is back. In trading rooms from London to Singapore, the argument for paying thirty-six times earnings is once again that <em>this time is different</em> — that artificial-intelligence capex will grow into any multiple, that the consumer is unbreakable, that central banks will blink first.</p>
              <p>The data desk’s reading is colder. The average policy rate across advanced economies now sits near four percent, roughly where it was before the 2008 crisis and a full three points above the decade that taught a generation of investors that money was free.</p>
              <h4 class="lg__cross">The repricing that wasn’t</h4>
              <p>Duration-heavy portfolios took the 2022 hit and never truly de-risked; they waited. And waiting has so far been rewarded — which is precisely what worries the people who model these things for a living.</p>
            </div>
            <aside class="lg__panel">
              <p class="lg__panel-t">THE NEW NEUTRAL</p>
              <p class="lg__panel-s">Average policy rate, advanced economies, %</p>
              <div class="lg__chart" role="img" aria-label="Bar chart of average policy rates, 2019 to 2026, rising from under two percent to nearly four percent">
                {rates.map((r, i) => (
                  <div class="lg__col">
                    <span class="lg__val">{r.v.toFixed(1)}</span>
                    <span class="lg__bar" data-reveal style={`--h:${(r.v / rateMax) * 100}%; --reveal-delay:${60 * i}ms`}></span>
                    <span class="lg__yr">{r.yr}</span>
                  </div>
                ))}
              </div>
              <p class="lg__src">DATA: BANK FOR INTERNATIONAL SETTLEMENTS; LEDGER CALCULATIONS</p>
              <div class="lg__stat" data-reveal style="--reveal-delay:480ms">
                <b>3.8%</b>
                <span>the “new neutral” — a full 300&nbsp;bp above the average of the 2010s</span>
              </div>
            </aside>
          </div>
          <div class="lg__ticker">
            <span><b>S&amp;P 500</b> 6,214.40 <i class="up">+0.8%</i></span>
            <span><b>10-YR</b> 98&hairsp;<em class="fr">17/32</em> <i class="dn">-0.2</i></span>
            <span><b>BRENT</b> 81.07 <i class="up">+1.1%</i></span>
            <span class="lg__tick-x"><b>EUR</b> 1.0842 <i class="dn">-0.3%</i></span>
            <span class="lg__tick-x"><b>GOLD</b> 2,648.20 <i class="up">+0.4%</i></span>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Archivo plays the Businessweek role end to end: width-78 headline, condensed folios and chart furniture, tabular figures down the bars, a typographic fraction in the ticker — over a Libre Baskerville text block. Hover the bars.</p>
  </figure>

  <!-- ============ 03 — WEB & APP UI ============ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click="[data-tm-density]">
    <figcaption class="iu__cap">
      <span class="index-num">03</span>
      <span class="label">Web &amp; app UI — an equities monitor at real device scale, after the Bloomberg Terminal’s dense keyed-and-coloured screens (interactive)</span>
    </figcaption>
    <div class="iu__scene">
      <div class="tm" data-tm>
        <div class="tm__cmd">
          <span class="tm__app">ARCV 4.2</span>
          <span class="tm__path">EQUITY ▸ MONITOR ▸ US LARGE CAP</span>
          <span class="tm__clock" data-tm-clock>12-JUN-2026 14:32:08 ET</span>
          <button class="tm__density" data-tm-density type="button" aria-pressed="false">DENS ▸ <b data-tm-denslabel>COMFORT</b></button>
        </div>
        <div class="tm__grid">
          <div class="tm__main">
            <table class="tm__table" data-tm-table>
              <thead>
                <tr>
                  <th class="tm__th-l">TICKER</th>
                  <th class="tm__th-l tm__name">NAME</th>
                  <th data-sort="last" data-active="desc">LAST <i></i></th>
                  <th data-sort="pct">CHG% <i></i></th>
                  <th data-sort="vol">VOLUME <i></i></th>
                  <th data-sort="cap" class="tm__xcol">MKT CAP <i></i></th>
                  <th class="tm__xcol">P/E</th>
                  <th class="tm__xcol">YTD%</th>
                </tr>
              </thead>
              <tbody data-tm-body>
                {eq.map((r) => (
                  <tr data-last={r.last} data-pct={r.pct} data-vol={r.volN} data-cap={r.capN}>
                    <td class="tm__th-l"><b class="tm__sym">{r.sym}</b></td>
                    <td class="tm__th-l tm__name tm__dim">{r.name}</td>
                    <td class="tm__num" data-cell="last">{r.last}</td>
                    <td class={`tm__num ${r.pct.startsWith('+') ? 'tm__up' : 'tm__dn'}`} data-cell="pct">{r.pct}</td>
                    <td class="tm__num tm__dim">{r.vol}</td>
                    <td class="tm__num tm__xcol">{r.cap}</td>
                    <td class="tm__num tm__dim tm__xcol">{r.pe}</td>
                    <td class={`tm__num tm__xcol ${r.ytd.startsWith('+') ? 'tm__up' : 'tm__dn'}`}>{r.ytd}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <aside class="tm__side">
            <div class="tm__panel">
              <p class="tm__panel-h">GOVT — US TREASURY · 32NDS</p>
              {govt.map((g) => (
                <p class="tm__row">
                  <span class="tm__sym">{g.t}</span>
                  <span class="tm__num">{g.px}&hairsp;<em class="fr">{g.fr}</em></span>
                  <span class={`tm__num ${g.up ? 'tm__up' : 'tm__dn'}`}>{g.yld}</span>
                </p>
              ))}
            </div>
            <div class="tm__panel">
              <p class="tm__panel-h">FX — MAJORS + ARS</p>
              {fx.map((f) => (
                <p class="tm__row">
                  <span class="tm__sym">{f.p}</span>
                  <span class={`tm__num ${f.up ? 'tm__up' : 'tm__dn'}`}>{f.v}</span>
                </p>
              ))}
            </div>
          </aside>
        </div>
        <div class="tm__keys" aria-hidden="true">
          <span class="tm__key tm__key--acc">F1 HELP</span>
          <span class="tm__key">F2 EQ</span>
          <span class="tm__key">F3 FX</span>
          <span class="tm__key">F4 GOVT</span>
          <span class="tm__key tm__key--ghost">F8 NEWS</span>
          <span class="tm__key tm__key--ghost">F9 MSG</span>
          <span class="tm__hintline">SORT: CLICK A COLUMN HEAD · DENS COMPACT SETS THE GRID AT WIDTH 80 AND SEATS THREE MORE COLUMNS</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Genuinely driven: sort any numeric column, and flip DENS to COMPACT — the whole grid re-sets at wdth 80, the row module tightens, and Mkt&nbsp;Cap / P&#47;E / YTD take the reclaimed inches. Treasury prices run in true 32nd fractions (frac); every figure is tabular (tnum).</p>
  </figure>

  <!-- ============ 04 — BRANDING & IDENTITY ============ -->
  <figure class="iu__item" data-shoot-click="[data-station='rosas']">
    <figcaption class="iu__cap">
      <span class="index-num">04</span>
      <span class="label">Branding &amp; identity — a signage programme for the Subte de Buenos Aires, after Massimo Vignelli &amp; Bob Noorda’s NYC Transit Authority Graphics Standards Manual (1970)</span>
    </figcaption>
    <div class="iu__scene">
      <div class="sg" data-sg>
        <div class="sg__sheethead">
          <span class="sg__man">PROGRAMA DE SEÑALIZACIÓN — SUBTERRÁNEOS DE BUENOS AIRES</span>
          <span class="sg__sheet">SHEET 7 · PLATFORM SIGN, TYPE B</span>
        </div>
        <div class="sg__band">
          <span class="sg__roundel" aria-hidden="true">B</span>
          <span class="sg__msg">
            <span class="sg__name-wrap"><span class="sg__name" data-sg-name>LEANDRO N. ALEM</span></span>
            <span class="sg__sub" data-sg-sub>Salida: Av. Corrientes y L. N. Alem</span>
          </span>
          <svg class="sg__arrow" viewBox="0 0 48 32" aria-hidden="true"><path d="M30 2l14 14-14 14m13-14H2" fill="none" stroke="currentColor" stroke-width="5"/></svg>
        </div>
        <div class="sg__controls" role="group" aria-label="Station message">
          <span class="sg__ctrl-k">MESSAGE ▸</span>
          {stations.map((s, i) => (
            <button class={`sg__btn ${i === 0 ? 'is-on' : ''}`} data-station={s.id} data-name={s.name} data-sub={s.sub} type="button">{s.name}</button>
          ))}
          <span class="sg__readout" data-sg-readout>wdth 100.0 · scale 100%</span>
        </div>
        <div class="sg__notes">
          <span>ONE MASTER, EVERY PLATE — the message condenses along the width axis before it is ever scaled. Floor: wdth 62.</span>
          <span>White out of process black · cap height 87.5&nbsp;mm · Archivo Variable wght 600 · line roundel PMS 485 (Línea B)</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">The standards-manual problem, solved by an axis: pick a station and the plate copy-fits itself — “Juan Manuel de Rosas” rides the width axis to its 62 floor before any reduction. Vignelli needed cut Helvetica plates; Archivo needs one file.</p>
  </figure>

  <!-- ============ 05 — INTERACTIVE & EXPERIMENTAL ============ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click="[data-measure='0.55']">
    <figcaption class="iu__cap">
      <span class="index-num">05</span>
      <span class="label">Interactive &amp; experimental — a foundry broadside justified by the width axis alone, after the Hamilton wood-type playbill and DIA Studio’s kinetic-type practice</span>
    </figcaption>
    <div class="iu__scene">
      <div class="bs" data-bs>
        <div class="bs__bar">
          <span class="bs__bar-t">A BROADSIDE SET LIVE IN THE BROWSER</span>
          <span class="bs__presets" role="group" aria-label="Measure">
            <span class="bs__ctrl-k">MEASURE ▸</span>
            <button data-measure="0.55" type="button">NARROW</button>
            <button data-measure="0.8" type="button" class="is-on">BILL</button>
            <button data-measure="0.94" type="button">FULL</button>
          </span>
        </div>
        <div class="bs__stage" data-bs-stage>
          <div class="bs__inner" data-bs-inner>
            {bill.map((l) => (
              <div class="bs__row">
                <p class={`bs__line ${l.acc ? 'bs__line--acc' : ''}`} data-basis={l.basis} data-wght={l.wght}>{l.txt}</p>
                <span class="bs__tag" data-tag aria-hidden="true">wdth —</span>
              </div>
            ))}
          </div>
          <div class="bs__rule" data-bs-rule role="slider" aria-label="Measure" aria-valuemin="42" aria-valuemax="96" aria-valuenow="80" tabindex="0">
            <span class="bs__rule-grip" aria-hidden="true"></span>
            <span class="bs__rule-tag" aria-hidden="true">MEASURE</span>
          </div>
        </div>
        <p class="bs__colophon">EACH LINE IS SOLVED TO THE MEASURE — WIDTH FIRST, SIZE TO TRIM · DRAG THE RULE OR PICK A PRESET · BUENOS AIRES, MMXXVI</p>
      </div>
    </div>
    <p class="iu__hint label">The playbill’s old law — every line full measure — enforced by wdth instead of a case of different gothics. Drag the measure rule (or arrow keys) and watch each line re-solve: short lines swell toward 125, long lines crush toward 62, the solved value annotated beside every row.</p>
  </figure>

</div>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // NOTE: scroll reveals ride the site-wide [data-reveal] system (Layout adds
  // .is-visible; the shoot harness strips the attribute) — no local observer.

  // ===== shared copy-fit solver (wdth 62–125, then a size trim) =============
  function fitWidth(el: HTMLElement, target: number, wght: number, fsPx: number, opts?: { fill?: boolean }) {
    el.style.fontSize = fsPx + 'px';
    const set = (w: number) => { el.style.fontVariationSettings = `'wdth' ${w}, 'wght' ${wght}`; };
    const wOf = () => el.getBoundingClientRect().width;
    set(125);
    if (wOf() < target) {
      if (opts?.fill) { // grow size at full expansion to land exactly
        el.style.fontSize = (fsPx * target / Math.max(wOf(), 1)) + 'px';
        return 125;
      }
      return 125;
    }
    set(62);
    if (wOf() > target) { // even fully condensed it overflows: scale down
      el.style.fontSize = (fsPx * target / Math.max(wOf(), 1)) + 'px';
      return 62;
    }
    let lo = 62, hi = 125;
    for (let i = 0; i < 8; i++) {
      const mid = (lo + hi) / 2;
      set(mid);
      if (wOf() > target) hi = mid; else lo = mid;
    }
    set(lo);
    if (opts?.fill) {
      el.style.fontSize = (parseFloat(el.style.fontSize) * target / Math.max(wOf(), 1)) + 'px';
    }
    return lo;
  }

  // ===== 03 · Terminal: sort, density, live ticks ============================
  document.querySelectorAll<HTMLElement>('[data-tm]').forEach((tm) => {
    const tbody = tm.querySelector('[data-tm-body]') as HTMLElement;
    const table = tm.querySelector('[data-tm-table]') as HTMLTableElement;
    let sortKey = 'last', sortAsc = false;

    table.querySelectorAll<HTMLElement>('[data-sort]').forEach((th) => {
      th.addEventListener('click', () => {
        const k = th.dataset.sort!;
        if (k === sortKey) sortAsc = !sortAsc;
        else { sortKey = k; sortAsc = false; }
        table.querySelectorAll('th').forEach((x) => x.removeAttribute('data-active'));
        th.setAttribute('data-active', sortAsc ? 'asc' : 'desc');
        const rows = Array.from(tbody.querySelectorAll('tr'));
        rows.sort((a, b) => {
          const av = parseFloat(a.dataset[k] || '0');
          const bv = parseFloat(b.dataset[k] || '0');
          return (av - bv) * (sortAsc ? 1 : -1);
        });
        rows.forEach((r) => tbody.appendChild(r));
      });
    });

    const dens = tm.querySelector('[data-tm-density]') as HTMLButtonElement | null;
    const densLabel = tm.querySelector('[data-tm-denslabel]') as HTMLElement | null;
    dens?.addEventListener('click', () => {
      const on = tm.classList.toggle('is-compact');
      dens.setAttribute('aria-pressed', on ? 'true' : 'false');
      if (densLabel) densLabel.textContent = on ? 'COMPACT' : 'COMFORT';
    });

    if (!reduce) {
      // live price drift + clock
      const clock = tm.querySelector('[data-tm-clock]') as HTMLElement | null;
      let sec = 8;
      setInterval(() => {
        sec = (sec + 1) % 60;
        if (clock) clock.textContent = `12-JUN-2026 14:32:${String(sec).padStart(2, '0')} ET`;
      }, 1000);
      setInterval(() => {
        const rows = Array.from(tbody.querySelectorAll<HTMLTableRowElement>('tr'));
        const r = rows[Math.floor(Math.random() * rows.length)];
        const last = parseFloat(r.dataset.last || '100');
        const drift = last * (Math.random() - 0.48) * 0.004;
        const next = last + drift;
        r.dataset.last = next.toFixed(2);
        const pct = parseFloat(r.dataset.pct || '0') + (drift / last) * 100;
        r.dataset.pct = pct.toFixed(2);
        const lastCell = r.querySelector('[data-cell="last"]') as HTMLElement;
        const pctCell = r.querySelector('[data-cell="pct"]') as HTMLElement;
        lastCell.textContent = next.toFixed(2);
        pctCell.textContent = (pct >= 0 ? '+' : '') + pct.toFixed(2);
        pctCell.classList.toggle('tm__up', pct >= 0);
        pctCell.classList.toggle('tm__dn', pct < 0);
        lastCell.classList.remove('is-flash');
        void lastCell.offsetWidth;
        lastCell.classList.add('is-flash');
      }, 1800);
    }
  });

  // ===== 04 · Subte sign: copy-fit via wdth ==================================
  document.querySelectorAll<HTMLElement>('[data-sg]').forEach((sg) => {
    const name = sg.querySelector('[data-sg-name]') as HTMLElement;
    const sub = sg.querySelector('[data-sg-sub]') as HTMLElement;
    const wrap = name.parentElement as HTMLElement;
    const readout = sg.querySelector('[data-sg-readout]') as HTMLElement | null;

    function solveSign() {
      const target = wrap.getBoundingClientRect().width;
      if (target < 10) return;
      const base = Math.max(22, Math.min(72, target * 0.105));
      // signage system: never expand past 100 — condense first, then scale
      name.style.fontSize = base + 'px';
      name.style.fontVariationSettings = `'wdth' 100, 'wght' 600`;
      let w = 100;
      if (name.getBoundingClientRect().width > target) {
        w = fitWidth(name, target, 600, base);
      }
      const scale = Math.round((parseFloat(name.style.fontSize) / base) * 100);
      if (readout) readout.textContent = `wdth ${w.toFixed(1)} · scale ${scale}%`;
    }

    sg.querySelectorAll<HTMLButtonElement>('[data-station]').forEach((btn) => {
      btn.addEventListener('click', () => {
        sg.querySelectorAll('[data-station]').forEach((b) => b.classList.toggle('is-on', b === btn));
        name.textContent = btn.dataset.name || '';
        sub.textContent = btn.dataset.sub || '';
        solveSign();
      });
    });

    const ro = new ResizeObserver(() => solveSign());
    ro.observe(wrap);
    if ((document as any).fonts?.ready) (document as any).fonts.ready.then(solveSign);
    solveSign();
  });

  // ===== 05 · Broadside: every line justified by wdth ========================
  document.querySelectorAll<HTMLElement>('[data-bs]').forEach((bs) => {
    const stage = bs.querySelector('[data-bs-stage]') as HTMLElement;
    const inner = bs.querySelector('[data-bs-inner]') as HTMLElement;
    const rule = bs.querySelector('[data-bs-rule]') as HTMLElement;
    const rows = Array.from(bs.querySelectorAll<HTMLElement>('.bs__row'));
    let measure = 0.8;

    function solve() {
      const stageW = stage.getBoundingClientRect().width;
      if (stageW < 10) return;
      const pad = parseFloat(getComputedStyle(inner).paddingLeft) || 0;
      const avail = stageW - pad * 2;
      const target = avail * measure;
      rows.forEach((row) => {
        const line = row.querySelector('.bs__line') as HTMLElement;
        const tag = row.querySelector('[data-tag]') as HTMLElement | null;
        const basis = parseFloat(line.dataset.basis || '0.06');
        const wght = parseInt(line.dataset.wght || '600', 10);
        const w = fitWidth(line, target, wght, Math.max(12, target * basis / 0.8), { fill: true });
        if (tag) tag.textContent = 'wdth ' + Math.round(w);
      });
      rule.style.left = (pad + target) + 'px';
      rule.setAttribute('aria-valuenow', String(Math.round(measure * 100)));
      bs.classList.toggle('is-wide', measure > 0.88);
    }

    function setMeasure(m: number) {
      measure = Math.max(0.42, Math.min(0.96, m));
      bs.querySelectorAll<HTMLButtonElement>('[data-measure]').forEach((b) =>
        b.classList.toggle('is-on', Math.abs(parseFloat(b.dataset.measure!) - measure) < 0.02));
      solve();
    }

    bs.querySelectorAll<HTMLButtonElement>('[data-measure]').forEach((btn) =>
      btn.addEventListener('click', () => setMeasure(parseFloat(btn.dataset.measure!))));

    // drag the rule
    let dragging = false;
    let raf = 0;
    rule.addEventListener('pointerdown', (e) => {
      dragging = true;
      rule.setPointerCapture(e.pointerId);
      bs.classList.add('is-dragging');
    });
    rule.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      const r = stage.getBoundingClientRect();
      const pad = parseFloat(getComputedStyle(inner).paddingLeft) || 0;
      const m = (e.clientX - r.left - pad) / Math.max(r.width - pad * 2, 1);
      if (!raf) raf = requestAnimationFrame(() => { raf = 0; setMeasure(m); });
    });
    const stop = () => { dragging = false; bs.classList.remove('is-dragging'); };
    rule.addEventListener('pointerup', stop);
    rule.addEventListener('pointercancel', stop);
    rule.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { setMeasure(measure - 0.04); e.preventDefault(); }
      if (e.key === 'ArrowRight') { setMeasure(measure + 0.04); e.preventDefault(); }
    });

    let roRaf = 0;
    const ro = new ResizeObserver(() => {
      if (!roRaf) roRaf = requestAnimationFrame(() => { roRaf = 0; solve(); });
    });
    ro.observe(stage);
    if ((document as any).fonts?.ready) (document as any).fonts.ready.then(solve);
    solve();
  });
</script>

