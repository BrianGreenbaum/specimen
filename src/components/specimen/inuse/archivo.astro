---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// --- 01 · Financial news dashboard (interactive, real device scale) ----------
const marketRows = [
  { sym: 'AAPL',  name: 'Apple Inc.',          px: '182.63', ch: '+1.42', pct: '+0.78%', vol: '62.4M', up: true  },
  { sym: 'NVDA',  name: 'NVIDIA Corp.',         px: '875.40', ch: '+22.10', pct: '+2.59%', vol: '41.8M', up: true  },
  { sym: 'MSFT',  name: 'Microsoft Corp.',      px: '420.17', ch: '-3.88', pct: '-0.91%', vol: '18.2M', up: false },
  { sym: 'TSLA',  name: 'Tesla Inc.',           px: '194.05', ch: '+6.27', pct: '+3.34%', vol: '88.1M', up: true  },
  { sym: 'META',  name: 'Meta Platforms',       px: '489.92', ch: '-1.14', pct: '-0.23%', vol: '12.7M', up: false },
  { sym: 'AMZN',  name: 'Amazon.com Inc.',      px: '191.78', ch: '+0.33', pct: '+0.17%', vol: '29.3M', up: true  },
] as { sym: string; name: string; px: string; ch: string; pct: string; vol: string; up: boolean }[];

const portfolioRows = [
  { sym: 'AAPL',  name: 'Apple Inc.',           value: '12,840.60', gain: '+2,840.60', gainPct: '+28.4%', shares: '70.3', up: true  },
  { sym: 'MSFT',  name: 'Microsoft Corp.',      value: '8,403.40',  gain: '+1,403.40', gainPct: '+20.0%', shares: '20.0', up: true  },
  { sym: 'NVDA',  name: 'NVIDIA Corp.',         value: '8,754.00',  gain: '+5,254.00', gainPct: '+150.2%', shares: '10.0', up: true },
  { sym: 'TSLA',  name: 'Tesla Inc.',           value: '3,881.00',  gain: '-1,619.00', gainPct: '-29.4%', shares: '20.0', up: false },
  { sym: 'META',  name: 'Meta Platforms',       value: '4,899.20',  gain: '+899.20',   gainPct: '+22.5%', shares: '10.0', up: true  },
] as { sym: string; name: string; value: string; gain: string; gainPct: string; shares: string; up: boolean }[];

const kpis = {
  markets:   { a: '4,217.40', b: '+12.4%', c: '2.4T',   d: '18.7' },
  portfolio: { a: '$38,777',  b: '+18.2%', c: '5 pos',  d: '1.14x' },
  watchlist: { a: '34 items', b: '21 up',  c: '13 dn',  d: '8 new' },
};
---

<div class="iu" style={`--fam:${fam}`}>

  <!-- 01 — INTERACTIVE financial news dashboard (real device scale) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Product UI — financial news dashboard, real device scale</span></figcaption>
    <div class="iu__scene">
      <div class="fin" data-fin>
        <div class="fin__chrome">
          <div class="fin__dots"><i></i><i></i><i></i></div>
          <span class="fin__addr">markets.meridian.io</span>
          <span class="fin__badge">LIVE</span>
        </div>
        <div class="fin__bar">
          <span class="fin__logo"><i class="fin__logo-mark">M</i>Meridian</span>
          <nav class="fin__tabs" role="tablist">
            <button class="is-on" data-tab="markets" role="tab" aria-selected="true">Markets</button>
            <button data-tab="portfolio" role="tab" aria-selected="false">Portfolio</button>
            <button data-tab="watchlist" role="tab" aria-selected="false">Watchlist</button>
          </nav>
          <span class="fin__time" data-clock>09:41 ET</span>
        </div>

        <div class="fin__kpis" data-kpis>
          <div class="fin__kpi">
            <span class="fin__kl">S&amp;P 500</span>
            <b data-kpi-a>{kpis.markets.a}</b>
            <i class="up" data-kpi-b>{kpis.markets.b}</i>
          </div>
          <div class="fin__kpi">
            <span class="fin__kl">Mkt Cap</span>
            <b data-kpi-c>{kpis.markets.c}</b>
            <i class="up">▲ today</i>
          </div>
          <div class="fin__kpi">
            <span class="fin__kl">P/E (avg)</span>
            <b data-kpi-d>{kpis.markets.d}</b>
            <i class="flat">index avg</i>
          </div>
          <div class="fin__kpi fin__kpi--accent">
            <span class="fin__kl">Yield 10Y</span>
            <b>4<span class="fin__frac">13/32</span>%</b>
            <i class="dn">▼ 2bp</i>
          </div>
        </div>

        <div class="fin__body">
          <div class="fin__table-wrap" data-table-wrap>
            <table class="fin__table" data-ftable>
              <thead>
                <tr>
                  <th data-sort="sym">Ticker</th>
                  <th data-sort="name" class="fin__tname">Company</th>
                  <th data-sort="px" class="fin__num" data-active="desc">Price</th>
                  <th data-sort="ch" class="fin__num">Change</th>
                  <th data-sort="vol" class="fin__num fin__hide-sm">Volume</th>
                </tr>
              </thead>
              <tbody data-tbody>
                {marketRows.map((r) => (
                  <tr data-sym={r.sym} data-px={r.px.replace(/,/g,'')} data-chval={r.ch.replace(/[+,]/g,'')} data-vol={r.vol}>
                    <td><b class="fin__sym">{r.sym}</b></td>
                    <td class="fin__tname fin__muted">{r.name}</td>
                    <td class="fin__num"><b class="fin__px">{r.px}</b></td>
                    <td class={`fin__num fin__ch ${r.up ? 'fin__up' : 'fin__dn'}`}>
                      {r.ch}<br/><span class="fin__pct">{r.pct}</span>
                    </td>
                    <td class="fin__num fin__muted fin__hide-sm">{r.vol}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="fin__side">
            <div class="fin__movers-h">Top movers</div>
            <div class="fin__movers" data-movers>
              {marketRows.filter(r=>r.up).slice(0,3).map(r => (
                <div class={`fin__mover fin__mover--up`}>
                  <span class="fin__mover-sym">{r.sym}</span>
                  <span class="fin__mover-pct">{r.pct}</span>
                </div>
              ))}
              {marketRows.filter(r=>!r.up).slice(0,2).map(r => (
                <div class={`fin__mover fin__mover--dn`}>
                  <span class="fin__mover-sym">{r.sym}</span>
                  <span class="fin__mover-pct">{r.pct}</span>
                </div>
              ))}
            </div>
            <div class="fin__gauge-h">Sentiment</div>
            <div class="fin__gauge">
              <div class="fin__gauge-bar">
                <span class="fin__gauge-fill" data-gfill style="width:64%"></span>
                <span class="fin__gauge-needle" data-gneedle style="left:64%"></span>
              </div>
              <div class="fin__gauge-labels"><span>Fear</span><span>Greed</span></div>
              <b class="fin__gauge-val" data-gval>64 — Greed</b>
            </div>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Click column headers to sort; switch tabs — portfolio and watchlist views reload with fresh data. Tabular figures keep every price column flush. The 10Y yield uses a typographic fraction (frac).</p>
  </figure>

  <!-- 02 — Width-axis kinetic poster: condensed → expanded breathe -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Kinetic — wdth axis condensed&#8596;expanded poster</span></figcaption>
    <div class="iu__scene scene-poster">
      <div class="poster" data-poster>
        <div class="poster__bg-grid" aria-hidden="true"></div>
        <div class="poster__top">
          <span class="poster__label">OMNIBUS&middot;TYPE&middot;ARCHIVO&middot;VARIABLE</span>
          <span class="poster__year">2017</span>
        </div>
        <div class="poster__stage">
          <div class="poster__word-wrap">
            <span class="poster__word" data-wdth-word>BROADCAST</span>
          </div>
          <div class="poster__axis-track">
            <span class="poster__axis-l">Condensed <em>62</em></span>
            <div class="poster__axis-bar"><span class="poster__axis-cursor" data-axis-cursor></span></div>
            <span class="poster__axis-r"><em>125</em> Expanded</span>
          </div>
        </div>
        <div class="poster__stack">
          <span class="poster__stack-word" data-stack-a style="--w:62;--wt:900">BOLD CONDENSED</span>
          <span class="poster__stack-word" data-stack-b style="--w:100;--wt:400">NORMAL REGULAR</span>
          <span class="poster__stack-word" data-stack-c style="--w:125;--wt:100">EXPANDED THIN</span>
        </div>
        <div class="poster__foot">
          <span class="poster__desc">Weight 100–900 &times; Width 62–125 &middot; Two axes, one file</span>
          <button class="poster__btn" data-poster-btn type="button">PAUSE</button>
        </div>
      </div>
    </div>
    <p class="iu__hint label">The word breathes across the full wdth axis (62 condensed &#8594; 125 expanded) while cycling through weights. Toggle PAUSE to freeze the demonstration.</p>
  </figure>

  <!-- 03 — Editorial news spread -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Editorial — news magazine feature spread</span></figcaption>
    <div class="iu__scene scene-tall">
      <div class="news">
        <div class="news__masthead">
          <span class="news__issue">THE MERIDIAN REPORT</span>
          <span class="news__rule" aria-hidden="true"></span>
          <span class="news__tagline">ECONOMICS &middot; MARKETS &middot; POLICY</span>
        </div>
        <div class="news__date-line">
          <span>Vol. XLII &middot; No. 24 &middot; June 2026</span>
        </div>
        <div class="news__body">
          <div class="news__col news__col--main">
            <span class="news__kicker">Global Markets</span>
            <h3 class="news__hed">Central banks signal coordinated pause as inflation cools</h3>
            <p class="news__deck">After eighteen months of consecutive hikes, the Federal Reserve, ECB and Bank of England all held rates steady this week, sparking the largest single-day equity rally of 2024.</p>
            <p class="news__byline">BY STAFF ECONOMISTS &middot; <time>4 hours ago</time></p>
            <p class="news__body-text">The decision marks a sharp pivot from the hawkish posture that defined central bank rhetoric since late 2022. Fed Chair signalled confidence that the disinflationary trend was "durable and broad-based," citing twelve consecutive months of core PCE at or below target. Bond markets repriced immediately, pushing the 10-year Treasury yield down by 14 basis points in less than an hour — a move that rippled through every major equity index before the close.</p>
            <p class="news__body-text news__body-text--cont">Analysts were quick to note that the pause is not a pivot; the median dot for year-end still shows rates on hold rather than cuts. But the psychological shift — from "higher for longer" to "steady and watching" — was enough to lift sentiment.</p>
          </div>
          <div class="news__col news__col--side">
            <div class="news__callout">
              <span class="news__callout-num">+2.4%</span>
              <span class="news__callout-cap">S&amp;P 500 single-session gain — largest since November 2023</span>
            </div>
            <div class="news__second">
              <span class="news__kicker">Technology</span>
              <h4 class="news__hed-sm">Open-source AI surpasses proprietary benchmarks for the first time</h4>
              <p class="news__deck-sm">A coalition of European universities released a 70-billion parameter model under a permissive licence, outperforming closed systems on seven standard reasoning tests.</p>
              <p class="news__byline">6 hours ago</p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Archivo's American grotesque authority: condensed kickers (wdth 72) frame open-measure body copy. The pull-quote stat reveals on scroll-into-view; hover the secondary story to slide in its deck. Tabular figures (tnum) keep the stat flush; kickers use wdth 72 condensed.</p>
  </figure>

  <!-- 04 — Media brand identity: masthead / wordmark with wdth-axis lock-up -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Brand — editorial media identity, width-axis wordmark system</span></figcaption>
    <div class="iu__scene scene-brand">
      <div class="brand" data-brand>
        <div class="brand__bg" aria-hidden="true"></div>
        <div class="brand__inner">
          <div class="brand__system">
            <span class="brand__eyebrow">Wordmark system &middot; Archivo Variable</span>
            <div class="brand__lockups">
              <div class="brand__lockup">
                <span class="brand__lockup-label">Condensed Black — display</span>
                <div class="brand__name brand__name--cond">MERIDIAN</div>
              </div>
              <div class="brand__divider" aria-hidden="true"></div>
              <div class="brand__lockup">
                <span class="brand__lockup-label">Regular Bold — masthead</span>
                <div class="brand__name brand__name--reg">MERIDIAN</div>
              </div>
              <div class="brand__divider" aria-hidden="true"></div>
              <div class="brand__lockup">
                <span class="brand__lockup-label">Expanded Thin — motto</span>
                <div class="brand__name brand__name--exp">MERIDIAN</div>
              </div>
            </div>
          </div>
          <div class="brand__tag">
            <div class="brand__full-lockup">
              <span class="brand__full-masthead" data-brand-hover>MERIDIAN</span>
              <span class="brand__full-sub">FINANCIAL INTELLIGENCE</span>
            </div>
            <div class="brand__meta">
              <div class="brand__axis-demo">
                <span class="brand__axis-key">wdth</span>
                <div class="brand__axis-slots">
                  <span class="brand__slot brand__slot--cond">62</span>
                  <span class="brand__slot brand__slot--mid">100</span>
                  <span class="brand__slot brand__slot--exp">125</span>
                </div>
              </div>
              <div class="brand__axis-demo">
                <span class="brand__axis-key">wght</span>
                <div class="brand__axis-slots">
                  <span class="brand__slot brand__slot--thin">100</span>
                  <span class="brand__slot brand__slot--reg-w">400</span>
                  <span class="brand__slot brand__slot--blk">900</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Hover the large masthead to cycle through the full width range (62 condensed &#8594; 125 expanded). Three lockups show how one typeface serves condensed display, standard brand, and expanded editorial cuts.</p>
  </figure>

</div>

<script id="archivo-fin-data" type="application/json" set:html={JSON.stringify({ marketRows, portfolioRows, kpis })} is:inline></script>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ===== 01 · Financial dashboard — tab switching + column sort =====
  type Row = { sym: string; name: string; px: string; ch: string; pct: string; vol: string; up: boolean };
  type PortRow = { sym: string; name: string; value: string; gain: string; gainPct: string; shares: string; up: boolean };
  type Kpis = Record<string, { a: string; b: string; c: string; d: string }>;
  const finIsland = document.getElementById('archivo-fin-data');
  let finData: { marketRows: Row[]; portfolioRows: PortRow[]; kpis: Kpis } =
    { marketRows: [], portfolioRows: [], kpis: {} };
  try { finData = finIsland ? JSON.parse(finIsland.textContent || '{}') : finData; } catch {}

  function makeCell(cls: string, text: string): HTMLTableCellElement {
    const td = document.createElement('td');
    if (cls) td.className = cls;
    td.textContent = text;
    return td;
  }

  function makeBoldCell(outerCls: string, boldCls: string, text: string): HTMLTableCellElement {
    const td = document.createElement('td');
    if (outerCls) td.className = outerCls;
    const b = document.createElement('b');
    b.className = boldCls;
    b.textContent = text;
    td.appendChild(b);
    return td;
  }

  function makeChangeCell(ch: string, pct: string, up: boolean): HTMLTableCellElement {
    const td = document.createElement('td');
    td.className = 'fin__num fin__ch ' + (up ? 'fin__up' : 'fin__dn');
    td.textContent = ch;
    const br = document.createElement('br');
    const span = document.createElement('span');
    span.className = 'fin__pct';
    span.textContent = pct;
    td.appendChild(br);
    td.appendChild(span);
    return td;
  }

  function buildMarketRow(r: Row): HTMLTableRowElement {
    const tr = document.createElement('tr');
    tr.dataset.sym = r.sym;
    tr.dataset.px = r.px.replace(/,/g, '');
    tr.dataset.chval = r.ch.replace(/[+,]/g, '');
    tr.dataset.vol = r.vol;
    tr.appendChild(makeBoldCell('', 'fin__sym', r.sym));
    tr.appendChild(makeCell('fin__tname fin__muted', r.name));
    tr.appendChild(makeBoldCell('fin__num', 'fin__px', r.px));
    tr.appendChild(makeChangeCell(r.ch, r.pct, r.up));
    tr.appendChild(makeCell('fin__num fin__muted fin__hide-sm', r.vol));
    return tr;
  }

  function buildPortRow(r: PortRow): HTMLTableRowElement {
    const tr = document.createElement('tr');
    tr.appendChild(makeBoldCell('', 'fin__sym', r.sym));
    tr.appendChild(makeCell('fin__tname fin__muted', r.name));
    tr.appendChild(makeBoldCell('fin__num', 'fin__px', r.value));
    tr.appendChild(makeChangeCell(r.gain, r.gainPct, r.up));
    tr.appendChild(makeCell('fin__num fin__muted fin__hide-sm', r.shares + ' sh'));
    return tr;
  }

  const watchItems = [
    { sym: 'GOOG', name: 'Alphabet Inc.',  px: '169.30', ch: '+0.44%', up: true  },
    { sym: 'AMD',  name: 'AMD Inc.',       px: '158.40', ch: '+1.82%', up: true  },
    { sym: 'INTC', name: 'Intel Corp.',    px: '31.22',  ch: '-2.14%', up: false },
    { sym: 'SPOT', name: 'Spotify',        px: '302.88', ch: '+3.61%', up: true  },
    { sym: 'SNAP', name: 'Snap Inc.',      px: '11.04',  ch: '-0.72%', up: false },
  ] as Row[];

  document.querySelectorAll<HTMLElement>('[data-fin]').forEach((fin) => {
    if (!finData.marketRows.length) return;
    const q = (s: string) => fin.querySelector(s) as HTMLElement | null;
    const tbody = q('[data-tbody]')!;
    const table = q('[data-ftable]') as HTMLTableElement | null;
    const kpiA = q('[data-kpi-a]'), kpiB = q('[data-kpi-b]');
    const kpiC = q('[data-kpi-c]'), kpiD = q('[data-kpi-d]');
    const gfill = q('[data-gfill]'), gneedle = q('[data-gneedle]'), gval = q('[data-gval]');
    let sortKey = 'px';
    let sortAsc = false;

    function setKpis(tab: string) {
      const k = finData.kpis[tab] || finData.kpis['markets'];
      if (kpiA) kpiA.textContent = k.a;
      if (kpiB) kpiB.textContent = k.b;
      if (kpiC) kpiC.textContent = k.c;
      if (kpiD) kpiD.textContent = k.d;
    }

    function render(tab: string) {
      fin.querySelectorAll<HTMLButtonElement>('[data-tab]').forEach((b) => {
        const on = b.dataset.tab === tab;
        b.classList.toggle('is-on', on);
        b.setAttribute('aria-selected', on ? 'true' : 'false');
      });
      setKpis(tab);
      tbody.replaceChildren();
      const rows: HTMLTableRowElement[] = [];
      if (tab === 'markets') {
        finData.marketRows.forEach((r) => rows.push(buildMarketRow(r)));
      } else if (tab === 'portfolio') {
        finData.portfolioRows.forEach((r) => rows.push(buildPortRow(r)));
      } else {
        watchItems.forEach((r) => rows.push(buildMarketRow(r)));
      }
      rows.forEach((r) => tbody.appendChild(r));
    }

    fin.querySelectorAll<HTMLButtonElement>('[data-tab]').forEach((btn) =>
      btn.addEventListener('click', () => render(btn.dataset.tab!))
    );

    if (table) {
      table.querySelectorAll<HTMLElement>('[data-sort]').forEach((th) =>
        th.addEventListener('click', () => {
          const k = th.dataset.sort!;
          if (k === sortKey) sortAsc = !sortAsc;
          else { sortKey = k; sortAsc = false; }
          table.querySelectorAll('th').forEach((x) => x.removeAttribute('data-active'));
          th.setAttribute('data-active', sortAsc ? 'asc' : 'desc');
          const rows = Array.from(tbody.querySelectorAll('tr'));
          rows.sort((ra, rb) => {
            const av = k === 'sym' ? (ra.querySelector('.fin__sym')?.textContent || '')
              : k === 'name' ? (ra.querySelector('.fin__tname')?.textContent || '')
              : parseFloat(ra.dataset[k === 'ch' ? 'chval' : k] || '0');
            const bv = k === 'sym' ? (rb.querySelector('.fin__sym')?.textContent || '')
              : k === 'name' ? (rb.querySelector('.fin__tname')?.textContent || '')
              : parseFloat(rb.dataset[k === 'ch' ? 'chval' : k] || '0');
            return (av < bv ? -1 : av > bv ? 1 : 0) * (sortAsc ? 1 : -1);
          });
          rows.forEach((r) => tbody.appendChild(r));
        })
      );
    }

    // gentle sentiment gauge animation (reduced-motion: static)
    if (!reduce && gfill && gneedle && gval) {
      let dir = 1;
      let val = 64;
      setInterval(() => {
        val += (Math.random() - 0.5) * 3 * dir;
        if (val > 80) dir = -1;
        if (val < 45) dir = 1;
        val = Math.max(30, Math.min(85, val));
        const pct = Math.round(val);
        gfill.style.width = pct + '%';
        gneedle.style.left = pct + '%';
        gval.textContent = pct + (pct >= 60 ? ' — Greed' : pct >= 45 ? ' — Neutral' : ' — Fear');
      }, 2400);
    }
  });

  // ===== 02 · Width-axis poster animation =====
  document.querySelectorAll<HTMLElement>('[data-poster]').forEach((poster) => {
    const word = poster.querySelector('[data-wdth-word]') as HTMLElement | null;
    const cursor = poster.querySelector('[data-axis-cursor]') as HTMLElement | null;
    const btn = poster.querySelector('[data-poster-btn]') as HTMLButtonElement | null;
    if (!word || !cursor) return;

    const keyframes = [
      { wdth: 62,  wght: 900 },
      { wdth: 62,  wght: 100 },
      { wdth: 100, wght: 400 },
      { wdth: 125, wght: 700 },
      { wdth: 125, wght: 100 },
      { wdth: 80,  wght: 600 },
    ];

    let frame = 0;
    let playing = !reduce;
    let intervalId: ReturnType<typeof setInterval> | null = null;

    function applyFrame(f: { wdth: number; wght: number }) {
      const fvs = `'wdth' ${f.wdth}, 'wght' ${f.wght}`;
      if (!reduce) {
        word.style.transition = 'font-variation-settings 0.8s cubic-bezier(0.4,0,0.2,1)';
        cursor.style.transition = 'left 0.8s cubic-bezier(0.4,0,0.2,1)';
      }
      word.style.fontVariationSettings = fvs;
      cursor.style.left = ((f.wdth - 62) / (125 - 62) * 100).toFixed(1) + '%';
    }

    function step() {
      applyFrame(keyframes[frame]);
      frame = (frame + 1) % keyframes.length;
    }

    function startLoop() {
      if (intervalId) clearInterval(intervalId);
      step();
      intervalId = setInterval(step, 1600);
    }

    if (btn) {
      btn.addEventListener('click', () => {
        playing = !playing;
        btn.textContent = playing ? 'PAUSE' : 'ANIMATE';
        if (playing) startLoop();
        else { if (intervalId) { clearInterval(intervalId); intervalId = null; } }
      });
    }

    if (!reduce) {
      startLoop();
    } else {
      applyFrame(keyframes[0]);
    }
  });

  // ===== 03 · Editorial — scroll-into-view reveal on pull-quote stat =====
  if (!reduce) {
    const callouts = document.querySelectorAll<HTMLElement>('.news__callout');
    if (callouts.length) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.25 });
      callouts.forEach((el) => io.observe(el));
    }
  }

  // ===== 04 · Brand — hover cycles wdth on masthead =====
  document.querySelectorAll<HTMLElement>('[data-brand-hover]').forEach((el) => {
    const steps = [62, 72, 85, 100, 112, 125];
    let i = 0;
    function cycle() {
      i = (i + 1) % steps.length;
      if (!reduce) {
        el.style.transition = 'font-variation-settings 0.35s cubic-bezier(0.4,0,0.2,1)';
      }
      el.style.fontVariationSettings = `'wdth' ${steps[i]}, 'wght' 700`;
    }
    if (!reduce) {
      el.addEventListener('mouseenter', cycle);
    }
    el.addEventListener('click', cycle);
  });
</script>

