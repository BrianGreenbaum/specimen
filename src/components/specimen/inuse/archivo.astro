  /* ============================================================
     03 · ARCV TERMINAL — Bloomberg-style monitor, real px
     intentional dark surface, fully self-declared
     ============================================================ */
  .tm {
    --t-bg: #0b0b0d;
    --t-panel: #121215;
    --t-fg: #e9e4da;
    --t-dim: #8f897f;
