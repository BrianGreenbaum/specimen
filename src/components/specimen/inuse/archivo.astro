  .tm__grid { display: grid; grid-template-columns: 1fr 304px; min-height: 0; }
  .tm__main { min-width: 0; overflow: hidden; }
  .tm__table { width: 100%; border-collapse: collapse; }
  .tm__table th {
    text-align: right; font-size: 10.5px; letter-spacing: 0.1em; color: var(--t-dim);
    font-variation-settings: 'wdth' 72, 'wght' 700; font-weight: normal;
    padding: 9px 14px; border-bottom: 1px solid var(--t-line);
