---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;
// Companion roman for ALL supporting copy — Pinyon is display-only, mixed case, short phrases.
const serif = "'EB Garamond Variable', 'EB Garamond', 'Spectral', Georgia, serif";

// Act 02 — cuvée range for the champagne house
const cuvees = [
  { key: 'brut',  tier: 'Grande Réserve',   name: 'Brut Réserve',    vintage: 'Sans Année',      detail: 'Pinot Noir · Chardonnay · Meunier', note: 'Dosage 8 g/ℓ — dégorgé à la main' },
  { key: 'blanc', tier: 'Côte des Blancs',  name: 'Blanc de Blancs', vintage: 'Millésime 2016',  detail: 'Chardonnay Grand Cru · Avize',      note: 'Huit années sur lattes' },
  { key: 'jos',   tier: 'Cuvée de Prestige', name: 'Joséphine',      vintage: 'Millésime 1996',  detail: 'Vieilles Vignes · Verzenay',        note: 'Oenothèque de la Maison — dégorgement 2024' },
];

const RAILS = 26;

// Act 01 — the off-hand striking: the actual "command of hand" exercise of the
// English roundhand masters — a continuous whole-arm oval drill, entered from the
// headline's final d and exited in a long hairline sweep. The centreline is
// pressure-weighted at build time: downstrokes swell as the split nib opens,
// upstrokes ride a single hair — the burin's own swelling line.
const STRIKE = (() => {
  const N = 360, cy = 165, shear = 0.35;
  const q  = (a: number, b: number, c: number, u: number) =>
    (1 - u) * (1 - u) * a + 2 * (1 - u) * u * b + u * u * c;
  const cb = (a: number, b: number, c: number, d: number, u: number) => {
    const v = 1 - u;
    return v * v * v * a + 3 * v * v * u * b + 3 * v * u * u * c + u * u * u * d;
  };
  const pts: Array<[number, number]> = [];
  for (let i = 0; i <= N; i++) {
    const t = i / N;
    let x: number, y: number;
    if (t < 0.14) {
      // entry hairline — leaves the exit stroke of the d in "Hand", sweeps
      // back left over the striking before the pen dives in
      const u = t / 0.14;
      x = cb(640, 500, 300, 232, u);
      y = cb(22, -14, 2, 45, u);
    } else if (t < 0.86) {
      // the striking — 3¼ diminishing ovals on the slant, travelling right
      const u = (t - 0.14) / 0.72;
      const th = -Math.PI / 2 - Math.PI * 6.5 * u;
      const k = 1 - 0.55 * u;
      y = cy + 120 * k * Math.sin(th);
      x = 190 + 370 * u + 120 * k * 0.66 * Math.cos(th) + shear * (cy - y);
    } else {
      // exit — the long flat sweep off the plate
      const u = (t - 0.86) / 0.14;
      x = cb(524, 560, 700, 818, u);
      y = cb(165, 288, 52, 108, u);
    }
    pts.push([x, y]);
  }
  const segs: Array<{ d: string; w: string; t: string }> = [];
  for (let i = 0; i < N; i++) {
    const [x1, y1] = pts[i], [x2, y2] = pts[i + 1];
    const len = Math.hypot(x2 - x1, y2 - y1) || 1;
    const down = Math.max(0, (y2 - y1) / len);      // pressure only on downstrokes
    const t = i / N;
    const env = Math.min(1, t * 9, (1 - t) * 7);    // taper entry & exit to hairline
    const w = 1.15 + 6.2 * Math.pow(down, 1.3) * env;
    segs.push({
      d: `M ${x1.toFixed(1)} ${y1.toFixed(1)} L ${x2.toFixed(1)} ${y2.toFixed(1)}`,
      w: w.toFixed(2),
      t: t.toFixed(4),
    });
  }
  return segs;
})();
---
<div class="iu ps" style={`--fam:${fam}; --serif:${serif}`}>

  <!-- ════════ 01 · ILLUSTRATION & COMMERCIAL — the engraver's broadside ════════ -->
  <figure class="iu__item iu__item--bleed">
    <div class="iu__scene ps-plate" data-plate>
      <span class="ps-plate__mark" aria-hidden="true"></span>
      <div class="ps-plate__sheet">
        <p class="ps-plate__series">The Universal Penman &nbsp;·&nbsp; <span class="ps-plate__rubric">Plate XLVII</span></p>

        <h3 class="ps-plate__hero ps-script">
          <span class="ps-plate__hero-l1"><span class="ps-plate__kernC">C</span>ommand</span>
          <span class="ps-plate__hero-l2">of Hand</span>
        </h3>

        <svg class="ps-plate__flourish" viewBox="0 0 820 320" aria-hidden="true">
          {STRIKE.map((s) => (
            <path data-seg data-reveal d={s.d} style={`stroke-width:${s.w};--d:calc(${s.t} * 2s + 0.2s)`} />
          ))}
        </svg>

        <p class="ps-plate__sub ps-script">or, the Art of Writing made Easy &amp; Ornamental</p>

        <p class="ps-plate__line">Exemplified in all the masterly performances of the pen, for the use of the youth of Great Britain</p>

        <div class="ps-plate__imprint">
          <span class="ps-plate__credit">G. Bickham <em>sculpsit.</em></span>
          <span class="ps-plate__pub">London: Printed for the Author, &amp; sold at the Crown in Bedford-Bury. MDCCXLI.</span>
          <span class="ps-plate__price">Price 1<em>s.</em></span>
        </div>
      </div>
    </div>
    <figcaption class="iu__cap">
      <span class="index-num">01</span>
      <span class="label">Illustration &amp; commercial — an engraver's broadside, after George Bickham's <em>Universal Penman</em>, London 1741</span>
    </figcaption>
  </figure>

  <!-- ════════ 02 · BRANDING & IDENTITY — the champagne house ════════ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click="[data-cuvee='jos']">
    <div class="iu__scene ps-maison" data-maison>
      <div class="ps-maison__grid">

        <div class="ps-maison__id">
          <span class="ps-maison__kicker">Champagne</span>
          <h3 class="ps-maison__mark ps-script">Veuve Aubert</h3>
          <span class="ps-maison__fils ps-script">&amp; Fils</span>
          <span class="ps-maison__rule" aria-hidden="true"></span>
          <p class="ps-maison__since">Maison fondée à Reims en 1838 — négociant-manipulant, caves de la Montagne de Reims</p>

          <div class="ps-maison__tabs" role="group" aria-label="Choose a cuvée">
            {cuvees.map((c, i) => (
              <button class={`ps-maison__tab${i === 0 ? ' is-on' : ''}`} data-cuvee={c.key}
                data-tier={c.tier} data-name={c.name} data-vintage={c.vintage} data-detail={c.detail} data-note={c.note}>
                {c.name}
              </button>
            ))}
          </div>
        </div>

        <div class="ps-maison__proof">
          <div class="ps-maison__label" data-label>
            <span class="ps-maison__sheen" aria-hidden="true"></span>
            <span class="ps-maison__keyline" aria-hidden="true"></span>
            <span class="ps-label__tier" data-f="tier">{cuvees[0].tier}</span>
            <span class="ps-label__champagne">Champagne</span>
            <span class="ps-label__name ps-script" data-f="name">{cuvees[0].name}</span>
            <span class="ps-label__vintage" data-f="vintage">{cuvees[0].vintage}</span>
            <span class="ps-label__rules" aria-hidden="true"><i></i><b>❦</b><i></i></span>
            <span class="ps-label__house ps-script">Veuve Aubert &amp; Fils</span>
            <span class="ps-label__detail" data-f="detail">{cuvees[0].detail}</span>
            <span class="ps-label__legal">Élaboré et mis en bouteille à Reims, France · NM-218-002 · 12% vol — 750 ml</span>
          </div>
          <p class="ps-maison__note" data-f="note">{cuvees[0].note}</p>
        </div>

      </div>
    </div>
    <figcaption class="iu__cap">
      <span class="index-num">02</span>
      <span class="label">Branding &amp; identity — a champagne house in the engraved négociant label manner, Reims c. 1890</span>
    </figcaption>
    <p class="iu__hint label">Choose a cuvée — the lithographer pulls a fresh label and the gold catches the light.</p>
  </figure>

  <!-- ════════ 03 · EDITORIAL — the Brodovitch feature opener ════════ -->
  <figure class="iu__item">
    <div class="iu__scene ps-mag" data-mag>
      <div class="ps-mag__folio">
        <span>Mirabelle</span>
        <span class="ps-mag__folio-mid">La Saison</span>
        <span>Décembre 1956</span>
      </div>

      <h3 class="ps-mag__head">
        <span class="ps-mag__h1 ps-script" data-nib>The Last Waltz</span>
        <span class="ps-mag__h2 ps-script" data-nib>of the Season</span>
      </h3>

      <p class="ps-mag__deck">As the orchestras of the winter season pack away their strings, our correspondent stays behind at the Crillon for one final turn of the floor.</p>
      <p class="ps-mag__byline">By Céleste Marchand</p>

      <div class="ps-mag__cols">
        <div class="ps-mag__body">
          <p><span class="ps-mag__dropcap ps-script" aria-hidden="true">T</span><span class="ps-mag__after-drop">here is an hour, somewhere past two, when a ball begins to dissolve and becomes finer for it.</span> The chandeliers are dimmed by a third; the kitchen sends up consommé instead of champagne; and the dancers who remain are no longer performing for anyone. It was at this hour, on the last Friday of the season, that the Comtesse de V— asked the orchestra for one more waltz, and the orchestra, halfway into its overcoats, obliged her.</p>
          <p>What followed lasted four minutes and has been discussed for three weeks. The gown was Balenciaga, the partner nobody's husband, and the floor — by then a thicket of abandoned gloves and place cards — entirely theirs. One thinks of such moments as belonging to another century. They do not. They belong to whoever is still standing when the music thins; which is to say, to the patient.</p>
        </div>
        <aside class="ps-mag__aside">
          <span class="ps-mag__pq-rule" aria-hidden="true"></span>
          <p class="ps-mag__pull ps-script">the floor was entirely theirs</p>
          <span class="ps-mag__pq-rule" aria-hidden="true"></span>
          <p class="ps-mag__credit">A waltz, for the record, runs at sixty bars to the minute; the orchestra that night managed fifty-one, and no one on the floor complained. — Hôtel de Crillon, the eighth of December.</p>
        </aside>
      </div>

      <div class="ps-mag__pagefoot">
        <span>85</span>
        <span>Mirabelle</span>
      </div>
    </div>
    <figcaption class="iu__cap">
      <span class="index-num">03</span>
      <span class="label">Editorial — a feature opener in the Brodovitch <em>Harper's Bazaar</em> manner, mid-century</span>
    </figcaption>
  </figure>

  <!-- ════════ 04 · INTERACTIVE & EXPERIMENTAL — the copybook ════════ -->
  <figure class="iu__item iu__item--bleed">
    <div class="iu__scene ps-copy" data-copy>
      <div class="ps-copy__head">
        <span class="ps-copy__lesson">Lesson N° 9 — the connected line</span>
        <span class="ps-copy__slant">Main slant 52° · whole-arm movement</span>
      </div>

      <div class="ps-copy__sheet" data-copy-sheet>
        <svg class="ps-copy__svg" data-copy-svg viewBox="0 0 1200 420" aria-label="Copybook practice sheet">
          <g class="ps-copy__rails" aria-hidden="true">
            {Array.from({ length: RAILS }).map(() => (<line data-rail x1="0" y1="0" x2="0" y2="0" />))}
          </g>
          <g class="ps-copy__stave ps-copy__stave--model" data-stave-model aria-hidden="true">
            <line data-gl="m-asc" /><line data-gl="m-x" /><line data-gl="m-base" class="ps-copy__baseline" /><line data-gl="m-desc" />
          </g>
          <g class="ps-copy__stave" aria-hidden="true">
            <line data-gl="p-asc" /><line data-gl="p-x" /><line data-gl="p-base" class="ps-copy__baseline" /><line data-gl="p-desc" />
          </g>
          <text class="ps-copy__modeltag" data-model-tag>the master's model —</text>
          <text class="ps-copy__model ps-script" data-copy-model>Practice maketh the pen obedient</text>
          <text class="ps-copy__live ps-script" data-copy-live>Yours faithfully,</text>
        </svg>
      </div>

      <div class="ps-copy__bench">
        <label class="ps-copy__field">
          <span>Your copy</span>
          <input class="ps-copy__input" data-copy-input type="text" maxlength="28" value="Yours faithfully," autocomplete="off" spellcheck="false" />
        </label>
        <label class="ps-copy__check">
          <input type="checkbox" data-copy-guides checked />
          <span>Slant rails</span>
        </label>
      </div>
    </div>
    <figcaption class="iu__cap">
      <span class="index-num">04</span>
      <span class="label">Interactive &amp; experimental — the copybook, a writing instrument after P. R. Spencer's <em>Key to Practical Penmanship</em>, 1866</span>
    </figcaption>
    <p class="iu__hint label">Write a line — the pointed pen takes it down on Spencerian guides, entry stroke to exit stroke.</p>
  </figure>

</div>

<script>
  const reduced = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── 01: the burin draws the flourish when the plate enters view ──
  document.querySelectorAll<HTMLElement>('[data-plate]').forEach((plate) => {
    if (reduced()) { plate.classList.add('is-inked'); return; }
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) { plate.classList.add('is-inked'); io.disconnect(); }
      });
    }, { threshold: 0.45 });
    io.observe(plate);
  });

  // ── 03: the nib takes the headline down when the page enters view ──
  document.querySelectorAll<HTMLElement>('[data-mag]').forEach((mag) => {
    const lines = [...mag.querySelectorAll<HTMLElement>('[data-nib]')];
    if (reduced() || !lines.length) return;
    lines.forEach((l) => l.setAttribute('data-reveal', 'wait'));
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          lines.forEach((l) => l.setAttribute('data-reveal', 'go'));
          io.disconnect();
        }
      });
    }, { threshold: 0.3 });
    io.observe(mag);
  });

  // ── 02: cuvée switcher — swap the label copy, replay the foil sheen ──
  document.querySelectorAll<HTMLElement>('[data-maison]').forEach((root) => {
    const label = root.querySelector<HTMLElement>('[data-label]')!;
    const fields = new Map<string, HTMLElement[]>();
    root.querySelectorAll<HTMLElement>('[data-f]').forEach((el) => {
      const k = el.dataset.f!;
      fields.set(k, [...(fields.get(k) ?? []), el]);
    });
    root.querySelectorAll<HTMLButtonElement>('[data-cuvee]').forEach((btn) => {
      btn.addEventListener('click', () => {
        root.querySelectorAll('[data-cuvee]').forEach((b) => b.classList.remove('is-on'));
        btn.classList.add('is-on');
        (['tier', 'name', 'vintage', 'detail', 'note'] as const).forEach((k) => {
          (fields.get(k) ?? []).forEach((el) => { el.textContent = btn.dataset[k] ?? ''; });
        });
        if (!reduced()) {
          label.classList.remove('is-fresh');
          void label.offsetWidth;
          label.classList.add('is-fresh');
        }
      });
    });
  });

  // ── 04: the copybook — JS-laid SVG so 390/768/1440 are true recompositions ──
  const XR = 760 / 2048;            // Pinyon x-height per em (verified in the woff2)
  const SLANT = Math.tan((90 - 52) * Math.PI / 180); // Spencerian main slant, 52° from horizontal

  document.querySelectorAll<HTMLElement>('[data-copy]').forEach((root) => {
    const sheet  = root.querySelector<HTMLElement>('[data-copy-sheet]')!;
    const svg    = root.querySelector<SVGSVGElement>('[data-copy-svg]')!;
    const rails  = [...svg.querySelectorAll<SVGLineElement>('[data-rail]')];
    const live   = svg.querySelector<SVGTextElement>('[data-copy-live]')!;
    const model  = svg.querySelector<SVGTextElement>('[data-copy-model]')!;
    const tag    = svg.querySelector<SVGTextElement>('[data-model-tag]')!;
    const input  = root.querySelector<HTMLInputElement>('[data-copy-input]')!;
    const guides = root.querySelector<HTMLInputElement>('[data-copy-guides]')!;
    const gl = (k: string) => svg.querySelector<SVGLineElement>(`[data-gl="${k}"]`)!;

    const setStave = (p: string, base: number, u: number, W: number, x0: number) => {
      const rows: Array<[string, number]> = [['asc', base - 2.33 * u], ['x', base - u], ['base', base], ['desc', base + 1.1 * u]];
      rows.forEach(([k, y]) => {
        const l = gl(`${p}-${k}`);
        l.setAttribute('x1', String(x0)); l.setAttribute('x2', String(W - x0));
        l.setAttribute('y1', String(y));  l.setAttribute('y2', String(y));
      });
    };

    const fit = (t: SVGTextElement, fs: number, maxW: number) => {
      t.setAttribute('font-size', String(fs));
      const w = t.getComputedTextLength();
      if (w > maxW) t.setAttribute('font-size', String(fs * maxW / w));
    };

    const layout = () => {
      const W = sheet.clientWidth;
      if (!W) return;
      const narrow = W < 640;
      const u  = narrow ? W * 0.092 : W * 0.044;       // x-height in px
      const H  = narrow ? Math.round(W * 0.56) : Math.round(W * 0.355);
      const x0 = W * 0.055;
      svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
      svg.style.aspectRatio = `${W} / ${H}`;
      svg.classList.toggle('is-narrow', narrow);

      // slant rails — leaning 52° toward the writing direction
      const dx = H * SLANT, step = narrow ? W * 0.12 : W * 0.068;
      rails.forEach((r, i) => {
        const x = i * step - dx * 0.5;
        r.setAttribute('x1', String(x + dx)); r.setAttribute('y1', '0');
        r.setAttribute('x2', String(x));      r.setAttribute('y2', String(H));
      });

      const fs = u / XR, maxW = W - 2 * x0;
      if (narrow) {
        const bP = H * 0.62;
        setStave('p', bP, u, W, x0);
        live.setAttribute('x', String(x0)); live.setAttribute('y', String(bP));
        fit(live, fs, maxW);
      } else {
        const bM = H * 0.33, bP = H * 0.80;
        setStave('m', bM, u, W, x0);
        setStave('p', bP, u, W, x0);
        model.setAttribute('x', String(x0)); model.setAttribute('y', String(bM));
        fit(model, fs, maxW);
        tag.setAttribute('x', String(x0)); tag.setAttribute('y', String(bM - 2.33 * u - H * 0.035));
        live.setAttribute('x', String(x0)); live.setAttribute('y', String(bP));
        fit(live, fs, maxW);
      }
    };

    const write = () => {
      live.textContent = input.value || ' ';
      layout();
      if (!reduced()) {
        live.classList.remove('is-writing');
        void (live as unknown as HTMLElement).getBoundingClientRect();
        live.classList.add('is-writing');
      }
    };

    input.addEventListener('input', write);
    guides.addEventListener('change', () => svg.classList.toggle('is-noguides', !guides.checked));
    new ResizeObserver(layout).observe(sheet);
    document.fonts.ready.then(layout);
    layout();
  });
</script>

<style>
  /* ───────────────────────── stack choreography ─────────────────────────
     One thread runs the whole sequence: the engraver's ruled hairline.
     01 cream plate → quick cut → 02 cellar-dark foil → a wide white breath
     → 03 the Brodovitch page → 04 the ruled copybook closes the loop. */
  .iu.ps { gap: 0; }
  .iu.ps > .iu__item + .iu__item { margin-top: clamp(2rem, 4vh, 3rem); }
  .iu.ps > .iu__item:nth-of-type(3) { margin-top: clamp(5.5rem, 13vh, 10rem); }
  .iu.ps > .iu__item:nth-of-type(4) { margin-top: clamp(4rem, 9vh, 7rem); }

  .iu__scene { font-family: var(--serif); }
  .ps-script {
    font-family: var(--fam);
    font-weight: 400;
    font-feature-settings: 'calt' 1, 'liga' 1;
  }
  .iu__hint { margin-top: var(--sp-2); }

  /* ════════════════════════════════════════════════════════════════════
     01 — THE ENGRAVER'S BROADSIDE  (self-declared surface: plate ink on
     laid paper; identical in light and dark)
     ════════════════════════════════════════════════════════════════════ */
  .ps-plate {
    --paper: #ece1c6;
    --paper-2: #e3d5b4;
    --ink: #29200f;
    --ink-2: #5c4f33;
    --rubric: #8e3a22;
    position: relative;
    background:
      radial-gradient(120% 90% at 50% 8%, var(--paper) 55%, var(--paper-2) 100%);
    color: var(--ink);
  }
  /* the intaglio plate-mark — the debossed impression the copper leaves in the sheet */
  .ps-plate__mark {
    position: absolute; inset: clamp(10px, 1.7cqi, 26px); pointer-events: none;
    border: 1px solid color-mix(in srgb, var(--ink) 15%, transparent);
    background: color-mix(in srgb, var(--paper-2) 32%, transparent);
    box-shadow:
      inset 0 1px 1px color-mix(in srgb, var(--ink) 12%, transparent),
      0 1px 0 rgb(255 251 238 / 0.65);
  }
  .ps-plate__sheet {
    display: flex; flex-direction: column; align-items: center; text-align: center;
    padding: 7cqi 6cqi 4.5cqi;
  }
  .ps-plate__series {
    margin: 0;
    font-size: clamp(11px, 1.15cqi, 17px);
    letter-spacing: 0.42em; text-transform: uppercase;
    color: var(--ink-2);
  }
  .ps-plate__rubric { color: var(--rubric); }
  /* the hero is composed, not set: C optically kerned into the o, the second
     line staggered right in the period-plate manner, its final d handing its
     exit stroke straight into the striking below */
  .ps-plate__hero {
    margin: 3cqi 0 0; align-self: stretch;
    display: flex; flex-direction: column; align-items: center;
    font-size: 12.5cqi; line-height: 1.06;
    color: var(--ink);
  }
  .ps-plate__kernC { margin-right: -0.055em; }
  .ps-plate__hero-l1 { transform: translateX(-9cqi); }
  .ps-plate__hero-l2 { transform: translateX(2cqi); margin-top: -2.2cqi; }
  .ps-plate__flourish {
    width: 60cqi; height: auto;
    align-self: center;
    margin-top: -4.5cqi; transform: translateX(6.5cqi);
    overflow: visible; pointer-events: none;
  }
  .ps-plate__flourish path {
    fill: none; stroke: var(--ink); stroke-linecap: round;
  }
  @media (prefers-reduced-motion: no-preference) {
    .ps-plate:not(.is-inked) .ps-plate__flourish path { opacity: 0; }
    .ps-plate.is-inked .ps-plate__flourish path {
      opacity: 0;
      animation: ps-burin 0.3s linear var(--d) forwards;
    }
    @keyframes ps-burin { to { opacity: 1; } }
  }
  .ps-plate__sub {
    margin: 1.6cqi 0 0;
    font-size: 4.6cqi; line-height: 1.4;
    color: var(--ink);
  }
  .ps-plate__line {
    margin: 2.6cqi auto 0; max-width: 52cqi;
    font-size: clamp(12px, 1.35cqi, 20px); line-height: 1.55;
    font-style: italic; color: var(--ink-2);
  }
  .ps-plate__imprint {
    display: flex; align-items: baseline; justify-content: space-between;
