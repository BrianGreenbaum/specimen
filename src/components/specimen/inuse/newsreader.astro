  .lb__colo-cuts { display: flex; align-items: baseline; gap: 1.1rem; margin-left: auto; flex-wrap: wrap; }
  .lb__cut { display: inline-flex; align-items: baseline; gap: 0.4em; white-space: nowrap; }
  .lb__cut b { font-weight: 400; font-size: 15px; color: var(--fg); }
  .lb__cut i { font-family: var(--font-mono); font-style: normal; font-size: 9px; letter-spacing: 0.08em; color: var(--fg-3); }

  /* ============================================================
     RESPONSIVE RECOMPOSITION — 768 first-class, 390 recomposed
     ============================================================ */
  @container (max-width: 900px) {
    /* 02: standfirst drops under the headline; two ranged columns */
    .lr__headblock { grid-template-columns: minmax(0, 1fr); }
    .lr__stand { margin-top: 1.1rem; max-width: 38ch; border-left: 0; padding-left: 0; border-top: 1px solid var(--line); padding-top: 1rem; }
    .lr__cols { columns: 2; }
    /* 03: the shelf becomes browsable — covers keep their full size
       and the row scrolls with snap, the next board peeking in */
    .ed__shelf {
      display: flex; overflow-x: auto; overscroll-behavior-x: contain;
      scroll-snap-type: x mandatory; scrollbar-width: none;
      margin-inline: calc(-1 * clamp(1.2rem, 5cqi, 4.5rem));
      padding-inline: clamp(1.2rem, 5cqi, 4.5rem);
    }
    .ed__cover { flex: 0 0 40cqi; scroll-snap-align: center; }
    /* 04: plate stacks — identity above, ladder below as its own band.
       minmax(0,1fr) so nowrap lockups can never push past the padding */
    .bd__grid { grid-template-columns: minmax(0, 1fr); gap: clamp(1.6rem, 4cqi, 2.6rem); }
    .bd__ladder { border-left: 0; border-top: 1px solid rgba(238, 232, 216, 0.18); padding-left: 0; padding-top: clamp(1.4rem, 3cqi, 2.2rem); }
    /* 05: colophon stacks its rows */
    .lb__colo-cuts { margin-left: 0; }
  }

  @container (max-width: 700px) {
    /* 02: the meta rail becomes a band above the text */
    .lr__body { grid-template-columns: minmax(0, 1fr); row-gap: 1.1rem; }
    .lr__rail {
      border-right: 0; padding-right: 0; border-bottom: 1px solid var(--line-soft); padding-bottom: 1rem;
      display: grid; grid-template-columns: 1fr auto; column-gap: 1.2rem; align-items: baseline;
    }
    .lr__name { grid-column: 1; }
    .lr__role { grid-column: 1; }
    .lr__when { grid-column: 2; grid-row: 1; margin-top: 0 !important; border-top: 0; padding-top: 0; text-align: right; }
    .lr__read { grid-column: 2; grid-row: 2; margin-top: 0.2em !important; text-align: right; }
    .lr__letters { grid-column: 1 / -1; margin-top: 0.8em !important; padding-top: 0.8em; }
  }

  @container (max-width: 560px) {
    /* 01: notes stack; proof rows stack their labels */
    .ax__word { font-size: clamp(64px, 21.5cqi, 96px); }
    .ax__notes { flex-direction: column; gap: 0.7rem; }
    .ax__notes li { opacity: 0.45; }
    .ax__proofrow { flex-direction: column; gap: 0.25rem; margin-bottom: 0.8em; }
    .ax__proofline { font-size: 15px; }
    .ax__end { display: none; }
    .ax__head { gap: 0.3em; }

    /* 02: single column; headline takes the full measure */
    .lr__cols { columns: 1; }
    .lr__head { font-size: clamp(38px, 11.5cqi, 52px); }
    .lr__stand { font-size: clamp(17px, 5cqi, 21px); }
    .lr__folio { flex-wrap: wrap; gap: 0.6em 1.4em; }
    .lr__foot span:last-child { display: none; }

    /* 03: one board fills the view; the next peeks to ask for a swipe */
    .ed__cover { flex-basis: 78cqi; }
    .ed__plate { gap: 0.3em; }

    /* 04: the ladder leads with smaller steps; the credit lockup wraps
       (never amputated) — the plate's own rule survives the phone */
    .bd__mark { font-size: clamp(52px, 16.5cqi, 72px); }
    .bd__use--1 { font-size: clamp(30px, 9cqi, 40px); }
    .bd__use--2 { font-size: clamp(19px, 5.6cqi, 24px); }
    .bd__use--4 { white-space: normal; overflow: visible; text-overflow: clip; }
    .bd__depts { gap: 0.3em 1.1em; }
    .bd__icons { gap: 1rem; }
    .bd__tile--a { width: 64px; height: 64px; font-size: 38px; }
    .bd__tilewrap b { font-size: 8.5px; }

    /* 05: chrome simplifies; entries hang the clock above the copy */
    .lb__mast { flex-wrap: wrap; gap: 0.5rem 0.7rem; padding: 0.7rem 0.9rem 0.6rem; }
    .lb__updated { width: 100%; margin-left: 0; }
    .lb__title { padding: 0.9rem 0.9rem 0.8rem; }
    .lb__title h3 { font-size: 22px; }
    .lb__bar { padding: 0.55rem 0.9rem; gap: 0.5rem; }
    .lb__glance { margin: 0.9rem 0.9rem 0.2rem; }
    .lb__feed { padding: 0.3rem 0.9rem 1.2rem; }
    .lb__e { grid-template-columns: 1fr; gap: 0.3rem; }
    .lb__scroll { height: 430px; }
    .lb__colo { padding: 0.7rem 0.9rem 0.8rem; gap: 0.6rem; }
    .lb__colo-cuts { gap: 0.9rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ax__notes li, .bd__toggle, .lb__filters button, .lb__pill { transition: none; }
  }
</style>
