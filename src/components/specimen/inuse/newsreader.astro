  }
  .lb__glance li span { font-size: 13.5px; line-height: 1.45; color: var(--fg); font-variation-settings: 'wght' 470, 'opsz' 13; }
  .lb__feed { padding: 0.4rem 1.1rem 1.4rem; }
  .lb__e {
    display: grid; grid-template-columns: 64px minmax(0, 1fr); gap: 1rem;
    padding: 0.95rem 0; border-bottom: 1px solid var(--line-soft);
