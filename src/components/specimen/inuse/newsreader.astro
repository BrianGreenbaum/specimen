  .lb__title { padding: 1.1rem 1.1rem 0.9rem; border-bottom: 1px solid var(--line); }
  .lb__title h3 {
    margin: 0; font-size: 27px; line-height: 1.1; letter-spacing: -0.008em;
    font-variation-settings: 'wght' 680, 'opsz' 34; color: var(--fg); text-wrap: balance;
  }
  .lb__title p {
    margin: 0.45rem 0 0; font-style: italic; font-size: 15px;
    font-variation-settings: 'wght' 400, 'opsz' 15; color: var(--fg-2);
  }
  .lb__bar {
    display: flex; align-items: center; gap: 0.8rem;
    padding: 0.6rem 1.1rem; border-bottom: 1px solid var(--line);
    background: color-mix(in srgb, var(--fg) 3%, var(--bg));
  }
  .lb__filters { display: flex; gap: 0.3rem; }
  .lb__filters button {
    font-family: var(--font-ui); font-size: 11.5px; font-weight: 600; color: var(--fg-3);
    cursor: pointer; background: transparent; border: 1px solid var(--line); border-radius: 100px;
    padding: 0.32rem 0.75rem; transition: all 0.18s var(--ease, ease-out); white-space: nowrap;
  }
  .lb__filters button:hover { color: var(--fg); border-color: var(--fg-3); }
  .lb__filters button.is-on { color: var(--accent-contrast); background: var(--accent); border-color: var(--accent); }
