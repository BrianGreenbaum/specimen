---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;
---
<div class="iu" style={`--fam:${fam}`}>

  <!-- ============================================================
       01 — INTERACTIVE & EXPERIMENTAL
       The optical-size axis played as an instrument. Reference:
       Linn Boyd Benton's pantographic engraver (ATF, 1885), the
       machine that mechanized optical scaling — reborn as `opsz`.
       ============================================================ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Interactive &mdash; an optical-size instrument: Benton&rsquo;s pantograph (1885), reborn as an axis</span></figcaption>
    <div class="iu__scene">
      <div class="ax" data-ax style="--x:16.32">
        <header class="ax__head">
          <span class="ax__title">Newsreader &middot; the optical-size axis</span>
          <span class="ax__meta">fvar &middot; &laquo;opsz&raquo; 6&ndash;72 &middot; one file, every cut</span>
        </header>
        <div class="ax__stage">
          <p class="ax__word" data-word>Reason</p>
          <p class="ax__sub" data-sub>You are looking at the 9&#8202;pt cut, blown up to poster size.</p>
        </div>
        <div class="ax__railwrap">
          <span class="ax__end">caption</span>
          <div class="ax__rail" data-rail role="slider" tabindex="0"
               aria-label="Optical size, 6 to 72 points" aria-valuemin="6" aria-valuemax="72" aria-valuenow="9">
            <span class="ax__line" aria-hidden="true"></span>
            <span class="ax__tick" style="--p:0%"><i>6</i></span>
            <span class="ax__tick" style="--p:16.3%"><i>9</i></span>
            <span class="ax__tick" style="--p:27.9%"><i>12</i></span>
            <span class="ax__tick" style="--p:44.2%"><i>18</i></span>
            <span class="ax__tick" style="--p:55.8%"><i>24</i></span>
            <span class="ax__tick" style="--p:72.1%"><i>36</i></span>
            <span class="ax__tick" style="--p:100%"><i>72</i></span>
            <span class="ax__thumb" aria-hidden="true"><b class="ax__readout" data-readout>opsz&#8201;9</b></span>
          </div>
          <span class="ax__end">display</span>
        </div>
        <ul class="ax__notes">
          <li data-zone="caption" class="is-on"><b>6&ndash;11 &middot; caption cut</b><span>serifs brace, strokes thicken, the fit opens</span></li>
          <li data-zone="text"><b>12&ndash;17 &middot; text cut</b><span>the even grey of a reading page</span></li>
          <li data-zone="display"><b>18&ndash;72 &middot; display cut</b><span>hairlines sharpen, the fit closes</span></li>
        </ul>
        <div class="ax__proof">
          <div class="ax__proofrow">
            <span class="ax__prooflabel">cut for 6&#8202;pt</span>
            <p class="ax__proofline ax__proofline--6">Benton&rsquo;s pantograph cut a different letter for every size; this file still does.</p>
          </div>
          <div class="ax__proofrow">
            <span class="ax__prooflabel">cut for 72&#8202;pt</span>
            <p class="ax__proofline ax__proofline--72">Benton&rsquo;s pantograph cut a different letter for every size; this file still does.</p>
          </div>
          <span class="ax__proofnote">both lines set at the same pixel size &mdash; only the cut changes</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Drag the rail (or focus it and use the arrow keys). Small cuts are sturdier and wider-set; the display cut is sharper and closer &mdash; the same trade a punchcutter made by hand, size by size.</p>
  </figure>

  <!-- ============================================================
       02 — EDITORIAL
       An opinion long-read front, committed to the Guardian's 2018
       relaunch (Guardian Headline + the Garnett grid, Commercial
       Type / GMG design team): section-colour kicker, black ragged
       headline, display standfirst in the true italic, a left meta
       rail, ranged-left text columns, section-colour drop cap and
       byline, inline pull quote with the oversized quote mark.
       ============================================================ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Editorial &mdash; an opinion long-read on the Garnett grid of the Guardian&rsquo;s 2018 relaunch</span></figcaption>
    <div class="iu__scene">
      <div class="lr">
        <div class="lr__inner">
          <header class="lr__folio">
            <span class="lr__brand">The Long View</span>
            <span class="lr__sect">Opinion</span>
            <span class="lr__no">&#8470;&#8201;1,062</span>
          </header>
          <div class="lr__headblock">
            <p class="lr__kicker">The slow lane</p>
            <h2 class="lr__head" data-reveal>The case for one story a&nbsp;day</h2>
            <p class="lr__stand" data-reveal>Three years ago we stopped chasing the wire and started publishing one story a day. The traffic charts never forgave us. The readers never had&nbsp;to.</p>
          </div>
          <div class="lr__body">
            <aside class="lr__rail">
              <p class="lr__name">Naomi Ostler</p>
              <p class="lr__role">Editor of The Long View</p>
              <p class="lr__when">Sat 13 Jun 2026 06.00&#8201;BST</p>
              <p class="lr__read">22&#8202;min read</p>
              <p class="lr__letters">Letters: long@thelongview.press</p>
            </aside>
            <div class="lr__cols">
              <p><span class="lr__drop">T</span>hree years ago this newspaper made a bet that looked, to everyone in the trade, like a resignation letter. We stopped chasing the wire. We closed the homepage that refreshed itself every ninety seconds, thanked the traffic dashboard for its service, and began publishing one story a day &mdash; reported for weeks, edited hard, and set in a typeface drawn to be read for forty minutes at a stretch.</p>
              <p>The bet was not that readers would tolerate less news. It was that most of what we had been calling news was noise with a timestamp &mdash; and that attention, once we stopped strip-mining it, might turn out to be renewable.</p>
              <p>It worked, though not in the way the projections promised. Membership grew slowly, then steadily, and it did not churn. The median visit now runs to thirty-eight minutes. Nobody bounces off a story they have decided, in advance, to finish.</p>
              <blockquote class="lr__pull"><span class="lr__q" aria-hidden="true">&ldquo;</span>Attention is not harvested here. It is spent &mdash; deliberately, the way you spend good&nbsp;money</blockquote>
              <p>There were costs, and we should be honest about them. We are never first. We have been beaten on every breaking story of the decade, usually by hours, occasionally by days. What we have instead is the second paragraph the first reports never reach &mdash; the one that explains what the event actually changes, and for whom.</p>
              <p>The lesson, three years in, is not that slowness is a virtue in itself; speed is a virtue too &mdash; ask an ambulance. The lesson is that a newspaper, like a typeface, should be cut for the size at which it will actually be read. <span class="lr__endmark" aria-hidden="true">&#9670;</span></p>
            </div>
          </div>
          <footer class="lr__foot">
            <span>Tomorrow: the riverfront contracts, properly read</span>
            <span>thelongview.press</span>
          </footer>
        </div>
      </div>
    </div>
    <p class="iu__hint label">The headline settles from its text weight into the display black it was cut for; the standfirst answers at display size in the true italic. One family, 200 to 800, ranged left on the meta-rail grid.</p>
  </figure>

  <!-- ============================================================
       03 — ILLUSTRATION & COMMERCIAL
       Type as the picture: an all-type book-cover series in the
       current David Pearson opened with Penguin's Great Ideas
       (2004→) — each cover set, not illustrated. Cover one is a
       knowing pastiche of Baskerville's 1757 Virgil title page
       (Newsreader's own lineage); cover two paints with the wght
       axis; cover three is a redacted document at the caption cut.
       ============================================================ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Illustration &mdash; an all-type cover series, in the Pearson&thinsp;/&thinsp;Penguin Great Ideas current (2004&rarr;)</span></figcaption>
    <div class="iu__scene">
      <div class="ed" data-ed>
        <header class="ed__plate">
          <span>Long View Editions &middot; the year&rsquo;s reporting, bound</span>
          <span>Series one &mdash; covers set, not illustrated</span>
        </header>
        <div class="ed__shelf">

          <article class="ed__cover">
            <div class="ed__page ed__page--c">
              <p class="ed__c-the">The</p>
              <p class="ed__c-title">Slow<br/>Lane</p>
              <span class="ed__c-rule" aria-hidden="true"></span>
              <p class="ed__c-or">or,</p>
              <p class="ed__c-sub">A Defence of Reading One Story a&nbsp;Day</p>
              <p class="ed__c-imprint">Collected columns from The&nbsp;Long&nbsp;View; with a preface by the editor, and a note on the&nbsp;type</p>
              <span class="ed__c-rule" aria-hidden="true"></span>
              <p class="ed__c-year">Printed for the members &middot; MMXXVI</p>
              <footer class="ed__band"><span>Long View Editions</span><b>&#8470;&#8201;1</b><span>&pound;10.99</span></footer>
            </div>
          </article>

          <article class="ed__cover">
            <div class="ed__page ed__page--a">
              <p class="ed__a-row" style="--w:800">Attention</p>
              <p class="ed__a-row" style="--w:630">Attention</p>
              <p class="ed__a-row" style="--w:490">Attention</p>
              <p class="ed__a-row" style="--w:380">Attention</p>
              <p class="ed__a-row ed__a-row--dim" style="--w:285">Attention</p>
              <p class="ed__a-row ed__a-row--last" style="--w:200">Attention</p>
              <p class="ed__a-title"><b>On Attention</b> &mdash; essays on what the wire age spent, and how it might be got&nbsp;back</p>
              <footer class="ed__band"><span>Long View Editions</span><b>&#8470;&#8201;2</b><span>&pound;10.99</span></footer>
            </div>
          </article>

          <article class="ed__cover">
            <div class="ed__page ed__page--r">
              <p class="ed__r-title">The<br/>Riverfront<br/>Papers</p>
              <p class="ed__r-sub">An anatomy of a public contract, with the redactions left&nbsp;showing</p>
              <p class="ed__r-doc">Memorandum of agreement, made this <i class="ed__bar" style="--w:5.5ch;--d:0" aria-label="redacted"></i> day of <i class="ed__bar" style="--w:7ch;--d:90" aria-label="redacted"></i> 2024, between the City and <i class="ed__bar" style="--w:9ch;--d:180" aria-label="redacted"></i> Ltd, for works upon the riverfront in the sum of &pound;8,400,000, procured under the emergency rule; witnessed by <i class="ed__bar" style="--w:8ch;--d:270" aria-label="redacted"></i>, and signed in the presence of <i class="ed__bar" style="--w:10ch;--d:360" aria-label="redacted"></i>, councillor, who has since <i class="ed__bar" style="--w:9ch;--d:450" aria-label="redacted"></i>. The rest publishes at six.</p>
              <footer class="ed__band"><span>Long View Editions</span><b>&#8470;&#8201;3</b><span>&pound;10.99</span></footer>
            </div>
          </article>

        </div>
        <p class="ed__colo">Set throughout in one file: the display cut for the boards, the caption cut for the documents &middot; thelongview.press/editions</p>
      </div>
    </div>
    <p class="iu__hint label">Three boards, no pictures &mdash; the type is the illustration. &#8470;&#8201;1 borrows the manner of Baskerville&rsquo;s 1757 Virgil title page; &#8470;&#8201;2 paints with the weight axis, 800 down to 200; &#8470;&#8201;3 sets the contract at the 7&#8202;pt caption cut and lets the censor&rsquo;s bars print across it as you arrive.</p>
  </figure>

  <!-- ============================================================
       04 — BRANDING & IDENTITY
       A slow-journalism identity in the serif-led, member-funded
       current of De Correspondent (Momkai, 2013) and Tortoise —
       presented as a guideline plate: the logotype is re-cut, never
       scaled.
       ============================================================ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click="[data-onecut]">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Branding &mdash; a slow-journalism identity, after De Correspondent (Momkai, 2013); the logotype re-cut at every size</span></figcaption>
    <div class="iu__scene">
      <div class="bd" data-bd>
        <header class="bd__plate">
          <span>Identity guidelines &middot; The Long View</span>
          <span>Plate 04 &mdash; logotype at size</span>
        </header>
        <div class="bd__grid">
          <div class="bd__id">
            <p class="bd__mark">The Long<br/>View</p>
            <p class="bd__manifesto">Slow news, told&nbsp;properly.</p>
            <p class="bd__est">Member-funded journalism &middot; Est. 2023 &middot; 41,206 readers &middot; no advertising</p>
            <ul class="bd__depts">
              <li>The Long View&thinsp;/&thinsp;<em>Climate</em></li>
              <li>The Long View&thinsp;/&thinsp;<em>Courts</em></li>
              <li>The Long View&thinsp;/&thinsp;<em>Money</em></li>
              <li>The Long View&thinsp;/&thinsp;<em>The Slow Lane</em></li>
            </ul>
            <div class="bd__icons">
              <span class="bd__tilewrap"><i class="bd__tile bd__tile--a">L.</i><b>88&#8202;px &middot; opsz&#8201;72</b></span>
              <span class="bd__tilewrap"><i class="bd__tile bd__tile--b">L.</i><b>46&#8202;px &middot; opsz&#8201;20</b></span>
              <span class="bd__tilewrap"><i class="bd__tile bd__tile--c">L.</i><b>26&#8202;px &middot; opsz&#8201;8</b></span>
            </div>
          </div>
          <div class="bd__ladder">
            <div class="bd__step">
              <p class="bd__use bd__use--1">The Long View</p>
              <span class="bd__spec"><b class="bd__right">masthead &middot; cut at opsz&#8201;72</b><b class="bd__wrong">one cut for all &middot; opsz&#8201;72</b></span>
            </div>
            <div class="bd__step">
              <p class="bd__use bd__use--2">The Long View &mdash; Courts</p>
              <span class="bd__spec"><b class="bd__right">section head &middot; re-cut at opsz&#8201;30</b><b class="bd__wrong">opsz&#8201;72 &mdash; hairlines starve</b></span>
            </div>
            <div class="bd__step">
              <p class="bd__use bd__use--3">The Long View &middot; Today&rsquo;s story &middot; Members</p>
              <span class="bd__spec"><b class="bd__right">app bar &middot; re-cut at opsz&#8201;15</b><b class="bd__wrong">opsz&#8201;72 &mdash; too tight to read</b></span>
            </div>
            <div class="bd__step">
              <p class="bd__use bd__use--4">From The Long View, a member-funded daily &middot; thelongview.press</p>
              <span class="bd__spec"><b class="bd__right">credit line &middot; re-cut at opsz&#8201;7</b><b class="bd__wrong">opsz&#8201;72 &mdash; gone at this size</b></span>
            </div>
            <button class="bd__toggle" type="button" data-onecut aria-pressed="false">
              <span class="bd__tg-a">Break the rule: one cut at every size</span>
              <span class="bd__tg-b">Restore the re-cut logotypes</span>
            </button>
            <p class="bd__rule">The logotype is never scaled &mdash; it is <em>re-cut</em>. Each size uses the optical cut drawn for it.</p>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Press the button to set every lockup in the display cut &mdash; and watch the small sizes starve. The system, not a logo, is the identity; the optical axis is its house rule.</p>
  </figure>

  <!-- ============================================================
       05 — WEB & APP UI (true px, user-driven)
       The Long View's daily live briefing, in the live-coverage
       format the NYT codified from 2020 on: timestamped entries,
       key-event filtering, corrections on the record. The masthead
       carries the navy of plate 04; the colophon shows the brand
       re-cut per the house rule.
       ============================================================ -->
  <figure class="iu__item" data-shoot-click="[data-newpill]">
    <figcaption class="iu__cap"><span class="index-num">05</span><span class="label">Web &amp; app UI &mdash; the daily live briefing, in the live-coverage format the NYT codified (2020&rarr;)</span></figcaption>
    <div class="iu__scene">
      <div class="iu__device lb" data-lb data-filter="all">
        <div class="iu__chrome">
          <div class="iu__dots"><i></i><i></i><i></i></div>
          <span class="iu__addr">thelongview.press/briefing/2026-06-10</span>
        </div>
        <div class="lb__mast">
          <span class="lb__brand">The Long View</span>
          <span class="lb__sub">Briefing</span>
          <span class="lb__live"><i aria-hidden="true"></i>Live</span>
          <span class="lb__updated">Updated <b data-updated>15:24</b></span>
        </div>
        <div class="lb__title">
          <h3>Wednesday 10 June &mdash; the day, as it happens</h3>
          <p>One story a day takes all day to choose. This is the choosing, on the record.</p>
        </div>
        <div class="lb__bar">
          <div class="lb__filters" role="group" aria-label="Filter entries">
            <button type="button" class="is-on" data-flt="all" aria-pressed="true">All entries</button>
            <button type="button" data-flt="key" aria-pressed="false">Key events</button>
          </div>
          <button type="button" class="lb__pill" data-newpill>2 new entries</button>
        </div>
        <div class="lb__scroll">
          <aside class="lb__glance">
            <h4>At a glance</h4>
            <ol>
              <li><b>01</b><span>Court orders the city to publish the riverfront contracts in full</span></li>
              <li><b>02</b><span>Contract figure corrected to &pound;8.4m after a reader&rsquo;s letter</span></li>
              <li><b>03</b><span>Tonight&rsquo;s story: who actually signed, and when</span></li>
            </ol>
          </aside>
          <div class="lb__feed" data-feed>
            <article class="lb__e" data-key>
              <div class="lb__when"><b>13:40</b></div>
              <div class="lb__what">
                <span class="lb__tag">Key event</span>
                <h4>What the riverfront ruling changes</h4>
                <p>The order is narrow but the precedent is not: every contract signed under the emergency procurement rule &mdash; <span class="lb__fig">31</span> of them since 2024 &mdash; is now presumptively public. The city has <span class="lb__fig">14</span> days to comply.</p>
              </div>
            </article>
            <article class="lb__e">
              <div class="lb__when"><b>11:02</b></div>
              <div class="lb__what">
                <h4>Markets, briefly</h4>
                <p>Quiet morning; the story is elsewhere.</p>
                <dl class="lb__tab">
                  <div><dt>10-yr gilt</dt><dd>4.12%</dd><dd class="lb__dn">&minus;0.03</dd></div>
                  <div><dt>Wheat, Dec.</dt><dd>187.25</dd><dd class="lb__dn">&minus;1.40</dd></div>
                  <div><dt>FTSE 250</dt><dd>21,408</dd><dd class="lb__up">+0.4%</dd></div>
                </dl>
              </div>
            </article>
            <article class="lb__e" data-key>
              <div class="lb__when"><b>09:14</b></div>
              <div class="lb__what">
                <span class="lb__tag">Key event</span>
                <h4>Court rules city must publish riverfront contracts</h4>
                <p>Justice Mbeki, for the court: <em>&ldquo;A public work, paid for publicly, may not be procured privately. The documents will be produced.&rdquo;</em> The city has not said whether it will appeal.</p>
              </div>
            </article>
            <article class="lb__e">
              <div class="lb__when"><b>06:30</b></div>
              <div class="lb__what">
                <h4>What matters this morning</h4>
                <p>The riverfront judgment lands at nine. We have read the <span class="lb__fig">212</span>-page bundle so you don&rsquo;t have to; the only page that matters is <span class="lb__fig">147</span>.</p>
              </div>
            </article>
          </div>
        </div>
        <footer class="lb__colo">
          <span class="lb__colo-note">House rule, plate 04 &mdash; re-cut, never scaled. Same 15&#8202;px, three cuts:</span>
          <span class="lb__colo-cuts">
            <span class="lb__cut"><b style="font-variation-settings:'wght' 560,'opsz' 72">The Long View</b><i>opsz&#8201;72</i></span>
            <span class="lb__cut"><b style="font-variation-settings:'wght' 560,'opsz' 22">The Long View</b><i>opsz&#8201;22</i></span>
            <span class="lb__cut"><b style="font-variation-settings:'wght' 600,'opsz' 7;letter-spacing:0.015em">The Long View</b><i>opsz&#8201;7</i></span>
          </span>
        </footer>
        <template data-newtpl>
          <article class="lb__e" data-key>
            <div class="lb__when"><b>17:05</b></div>
            <div class="lb__what">
              <span class="lb__tag">Key event</span>
              <h4>Tonight&rsquo;s story: who signed, and when</h4>
              <p>The contracts name three signatories. Two of them, as of <span class="lb__fig">16:50</span>, have stopped answering the phone. The full story publishes at six.</p>
            </div>
          </article>
          <article class="lb__e">
            <div class="lb__when"><b>16:41</b></div>
            <div class="lb__what">
              <span class="lb__tag lb__tag--corr">Correction</span>
              <h4>The contract figure is &pound;8.4m, not &pound;8.1m</h4>
              <p>A reader, rightly, counted. An earlier entry understated the riverfront contract value by <span class="lb__fig">&pound;0.3m</span>. The entry has been amended; the reader has been thanked.</p>
            </div>
          </article>
        </template>
      </div>
    </div>
    <p class="iu__hint label">Filter to the key events &mdash; the feed reflows, animated &mdash; then load the two new entries, one of them a correction on the record. Timestamps, ledger and tables sit in tabular figures; the quotes lean into the true italic.</p>
  </figure>

</div>

<script>
  // ---- 01 · optical-size instrument -------------------------------------
  document.querySelectorAll<HTMLElement>('[data-ax]').forEach((ax) => {
    const rail = ax.querySelector<HTMLElement>('[data-rail]')!;
    const word = ax.querySelector<HTMLElement>('[data-word]')!;
    const sub = ax.querySelector<HTMLElement>('[data-sub]')!;
    const readout = ax.querySelector<HTMLElement>('[data-readout]')!;
    const notes = Array.from(ax.querySelectorAll<HTMLElement>('[data-zone]'));
    const LOG12 = Math.log(12);
    let o = 9;

    const zone = (v: number) => (v < 12 ? 'caption' : v < 18 ? 'text' : 'display');
    const subline = (v: number) => {
      const z = zone(v);
      if (z === 'caption') return `You are looking at the ${v} pt cut, blown up to poster size.`;
      if (z === 'text') return `The ${v} pt cut — drawn for paragraphs, holding the line at any scale.`;
      return `The ${v} pt cut — hairlines drawn for headlines.`;
    };

    const apply = (v: number) => {
      o = Math.round(Math.max(6, Math.min(72, v)));
      const t = Math.log(o / 6) / LOG12;            // log position 0..1
      const ls = 0.045 - 0.057 * t;                  // caption cuts were fitted loose
      word.style.fontVariationSettings = `'wght' 440, 'opsz' ${o}`;
      word.style.letterSpacing = `${ls.toFixed(4)}em`;
      ax.style.setProperty('--x', (t * 100).toFixed(2));
      readout.textContent = `opsz ${o}`;
      sub.textContent = subline(o);
      rail.setAttribute('aria-valuenow', String(o));
      const z = zone(o);
      notes.forEach((n) => n.classList.toggle('is-on', n.dataset.zone === z));
    };

    const fromX = (clientX: number) => {
      const r = rail.getBoundingClientRect();
      const t = Math.max(0, Math.min(1, (clientX - r.left) / r.width));
      apply(6 * Math.pow(12, t));
    };
    let dragging = false;
    rail.addEventListener('pointerdown', (e) => {
      dragging = true; rail.setPointerCapture(e.pointerId); fromX(e.clientX);
    });
    rail.addEventListener('pointermove', (e) => { if (dragging) fromX(e.clientX); });
    rail.addEventListener('pointerup', () => { dragging = false; });
    rail.addEventListener('pointercancel', () => { dragging = false; });
    rail.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') { apply(o - 1); e.preventDefault(); }
      if (e.key === 'ArrowRight' || e.key === 'ArrowUp') { apply(o + 1); e.preventDefault(); }
      if (e.key === 'Home') { apply(6); e.preventDefault(); }
      if (e.key === 'End') { apply(72); e.preventDefault(); }
    });
    apply(9);
  });

  // ---- 02 · headline settles into its display weight on arrival ---------
  {
    const els = document.querySelectorAll<HTMLElement>('.lr [data-reveal]');
    const io = new IntersectionObserver((entries, obs) => {
      entries.forEach((en) => {
        if (en.isIntersecting) { en.target.removeAttribute('data-reveal'); obs.unobserve(en.target); }
      });
    }, { threshold: 0.5 });
    els.forEach((el) => io.observe(el));
  }

  // ---- 03 · the censor's bars print across the contract on arrival ------
  {
    const eds = document.querySelectorAll<HTMLElement>('[data-ed]');
    const io = new IntersectionObserver((entries, obs) => {
      entries.forEach((en) => {
        if (en.isIntersecting) { en.target.classList.add('is-in'); obs.unobserve(en.target); }
      });
    }, { threshold: 0.3 });
    eds.forEach((el) => io.observe(el));
  }

  // ---- 04 · one-cut toggle ----------------------------------------------
  document.querySelectorAll<HTMLElement>('[data-bd]').forEach((bd) => {
    const btn = bd.querySelector<HTMLButtonElement>('[data-onecut]')!;
    btn.addEventListener('click', () => {
      const on = bd.toggleAttribute('data-onecut-on');
      btn.setAttribute('aria-pressed', String(on));
    });
  });

  // ---- 05 · live briefing: FLIP-animated filter + new entries -----------
  document.querySelectorAll<HTMLElement>('[data-lb]').forEach((lb) => {
    const feed = lb.querySelector<HTMLElement>('[data-feed]')!;
    const reduced = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const setFilter = (f: string) => {
      if (reduced()) { lb.setAttribute('data-filter', f); return; }
      const entries = Array.from(feed.querySelectorAll<HTMLElement>('.lb__e'));
      const before = new Map(entries.map((e) => [e, e.getBoundingClientRect()]));
      lb.setAttribute('data-filter', f);
      entries.forEach((e) => {
        const a = before.get(e)!;
        const b = e.getBoundingClientRect();
        if (b.height === 0) return;                        // now hidden
        if (a.height === 0) {                              // re-entering
          e.animate([{ opacity: 0 }, { opacity: 1 }], { duration: 260, easing: 'ease-out' });
          return;
        }
        const dy = a.top - b.top;
        if (dy) e.animate(
          [{ transform: `translateY(${dy}px)` }, { transform: 'none' }],
          { duration: 340, easing: 'cubic-bezier(0.2, 0.7, 0.2, 1)' }
        );
      });
    };

    lb.querySelectorAll<HTMLButtonElement>('[data-flt]').forEach((btn) => {
      btn.addEventListener('click', () => {
        lb.querySelectorAll<HTMLButtonElement>('[data-flt]').forEach((b) => {
          b.classList.remove('is-on'); b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('is-on'); btn.setAttribute('aria-pressed', 'true');
        setFilter(btn.dataset.flt!);
      });
    });

    const pill = lb.querySelector<HTMLButtonElement>('[data-newpill]')!;
    const tpl = lb.querySelector<HTMLTemplateElement>('[data-newtpl]')!;
    const updated = lb.querySelector<HTMLElement>('[data-updated]')!;
    pill.addEventListener('click', () => {
      const frag = tpl.content.cloneNode(true) as DocumentFragment;
      const fresh = Array.from(frag.querySelectorAll<HTMLElement>('.lb__e'));
      feed.prepend(frag);
      if (!reduced()) fresh.forEach((e, i) => { e.style.animationDelay = `${i * 90}ms`; e.setAttribute('data-in', ''); });
      updated.textContent = '17:05';
      pill.hidden = true;
    });
  });
</script>

