    background: color-mix(in srgb, var(--accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    border-radius: 100px; padding: 0.32rem 0.85rem; white-space: nowrap;
    transition: all 0.18s var(--ease, ease-out);
  }
  .lb__pill:hover { color: var(--accent-contrast); background: var(--accent); }
  .lb__pill[hidden] { display: none; }
  .lb__scroll { height: 470px; overflow-y: auto; overscroll-behavior: contain; scrollbar-width: thin; }
