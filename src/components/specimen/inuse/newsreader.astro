  }
  @keyframes lb-in { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: none; } }
  .lb[data-filter='key'] .lb__e:not([data-key]) { display: none; }
  .lb__when b {
    font-weight: 400; font-size: 14px; color: var(--fg-2);
    font-variation-settings: 'wght' 560, 'opsz' 12;
    font-feature-settings: 'liga' 1, 'tnum' 1;
