---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;
// Real text companion (loaded site-wide in Layout.astro): a quiet serif for running body.
const serif = "'Spectral', Georgia, serif";
const ui = "'Inter Variable', system-ui, sans-serif";

// --- 02 · Interactive long-read reader (real device scale) ----------------
const para = [
  "For three hundred years type had been designed for a single object — the book — and at one rough size. The press printed sermons, almanacs and the occasional broadside, and the letters that served those pages were quiet, modest, made to disappear into a column of prose.",
  "Then the century turned industrial, and the street learned to shout. Railways needed timetables a foot tall. Auctioneers needed bills that carried across a market square. Manufacturers needed a name a customer could read from a moving carriage. The genteel book faces were useless for it, and printers went looking for letters with muscle.",
  "The answer was the slab: a sturdy skeleton with heavy rectangular serifs bolted on, black enough to hold as solid ink at any size. Robert Besley's refinement of 1845 rounded the joints with a gentle bracket — sturdy without being brutal — and the Clarendon was born. He patented it; everyone copied it anyway.",
];
---
<div class="iu" style={`--fam:${fam}; --serif:${serif}; --ui:${ui}`}>

  <!-- 01 — EDITORIAL: long-form feature spread, slab display over a serif text face -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Editorial — a feature spread, slab display over Spectral text</span></figcaption>
    <div class="iu__scene scene-feature">
      <div class="iu__poster feat" data-feat>
        <div class="feat__rail">
          <span class="feat__masth">The Fann Street Review</span>
          <span class="feat__folio"><i>No.</i> 18 · Industry &amp; Letters</span>
        </div>
        <div class="feat__grid">
          <div class="feat__lead">
            <span class="feat__kicker">A history of the loud</span>
            <h3 class="feat__head" data-breathe>The<br/>Industrial<br/>Shout</h3>
            <p class="feat__deck">How a patented slab serif taught the nineteenth&nbsp;century to <em>sell</em>.</p>
            <div class="feat__by">
              <span class="feat__by-name">Robert Besley</span>
              <span class="feat__by-meta">Fann Street Foundry · est. <i>MDCCCXLV</i></span>
            </div>
          </div>
          <div class="feat__cols">
            <p class="feat__first"><span class="feat__drop">F</span>or three hundred years the type that served the printing house was quiet — modest book letters made to vanish into a column of prose. Then the century turned industrial, and the street learned to shout.</p>
            <p>Railways wanted timetables a foot tall; auctioneers wanted bills that carried across a square. The answer was the <em>slab</em>: a sturdy skeleton with heavy rectangular serifs, black enough to hold as solid ink at any size.</p>
            <blockquote class="feat__pull">&ldquo;He took out one of the first type patents in history&nbsp;— and everyone copied it anyway.&rdquo;</blockquote>
            <p>Robert Besley rounded the joints with a gentle bracket in 1845, sturdy without being brutal, and the Clarendon was born — a face built to carry weight, the typographic equivalent of cast iron.</p>
          </div>
        </div>
        <div class="feat__foot">
          <span>fannstreet.review</span>
          <span class="feat__pg">— 18 —</span>
          <span>Industry &amp; Letters</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Besley sets the masthead, headline and pull-quote; Spectral carries the columns. The headline breathes across the weight axis.</p>
  </figure>

  <!-- 02 — INTERACTIVE READER at real device scale -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Product UI — a long-read reader, real device scale, interactive</span></figcaption>
    <div class="iu__scene scene-reader">
      <div class="iu__device reader" data-reader>
        <div class="iu__chrome">
          <div class="iu__dots"><i></i><i></i><i></i></div>
          <span class="iu__addr">read.clarendon.press/the-industrial-shout</span>
        </div>
        <div class="reader__bar">
          <span class="reader__logo">Clarendon</span>
          <div class="reader__tools">
            <div class="reader__seg" role="group" aria-label="Headline weight">
              <span class="reader__seg-h">Weight</span>
              <input class="reader__range" type="range" data-wght min="400" max="900" step="1" value="800" aria-label="Headline weight" />
              <i class="reader__seg-v" data-wght-out>800</i>
            </div>
            <div class="reader__seg" role="group" aria-label="Reading text size">
              <button class="reader__btn is-on" data-size="cozy">Cozy</button>
              <button class="reader__btn" data-size="dense">Dense</button>
            </div>
            <button class="reader__btn reader__btn--wide" data-serif aria-pressed="true">Serif body</button>
          </div>
        </div>
        <article class="reader__body" data-text data-textsize="cozy" data-bodyface="serif">
          <header class="reader__hd">
            <span class="reader__kicker">History · Type</span>
            <h4 class="reader__head" data-head>The Industrial Shout</h4>
            <p class="reader__byline">by R. Besley · <span class="reader__fig">9 min</span> · <span class="reader__fig">1845</span></p>
          </header>
          <div class="reader__flow">
            {para.map((p, i) => (
              <p class={i === 0 ? 'reader__lede' : ''}>{i === 0 ? <span class="reader__drop">F</span> : null}{i === 0 ? p.slice(1) : p}</p>
            ))}
            <blockquote class="reader__quote">Letters with muscle, black enough to hold as ink at any size.</blockquote>
            <div class="reader__end">
              <span class="reader__end-mark">⬡</span>
              <p class="reader__bio">Filed under <b>History</b> &amp; <b>Type</b>. Set in Besley, the modern Clarendon, with a Spectral text companion.</p>
            </div>
          </div>
        </article>
        <div class="reader__more">
          <span class="reader__more-h">More from Clarendon</span>
          <ul class="reader__more-list">
            <li><span class="reader__more-no">№ 02</span> Why the Victorians called them Egyptians</li>
            <li><span class="reader__more-no">№ 03</span> Bracketed vs. brutal: a field guide to the slab</li>
            <li><span class="reader__more-no">№ 04</span> Patenting a letter: Besley &amp; the Fann Street Foundry</li>
          </ul>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Drag the weight slider — the headline ramps 400→900 live. Toggle Cozy/Dense and the serif body; the column reflows.</p>
  </figure>

  <!-- 03 — BRAND/POSTER: cast-iron hardware identity, kinetic weight -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Brand poster — cast-iron identity, full wght axis kinetic</span></figcaption>
    <div class="iu__scene scene-tall">
      <div class="iu__poster forge" data-forge>
        <div class="forge__top">
          <span>EST. 1845</span>
          <span class="forge__mark">⬡ IRONWORKS ⬡</span>
          <span>NO. 011</span>
        </div>
        <div class="forge__stack">
          <span class="forge__sub forge__sub--thin">FANN STREET</span>
          <span class="forge__word" data-pump data-fit style="--d:0s"><span class="forge__fit">CAST</span></span>
          <span class="forge__word forge__word--accent" data-pump data-fit style="--d:-2.25s"><span class="forge__fit">IRON</span></span>
          <span class="forge__sub forge__sub--thin">HARDWARE &amp; HEAVY GOODS</span>
        </div>
        <div class="forge__foot">
          <span class="forge__tag">FORGED TO HOLD</span>
          <span class="forge__rail">wght 400 → 900</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">The two slab words pump across the whole weight axis, phase-offset — Besley from readable Regular to a planted, cast-iron Black.</p>
  </figure>

  <!-- 04 — ARTIFACT: coffee tin label, tabular figures + fractions + grind selector -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Packaging — a coffee tin label, interactive grind &amp; strength</span></figcaption>
    <div class="iu__scene iu__scene--portrait" style="--card-ar: 4 / 5;">
      <div class="iu__poster tin" data-tin>
        <div class="tin__top">
          <span class="tin__est">EST. 1845</span>
          <span class="tin__net">NET <i data-net>340</i> g</span>
        </div>
        <div class="tin__brandblock">
          <span class="tin__pre">SINGLE&nbsp;ORIGIN · WHOLE&nbsp;BEAN</span>
          <h3 class="tin__brand">BESLEY<br/>&amp; SON</h3>
          <span class="tin__roast" data-roast><span data-roast-txt>DARK ROAST · BATCH&nbsp;</span><i data-roast-batch>№ 18</i></span>
        </div>
        <p class="tin__notes">Cocoa, dried fig &amp; a long, cast-iron finish. Roasted in small batches on Fann&nbsp;Street.</p>
        <div class="tin__spec">
          <div class="tin__row"><span>ALTITUDE</span><b><i>1,845</i> m</b></div>
          <div class="tin__row"><span>PROCESS</span><b>WASHED</b></div>
          <div class="tin__row"><span>RATIO</span><b data-ratio><i class="tin__num">1</i><span class="tin__sol">&#8260;</span><i class="tin__den">16</i></b></div>
        </div>
        <div class="tin__strength">
          <span class="tin__strength-h">BODY</span>
          <span class="tin__meter" data-meter aria-hidden="true">
            <i class="is-on"></i><i class="is-on"></i><i class="is-on"></i><i class="is-on"></i><i></i>
          </span>
          <span class="tin__strength-v" data-strength>FULL</span>
        </div>
        <div class="tin__control">
          <span class="tin__control-h">GRIND</span>
          <div class="tin__seg" role="group" aria-label="Grind">
            <button class="tin__segbtn is-on" data-grind="WHOLE" data-net="340" data-ratio="1/16" data-roast="DARK ROAST · BATCH&nbsp;" data-batch="№ 18" data-body="4" data-strength="FULL">WHOLE</button>
            <button class="tin__segbtn" data-grind="FILTER" data-net="340" data-ratio="1/15" data-roast="MEDIUM ROAST · BATCH&nbsp;" data-batch="№ 24" data-body="3" data-strength="ROUND">FILTER</button>
            <button class="tin__segbtn" data-grind="ESPRESSO" data-net="250" data-ratio="1/2" data-roast="ESPRESSO ROAST · BATCH&nbsp;" data-batch="№ 07" data-body="5" data-strength="INTENSE">ESPRESSO</button>
          </div>
        </div>
        <div class="tin__foot">
          <span class="tin__barcode" aria-hidden="true"></span>
          <span class="tin__price">£<i>14</i><sup>.50</sup></span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Pick a grind — the net weight, brew ratio and roast batch reset. Tabular lining figures (<em>tnum</em>) hold the spec column flush right.</p>
  </figure>

</div>

<script>
  // ---- 02 reader: weight slider + text size + body face ----
  document.querySelectorAll<HTMLElement>('[data-reader]').forEach((reader) => {
    const head = reader.querySelector<HTMLElement>('[data-head]')!;
    const out = reader.querySelector<HTMLElement>('[data-wght-out]')!;
    const range = reader.querySelector<HTMLInputElement>('[data-wght]')!;
    const body = reader.querySelector<HTMLElement>('[data-text]')!;

    const applyW = (v: number) => {
      head.style.fontVariationSettings = `'wght' ${v}`;
      out.textContent = String(v);
    };
    range.addEventListener('input', () => applyW(+range.value));
    applyW(+range.value);

    reader.querySelectorAll<HTMLButtonElement>('[data-size]').forEach((btn) =>
      btn.addEventListener('click', () => {
        reader.querySelectorAll('[data-size]').forEach((b) => b.classList.remove('is-on'));
        btn.classList.add('is-on');
        body.setAttribute('data-textsize', btn.dataset.size!);
      })
    );

    const serifBtn = reader.querySelector<HTMLButtonElement>('[data-serif]');
    serifBtn?.addEventListener('click', () => {
      const on = body.getAttribute('data-bodyface') === 'serif';
      body.setAttribute('data-bodyface', on ? 'slab' : 'serif');
      serifBtn.setAttribute('aria-pressed', String(!on));
      serifBtn.textContent = on ? 'Slab body' : 'Serif body';
    });
  });

  // ---- 03 forge: optically equalize CAST / IRON to a shared cap-width ----
  document.querySelectorAll<HTMLElement>('[data-forge]').forEach((forge) => {
    const words = Array.from(forge.querySelectorAll<HTMLElement>('[data-fit]'));
    const fits = words.map((w) => w.querySelector<HTMLElement>('.forge__fit')!);
    const fit = () => {
      // measure intrinsic widths at scaleX(1)
      fits.forEach((f) => (f.style.transform = 'scaleX(1)'));
      const widths = fits.map((f) => f.getBoundingClientRect().width);
      const target = Math.max(...widths);
      fits.forEach((f, i) => {
        const w = widths[i] || target;
        f.style.transform = `scaleX(${(target / w).toFixed(4)})`;
      });
    };
    if (document.fonts && document.fonts.ready) document.fonts.ready.then(fit);
    fit();
    let raf = 0;
    new ResizeObserver(() => { cancelAnimationFrame(raf); raf = requestAnimationFrame(fit); }).observe(forge);
  });

  // ---- 04 coffee tin: grind selector drives net weight / ratio / batch ----
  document.querySelectorAll<HTMLElement>('[data-tin]').forEach((tin) => {
    const net = tin.querySelector<HTMLElement>('[data-net]')!;
    const ratio = tin.querySelector<HTMLElement>('[data-ratio]')!;
    const roastTxt = tin.querySelector<HTMLElement>('[data-roast-txt]')!;
    const roastBatch = tin.querySelector<HTMLElement>('[data-roast-batch]')!;
    const strength = tin.querySelector<HTMLElement>('[data-strength]')!;
    const pips = Array.from(tin.querySelectorAll<HTMLElement>('[data-meter] i'));
    tin.querySelectorAll<HTMLButtonElement>('[data-grind]').forEach((btn) =>
      btn.addEventListener('click', () => {
        tin.querySelectorAll('[data-grind]').forEach((b) => b.classList.remove('is-on'));
        btn.classList.add('is-on');
        net.textContent = btn.dataset.net!;
        const [a, b] = btn.dataset.ratio!.split('/');
        ratio.replaceChildren();
        const ia = document.createElement('i'); ia.className = 'tin__num'; ia.textContent = a;
        const sol = document.createElement('span'); sol.className = 'tin__sol'; sol.textContent = '⁄';
        const ib = document.createElement('i'); ib.className = 'tin__den'; ib.textContent = b;
        ratio.append(ia, sol, ib);
        roastTxt.textContent = (btn.dataset.roast || '').replace(/&nbsp;/g, ' ');
        roastBatch.textContent = btn.dataset.batch!;
        const bodyLevel = +(btn.dataset.body || '0');
        pips.forEach((p, i) => p.classList.toggle('is-on', i < bodyLevel));
        strength.textContent = btn.dataset.strength!;
      })
    );
  });
</script>

<style>
  .iu__item { margin: 0; }
  .iu__hint { margin-top: var(--sp-2); color: var(--fg-3); }
  .iu * { font-family: var(--fam); }
  .iu__scene * { font-family: var(--fam); }

  .scene-tall { aspect-ratio: 4 / 5; }
  @container (min-width: 720px) { .scene-tall { aspect-ratio: 16 / 11; } }
  .scene-feature { aspect-ratio: 4 / 5; }
  @container (min-width: 720px) { .scene-feature { aspect-ratio: 16 / 10; } }
  .scene-reader { aspect-ratio: 4 / 5; }
  @container (min-width: 720px) { .scene-reader { aspect-ratio: 16 / 9; } }

  /* ============ 01 · FEATURE SPREAD (slab display + Spectral text) ============ */
  .feat { background: var(--bg); color: var(--fg); padding: 4.5cqi 5cqi 0; display: flex; flex-direction: column; overflow: hidden; --bodysize: 2cqi; }
  .feat__rail { display: flex; align-items: baseline; justify-content: space-between; border-bottom: 1px solid var(--line); padding-bottom: 1.6cqi; }
  .feat__masth { font-size: 3.3cqi; font-weight: 600; letter-spacing: -0.005em; font-variation-settings: 'wght' 560; color: var(--fg); }
  .feat__folio { font-size: 1.9cqi; font-style: italic; color: var(--fg-3); letter-spacing: 0.01em; font-feature-settings: 'tnum'; }
  .feat__folio i { font-style: italic; }
  .feat__grid { flex: 1; display: grid; grid-template-columns: 0.94fr 1.06fr; gap: 5cqi; min-height: 0; padding: 3.4cqi 0 2.6cqi; }
  .feat__lead { display: flex; flex-direction: column; }
  .feat__kicker { font-size: 1.8cqi; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); }
  .feat__head { font-size: 11.5cqi; font-weight: 800; line-height: 0.88; letter-spacing: -0.015em; margin: 1.6cqi 0 0; font-variation-settings: 'wght' 820; }
  .feat__deck { font-family: var(--serif); font-size: 2.7cqi; line-height: 1.32; color: var(--fg-2); margin-top: 2.8cqi; max-width: 92%; }
  .feat__deck em { font-style: italic; color: var(--accent); }
  .feat__by { margin-top: auto; padding-top: 2.6cqi; border-top: 1px solid var(--line); display: flex; flex-direction: column; gap: 0.3cqi; }
  .feat__by-name { font-size: 2.1cqi; font-weight: 700; letter-spacing: 0.01em; color: var(--fg); }
  .feat__by-meta { font-family: var(--serif); font-style: italic; font-size: 1.8cqi; color: var(--fg-3); letter-spacing: 0.01em; }
  .feat__by-meta i { font-style: italic; font-feature-settings: 'tnum'; letter-spacing: 0.04em; }
  .feat__cols { display: flex; flex-direction: column; font-family: var(--serif); }
  .feat__cols p { font-size: var(--bodysize); line-height: 1.46; color: var(--fg-2); margin: 0 0 1.1cqi; text-align: left; hyphens: auto; }
  .feat__cols p em { font-style: italic; color: var(--fg); }
  .feat__first { margin-top: 0; }
  .feat__drop { float: left; font-family: var(--fam); font-weight: 800; font-size: 8cqi; line-height: 0.66; padding: 0.5cqi 0.8cqi 0 0; color: var(--accent); }
  .feat__pull { font-family: var(--fam); font-style: italic; font-weight: 500; font-size: 3.3cqi; line-height: 1.12; color: var(--accent); margin: 1.8cqi 0; padding: 0 0 0 2.4cqi; border-left: 0.6cqi solid var(--accent); font-variation-settings: 'wght' 520; }
  .feat__foot { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; border-top: 1px solid var(--line); padding: 1.6cqi 0 2cqi; font-size: 1.7cqi; letter-spacing: 0.04em; color: var(--fg-3); font-style: italic; font-family: var(--serif); }
  .feat__foot > :last-child { text-align: right; }
  .feat__pg { letter-spacing: 0.1em; font-feature-settings: 'tnum'; }

  @media (prefers-reduced-motion: no-preference) {
    .feat__head[data-breathe] { animation: feat-breathe 6s var(--ease-out, ease-in-out) infinite alternate; }
    @keyframes feat-breathe {
      from { font-variation-settings: 'wght' 560; }
      to   { font-variation-settings: 'wght' 900; }
    }
  }

  @container (max-width: 560px) {
    .feat { --bodysize: 3.4cqi; padding: 5cqi 5.5cqi 0; }
    .feat__grid { grid-template-columns: 1fr; gap: 4cqi; padding: 4cqi 0 3cqi; }
    .feat__head { font-size: 14cqi; margin-top: 2.4cqi; }
    .feat__deck { font-size: 4.2cqi; margin-top: 3.2cqi; max-width: 100%; }
    .feat__kicker { font-size: 3cqi; }
    .feat__by { padding-top: 3.6cqi; gap: 0.6cqi; }
    .feat__by-name { font-size: 3.6cqi; }
    .feat__by-meta { font-size: 3cqi; }
    .feat__pull { font-size: 5.2cqi; margin: 3cqi 0; padding-left: 3.2cqi; }
    .feat__drop { font-size: 13cqi; }
    .feat__masth { font-size: 5cqi; }
    .feat__folio { font-size: 3cqi; }
    .feat__foot { font-size: 2.8cqi; }
  }

  /* ============ 02 · READER (real px, interactive) ============ */
  .reader { position: absolute; inset: 0; display: flex; flex-direction: column; font-size: 14px; background: var(--bg); }
  .reader__bar { display: flex; align-items: center; gap: 1rem; padding: 0.6rem 1.1rem; border-bottom: 1px solid var(--line); flex-wrap: wrap; }
  .reader__logo { font-size: 20px; font-weight: 800; color: var(--fg); letter-spacing: -0.01em; font-variation-settings: 'wght' 760; }
  .reader__tools { display: flex; align-items: center; gap: 0.7rem; margin-left: auto; flex-wrap: wrap; }
  .reader__seg { display: inline-flex; align-items: center; gap: 0.5rem; }
  .reader__seg-h { font-family: var(--ui); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--fg-3); }
  .reader__seg-v { font-family: var(--ui); font-style: normal; font-size: 11px; font-weight: 600; color: var(--accent); font-feature-settings: 'tnum'; min-width: 22px; text-align: right; }
  .reader__range { -webkit-appearance: none; appearance: none; width: 92px; height: 3px; background: var(--line); border-radius: 3px; cursor: pointer; }
  .reader__range::-webkit-slider-thumb { -webkit-appearance: none; appearance: none; width: 15px; height: 15px; border-radius: 50%; background: var(--accent); border: 2px solid var(--bg); box-shadow: 0 0 0 1px var(--accent); }
  .reader__range::-moz-range-thumb { width: 15px; height: 15px; border-radius: 50%; background: var(--accent); border: 2px solid var(--bg); box-shadow: 0 0 0 1px var(--accent); }
  .reader__btn { font-family: var(--ui); font-size: 11px; font-weight: 500; letter-spacing: 0.02em; color: var(--fg-3); padding: 0.34rem 0.7rem; border-radius: 100px; border: 1px solid var(--line); cursor: pointer; background: transparent; transition: color 0.15s, background 0.15s, border-color 0.15s; white-space: nowrap; }
  .reader__btn:hover { color: var(--fg); border-color: var(--fg-3); }
  .reader__btn.is-on, .reader__btn[aria-pressed='true'] { color: var(--accent-contrast); background: var(--accent); border-color: var(--accent); }

  .reader__body { flex: 1; min-height: 0; padding: 1.8rem clamp(1.2rem, 6cqi, 5rem); overflow: auto; --rsize: 16px; --rlead: 1.62; }
  .reader__hd, .reader__flow { max-width: 78ch; margin-inline: auto; }
  .reader__more { flex: none; padding: 1rem clamp(1.2rem, 5cqi, 3.4rem) 1.2rem; border-top: 1px solid var(--line); background: color-mix(in srgb, var(--fg) 3%, var(--bg)); }
  .reader__more-h { font-family: var(--ui); font-size: 10px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--fg-3); }
  .reader__more-list { list-style: none; margin: 0.6rem 0 0; padding: 0; display: grid; grid-template-columns: 1fr; gap: 0.5rem; }
  @container (min-width: 720px) { .reader__more-list { grid-template-columns: repeat(3, 1fr); gap: 1.4rem; } }
  .reader__more-list li { font-size: 14px; line-height: 1.25; color: var(--fg-2); font-variation-settings: 'wght' 500; }
  .reader__more-no { display: block; font-family: var(--ui); font-size: 10px; font-weight: 600; letter-spacing: 0.08em; color: var(--accent); margin-bottom: 0.25rem; font-feature-settings: 'tnum'; }
  .reader__body[data-textsize='dense'] { --rsize: 14px; --rlead: 1.5; }
  .reader__flow { margin-top: 0.4rem; }
  @container (min-width: 720px) {
    .reader__flow { columns: 2; column-gap: 2.4rem; column-rule: 1px solid var(--line-soft); }
    .reader__quote, .reader__end { break-inside: avoid-column; }
  }
