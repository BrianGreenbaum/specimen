---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;
// Companions (loaded site-wide in Layout.astro)
const serif = "'Spectral', Georgia, serif";
const ui = "'Inter Variable', system-ui, sans-serif";

// --- 04 · The Saleroom: timed online sale, Clarendon's auction-bill ancestry ---
const lots = [
  { no: 17, title: 'Twelve-line condensed gothic, wood', sub: 'Wm. H. Page & Co., Connecticut, c. 1872', low: 3000, high: 5000, bid: 4200, step: 200, bids: 11 },
  { no: 18, title: 'Clarendon patent specimen sheets', sub: 'Besley & Co., Fann Street Foundry, 1845', low: 12000, high: 18000, bid: 13000, step: 500, bids: 18 },
  { no: 19, title: 'Albion hand press, demy folio', sub: 'Hopkinson & Cope, London, 1851', low: 8000, high: 12000, bid: 8500, step: 250, bids: 6 },
  { no: 20, title: 'Playbill archive, 214 items', sub: 'Theatre Royal, Drury Lane, 1838–1871', low: 5000, high: 7000, bid: 5250, step: 250, bids: 4 },
];
const gbp = (n: number) => '£' + n.toLocaleString('en-GB');
---
<div class="iu" style={`--fam:${fam}; --serif:${serif}; --ui:${ui}`}>

  <!-- ============================================================ -->
  <!-- 01 — ILLUSTRATION & COMMERCIAL · the 1845 patent specimen    -->
  <!-- ============================================================ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap">
      <span class="index-num">01</span>
      <span class="label">Illustration &amp; commercial — the patent specimen broadside, after Besley &amp; Co.’s 1845 Clarendon showing, the first typeface registered under the Ornamental Designs Act of 1842</span>
    </figcaption>
    <div class="iu__scene spec" data-spec>
      <div class="spec__sheet">
        <div class="spec__rules" aria-hidden="true"></div>
        <p class="spec__house">Fann Street Letter Foundry &nbsp;·&nbsp; London</p>
        <p class="spec__to">TO PRINTERS.</p>
        <h3 class="spec__word" data-press>CLARENDON</h3>
        <p class="spec__reg"><em>Registered at Stationers’ Hall pursuant to the Act — the design protected for three years.</em></p>
        <div class="spec__showings">
          <div class="spec__show">
            <span class="spec__body">TWO-LINE GREAT PRIMER</span>
            <span class="spec__line spec__line--900">DURABLE</span>
            <span class="spec__note">wght 900 — black enough to hold as solid ink</span>
          </div>
          <div class="spec__show">
            <span class="spec__body">TWO-LINE PICA</span>
            <span class="spec__line spec__line--700">EXPRESSIVE</span>
            <span class="spec__note">wght 700 — the bill-poster’s workhorse</span>
          </div>
          <div class="spec__show">
            <span class="spec__body">GREAT PRIMER</span>
            <span class="spec__line spec__line--400">Useful to all</span>
            <span class="spec__note">wght 400 — reads quietly beside the roman</span>
          </div>
        </div>
        <div class="spec__rules spec__rules--foot" aria-hidden="true"></div>
        <p class="spec__imprint">BESLEY &amp; CO. (LATE THOROWGOOD &amp; BESLEY) · Nº 31 FANN STREET, ALDERSGATE · MDCCCXLV</p>
        <span class="spec__ink" aria-hidden="true"></span>
      </div>
    </div>
    <p class="iu__hint label">Press the big word — the forme bites into the sheet and the ink gains. Three showings climb the weight axis the way a foundry book climbed its bodies.</p>
  </figure>

  <!-- ============================================================ -->
  <!-- 02 — BRANDING & IDENTITY · the express-company system        -->
  <!-- ============================================================ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap">
      <span class="index-num">02</span>
      <span class="label">Branding &amp; identity — an overland express company, after Wells Fargo’s Clarendon wordmark and the stagecoach express vernacular</span>
    </figcaption>
    <div class="iu__scene exco">
      <div class="exco__grid">
        <div class="exco__lock">
          <span class="exco__est">ESTᴰ 1852 · CALIFORNIA &amp; THE STATES</span>
          <h3 class="exco__mark">OVERLAND<br/>EXPRESS</h3>
          <span class="exco__amp">&amp; BANKING COMPANY</span>
          <p class="exco__motto"><em>Carried through, whatever the road.</em></p>
        </div>
        <div class="exco__apps">
          <div class="exco__waybill">
            <div class="exco__wb-head"><span>WAYBILL</span><b>Nº 04,318</b></div>
            <div class="exco__wb-row"><span>FROM</span><b>SAN FRANCISCO</b></div>
            <div class="exco__wb-row"><span>TO</span><b>ST. JOSEPH, MO.</b></div>
            <div class="exco__wb-row"><span>WEIGHT</span><b>48 lb 12 oz</b></div>
            <div class="exco__wb-row"><span>CHARGES</span><b>$2.25 PAID</b></div>
            <div class="exco__wb-row exco__wb-row--last"><span>VIA</span><b>OVERLAND, 25 DAYS</b></div>
          </div>
          <div class="exco__specrow">
            <button class="exco__w is-on" data-w="900"><i>900</i><span>WORDMARK</span></button>
            <button class="exco__w" data-w="700"><i>700</i><span>SIGNAGE</span></button>
            <button class="exco__w" data-w="500"><i>500</i><span>DOCUMENT</span></button>
          </div>
        </div>
      </div>
      <div class="exco__band" aria-hidden="true">
        <div class="exco__belt">
          <span>★ OVERLAND EXPRESS ★ SAN FRANCISCO ★ SACRAMENTO ★ SALT LAKE ★ ST. JOSEPH ★ TREASURE SHIPPED UNDER GUARD&nbsp;</span>
          <span>★ OVERLAND EXPRESS ★ SAN FRANCISCO ★ SACRAMENTO ★ SALT LAKE ★ ST. JOSEPH ★ TREASURE SHIPPED UNDER GUARD&nbsp;</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">One drawing, three duties: pick a grade — the wordmark re-weights live between its 900 mark, 700 signage and 500 document cuts. Tabular figures keep the waybill ledger flush.</p>
  </figure>

  <!-- ============================================================ -->
  <!-- 03 — EDITORIAL · the dictionary page, the first related bold -->
  <!-- ============================================================ -->
  <figure class="iu__item" data-shoot-click="[data-bold-toggle]">
    <figcaption class="iu__cap">
      <span class="index-num">03</span>
      <span class="label">Editorial — a dictionary page, after the Clarendon Press convention: the first bold designed to sit <em>inside</em> roman text, not beside it</span>
    </figcaption>
    <div class="iu__scene dict" data-dict>
      <div class="dict__page">
        <div class="dict__rh">
          <span class="dict__rh-w">CLARENDON</span>
          <span class="dict__folio">346</span>
          <span class="dict__rh-w dict__rh-w--r">CLARION</span>
        </div>
        <div class="dict__cols">
          <div class="dict__entry">
            <p><b class="dict__hw">Clar·en·don</b>, <i>n.</i> <span class="dict__pron">/ˈklarəndən/</span> <span class="dict__ety">[after the <i>Clarendon Press</i>, Oxford.]</span>
            <b class="dict__sense">1.</b> A letter of slab serif and low contrast, the serifs joined to the stem by a curved bracket; cut 1845 by Robert Besley at the Fann Street Foundry, London, and patented by him — the first such grant for a type design.
            <b class="dict__sense">2.</b> The first <b class="dict__em">related bold</b>: a dark companion drawn to share a roman’s body and set within its line for emphasis, where earlier printers could only resort to <i>italic</i> or LETTER-SPACED CAPITALS.</p>
          </div>
          <div class="dict__entry">
            <p><b class="dict__hw">clar·i·fy</b>, <i>v.t.</i> <span class="dict__ety">[L. <i>clarus</i> clear + <i>facere</i> to make.]</span>
            <b class="dict__sense">1.</b> To free from ambiguity or obscurity; to make intelligible.
            <b class="dict__sense">2.</b> <i>Printing.</i> To mark the load-bearing words of a passage with a related bold, that a reader skimming the column may <b class="dict__em">catch the sense at a glance</b>.</p>
          </div>
          <div class="dict__entry">
            <p><b class="dict__hw">clar·i·on</b>, <i>n.</i> <span class="dict__ety">[O.Fr. <i>claron</i>, f. L. <i>clarus</i>.]</span>
            <b class="dict__sense">1.</b> A shrill, clear-sounding trumpet of war.
            <b class="dict__sense">2.</b> <i>fig.</i> Loud and unmistakable; spoken so as to carry: <i>the auctioneer’s bill was set</i> <b class="dict__em">two-line clarendon, a clarion in ink</b>.</p>
          </div>
        </div>
        <div class="dict__margin">
          <span class="dict__m-h">THE RELATED BOLD</span>
          <button class="dict__toggle" data-bold-toggle aria-pressed="true"><i class="dict__pip"></i><span data-bold-label>1845 — ON</span></button>
          <p class="dict__m-note">Strip Besley out and the page loses its signposts — every emphasis falls back to the roman, as it stood before 1845.</p>
        </div>
        <p class="dict__foot">Headwords &amp; emphasis: Besley · text: Spectral — the bold sharing the roman’s line, as Besley cut it to.</p>
      </div>
    </div>
    <p class="iu__hint label">Throw the switch in the margin — the related bold drains out of the page and the entries go flat. That difference is the invention.</p>
  </figure>

  <!-- ============================================================ -->
  <!-- 04 — WEB & APP UI · the saleroom, real device scale          -->
  <!-- ============================================================ -->
  <figure class="iu__item" data-shoot-click="[data-bid]">
    <figcaption class="iu__cap">
      <span class="index-num">04</span>
      <span class="label">Web &amp; app UI — a timed online auction at real device scale, after contemporary saleroom platforms; the auction bill come home as product</span>
    </figcaption>
    <div class="iu__scene sale">
      <div class="iu__device saleui" data-sale>
        <div class="iu__chrome">
          <div class="iu__dots"><i></i><i></i><i></i></div>
          <span class="iu__addr">saleroom.fannstreet.co/sale-1845/printing-and-the-industrial-image</span>
        </div>
        <div class="sale__bar">
          <span class="sale__logo">Fann Street</span>
          <span class="sale__sale">SALE 1845 · Printing &amp; the Industrial Image · <b data-clock>ends 17:00 BST</b></span>
        </div>
        <div class="sale__main">
          <div class="sale__live">
            <div class="sale__lothead">
              <span class="sale__lotno">LOT <b data-lot-no>18</b></span>
              <button class="sale__watch" data-watch aria-pressed="false">☆ Watch</button>
            </div>
            <h4 class="sale__title" data-lot-title>Clarendon patent specimen sheets</h4>
            <p class="sale__sub" data-lot-sub>Besley &amp; Co., Fann Street Foundry, 1845</p>
            <p class="sale__est"><i>Estimate</i> <span data-lot-est>£12,000 – £18,000</span></p>
            <div class="sale__bidrow">
              <div class="sale__current">
                <span class="sale__cur-h">CURRENT BID · <b data-lot-count>18</b> BIDS</span>
                <strong class="sale__cur-v" data-lot-bid>£13,000</strong>
                <span class="sale__lead" data-lead hidden>PADDLE 1845 — YOU LEAD</span>
              </div>
              <button class="sale__bid" data-bid>Bid <b data-next>£13,500</b></button>
            </div>
            <div class="sale__hist">
              <span class="sale__hist-h">BIDDING</span>
              <ul class="sale__hist-list" data-hist>
                <li><b>£13,000</b><span>Paddle 0072</span><i>2 min ago</i></li>
                <li><b>£12,500</b><span>Paddle 0418</span><i>9 min ago</i></li>
                <li><b>£12,000</b><span>Paddle 0072</span><i>14 min ago</i></li>
              </ul>
            </div>
          </div>
          <div class="sale__lots">
            <span class="sale__lots-h">LOTS IN THIS SALE</span>
            <div class="sale__lotlist" role="listbox" aria-label="Lots">
              {lots.map((l) => (
                <button class={`sale__lot${l.no === 18 ? ' is-on' : ''}`} data-lot={l.no} role="option" aria-selected={l.no === 18 ? 'true' : 'false'}>
                  <span class="sale__lot-no">LOT {l.no}</span>
                  <span class="sale__lot-t">{l.title}</span>
                  <span class="sale__lot-bid" data-lot-cur={l.no}>{gbp(l.bid)}</span>
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
      <template data-hist-row><li><b></b><span></span><i></i></li></template>
    </div>
    <p class="iu__hint label">Place a bid — the price advances by the lot’s increment, your paddle takes the lead, the ledger prepends (and the under-bidder answers). Switch lots; tabular figures hold every column.</p>
  </figure>

  <!-- ============================================================ -->
  <!-- 05 — INTERACTIVE & EXPERIMENTAL · the bounty as an axis      -->
  <!-- ============================================================ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click="[data-rate='5']">
    <figcaption class="iu__cap">
      <span class="index-num">05</span>
      <span class="label">Interactive &amp; experimental — <em>The Going Rate</em>: the American-West reward bill rebuilt as a weight-axis instrument; the louder the money, the blacker the type</span>
    </figcaption>
    <div class="iu__scene bounty" data-bounty data-tier="3">
      <div class="bounty__sheet">
        <p class="bounty__top" data-toplines>
          <span class="bounty__topline" data-top="1">INFORMATION WANTED — APPLY TO THE PARISH CONSTABLE</span>
          <span class="bounty__topline" data-top="2">PROCLAMATION — BY ORDER OF THE COUNTY SHERIFF</span>
          <span class="bounty__topline" data-top="3">PROCLAMATION — OVERLAND MAIL ROBBED AT DRY CREEK</span>
          <span class="bounty__topline" data-top="4">PROCLAMATION — EXPRESS SAFE BLOWN, BULLION TAKEN</span>
          <span class="bounty__topline" data-top="5">DEAD OR ALIVE</span>
        </p>
        <h3 class="bounty__word" data-word>REWARD</h3>
        <p class="bounty__sum" data-sum>$1,000</p>
        <p class="bounty__for">
          <span class="bounty__crime" data-crime="1">for the recovery of one stray mule, answers to GENERAL</span>
          <span class="bounty__crime" data-crime="2">for the apprehension of the horse thieves lately at large</span>
          <span class="bounty__crime" data-crime="3">for the road agents who stopped the OVERLAND EXPRESS</span>
          <span class="bounty__crime" data-crime="4">for the gang that dynamited the through-freight express car</span>
          <span class="bounty__crime" data-crime="5">for the outlaw known in three territories as THE PRINTER</span>
        </p>
        <div class="bounty__rates" role="group" aria-label="Raise the bounty">
          <span class="bounty__rates-h">RAISE THE BOUNTY</span>
          <div class="bounty__btns">
            <button class="bounty__rate" data-rate="1">$50</button>
            <button class="bounty__rate" data-rate="2">$250</button>
            <button class="bounty__rate is-on" data-rate="3">$1,000</button>
            <button class="bounty__rate" data-rate="4">$5,000</button>
            <button class="bounty__rate" data-rate="5">$10,000</button>
          </div>
          <span class="bounty__axis" data-axis>wght 640</span>
        </div>
        <p class="bounty__imprint">PRINTED AT THE OFFICE OF THE TERRITORIAL ENTERPRISE — CLARENDONS &amp; WOOD LETTER KEPT IN ALL BODIES</p>
      </div>
    </div>
    <p class="iu__hint label">Raise the money and the bill re-sets itself: REWARD and the sum climb the axis 430 → 900, tracking tightens, the charge escalates — at $10,000 the sheet finally says it: dead or alive.</p>
  </figure>

</div>

<script>
  // ---- 02 · express co: grade picker re-weights the wordmark ----
  document.querySelectorAll<HTMLElement>('.exco').forEach((ex) => {
    const mark = ex.querySelector<HTMLElement>('.exco__mark')!;
    ex.querySelectorAll<HTMLButtonElement>('[data-w]').forEach((btn) =>
      btn.addEventListener('click', () => {
        ex.querySelectorAll('[data-w]').forEach((b) => b.classList.remove('is-on'));
        btn.classList.add('is-on');
        mark.style.fontVariationSettings = `'wght' ${btn.dataset.w}`;
      })
    );
  });

  // ---- 03 · dictionary: strip / restore the related bold ----
  document.querySelectorAll<HTMLElement>('[data-dict]').forEach((dict) => {
    const btn = dict.querySelector<HTMLButtonElement>('[data-bold-toggle]')!;
    const label = dict.querySelector<HTMLElement>('[data-bold-label]')!;
    btn.addEventListener('click', () => {
      const on = !dict.classList.contains('is-flat');
      dict.classList.toggle('is-flat', on);
      btn.setAttribute('aria-pressed', String(!on));
      label.textContent = on ? '1845 — OFF' : '1845 — ON';
    });
  });

  // ---- 04 · saleroom: lot switching, bidding, watch ----
  document.querySelectorAll<HTMLElement>('[data-sale]').forEach((sale) => {
    type Lot = { no: number; title: string; sub: string; low: number; high: number; bid: number; step: number; bids: number; hist: Array<[string, string, string]> };
    const data: Record<number, Lot> = {
      17: { no: 17, title: 'Twelve-line condensed gothic, wood', sub: 'Wm. H. Page & Co., Connecticut, c. 1872', low: 3000, high: 5000, bid: 4200, step: 200, bids: 11, hist: [['£4,200', 'Paddle 0301', '5 min ago'], ['£4,000', 'Paddle 0118', '12 min ago']] },
      18: { no: 18, title: 'Clarendon patent specimen sheets', sub: 'Besley & Co., Fann Street Foundry, 1845', low: 12000, high: 18000, bid: 13000, step: 500, bids: 18, hist: [['£13,000', 'Paddle 0072', '2 min ago'], ['£12,500', 'Paddle 0418', '9 min ago'], ['£12,000', 'Paddle 0072', '14 min ago']] },
      19: { no: 19, title: 'Albion hand press, demy folio', sub: 'Hopkinson & Cope, London, 1851', low: 8000, high: 12000, bid: 8500, step: 250, bids: 6, hist: [['£8,500', 'Paddle 0509', '21 min ago'], ['£8,250', 'Paddle 0044', '40 min ago']] },
      20: { no: 20, title: 'Playbill archive, 214 items', sub: 'Theatre Royal, Drury Lane, 1838–1871', low: 5000, high: 7000, bid: 5250, step: 250, bids: 4, hist: [['£5,250', 'Paddle 0188', '8 min ago'], ['£5,000', 'Paddle 0044', '33 min ago']] },
    };
    const gbp = (n: number) => '£' + n.toLocaleString('en-GB');
    let cur = 18;
    const q = <T extends HTMLElement>(s: string) => sale.querySelector<T>(s)!;
    const no = q('[data-lot-no]'), title = q('[data-lot-title]'), sub = q('[data-lot-sub]'),
      est = q('[data-lot-est]'), bidV = q('[data-lot-bid]'), count = q('[data-lot-count]'),
      next = q('[data-next]'), lead = q('[data-lead]'), hist = q('[data-hist]'),
      bidBtn = q<HTMLButtonElement>('[data-bid]'), watch = q<HTMLButtonElement>('[data-watch]');
    const rowTpl = sale.closest('.sale')!.querySelector<HTMLTemplateElement>('[data-hist-row]')!;
    const watched = new Set<number>();

    const row = (price: string, who: string, when: string) => {
      const li = (rowTpl.content.cloneNode(true) as DocumentFragment).querySelector('li')!;
      li.querySelector('b')!.textContent = price;
      li.querySelector('span')!.textContent = who;
      li.querySelector('i')!.textContent = when;
      return li;
    };
    const render = () => {
      const l = data[cur];
      no.textContent = String(l.no);
      title.textContent = l.title;
      sub.textContent = l.sub;
      est.textContent = `${gbp(l.low)} – ${gbp(l.high)}`;
      bidV.textContent = gbp(l.bid);
      count.textContent = String(l.bids);
      next.textContent = gbp(l.bid + l.step);
      lead.hidden = l.hist[0]?.[1] !== 'Paddle 1845';
      hist.replaceChildren(...l.hist.slice(0, 4).map((h) => row(h[0], h[1], h[2])));
      watch.textContent = watched.has(cur) ? '★ Watching' : '☆ Watch';
      watch.setAttribute('aria-pressed', String(watched.has(cur)));
      const curCell = sale.querySelector(`[data-lot-cur='${cur}']`);
      if (curCell) curCell.textContent = gbp(l.bid);
    };
    sale.querySelectorAll<HTMLButtonElement>('[data-lot]').forEach((btn) =>
      btn.addEventListener('click', () => {
        sale.querySelectorAll('[data-lot]').forEach((b) => { b.classList.remove('is-on'); b.setAttribute('aria-selected', 'false'); });
        btn.classList.add('is-on');
        btn.setAttribute('aria-selected', 'true');
        cur = +btn.dataset.lot!;
        render();
      })
    );
    bidBtn.addEventListener('click', () => {
      const l = data[cur];
      l.bid += l.step;
      l.bids += 1;
      l.hist.unshift([gbp(l.bid), 'Paddle 1845', 'just now']);
      render();
      bidV.classList.remove('is-tick');
      void bidV.offsetWidth;
      bidV.classList.add('is-tick');
      const mine = cur;
      window.setTimeout(() => {                      // the room answers
        const m = data[mine];
        if (m.hist[0]?.[1] !== 'Paddle 1845') return;
        m.bid += m.step;
        m.bids += 1;
        m.hist.unshift([gbp(m.bid), 'Paddle 0072', 'just now']);
        if (cur === mine) render();
      }, 2600);
    });
    watch.addEventListener('click', () => {
      watched.has(cur) ? watched.delete(cur) : watched.add(cur);
      render();
    });
    render();
  });

  // ---- 05 · bounty: tier drives weight, tracking, copy ----
  document.querySelectorAll<HTMLElement>('[data-bounty]').forEach((b) => {
    const word = b.querySelector<HTMLElement>('[data-word]')!;
    const sum = b.querySelector<HTMLElement>('[data-sum]')!;
    const axis = b.querySelector<HTMLElement>('[data-axis]')!;
    const sums = ['', '$50', '$250', '$1,000', '$5,000', '$10,000'];
    const wghts = [0, 430, 540, 640, 780, 900];
    b.querySelectorAll<HTMLButtonElement>('[data-rate]').forEach((btn) =>
      btn.addEventListener('click', () => {
        const t = +btn.dataset.rate!;
        b.querySelectorAll('[data-rate]').forEach((x) => x.classList.remove('is-on'));
        btn.classList.add('is-on');
        b.setAttribute('data-tier', String(t));
        word.style.fontVariationSettings = `'wght' ${wghts[t]}`;
        word.style.letterSpacing = `${(0.015 - t * 0.009).toFixed(3)}em`;
        sum.style.fontVariationSettings = `'wght' ${wghts[t]}`;
        sum.textContent = sums[t];
        axis.textContent = `wght ${wghts[t]}`;
      })
    );
  });
</script>

<style>
  /* ---- the stack: alternating paper / iron beats, tightened gap ---- */
  .iu { gap: clamp(3rem, 7vh, 5rem); }
  .iu__hint { margin-top: var(--sp-2); color: var(--fg-3); }
  .iu__scene * { font-family: var(--fam); }

  /* shared paper + ink (acts 01, 03, 05 — printed artifacts, self-declared) */
  .spec, .dict, .bounty { --paper: #ede3cd; --paper-2: #e4d7bb; --ink: #221b12; --ink-2: #564a37; --rust: #b04a18; }

  /* ============ 01 · PATENT SPECIMEN BROADSIDE ============ */
  .spec { background: linear-gradient(175deg, var(--paper) 0%, var(--paper-2) 100%); color: var(--ink); }
  .spec__sheet { position: relative; max-width: 1180px; margin-inline: auto; padding: 5cqi 6cqi 3.5cqi; text-align: center; container-type: inline-size; }
  @container (min-width: 900px) { .spec__sheet { padding: 3.5cqi 6cqi 2.5cqi; } }
  .spec__rules { height: 7px; border-top: 3px solid var(--ink); border-bottom: 1px solid var(--ink); }
  .spec__rules--foot { height: 7px; border-top: 1px solid var(--ink); border-bottom: 3px solid var(--ink); margin-top: 3cqi; }
