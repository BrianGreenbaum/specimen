---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// Boutique storefront data (scene 05, interactive). Prices tuned to align in a
// tabular column (right-set, onum off so lining figures keep an even rhythm).
const pieces = [
  { id: '01', name: 'Mirabelle', cat: 'gowns',  price: '2,480', detail: 'Silk-crepe bias gown',     swatch: '#7c2233', tone: '#b9485c' },
  { id: '02', name: 'Cassis',    cat: 'gowns',  price: '1,950', detail: 'Velvet column dress',      swatch: '#3a2740', tone: '#6e4d78' },
  { id: '03', name: 'Verveine',  cat: 'coats',  price: '3,200', detail: 'Wool opera coat',          swatch: '#2f4036', tone: '#5d7a63' },
  { id: '04', name: 'Aubépine',  cat: 'coats',  price: '2,140', detail: 'Belted cashmere trench',   swatch: '#7a5a2e', tone: '#b08a4d' },
  { id: '05', name: 'Pivoine',   cat: 'jewels', price: '880',   detail: 'Freshwater pearl drops',   swatch: '#6d3550', tone: '#a35c80' },
  { id: '06', name: 'Giroflée',  cat: 'jewels', price: '1,460', detail: 'Hammered gold signet',     swatch: '#5a4a2c', tone: '#8c7440' },
];
---
<div class="iu" style={`--fam:${fam}`}>

  <!-- 01 — FASHION COVER (full-bleed art object) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Magazine — the fashion cover</span></figcaption>
    <div class="iu__scene scene-cover">
      <div class="iu__poster cover" data-weigh>
        <div class="cover__top">
          <span class="cover__logo">MAVEN</span>
          <span class="cover__meta"><span class="cover__no">N&deg;&#8202;09</span> &middot; Automne</span>
        </div>
        <div class="cover__stage">
          <span class="cover__over">The contrast issue</span>
          <h3 class="cover__hl">
            <span class="cover__hl-a" data-weigh-word>Hair</span><span class="cover__hl-b">line</span>
          </h3>
          <p class="cover__deck">Couture cut to the thinnest possible stroke &mdash; and the quiet luxury of the new restraint.</p>
        </div>
        <div class="cover__foot">
          <span class="cover__cred">Paris, at midnight</span>
          <span class="cover__price">&euro;&#8202;14</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">A cover built on Playfair&rsquo;s thick-to-thin drama; hover the title and the weight axis swells from hairline Regular to Black.</p>
  </figure>

  <!-- 02 — WEDDING INVITATION (asymmetric, oldstyle figures, true italic) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Invitation — an engraved wedding suite</span></figcaption>
    <div class="iu__scene scene-invite">
      <div class="iu__poster invite" data-draw>
        <span class="invite__over">Together with their families</span>
        <div class="invite__names">
          <span class="invite__n">Élodie</span>
          <span class="invite__amp">
            <svg class="invite__amp-rule" viewBox="0 0 40 60" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
              <path class="invite__draw" d="M20 4 V24" /><path class="invite__draw" d="M20 36 V56" />
            </svg>
            <em>and</em>
          </span>
          <span class="invite__n">Laurent</span>
        </div>
        <p class="invite__req">request the pleasure of your company at the celebration of their marriage</p>
        <div class="invite__when">
          <span class="invite__day">Saturday</span>
          <span class="invite__date"><span class="onum">12</span> September <span class="onum">2026</span></span>
          <span class="invite__time">half past four o&rsquo;clock in the afternoon</span>
        </div>
        <span class="invite__where">Château de Vauluisant &middot; Bourgogne</span>
      </div>
    </div>
    <p class="iu__hint label">Set in true italics with old-style figures (<code class="iu__ot">onum</code>) on the date; the hairline divider draws in on view.</p>
  </figure>

  <!-- 03 — LITERARY BOOK COVER (own palette, real small caps spacing, no wght-bloom) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Book — a literary cover</span></figcaption>
    <div class="iu__scene scene-book">
      <div class="iu__poster book">
        <div class="book__frame">
          <span class="book__pub">Pellier &amp; Wren &middot; London</span>
          <div class="book__center">
            <h3 class="book__title">The<br/><em>Hours</em><br/>Between</h3>
            <span class="book__rule" aria-hidden="true"></span>
            <span class="book__author">Marguerite Vail</span>
          </div>
          <p class="book__blurb">&ldquo;A vertiginous, hairline-fine debut.&rdquo; <span class="book__src">The Paris Review</span></p>
        </div>
      </div>
    </div>
    <p class="iu__hint label">A jacket built from Playfair&rsquo;s upright/italic contrast on a deep editorial ground &mdash; the kind of restraint the face was drawn for.</p>
  </figure>

  <!-- 04 — EDITORIAL FEATURE OPENER (kept; tightened) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Editorial — the feature opener</span></figcaption>
    <div class="iu__scene scene-spread">
      <div class="iu__poster spread" data-weigh>
        <div class="spread__rail">
          <span class="spread__folio">Feature &middot; <span class="onum">072</span></span>
          <span class="spread__sec">Letters</span>
        </div>
        <div class="spread__main">
          <span class="spread__kicker">On Type</span>
          <h3 class="spread__head" data-weigh-word>A Life in <em>Letters</em></h3>
          <p class="spread__deck">She drew by candlelight, and printed by reason.</p>
          <div class="spread__body">
            <p><span class="spread__drop">B</span>y the seventeen-nineties the press had finally caught the eye: paper smoother, ink blacker, the burin sharper. The contrast ran riot &mdash; heavy vertical stems beside hairlines fine enough to vanish, finished with crisp round ball terminals that Sørensen would revive two centuries later.</p>
            <p>The same drama now reads as one thing only: quiet, expensive restraint, set large on an editorial page. The thinner the stroke, the louder the elegance &mdash; which is exactly why a hairline serif belongs to the title and never to the footnote.</p>
            <p>Use it the wrong way and it tells you. At small sizes the contrast that makes it beautiful begins to fight the reader, and the page sparkles uncomfortably underfoot.</p>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Hover the headline &mdash; the weight blooms to Black while the italic word stays a fine flourish.</p>
  </figure>

  <!-- 05 — INTERACTIVE: boutique storefront UI (true scale; filter + sort + bag) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">05</span><span class="label">Product UI — boutique storefront (real scale, interactive)</span></figcaption>
    <div class="iu__scene">
      <div class="iu__device shop" data-shop>
        <div class="iu__chrome">
          <div class="iu__dots"><i></i><i></i><i></i></div>
          <span class="iu__addr">maison-vail.com/automne</span>
        </div>
        <header class="shop__head">
          <span class="shop__logo">Vail</span>
          <nav class="shop__filters" aria-label="Filter collection">
            <button class="is-on" data-filter="all">All</button>
            <button data-filter="gowns">Gowns</button>
            <button data-filter="coats">Coats</button>
            <button data-filter="jewels">Jewels</button>
          </nav>
          <span class="shop__bag" data-bag-label>Bag &middot; <span class="onum" data-bag>0</span></span>
        </header>

        <div class="shop__hero">
          <div class="shop__hero-text">
            <span class="shop__hero-kicker">Automne / Hiver &middot; Collection privée</span>
            <h4 class="shop__hero-word">Maison<br/><em>Vail</em></h4>
            <p class="shop__hero-sub">Hand-finished in the seventh arrondissement, delivered worldwide.</p>
          </div>
          <div class="shop__hero-sort">
            <span class="shop__sort-lbl">Sort</span>
            <button data-sort="curated" class="is-on">Curated</button>
            <button data-sort="low">Price ↑</button>
            <button data-sort="high">Price ↓</button>
          </div>
        </div>

        <div class="shop__grid" data-grid>
          {pieces.map((p) => (
            <article class="card" data-cat={p.cat} data-price={p.price.replace(',', '')}>
              <div class="card__img" style={`--swatch:${p.swatch};--tone:${p.tone}`} aria-hidden="true">
                <span class="card__plate">{p.id}</span>
                <span class="card__big">{p.name}</span>
              </div>
              <div class="card__meta">
                <div class="card__line">
                  <h5 class="card__name">{p.name}</h5>
                  <span class="card__price"><span class="card__cur">€</span><span class="onum">{p.price}</span></span>
                </div>
                <div class="card__line card__line--sub">
                  <span class="card__detail">{p.detail}</span>
                  <button class="card__add" type="button" data-add aria-label={`Add ${p.name} to bag`}>Add</button>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
    <p class="iu__hint label">Filter the collection and sort by price &mdash; the tabular figure column stays optically aligned. Add a piece and the bag count ticks up.</p>
  </figure>

</div>

<script>
  // ---- Scene 05: filter + sort + add-to-bag ----
  document.querySelectorAll<HTMLElement>('[data-shop]').forEach((shop) => {
    const grid = shop.querySelector('[data-grid]') as HTMLElement;
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.card'));
    const order = cards.slice();

    shop.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach((b) =>
      b.addEventListener('click', () => {
        shop.querySelectorAll('[data-filter]').forEach((x) => x.classList.remove('is-on'));
        b.classList.add('is-on');
        const f = b.dataset.filter!;
        cards.forEach((c) => c.classList.toggle('is-hidden', !(f === 'all' || c.dataset.cat === f)));
      })
    );

    shop.querySelectorAll<HTMLButtonElement>('[data-sort]').forEach((b) =>
      b.addEventListener('click', () => {
        shop.querySelectorAll('[data-sort]').forEach((x) => x.classList.remove('is-on'));
        b.classList.add('is-on');
        const mode = b.dataset.sort!;
        let arr = order.slice();
        if (mode === 'low') arr.sort((a, z) => +a.dataset.price! - +z.dataset.price!);
        else if (mode === 'high') arr.sort((a, z) => +z.dataset.price! - +a.dataset.price!);
        arr.forEach((c) => grid.appendChild(c));
      })
    );

    let count = 0;
    const bag = shop.querySelector('[data-bag]') as HTMLElement;
    const bagLabel = shop.querySelector('[data-bag-label]') as HTMLElement;
    shop.querySelectorAll<HTMLButtonElement>('[data-add]').forEach((b) =>
      b.addEventListener('click', () => {
        count += 1;
        bag.textContent = String(count);
        bagLabel.classList.add('is-bumped');
        b.classList.add('is-added');
        b.textContent = 'Added';
        setTimeout(() => bagLabel.classList.remove('is-bumped'), 320);
        setTimeout(() => { b.classList.remove('is-added'); b.textContent = 'Add'; }, 1100);
      })
    );
  });

  // ---- Scenes 01/04: pointer-driven weight bloom on a display word ----
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduce) {
    document.querySelectorAll<HTMLElement>('[data-weigh]').forEach((scene) => {
      const word = scene.querySelector<HTMLElement>('[data-weigh-word]');
      if (!word) return;
      const rest = getComputedStyle(word).getPropertyValue('--wght').trim() || '400';
      scene.addEventListener('pointerenter', () => word.style.setProperty('--wght', '900'));
      scene.addEventListener('pointerleave', () => word.style.setProperty('--wght', rest));
    });
  }
</script>

<style>
  .iu__item { margin: 0; }
  .iu__hint { margin-top: var(--sp-2); color: var(--fg-3); }
  .iu__scene * { font-family: var(--fam); }
  .iu__ot { font-family: var(--font-mono); font-size: 0.85em; color: var(--accent); letter-spacing: 0.02em; }
  .onum { font-feature-settings: 'onum' 1; }

  /* Print scenes fill the mat as a single art-directed object (no floating card). */
  .scene-cover > .iu__poster,
  .scene-invite > .iu__poster,
  .scene-book > .iu__poster,
  .scene-spread > .iu__poster { position: relative; inset: auto; }

  /* ============================================================
     01 — FASHION COVER  (full-bleed, accent ground)
     ============================================================ */
  .scene-cover { background: var(--accent); border-color: var(--accent); }
  .cover {
    aspect-ratio: 4 / 5; background: var(--accent); color: var(--accent-contrast);
    display: grid; grid-template-rows: auto 1fr auto; padding: 5cqi 5cqi 4.5cqi;
  }
  .cover__top { display: flex; justify-content: space-between; align-items: baseline; }
  .cover__logo { font-size: 3.4cqi; font-weight: 700; letter-spacing: 0.42em; padding-left: 0.42em; }
  .cover__meta { font-size: 2.6cqi; font-style: italic; color: color-mix(in srgb, var(--accent-contrast) 78%, transparent); letter-spacing: 0.02em; }
  .cover__meta .cover__no { font-style: normal; font-feature-settings: 'onum' 1; letter-spacing: 0.08em; }
  .cover__stage { align-self: center; display: flex; flex-direction: column; align-items: center; text-align: center; }
  .cover__over { font-size: 3cqi; font-style: italic; letter-spacing: 0.04em; color: color-mix(in srgb, var(--accent-contrast) 80%, transparent); margin-bottom: 1cqi; }
  .cover__hl { --wght: 400; font-size: 25cqi; line-height: 0.86; letter-spacing: -0.015em; margin: 0; display: flex; justify-content: center; }
  .cover__hl-a { font-variation-settings: 'wght' var(--wght); transition: font-variation-settings 0.55s var(--ease); }
  .cover__hl-b { font-style: italic; font-weight: 400; }
  .cover__deck { font-size: 3.1cqi; line-height: 1.32; font-style: italic; color: color-mix(in srgb, var(--accent-contrast) 86%, transparent); max-width: 34ch; margin: 2.6cqi auto 0; }
  .cover__foot { display: flex; justify-content: space-between; align-items: flex-end; border-top: 1px solid color-mix(in srgb, var(--accent-contrast) 30%, transparent); padding-top: 2.4cqi; }
  .cover__cred { font-size: 2.5cqi; font-style: italic; color: color-mix(in srgb, var(--accent-contrast) 82%, transparent); }
  .cover__price { font-size: 2.8cqi; font-feature-settings: 'onum' 1; letter-spacing: 0.04em; }

  /* ============================================================
     02 — WEDDING INVITATION  (asymmetric, engraved, onum)
     ============================================================ */
  .invite {
    background: var(--bg); color: var(--fg); aspect-ratio: 5 / 6;
    display: flex; flex-direction: column; justify-content: center; gap: 3.4cqi;
    text-align: center; padding: 7cqi 7cqi;
    box-shadow: inset 0 0 0 1px var(--line), inset 0 0 0 5cqi var(--bg);
    border: 1px solid var(--line);
  }
  .invite__over { font-size: 2.5cqi; font-style: italic; letter-spacing: 0.06em; color: var(--fg-3); }
  .invite__names { display: flex; flex-direction: column; align-items: center; gap: 1cqi; }
  .invite__n { font-size: 15cqi; line-height: 0.9; font-style: italic; font-weight: 400; color: var(--fg); }
  .invite__amp { display: flex; flex-direction: column; align-items: center; gap: 0.4cqi; }
  .invite__amp em { font-size: 4.2cqi; font-style: italic; color: var(--accent); letter-spacing: 0.02em; }
  .invite__amp-rule { width: 4cqi; height: 6cqi; }
  .invite__draw { stroke: var(--line); stroke-width: 1; fill: none; }
  .invite__req { font-size: 3cqi; line-height: 1.55; font-style: italic; color: var(--fg-2); max-width: 26ch; margin: 0.6cqi auto 0; }
  .invite__when { display: flex; flex-direction: column; gap: 1cqi; }
  .invite__day { font-size: 2.6cqi; letter-spacing: 0.3em; text-transform: uppercase; color: var(--fg-3); }
  .invite__date { font-size: 6.4cqi; font-weight: 600; color: var(--fg); line-height: 1; letter-spacing: 0.005em; }
  .invite__time { font-size: 2.7cqi; font-style: italic; color: var(--fg-2); }
  .invite__where { font-size: 2.5cqi; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); }
  @media (prefers-reduced-motion: no-preference) {
    .invite__draw { stroke-dasharray: 22; stroke-dashoffset: 22; }
    .invite[data-draw] .invite__draw { animation: pf-draw 1s var(--ease) 0.3s both; }
    .invite[data-draw]:hover .invite__draw { animation: pf-draw 0.8s var(--ease); }
    @keyframes pf-draw { to { stroke-dashoffset: 0; } }
  }

  /* ============================================================
     03 — LITERARY BOOK COVER  (own deep ground, upright/italic contrast)
     ============================================================ */
  .scene-book { --ink: #14110d; --paper: #ece3d1; --gilt: #b08a4d; }
  .book { aspect-ratio: 3 / 4; background: var(--ink); display: grid; place-items: stretch; padding: 4cqi; }
  .book__frame {
    border: 1px solid color-mix(in srgb, var(--gilt) 55%, transparent);
    display: grid; grid-template-rows: auto 1fr auto; padding: 6cqi 5cqi 5cqi; text-align: center;
  }
  .book__pub { font-size: 2.4cqi; letter-spacing: 0.26em; text-transform: uppercase; color: color-mix(in srgb, var(--paper) 60%, transparent); }
  .book__center { display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .book__title { font-size: 21cqi; line-height: 0.94; color: var(--paper); letter-spacing: -0.005em; margin: 0; }
  .book__title em { font-style: italic; font-weight: 400; color: var(--gilt); }
  .book__rule { display: block; width: 14cqi; height: 1px; background: color-mix(in srgb, var(--gilt) 70%, transparent); margin: 3.4cqi auto; }
  .book__author { font-size: 3.6cqi; font-style: italic; color: color-mix(in srgb, var(--paper) 88%, transparent); }
  .book__blurb { font-size: 2.6cqi; line-height: 1.5; font-style: italic; color: color-mix(in srgb, var(--paper) 64%, transparent); max-width: 30ch; margin: 0 auto; }
  .book__src { display: block; font-style: normal; font-size: 2.1cqi; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gilt); margin-top: 0.8cqi; }

  /* ============================================================
     04 — EDITORIAL FEATURE OPENER  (kept; minor fixes)
     ============================================================ */
  .scene-spread { aspect-ratio: 4 / 3; }
  .spread { background: var(--bg); color: var(--fg); display: grid; grid-template-columns: 11% 1fr; padding: 4.5cqi; gap: 3.5cqi; }
  .spread__rail { display: flex; flex-direction: column; justify-content: space-between; border-right: 1px solid var(--line); padding-right: 2.5cqi; }
  .spread__folio { font-size: 1.9cqi; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); }
  .spread__folio .onum { letter-spacing: 0.1em; }
  .spread__sec { font-size: 1.9cqi; letter-spacing: 0.16em; text-transform: uppercase; color: var(--fg-3); writing-mode: vertical-rl; }
  .spread__main { grid-column: 2; display: flex; flex-direction: column; min-height: 0; }
  .spread__kicker { font-size: 2.2cqi; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); }
  .spread__head {
    --wght: 500;
    font-size: 12.5cqi; line-height: 0.9; letter-spacing: -0.015em; color: var(--fg); margin-top: 1.4cqi;
    font-variation-settings: 'wght' var(--wght);
    transition: font-variation-settings 0.55s var(--ease);
  }
  .spread__head em { font-weight: 400; font-style: italic; color: var(--fg); font-variation-settings: 'wght' 400; }
  .spread__deck { font-size: 2.9cqi; line-height: 1.2; font-style: italic; color: var(--fg-2); max-width: 72%; margin-top: 2cqi; }
  .spread__body { columns: 2; column-gap: 3.5cqi; font-size: clamp(11px, 2cqi, 15px); line-height: 1.52; color: var(--fg-2); margin-top: 2.8cqi; text-align: justify; hyphens: auto; }
  .spread__body p { margin: 0 0 0.8em; }
  .spread__body p:first-child { text-indent: 0; }
  .spread__drop {
    float: left; font-size: 8.2cqi; line-height: 0.66; font-weight: 700;
    margin: 0.08em 0.12em -0.04em 0; color: var(--fg); hyphens: none;
  }

  /* ============================================================
     05 — BOUTIQUE STOREFRONT UI  (real px; filter + sort + bag)
     ============================================================ */
  .shop { font-size: 13px; line-height: 1.4; background: var(--bg); }
  .shop__head { display: flex; align-items: center; gap: 1.2rem; padding: 0.9rem 1.1rem; border-bottom: 1px solid var(--line); }
  .shop__logo { font-size: 24px; font-weight: 700; letter-spacing: 0.01em; color: var(--fg); }
  .shop__filters { display: flex; gap: 0.25rem; margin-left: 0.6rem; }
  .shop__filters button { font-size: 13px; color: var(--fg-3); padding: 0.3rem 0.7rem; border-radius: 100px; letter-spacing: 0.02em; transition: color .15s var(--ease), background .15s var(--ease); }
  .shop__filters button:hover { color: var(--fg); }
  .shop__filters button.is-on { color: var(--accent-contrast); background: var(--accent); font-weight: 600; }
  .shop__bag { margin-left: auto; font-size: 12.5px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--fg-2); transition: transform .3s var(--ease); }
  .shop__bag.is-bumped { transform: scale(1.16); color: var(--accent); }

  .shop__hero { display: flex; align-items: flex-end; justify-content: space-between; gap: 1.5rem; padding: 1.9rem 1.4rem 1.5rem; border-bottom: 1px solid var(--line); background: var(--bg-2); }
  .shop__hero-text { min-width: 0; }
  .shop__hero-kicker { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--fg-3); }
  .shop__hero-word { font-size: clamp(40px, 8vw, 64px); line-height: 0.92; color: var(--fg); margin: 0.25rem 0 0.45rem; letter-spacing: -0.01em; }
  .shop__hero-word em { font-style: italic; font-weight: 400; color: var(--accent); }
  .shop__hero-sub { font-size: 13.5px; font-style: italic; color: var(--fg-2); }
  .shop__hero-sort { display: flex; align-items: baseline; gap: 0.4rem; white-space: nowrap; flex: none; }
  .shop__sort-lbl { font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--fg-3); margin-right: 0.2rem; }
  .shop__hero-sort button { font-size: 12px; color: var(--fg-3); padding: 0.2rem 0.5rem; border-radius: 100px; transition: color .15s var(--ease), background .15s var(--ease); }
  .shop__hero-sort button:hover { color: var(--fg); }
  .shop__hero-sort button.is-on { color: var(--fg); background: color-mix(in srgb, var(--fg) 8%, transparent); }

