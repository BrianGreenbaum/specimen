---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;
---
<div class="iu" style={`--fam:${fam}`}>
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Masthead — a fashion title</span></figcaption>
    <div class="iu__scene cover34 iu__scene--portrait">
      <div class="iu__poster vogueish">
        <div class="vg__top"><span>SPRING</span><span>MMXXVI</span></div>
        <h3 class="vg__name">Élégance</h3>
        <div class="vg__lines">
          <span>The Return of the <i>Hairline</i></span>
          <span>72 Pages of Quiet Luxury</span>
        </div>
      </div>
    </div>
  </figure>

  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Editorial — the opening spread</span></figcaption>
    <div class="iu__scene scene16">
      <div class="iu__poster pf-spread">
        <span class="pf__kicker">Profile</span>
        <h3 class="pf__head">A Life in<br/><em>Letters</em></h3>
        <p class="pf__deck">She drew by candlelight and printed by reason. Two centuries later, her serifs still set the tone for elegance.</p>
      </div>
    </div>
  </figure>
</div>

<style>
  .iu__item { margin: 0; }
  .scene16 { aspect-ratio: 16 / 9; }
  .cover34 { --card-ar: 3 / 4; }

  .vogueish { background: var(--bg); color: var(--fg); display: flex; flex-direction: column; padding: 5cqi; }
  .vg__top { display: flex; justify-content: space-between; font-size: 2.8cqi; letter-spacing: 0.2em; color: var(--fg-2); }
  .vg__name { font-size: 21cqi; line-height: 0.86; font-weight: 700; text-align: center; font-style: italic; margin: auto 0 0; color: var(--fg); }
  .vg__lines { display: flex; flex-direction: column; gap: 1.4cqi; margin-top: 4cqi; }
  .vg__lines span { font-size: 3.4cqi; color: var(--fg-2); }
  .vg__lines i { color: var(--accent); }

  .pf-spread { background: var(--bg); padding: 5cqi; display: flex; flex-direction: column; justify-content: center; }
  .pf__kicker { font-size: 2.6cqi; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); }
  .pf__head { font-size: 18cqi; line-height: 0.9; font-weight: 700; margin-top: 2cqi; color: var(--fg); }
  .pf__head em { font-style: italic; color: var(--accent); font-weight: 500; }
  .pf__deck { font-size: 3cqi; font-style: italic; color: var(--fg-2); max-width: 66%; margin-top: 3cqi; }
</style>
