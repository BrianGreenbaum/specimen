  .eb-ple__body [data-pass].is-lit { background: #a0302226; }
  .eb-ple__body sup.is-lit { color: #fff; background: #a03022; border-radius: 2px; }

  .eb-ple__napp { font-size: max(10.5px, 1.42cqi); line-height: 1.58; }
  .eb-ple__nintro {
    margin: 0 0 1.3em; font-style: italic; color: #6d5e43;
    padding-bottom: 0.9em; border-bottom: 1px solid #241c1026;
  }
  .eb-ple__note {
    margin: 0 0 1em; padding-left: 0.85em; border-left: 2px solid transparent;
    transition: border-color 0.3s var(--ease), color 0.3s var(--ease);
    cursor: default; color: #3c321f;
  }
  .eb-ple__note b { font-weight: 500; color: #a03022; letter-spacing: 0.03em; }
  /* NOTE: the italic woff2 does carry init/fina, but CSS font-feature-settings
     forces positional features onto EVERY glyph (every e takes the finishing
     tail) — so they are not performable honestly from CSS and are not claimed */
  .eb-ple__note i { font-style: italic; }
  .eb-ple__note.is-lit { border-left-color: #a03022; color: #241c10; }
  .eb-ple__note:focus-visible { outline: 1px dotted #a03022; outline-offset: 3px; }

  /* ════════════════════════════════════════════════════════════════════
     03 · ÉDITIONS DU CADRAN — the identity that survives its negative
     ════════════════════════════════════════════════════════════════════ */
  .eb-id {
    --id-field: #e6dec9; --id-ink: #211a10; --id-soft: #71644e; --id-acc: #ad3a22;
    display: grid; grid-template-columns: minmax(228px, 300px) 1fr;
    gap: clamp(1.6rem, 3.4cqi, 3.4rem);
    background: var(--id-field); color: var(--id-ink);
    padding: clamp(1.7rem, 4cqi, 3.6rem) clamp(1.1rem, 4.5cqi, 4.5rem);
    transition: background 0.55s var(--ease), color 0.55s var(--ease);
  }
  .eb-id[data-coll='noire'] {
    --id-field: #15120d; --id-ink: #eae1ca; --id-soft: #8f8468; --id-acc: #d9aa32;
  }
  .eb-id__rail { display: flex; flex-direction: column; min-width: 0; }
  .eb-id__press { font-size: 17px; letter-spacing: 0.26em; font-weight: 500; }
  .eb-id__since { font-size: 13px; font-style: italic; color: var(--id-soft); margin-top: 0.45em; }
  /* the collection tabs belong to the maquette: the press's own letterspaced
     caps over a fillet, an ink chip for each forme — no 2020s pill buttons */
  .eb-id__tog {
    display: flex; gap: 1.7rem; margin-top: 1.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--id-ink) 26%, transparent);
  }
  .eb-id__tog button {
    display: inline-flex; align-items: center; gap: 0.55em;
    font-size: 11.5px; letter-spacing: 0.22em; font-weight: 500;
    padding: 0.1rem 0 0.55rem; cursor: pointer;
    background: transparent; color: var(--id-soft);
    border: 0; border-bottom: 2px solid transparent; margin-bottom: -1px;
    transition: color 0.3s var(--ease), border-color 0.3s var(--ease);
  }
  .eb-id__tog button:hover { color: var(--id-ink); }
  .eb-id__tog button.is-on { color: var(--id-ink); border-bottom-color: var(--id-acc); }
  .eb-id__chip { width: 10px; height: 10px; border: 1px solid color-mix(in srgb, var(--id-ink) 55%, transparent); }
  .eb-id__chip--b { background: #f6f0e1; }
  .eb-id__chip--n { background: #0d0c0a; }
  .eb-id__rules { margin-top: 1.7rem; border-top: 1px solid color-mix(in srgb, var(--id-ink) 22%, transparent); padding-top: 1.2rem; }
  .eb-id__rhead { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--id-acc); }
  .eb-id__rlist { margin: 0.8rem 0 0; padding: 0; list-style: none; counter-reset: rule; }
  .eb-id__rlist li {
    counter-increment: rule; position: relative;
    font-size: 13.5px; line-height: 1.5; font-style: italic; color: var(--id-ink);
    padding: 0.34rem 0 0.34rem 1.7rem;
  }
  .eb-id__rlist li::before {
    content: counter(rule); position: absolute; left: 0; top: 0.34rem;
    font-style: normal; color: var(--id-acc); font-weight: 500;
  }
  .eb-id__rlist--n { display: none; }
  .eb-id[data-coll='noire'] .eb-id__rlist--b { display: none; }
  .eb-id[data-coll='noire'] .eb-id__rlist--n { display: block; }
  .eb-id__railfoot { margin-top: auto; padding-top: 1.4rem; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--id-soft); }

  .eb-id__main { display: flex; flex-direction: column; gap: clamp(1rem, 2.2cqi, 1.8rem); min-width: 0; }
  .eb-id__covs { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: clamp(0.9rem, 2.2cqi, 2rem); }
  /* the cover is the container; the face inside it sizes in the cover's
     own cqi (padding on the cover itself would resolve against the scene) */
  .eb-id__cov {
    aspect-ratio: 14 / 20.5; container-type: inline-size;
    position: relative; min-width: 0;
  }
  .eb-id__face {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center;
    text-align: center; padding: 14cqi 10cqi 9cqi;
  }
  /* the white collection: two fillets, black then red */
  .eb-id__cov--b {
    background: #f6f0e1; color: #211a10;
    box-shadow: 0 14px 26px -16px rgba(28, 20, 8, 0.5);
  }
  .eb-id__cov--b .eb-id__face::before {
    content: ''; position: absolute; inset: 4.2cqi; border: 1.5px solid #211a10; pointer-events: none;
  }
  .eb-id__cov--b .eb-id__face::after {
    content: ''; position: absolute; inset: calc(4.2cqi + 5px); border: 1px solid #ad3a22; pointer-events: none;
  }
  /* the night series: one ivory hairline */
  .eb-id__cov--n {
    background: #0d0c0a; color: #eae1ca;
    box-shadow: 0 14px 26px -16px rgba(0, 0, 0, 0.8);
    display: none;
  }
  .eb-id__cov--n .eb-id__face::before {
    content: ''; position: absolute; inset: 4.2cqi; border: 1px solid #eae1ca66; pointer-events: none;
  }
  .eb-id[data-coll='noire'] .eb-id__cov--b { display: none; }
  .eb-id[data-coll='noire'] .eb-id__cov--n { display: block; }

  .eb-id__author { font-size: 5.6cqi; letter-spacing: 0.2em; text-indent: 0.2em; line-height: 1.45; }
  .eb-id__cti {
    margin-top: 7cqi; font-size: 8.6cqi; line-height: 1.22; letter-spacing: 0.05em;
    color: #ad3a22; font-weight: 430; text-wrap: balance;
  }
  .eb-id__cov--n .eb-id__cti { color: #d9aa32; font-weight: 800; letter-spacing: 0.03em; }
  .eb-id__genre { margin-top: 5.5cqi; font-size: 5.4cqi; font-style: italic; color: #6f6450; }
  .eb-id__cov--n .eb-id__genre { color: #9c9176; }
  .eb-id__oval { width: 17cqi; margin-top: auto; color: #211a10; }
  .eb-id__oval text { font-size: 22px; font-style: italic; fill: currentColor; }
  .eb-id__cov--n .eb-id__oval { color: #eae1ca; }
  .eb-id__pfoot { margin-top: 5cqi; font-size: 3.9cqi; letter-spacing: 0.3em; text-indent: 0.3em; color: #4d4232; }
  .eb-id__cov--n .eb-id__pfoot { color: #d9aa32; }

  /* a spine laid flat under the row */
  .eb-id__spines { display: block; }
  .eb-id__spine {
    display: none; align-items: center; gap: 1.4rem;
    height: clamp(34px, 4cqi, 48px); padding-inline: 1.2rem;
    font-size: clamp(11px, 1.25cqi, 14px); letter-spacing: 0.2em;
  }
  .eb-id__spine b { font-weight: 500; letter-spacing: 0.06em; }
  .eb-id__spine i { font-style: normal; font-weight: 500; }
  .eb-id__spine span { color: inherit; opacity: 0.72; }
  .eb-id__spine em { margin-left: auto; font-style: italic; letter-spacing: 0; font-size: 1.15em; }
  .eb-id__spine--b { background: #f6f0e1; color: #211a10; box-shadow: inset 0 0 0 1px #211a1022, 0 10px 18px -12px rgba(28, 20, 8, 0.5); }
  .eb-id__spine--b b, .eb-id__spine--b em { color: #ad3a22; }
  .eb-id__spine--n { background: #0d0c0a; color: #eae1ca; box-shadow: inset 0 0 0 1px #eae1ca33, 0 10px 18px -12px rgba(0, 0, 0, 0.8); }
  .eb-id__spine--n b, .eb-id__spine--n em { color: #d9aa32; }
  .eb-id[data-coll='blanche'] .eb-id__spine--b { display: flex; }
  .eb-id[data-coll='noire'] .eb-id__spine--n { display: flex; }

  /* the catalogue ad — the same five rules at landscape, press-announcement size */
  .eb-id__ad {
    position: relative; display: none; flex-direction: column; align-items: center;
    text-align: center; gap: 0.32em;
    padding: clamp(1.1rem, 2.6cqi, 1.9rem) clamp(1rem, 4cqi, 3rem) clamp(1rem, 2.4cqi, 1.7rem);
  }
  .eb-id__ad--b {
    background: #f6f0e1; color: #211a10;
    box-shadow: 0 14px 26px -16px rgba(28, 20, 8, 0.5);
  }
  .eb-id__ad--b::before { content: ''; position: absolute; inset: 9px; border: 1.5px solid #211a10; pointer-events: none; }
  .eb-id__ad--b::after { content: ''; position: absolute; inset: 14px; border: 1px solid #ad3a22; pointer-events: none; }
  .eb-id__ad--n {
    background: #0d0c0a; color: #eae1ca;
    box-shadow: 0 14px 26px -16px rgba(0, 0, 0, 0.8);
  }
  .eb-id__ad--n::before { content: ''; position: absolute; inset: 9px; border: 1px solid #eae1ca66; pointer-events: none; }
  .eb-id[data-coll='blanche'] .eb-id__ad--b { display: flex; }
  .eb-id[data-coll='noire'] .eb-id__ad--n { display: flex; }
  .eb-id__adover { font-size: clamp(11px, 1.15cqi, 13px); letter-spacing: 0.34em; text-indent: 0.34em; color: #ad3a22; }
  .eb-id__ad--n .eb-id__adover { color: #eae1ca; }
  .eb-id__adauthor { margin-top: 0.5em; font-size: clamp(13px, 1.5cqi, 17px); letter-spacing: 0.2em; text-indent: 0.2em; }
  .eb-id__adtitle { font-size: clamp(22px, 3.1cqi, 34px); line-height: 1.15; letter-spacing: 0.05em; color: #ad3a22; font-weight: 430; }
  .eb-id__ad--n .eb-id__adtitle { color: #d9aa32; font-weight: 800; letter-spacing: 0.03em; }
  .eb-id__adgenre { font-size: clamp(12px, 1.3cqi, 14.5px); font-style: italic; color: #6f6450; }
  .eb-id__ad--n .eb-id__adgenre { color: #9c9176; }
  .eb-id__adfoot { margin-top: 0.7em; font-size: clamp(10.5px, 1.1cqi, 12.5px); letter-spacing: 0.08em; color: #4d4232; }
  .eb-id__ad--n .eb-id__adfoot { color: #9c9176; }
  .eb-id__adfoot sup { font-size: 0.72em; }

  .eb-id__colo { margin: 0; font-size: 13px; font-style: italic; color: var(--id-soft); }

  /* the re-inking: on flip, covers → ad → spine → rules re-enter ~80ms apart;
     under reduced motion none of this runs and the flip snaps */
  @media (prefers-reduced-motion: no-preference) {
    .eb-id.is-reink .eb-id__cov { animation: eb-reink 0.42s var(--ease-out) backwards; }
    .eb-id.is-reink .eb-id__covs .eb-id__cov:nth-of-type(2),
    .eb-id.is-reink .eb-id__covs .eb-id__cov:nth-of-type(5) { animation-delay: 0.08s; }
    .eb-id.is-reink .eb-id__covs .eb-id__cov:nth-of-type(3),
    .eb-id.is-reink .eb-id__covs .eb-id__cov:nth-of-type(6) { animation-delay: 0.16s; }
    .eb-id.is-reink .eb-id__ad { animation: eb-reink 0.42s var(--ease-out) 0.24s backwards; }
    .eb-id.is-reink .eb-id__spine { animation: eb-reink 0.42s var(--ease-out) 0.32s backwards; }
    .eb-id.is-reink .eb-id__rlist { animation: eb-reink 0.42s var(--ease-out) 0.4s backwards; }
    @keyframes eb-reink {
      from { opacity: 0; transform: translateY(7px); }
      to { opacity: 1; transform: none; }
    }
  }

  /* ════════════════════════════════════════════════════════════════════
     04 · OCTAVO — real px, every control live (tokens for the chrome,
     the page declares its own paper per theme)
     ════════════════════════════════════════════════════════════════════ */
  .eb-rd { max-width: 980px; margin-inline: auto; width: 100%; border: 1px solid var(--line); }
  .eb-rd__split { display: grid; grid-template-columns: 248px 1fr; background: var(--bg); }
  .eb-rd__rail {
    display: flex; flex-direction: column; gap: 1.05rem;
    padding: 1.2rem 1.15rem 1.1rem;
    border-right: 1px solid var(--line);
    background: color-mix(in srgb, var(--fg) 3%, var(--bg));
  }
  .eb-rd__logo { font-size: 23px; font-weight: 600; color: var(--fg); line-height: 1; }
  .eb-rd__sub { font-size: 12.5px; font-style: italic; color: var(--fg-3); margin-top: -0.75rem; }
  .eb-rd__group { display: flex; flex-direction: column; gap: 0.4rem; }
  .eb-rd__lab { font-size: 11.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--fg-3); }
  .eb-rd__lab b { font-weight: 500; color: var(--accent); letter-spacing: 0.04em; }
  .eb-rd__seg { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .eb-rd__seg button {
    font-size: 12.5px; line-height: 1; color: var(--fg-2);
    padding: 0.4rem 0.6rem; cursor: pointer;
    background: var(--bg); border: 1px solid var(--line); border-radius: 6px;
    transition: color 0.18s var(--ease), border-color 0.18s var(--ease), background 0.18s var(--ease);
  }
  .eb-rd__seg button i { font-style: normal; color: var(--fg-3); }
  .eb-rd__seg button:hover { color: var(--fg); border-color: var(--fg-3); }
  .eb-rd__seg button.is-on { color: var(--accent-contrast); background: var(--accent); border-color: var(--accent); }
  .eb-rd__seg button.is-on i { color: var(--accent-contrast); opacity: 0.85; }
  .eb-rd__lf { font-feature-settings: 'pnum' 1; }
  .eb-rd__figno { font-size: 11px; font-style: italic; color: var(--fg-3); line-height: 1.4; }
  .eb-rd input[type='range'] { width: 100%; accent-color: var(--accent); }
  .eb-rd__grade { font-size: 11.5px; font-style: italic; color: var(--accent); line-height: 1.45; }
  .eb-rd__proof {
    margin-top: 0.2rem; padding: 0.7rem 0.75rem 0.6rem;
    border: 1px dashed var(--line); border-radius: 6px;
    display: flex; flex-direction: column; gap: 0.3rem;
  }
  .eb-rd__proofline { font-size: 20px; line-height: 1.2; color: var(--fg); }
  .eb-rd__frac { font-feature-settings: 'frac' 1; color: var(--accent); }
  .eb-rd__proof i { font-size: 11px; font-style: italic; color: var(--fg-3); }
  .eb-rd__prog { margin-top: auto; position: relative; padding-top: 0.75rem; }
  .eb-rd__prog i {
    position: absolute; top: 0; left: 0; height: 2px; background: var(--accent); display: block;
  }
  .eb-rd__prog::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--line); z-index: -1; }
  .eb-rd__prog span { font-size: 12.5px; color: var(--fg-3); }

  /* the page declares its own paper, per theme */
  .eb-rd__page {
    --pp: #faf5e8; --pi: #282113;
    position: relative;
    padding: clamp(1.6rem, 4.5cqi, 3rem) clamp(1.4rem, 6cqi, 4rem) clamp(2rem, 5cqi, 3.4rem);
    background: var(--pp); color: var(--pi);
    transition: background 0.4s var(--ease), color 0.4s var(--ease);
    min-width: 0;
  }
  /* the compositor's margin note: the live weight value, set large */
  .eb-rd__inkmark {
    position: absolute; top: 1rem; right: 1.2rem;
    display: flex; flex-direction: column; align-items: flex-end;
    pointer-events: none; text-align: right;
    color: var(--accent); opacity: 0.42;
  }
  .eb-rd__inkmark i { font-style: normal; font-size: 84px; line-height: 0.82; letter-spacing: -0.01em; }
  .eb-rd__inkmark em { font-style: italic; font-size: 13px; margin-top: 0.3em; }
  .eb-rd[data-theme='night'] .eb-rd__inkmark { color: #c98a4e; opacity: 0.6; }
  .eb-rd[data-theme='day'] .eb-rd__page { --pp: #faf5e8; --pi: #28211f; }
  .eb-rd[data-theme='sepia'] .eb-rd__page { --pp: #efe2c4; --pi: #33270f; }
  .eb-rd[data-theme='night'] .eb-rd__page { --pp: #16120b; --pi: #e7dcc2; }
  .eb-rd__kick { font-size: 12px; letter-spacing: 0.2em; color: var(--accent); }
  .eb-rd[data-theme='night'] .eb-rd__kick { color: #c98a4e; }
  .eb-rd__head { margin: 0.55rem 0 0.4rem; font-size: 31px; line-height: 1.12; font-weight: 500; }
  .eb-rd__by { margin: 0 0 1.4rem; font-size: 14px; font-style: italic; opacity: 0.62; }
  .eb-rd__page p { margin: 0 0 1em; line-height: 1.66; max-width: 62ch; }
  .eb-rd__quote {
    margin: 1.5rem 0 0.4rem; padding-left: 1.1rem; border-left: 2px solid var(--accent);
    font-size: 1.18em; line-height: 1.5;
  }
  .eb-rd[data-theme='night'] .eb-rd__quote { border-left-color: #c98a4e; }
  .eb-rd__quote em { font-style: italic; }

  /* ════════════════════════════════════════════════════════════════════
     05 · PLANTIN-MORETUS — the conjunction, breathing on the axis
     ════════════════════════════════════════════════════════════════════ */
  .eb-po { background: #14110b; color: #e9ddc1; }
  .eb-po__in {
    max-width: 1240px; margin-inline: auto; min-height: clamp(560px, 88vh, 880px);
    display: flex; flex-direction: column;
    padding: clamp(1.6rem, 3.6cqi, 3.4rem) clamp(1.2rem, 4.5cqi, 4.5rem) clamp(1.8rem, 4cqi, 3.6rem);
  }
  .eb-po__top {
    display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;
    font-size: clamp(11px, 1.15cqi, 15px); letter-spacing: 0.22em; text-transform: uppercase;
    color: #a3946f; padding-bottom: clamp(0.8rem, 1.6cqi, 1.4rem);
    border-bottom: 1px solid #e9ddc12b;
  }
  .eb-po__topm { color: #c23a20; }
  .eb-po__art {
    position: relative; flex: 1; display: flex; flex-direction: column; justify-content: center;
    padding-block: clamp(1rem, 2.5cqi, 2rem);
  }
  .eb-po__row { display: flex; align-items: baseline; gap: clamp(0.8rem, 2.4cqi, 2.4rem); flex-wrap: wrap; }
  .eb-po__row--1 { justify-content: flex-start; }
  .eb-po__row--2 { justify-content: flex-end; }
  .eb-po__name {
    margin: 0; font-size: clamp(38px, 8.6cqi, 118px); line-height: 1;
    font-weight: 430; letter-spacing: 0.045em; color: #e9ddc1;
  }
  .eb-po__name--it em { font-style: italic; letter-spacing: 0.02em; }
  .eb-po__role { font-size: clamp(11px, 1.2cqi, 16px); font-style: italic; color: #a3946f; }
  .eb-po__amp {
    align-self: center; font-style: italic; line-height: 0.62;
    font-size: clamp(170px, 30cqi, 420px);
    color: #c23a20;
    margin-block: clamp(-1.4rem, -2cqi, -0.6rem);
    font-variation-settings: 'wght' 640;
  }
  /* breathing is JS-driven (so the footer can read the value back);
     reduced motion never starts the loop and the amp holds 640 */
  .eb-po__foot {
    display: flex; justify-content: space-between; align-items: flex-end; gap: 1.4rem;
    padding-top: clamp(0.9rem, 1.8cqi, 1.6rem); border-top: 1px solid #e9ddc12b;
  }
  .eb-po__lede { margin: 0; font-size: clamp(13px, 1.5cqi, 19px); line-height: 1.5; max-width: 44ch; }
  .eb-po__lede em { font-style: italic; color: #a3946f; }
  .eb-po__meta {
    display: flex; flex-direction: column; align-items: flex-end; gap: 0.3em; text-align: right;
    font-size: clamp(12px, 1.3cqi, 17px);
  }
  .eb-po__meta b { font-weight: 600; color: #c23a20; font-size: 1.2em; }
  .eb-po__meta span { color: #a3946f; }
  /* the score line: the live axis value — the default tabular-lining digits
     keep it from jittering as it counts */
  .eb-po__axis { margin-top: 0.45em; font-style: italic; }
  .eb-po__axis b { font-style: normal; font-weight: 500; font-size: 1em; letter-spacing: 0.04em; }

  /* ════════════════════════════════════════════════════════════════════
     RESPONSIVE — three compositions, not one squished
     ════════════════════════════════════════════════════════════════════ */
  /* 01 · the sheet stacks its labels above the lines */
  @container (max-width: 700px) {
    .eb-sh__row { grid-template-columns: 1fr; gap: 0.25rem; padding-block: 0.7rem; }
    .eb-sh__name { flex-direction: row; align-items: baseline; gap: 0.7em; }
    .eb-lens { width: clamp(120px, 36cqi, 170px); border-width: 2px; }
    /* narrow sheet: the Gros Canon line overflows again, so it takes the
       same long margin fade as the running lines — ink, not a clip */
    .eb-sh__row--fit .eb-sh__line { mask-image: linear-gradient(90deg, #000 84%, transparent 98%); }
  }
  /* 02 · the spread becomes successive openings */
  @container (max-width: 660px) {
    .eb-ple__book { grid-template-columns: 1fr; }
    .eb-ple__page--text { box-shadow: none; border-bottom: 1px solid #241c1026; }
