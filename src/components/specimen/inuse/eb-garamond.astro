---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// ── The sequence ─────────────────────────────────────────────────────────────
// FIVE CENTURIES OF THE READING LETTER, ONE THREAD OF PRINTER'S RED.
// EB Garamond is cut from the Egenolff-Berner broadsheet of 1592, so the
// stack is that letter's whole life told forward: the source sheet under a
// reading glass (01) → the book it set for a century, the Pléiade (02) →
// the white cover of French publishing it dressed (03) → the screen it
// reads on now (04) → home to Antwerp, where the actual punches sleep (05).
// Surfaces: parchment light → leather dark → ivory/black flip → device →
// near-black finale. The rubricator's red runs through every act.

// Honesty notes, verified against the fontsource woff2s (fontTools, round 2):
// · wght 400–800 in BOTH roman and italic files — the only axis performed.
// · GSUB (latin roman): liga, frac, pnum, tnum, locl ONLY. There is no
//   smcp / dlig / onum / swsh in this build — never claimed anywhere below.
// · DEFAULT FIGURES ARE TABULAR LINING (digit tops 626–643 vs cap 650;
//   bottoms −3..−38 are overshoot, not descenders; every advance 480).
//   `pnum` maps to the .lf PROPORTIONAL-LINING alternates (same vertical
//   bounds, advances 382–506) and `tnum` maps them back. So the only
//   honest figures story is Tabular ↔ Proportional — told in act 04 where
//   spacing shows. No old-style-figure claim anywhere in this file.
// · The ITALIC additionally carries init (v→v.init, w→w.init) and
//   fina (e→e.fina) — but CSS font-feature-settings forces positional
//   features onto every glyph, so they are NOT performed or claimed.
// · `liga` carries f_i f_l f_f f_f_i f_f_l. `frac` works (1/2 in act 04).
// · Greek (incl. polytonic) and Cyrillic subsets are loaded site-wide;
//   EB Garamond's Greek follows the Grecs du Roi model.

// ── Act 01 — the 1592 sheet, size by size ────────────────────────────────────
const rows = [
  { name: 'Gros Canon',     pt: '≈44 pt', by: 'romain de Garamont',   cqi: 4.1,  px: 29, fit: true, text: 'Quousque tandem abutere, Catilina,' },
  { name: 'Petit Canon',    pt: '≈28 pt', by: 'romain de Garamont',   cqi: 3.5,  px: 25,   text: 'patientia nostra? quam diu etiam furor iste tuus' },
  { name: 'Gros Parangon',  pt: '≈22 pt', by: 'italique de Granjon',  cqi: 2.9,  px: 21,  it: true, text: 'iste tuus nos eludet? quem ad finem sese effrenata' },
  { name: 'Gros Romain',    pt: '≈18 pt', by: 'romain de Garamont',   cqi: 2.35, px: 18,   text: 'effrenata iactabit audacia? Nihilne te nocturnum praesidium' },
  { name: 'Saint Augustin', pt: '≈14 pt', by: 'italique de Granjon',  cqi: 2.0,  px: 16,  it: true, park: true, text: 'praesidium Palatii, nihil urbis vigiliae, nihil timor populi, nihil consensus' },
  { name: 'Cicéro',         pt: '≈12 pt', by: 'romain de Garamont',   cqi: 1.7,  px: 14.5, text: 'nihil consensus bonorum omnium, nihil hic munitissimus habendi senatus' },
  { name: 'Grec',           pt: '≈12 pt', by: 'd’après les Grecs du Roi', cqi: 1.7, px: 14.5, gr: true, text: 'Ἐν ἀρχῇ ἦν ὁ λόγος, καὶ ὁ λόγος ἦν πρὸς τὸν θεόν, καὶ θεὸς ἦν ὁ λόγος.' },
  { name: 'Petit Texte',    pt: '≈7½ pt', by: 'romain de Garamont',   cqi: 1.38, px: 12.5, text: 'locus, nihil horum ora voltusque moverunt? patere tua consilia non sentis? constrictam iam horum' },
  { name: 'Nonpareille',    pt: '≈6 pt',  by: 'romain de Garamont',   cqi: 1.12, px: 10.5, text: 'omnium scientia teneri coniurationem tuam non vides? quid proxima, quid superiore nocte egeris, ubi fueris, quos convocaveris, quid consilii ceperis, quem nostrum ignorare arbitraris?' },
];

// ── Act 03 — one press, two collections ──────────────────────────────────────
const blanche = [
  { author: 'HÉLÈNE VASSEUR',   title: 'LA LISIÈRE',          genre: 'roman',     no: '412' },
  { author: 'PAUL MARAVAL',     title: 'UN HIVER À TRIESTE',  genre: 'récit',     no: '413' },
  { author: 'MARGUERITE ANDRAL', title: 'LES HEURES BLEUES',  genre: 'nouvelles', no: '414' },
];
const noire = [
  { author: 'JEAN SERVAT',     title: 'LA NUIT TOMBE DEUX FOIS', genre: 'roman noir', no: '87' },
  { author: 'ODILE FRESNAY',   title: 'LE QUAI DES ARDOISES',    genre: 'roman noir', no: '88' },
  { author: 'VICTOR LAMBALLE', title: 'TROIS BALLES POUR RIEN',  genre: 'roman noir', no: '89' },
];
const rulesB = [
  'The author in black — capitals, letterspaced half a quad.',
  'The title in the printer’s red, at double body.',
  'The genre in italic lower case, never capitalised.',
  'Two fillets round the page: black outside, red within.',
  'The oval device at the foot, never wider than the title line.',
];
const rulesN = [
  'The field printed full black, to the trim.',
  'The author in ivory; the title in sulphur yellow.',
  'The title at weight 800 — the bold Octavio Pardo cut for the revival in 2011; the 1592 sheet had no such thing.',
  'One fillet only, ivory, hairline.',
  'The same oval, turned to face the night.',
];
---

<div class="iu eb" style={`--fam:${fam}`}>

  <!-- ════════════════════════════════════════════════════════════════════
       01 · INTERACTIVE & EXPERIMENTAL — the Egenolff-Berner sheet, 1592.
       Reference: the Egenolff-Berner specimen broadsheet (Conrad Berner,
       Frankfurt, 1592) — the literal source document of this revival, the
       most celebrated specimen sheet of the hand-press era. Rebuilt as
       live type, Gros Canon down to Nonpareille, with a scholar's reading
       glass that rests on the Granjon italic and follows the hand.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Experimental — the Egenolff-Berner sheet of 1592, under the reading glass</span></figcaption>
    <div class="iu__scene eb-sh-scene">
      <div class="eb-sh" data-sheet>
        <div class="eb-sh__inner" data-sheet-art>
          <header class="eb-sh__head">
            <p class="eb-sh__over">Specimen</p>
            <h3 class="eb-sh__title">CHARACTERVM SEV TYPORVM PROBATISSIMORVM</h3>
            <p class="eb-sh__sub" lang="la"><em>incondite quidem, sed secundum suas tamen differentias propositum</em> — ex officina <em>Conradi Berneri</em>, Francofvrti ad Moenvm, anno <b>M&middot;D&middot;XCII</b></p>
          </header>
          <div class="eb-sh__rows">
            {rows.map((r) => (
              <div class={`eb-sh__row${r.it ? ' eb-sh__row--it' : ''}${r.gr ? ' eb-sh__row--gr' : ''}${r.fit ? ' eb-sh__row--fit' : ''}`}>
                <span class="eb-sh__name">{r.name}<b>{r.pt}</b><i>{r.by}</i></span>
                <span class="eb-sh__line" lang={r.gr ? 'grc' : undefined} data-park={r.park ? '' : undefined} style={`font-size:clamp(${r.px}px, ${r.cqi}cqi, ${Math.round(r.cqi * 14.4)}px)`}>{r.text}</span>
              </div>
            ))}
          </div>
          <footer class="eb-sh__foot">
            <span>Romains de Claude Garamont</span><i aria-hidden="true">❧</i><span>Italiques de Robert Granjon</span><i aria-hidden="true">❧</i><span>Grec d&rsquo;après les Grecs du Roi</span>
          </footer>
        </div>
        <div class="eb-lens" data-lens aria-hidden="true"></div>
      </div>
    </div>
    <p class="iu__hint label">The broadsheet this revival is cut from: Conrad Berner&rsquo;s 1592 sheet, the romans of Garamont and the italics of Granjon shown body by body, Gros Canon down to Nonpareille — with the Greek that Duffner drew after the Grecs du Roi Garamont cut for Fran&ccedil;ois&nbsp;I<sup>er</sup>. A reading glass rests on the Granjon line; move your hand across the paper and it follows, holding the letter at punch scale.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       02 · EDITORIAL — la Bibliothèque de la Pléiade.
       Reference: Jacques Schiffrin's Bibliothèque de la Pléiade (1931,
       Gallimard from 1933) — French literature's canonical edition, set
       in Garamond on bible paper with gilt edges and a sewn-in ribbon.
       Two openings of the same volume, eleven hundred pages apart,
       brought face to face: the text and its critical apparatus.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click="[data-note='n3']">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Editorial — la Biblioth&egrave;que de la Pl&eacute;iade, text against apparatus</span></figcaption>
    <div class="iu__scene eb-ple">
      <div class="eb-ple__stage">
        <div class="eb-ple__book" lang="fr" data-ple>
          <i class="eb-ple__gilt" aria-hidden="true"></i>
          <i class="eb-ple__ribbon" aria-hidden="true"></i>
          <section class="eb-ple__page eb-ple__page--text">
            <header class="eb-ple__rh"><span class="eb-ple__folio">4</span><span class="eb-ple__rht">DU C&Ocirc;T&Eacute; DE CHEZ SWANN</span></header>
            <div class="eb-ple__open">
              <span class="eb-ple__part">PREMI&Egrave;RE PARTIE</span>
              <span class="eb-ple__chap">COMBRAY</span>
              <span class="eb-ple__no"><em>I</em></span>
            </div>
            <div class="eb-ple__body">
              <p><span data-pass="n1">Longtemps, je me suis couch&eacute; de bonne heure.</span><sup class="eb-ple__cue" data-cue="n1">1</sup> Parfois, &agrave; peine ma bougie &eacute;teinte, mes yeux se fermaient si vite que je n&rsquo;avais pas le temps de me dire&nbsp;: &laquo;&nbsp;Je m&rsquo;endors.&nbsp;&raquo; Et, une demi-heure apr&egrave;s, la pens&eacute;e qu&rsquo;il &eacute;tait temps de chercher le sommeil m&rsquo;&eacute;veillait&nbsp;; je voulais poser <span data-pass="n2">le volume que je croyais avoir encore dans les mains</span><sup class="eb-ple__cue" data-cue="n2">2</sup> et souffler ma lumi&egrave;re&nbsp;; je n&rsquo;avais pas cess&eacute; en dormant de faire des r&eacute;flexions sur ce que je venais de lire, mais ces r&eacute;flexions avaient pris un tour un peu particulier&nbsp;; il me semblait que j&rsquo;&eacute;tais moi-m&ecirc;me ce dont parlait l&rsquo;ouvrage&nbsp;: une &eacute;glise, un quatuor, <span data-pass="n3">la rivalit&eacute; de Fran&ccedil;ois&nbsp;I<sup>er</sup> et de Charles&#8209;Quint</span>.<sup class="eb-ple__cue" data-cue="n3">3</sup></p>
              <p>Cette croyance survivait pendant quelques secondes &agrave; mon r&eacute;veil&nbsp;; elle ne choquait pas ma raison mais pesait comme des &eacute;cailles sur mes yeux et les emp&ecirc;chait de se rendre compte que le bougeoir n&rsquo;&eacute;tait plus allum&eacute;.</p>
              <p>Je me demandais quelle heure il pouvait &ecirc;tre&nbsp;; <span data-pass="n4">j&rsquo;entendais le sifflement des trains</span><sup class="eb-ple__cue" data-cue="n4">4</sup> qui, plus ou moins &eacute;loign&eacute;, comme le chant d&rsquo;un oiseau dans une for&ecirc;t, relevant les distances, me d&eacute;crivait l&rsquo;&eacute;tendue de la campagne d&eacute;serte o&ugrave; le voyageur se h&acirc;te vers la station prochaine.</p>
            </div>
          </section>
          <section class="eb-ple__page eb-ple__page--notes">
            <header class="eb-ple__rh"><span class="eb-ple__rht">NOTES ET VARIANTES</span><span class="eb-ple__folio">1126</span></header>
            <div class="eb-ple__napp">
              <p class="eb-ple__nintro">On donne ici les principaux &eacute;tats du texte&nbsp;; les chiffres renvoient &agrave; la page et &agrave; l&rsquo;appel de note.</p>
              <p class="eb-ple__note" data-note="n1" tabindex="0"><b>Page 4, 1.</b>&nbsp;<i>Longtemps, je me suis couch&eacute; de bonne heure</i>&nbsp;: l&rsquo;attaque du livre est arr&ecirc;t&eacute;e d&egrave;s le Cahier 8, en 1909, apr&egrave;s trois &eacute;tats successifs&nbsp;; Proust ne la retouchera plus.</p>
              <p class="eb-ple__note" data-note="n2" tabindex="0"><b>4, 2.</b>&nbsp;<i>le volume que je croyais avoir encore dans les mains</i>&nbsp;: la dactylographie de 1911 porte d&rsquo;abord &laquo;&nbsp;le livre&nbsp;&raquo;&nbsp;; la correction restitue le mot du manuscrit.</p>
              <p class="eb-ple__note" data-note="n3" tabindex="0"><b>4, 3.</b>&nbsp;<i>la rivalit&eacute; de Fran&ccedil;ois&nbsp;I<sup>er</sup> et de Charles&#8209;Quint</i>&nbsp;: l&rsquo;exemple revient dans les esquisses de <i>Contre Sainte-Beuve</i>&nbsp;; Proust y tenait comme &agrave; une mesure du temps historique entr&eacute; dans le demi-sommeil.</p>
              <p class="eb-ple__note" data-note="n4" tabindex="0"><b>4, 4.</b>&nbsp;<i>j&rsquo;entendais le sifflement des trains</i>&nbsp;: souvenir des nuits d&rsquo;Illiers&nbsp;; d&egrave;s ce premier feuillet, l&rsquo;espace est mesur&eacute; par le son, comme le temps le sera par le go&ucirc;t.</p>
            </div>
          </section>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Jacques Schiffrin&rsquo;s Biblioth&egrave;que de la Pl&eacute;iade (1931) has set French literature in Garamond on bible paper for nearly a century. Two openings of the same volume, eleven hundred pages apart, face to face: the first variant is already lit when the page finds you — touch any other and it lights the line it argues with. The compositor&rsquo;s French is kept whole — espaces fines inside the guillemets, the lemma quoted in Granjon&rsquo;s italic, the rubricator&rsquo;s red on every cue and on the sewn-in signet.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       03 · BRANDING & IDENTITY — one press, two collections.
       Reference: Gallimard's Collection Blanche (the nrf white cover,
       1911) — the most durable identity in publishing — and its shadow,
       Marcel Duhamel's Série Noire (1945). A fictional press, Éditions du
       Cadran, run on the same two grids: flip the house from ivory to
       night and the system survives its own negative.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click="[data-coll='noire']">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Branding — &Eacute;ditions du Cadran, one grid, two collections</span></figcaption>
    <div class="iu__scene">
      <div class="eb-id" data-id data-coll="blanche">
        <aside class="eb-id__rail">
          <span class="eb-id__press">&Eacute;DITIONS DU CADRAN</span>
          <span class="eb-id__since">Paris &middot; fond&eacute;es en 1923</span>
          <div class="eb-id__tog" role="group" aria-label="Choose the collection">
            <button type="button" class="is-on" data-coll="blanche" aria-pressed="true"><i class="eb-id__chip eb-id__chip--b" aria-hidden="true"></i>COLLECTION IVOIRE</button>
            <button type="button" data-coll="noire" aria-pressed="false"><i class="eb-id__chip eb-id__chip--n" aria-hidden="true"></i>S&Eacute;RIE NOCTURNE</button>
          </div>
          <div class="eb-id__rules">
            <span class="eb-id__rhead">From the maquette — the five rules</span>
            <ol class="eb-id__rlist eb-id__rlist--b">{rulesB.map((r) => <li>{r}</li>)}</ol>
            <ol class="eb-id__rlist eb-id__rlist--n">{rulesN.map((r) => <li>{r}</li>)}</ol>
          </div>
          <span class="eb-id__railfoot">Une seule lettre &middot; deux encres &middot; tout le fonds</span>
        </aside>
        <div class="eb-id__main">
          <div class="eb-id__covs">
            {blanche.map((c) => (
              <div class="eb-id__cov eb-id__cov--b">
                <div class="eb-id__face" lang="fr">
                  <span class="eb-id__author">{c.author}</span>
                  <span class="eb-id__cti">{c.title}</span>
                  <span class="eb-id__genre">{c.genre}</span>
                  <svg class="eb-id__oval" viewBox="0 0 84 46" aria-hidden="true"><ellipse cx="42" cy="23" rx="40" ry="21" fill="none" stroke="currentColor" stroke-width="1.1"/><text x="42" y="30" text-anchor="middle">&eacute;dc</text></svg>
                  <span class="eb-id__pfoot">&Eacute;DITIONS DU CADRAN</span>
                </div>
              </div>
            ))}
            {noire.map((c) => (
              <div class="eb-id__cov eb-id__cov--n">
                <div class="eb-id__face" lang="fr">
                  <span class="eb-id__author">{c.author}</span>
                  <span class="eb-id__cti">{c.title}</span>
                  <span class="eb-id__genre">{c.genre}</span>
                  <svg class="eb-id__oval" viewBox="0 0 84 46" aria-hidden="true"><ellipse cx="42" cy="23" rx="40" ry="21" fill="none" stroke="currentColor" stroke-width="1.1"/><text x="42" y="30" text-anchor="middle">&eacute;dc</text></svg>
                  <span class="eb-id__pfoot">S&Eacute;RIE NOCTURNE</span>
                </div>
              </div>
            ))}
          </div>
          <div class="eb-id__spines" aria-hidden="true">
            <span class="eb-id__spine eb-id__spine--b"><b>412</b><i>LA LISI&Egrave;RE</i><span>H&Eacute;L&Egrave;NE VASSEUR</span><em>&eacute;dc</em></span>
            <span class="eb-id__spine eb-id__spine--n"><b>87</b><i>LA NUIT TOMBE DEUX FOIS</i><span>JEAN SERVAT</span><em>&eacute;dc</em></span>
          </div>
          <!-- the fourth artifact: the press's own catalogue ad, same grid,
               same five rules — proof the identity is the rules -->
          <div class="eb-id__ad eb-id__ad--b" lang="fr">
            <span class="eb-id__adover">VIENT DE PARA&Icirc;TRE</span>
            <span class="eb-id__adauthor">H&Eacute;L&Egrave;NE VASSEUR</span>
            <span class="eb-id__adtitle">LA LISI&Egrave;RE</span>
            <span class="eb-id__adgenre">roman &middot; n&ordm;&nbsp;412 de la collection</span>
            <span class="eb-id__adfoot">Le volume&nbsp;: 18&nbsp;fr. &mdash; en vente chez tous les libraires &mdash; 9,&nbsp;quai du Cadran, Paris&nbsp;VI<sup>e</sup></span>
          </div>
          <div class="eb-id__ad eb-id__ad--n" lang="fr">
            <span class="eb-id__adover">PARU CE JOUR</span>
            <span class="eb-id__adauthor">JEAN SERVAT</span>
            <span class="eb-id__adtitle">LA NUIT TOMBE DEUX FOIS</span>
            <span class="eb-id__adgenre">roman noir &middot; n&ordm;&nbsp;87 de la s&eacute;rie</span>
            <span class="eb-id__adfoot">Le volume&nbsp;: 350&nbsp;fr. &mdash; en vente chez tous les libraires &mdash; 9,&nbsp;quai du Cadran, Paris&nbsp;VI<sup>e</sup></span>
          </div>
          <p class="eb-id__colo" lang="fr">Achev&eacute; d&rsquo;imprimer en juin 2026 sur les presses du Cadran — couverture ivoire 240&nbsp;g, deux encres, caract&egrave;res de Garamont &amp; de Granjon.</p>
        </div>
      </div>
    </div>
    <p class="iu__hint label">After the white cover of the nrf — Gallimard&rsquo;s Collection Blanche (1911), two fillets and two inks around one Garalde — and its shadow, the S&eacute;rie Noire of 1945. The same five rules dress every artifact the house prints: three covers, a spine, and the morning&rsquo;s catalogue ad. Flip to the crime list and watch the press re-ink them in order — the grid turns black and the titles take weight 800, the bold Octavio Pardo drew for this revival in 2011. The identity is the rules, not the logo; the letter survives its own negative.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       04 · WEB & APP UI — Octavo, a reading room. Real px, user-driven.
       Reference: the Standard Ebooks current (the volunteer press that
       holds public-domain ebooks to fine-typography standards) and the
       reader-mode lineage of Instapaper / iA. Every control is live on
       the text and every claim is in the file: liga, the tabular ↔
       proportional figure toggle (default tabular; pnum → .lf), frac in
       the proof, wght 400–800 graded for night — and the ink slider
       grades the headline live, its value set large in the page margin.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item" data-shoot-click="[data-th='night']">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Product UI — Octavo, a reading room (real scale, interactive)</span></figcaption>
    <div class="iu__scene">
      <div class="iu__device eb-rd" data-rd data-theme="day">
        <div class="iu__chrome">
          <div class="iu__dots"><i></i><i></i><i></i></div>
          <span class="iu__addr">octavo.press/essays/montaigne/foreword</span>
        </div>
        <div class="eb-rd__split">
          <aside class="eb-rd__rail">
            <span class="eb-rd__logo">Octavo</span>
            <span class="eb-rd__sub">A reading room for the public domain</span>
            <div class="eb-rd__group">
              <span class="eb-rd__lab">Body</span>
              <div class="eb-rd__seg" role="group" aria-label="Body size">
                <button type="button" data-size="15.5">S</button><button type="button" class="is-on" data-size="17">M</button><button type="button" data-size="19">L</button>
              </div>
            </div>
            <div class="eb-rd__group">
              <label class="eb-rd__lab" for="eb-rd-ink">Ink &middot; weight <b data-wout>430</b></label>
              <input id="eb-rd-ink" type="range" min="400" max="600" step="10" value="430" data-wght />
            </div>
            <div class="eb-rd__group eb-rd__group--fig">
              <span class="eb-rd__lab">Figures</span>
              <div class="eb-rd__seg eb-rd__seg--fig" role="group" aria-label="Figure spacing">
                <button type="button" class="is-on" data-fig="tab">Tabular&nbsp;<i>1841</i></button><button type="button" data-fig="prop">Proportional&nbsp;<i class="eb-rd__lf">1841</i></button>
              </div>
              <span class="eb-rd__figno">proportional closes up the 1s — watch the page count below</span>
            </div>
            <div class="eb-rd__group">
              <span class="eb-rd__lab">Ligatures</span>
              <div class="eb-rd__seg" role="group" aria-label="Ligatures">
                <button type="button" class="is-on" data-liga="1">On&nbsp;<i>ﬁ&nbsp;ﬄ</i></button><button type="button" data-liga="0">Off&nbsp;<i>f&#8288;i&nbsp;f&#8288;f&#8288;l</i></button>
              </div>
            </div>
            <div class="eb-rd__group">
              <span class="eb-rd__lab">Page</span>
              <div class="eb-rd__seg" role="group" aria-label="Page colour">
                <button type="button" class="is-on" data-th="day">Day</button><button type="button" data-th="sepia">Sepia</button><button type="button" data-th="night">Night</button>
              </div>
              <span class="eb-rd__grade" data-grade hidden>night grades the weight axis +60 — ink that glows, not bites</span>
            </div>
            <div class="eb-rd__proof">
              <span class="eb-rd__proofline" data-fx>first afflicted &middot; 1580 &middot; <span class="eb-rd__frac">1/2</span></span>
