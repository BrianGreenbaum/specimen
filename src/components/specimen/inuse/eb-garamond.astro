<script>
  // ── 01 · the reading glass ───────────────────────────────────────────────
  // The lens clones the rendered sheet (cloneNode keeps Astro's scoped-style
  // attribute — never innerHTML) and magnifies it 2.3×. It rests parked on
  // the Granjon italic line; the pointer picks it up, leaving sets it back.
  document.querySelectorAll<HTMLElement>('[data-sheet]').forEach((wrap) => {
    const art = wrap.querySelector<HTMLElement>('[data-sheet-art]')!;
    const lens = wrap.querySelector<HTMLElement>('[data-lens]')!;
    const clone = art.cloneNode(true) as HTMLElement;
    clone.setAttribute('aria-hidden', 'true');
    clone.classList.add('eb-lens__art');
    lens.appendChild(clone);
    const Z = 2.3;
    let R = 0, ax = 0, ay = 0;   // ax/ay: the art's offset inside the wrap
    let parked = true;
    const park = wrap.querySelector<HTMLElement>('[data-park]');
    const place = (x: number, y: number) => {
      const w = wrap.clientWidth, h = wrap.clientHeight;
      x = Math.max(R * 0.5, Math.min(w - R * 0.5, x));
      y = Math.max(R * 0.5, Math.min(h - R * 0.5, y));
      lens.style.transform = `translate(${(x - R).toFixed(1)}px, ${(y - R).toFixed(1)}px)`;
      clone.style.transform = `translate(${(R - (x - ax) * Z).toFixed(1)}px, ${(R - (y - ay) * Z).toFixed(1)}px) scale(${Z})`;
    };
    const toPark = () => {
      if (!park) return;
      const pr = park.getBoundingClientRect(), wr = wrap.getBoundingClientRect();
      place(pr.left - wr.left + Math.min(pr.width * 0.3, wrap.clientWidth * 0.3), pr.top - wr.top + pr.height / 2);
    };
    const measure = () => {
      R = lens.offsetWidth / 2;
      const ar = art.getBoundingClientRect(), wr = wrap.getBoundingClientRect();
      ax = ar.left - wr.left;
      ay = ar.top - wr.top;
      clone.style.width = `${art.clientWidth}px`;
      clone.style.maxWidth = 'none';
      if (parked) toPark();
    };
    new ResizeObserver(measure).observe(wrap);
    document.fonts?.ready.then(measure);
    measure();
    wrap.addEventListener('pointermove', (e) => {
      parked = false;
      lens.classList.add('is-live');
      const r = wrap.getBoundingClientRect();
      place(e.clientX - r.left, e.clientY - r.top);
    });
    wrap.addEventListener('pointerleave', () => {
      parked = true;
      lens.classList.remove('is-live');
      toPark();
    });
  });

  // ── 02 · apparatus ↔ text crosslight ─────────────────────────────────────
  // Note 1 is pre-lit when the spread scrolls into view (static under
  // reduced motion — the transition is simply off), so the crosslight is
  // discoverable at rest; the first touch hands the light to the reader.
  document.querySelectorAll<HTMLElement>('[data-ple]').forEach((book) => {
    let touched = false;
    const light = (id: string | undefined, on: boolean) => {
      if (!id) return;
      book.querySelectorAll<HTMLElement>(`[data-note='${id}'], [data-pass='${id}'], [data-cue='${id}']`)
        .forEach((el) => el.classList.toggle('is-lit', on));
    };
    const clear = () => book.querySelectorAll('.is-lit').forEach((el) => el.classList.remove('is-lit'));
    book.querySelectorAll<HTMLElement>('[data-note], [data-cue]').forEach((el) => {
      const id = el.dataset.note || el.dataset.cue;
      el.addEventListener('pointerenter', () => { touched = true; clear(); light(id, true); });
      el.addEventListener('pointerleave', () => light(id, false));
      el.addEventListener('focus', () => { touched = true; clear(); light(id, true); });
      el.addEventListener('blur', () => light(id, false));
      // tap/click pins the pair (touch has no hover; also the shoot evidence)
      el.addEventListener('click', () => { touched = true; clear(); light(id, true); });
    });
    const io = new IntersectionObserver((entries) => {
      entries.forEach((en) => {
        if (en.isIntersecting && !touched) { light('n1', true); io.disconnect(); }
      });
    }, { threshold: 0.45 });
    io.observe(book);
  });

  // ── 03 · the house flips collection — and visibly re-inks ────────────────
  // Covers, ad, spine and rules re-enter staggered ~80ms apart (the press
  // re-inking the formes); the animation lives behind a no-preference media
  // query, so under reduced motion the flip simply snaps.
  document.querySelectorAll<HTMLElement>('[data-id]').forEach((id) => {
    const btns = Array.from(id.querySelectorAll<HTMLButtonElement>('button[data-coll]'));
    btns.forEach((b) => b.addEventListener('click', () => {
      if (id.dataset.coll === b.dataset.coll) return;
      id.dataset.coll = b.dataset.coll;
      btns.forEach((x) => {
        x.classList.toggle('is-on', x === b);
        x.setAttribute('aria-pressed', String(x === b));
      });
      id.classList.remove('is-reink');
      void id.offsetWidth; // restart the stagger
      id.classList.add('is-reink');
    }));
  });

  // ── 04 · Octavo: every control live on the column ────────────────────────
  // Honest features only: liga (real), pnum → the .lf PROPORTIONAL-lining
  // alternates (default figures are tabular lining in this build — so the
  // toggle is Tabular ↔ Proportional, shown where spacing shows), and
  // wght 400–800 (real axis). Night adds +60 grade. The ink slider also
  // grades the headline (+120) and writes its value large in the margin.
  document.querySelectorAll<HTMLElement>('[data-rd]').forEach((rd) => {
    const fx = Array.from(rd.querySelectorAll<HTMLElement>('[data-fx]'));
    const wout = rd.querySelector<HTMLElement>('[data-wout]')!;
    const grade = rd.querySelector<HTMLElement>('[data-grade]')!;
    const inkmark = rd.querySelector<HTMLElement>('[data-inkmark]')!;
    const head = rd.querySelector<HTMLElement>('.eb-rd__head')!;
    const state = { size: 17, wght: 430, prop: false, liga: true, theme: 'day' };
    const page = rd.querySelector<HTMLElement>('.eb-rd__page')!;
    const apply = () => {
      const w = state.wght + (state.theme === 'night' ? 60 : 0);
      fx.forEach((el) => {
        el.style.fontFeatureSettings = `'liga' ${state.liga ? 1 : 0}, 'pnum' ${state.prop ? 1 : 0}`;
        el.style.fontWeight = String(w);
      });
      page.style.fontSize = `${state.size}px`;
      head.style.fontWeight = String(Math.min(800, w + 120));
      inkmark.textContent = String(w);
      inkmark.style.fontWeight = String(w);
      rd.dataset.theme = state.theme;
      wout.textContent = String(w);
      grade.hidden = state.theme !== 'night';
    };
    const seg = (sel: string, fn: (b: HTMLButtonElement) => void) => {
      const btns = Array.from(rd.querySelectorAll<HTMLButtonElement>(sel));
      btns.forEach((b) => b.addEventListener('click', () => {
        btns.forEach((x) => x.classList.toggle('is-on', x === b));
        fn(b);
        apply();
      }));
    };
    seg('[data-size]', (b) => { state.size = parseFloat(b.dataset.size!); });
    seg('[data-fig]', (b) => { state.prop = b.dataset.fig === 'prop'; });
    seg('[data-liga]', (b) => { state.liga = b.dataset.liga === '1'; });
    seg('[data-th]', (b) => { state.theme = b.dataset.th!; });
    rd.querySelector<HTMLInputElement>('[data-wght]')!.addEventListener('input', (e) => {
      state.wght = parseInt((e.target as HTMLInputElement).value, 10);
      apply();
    });
    apply();
  });

  // ── 05 · the ampersand breathes; the footer keeps the score ──────────────
  // JS drives the weight axis so the meta line can read it back live
  // ('wght 412 …') — the poster's argument made explicit. Runs only while
  // the act is in view; under reduced motion the amp holds 640 and the
  // readout states the range as static text.
  document.querySelectorAll<HTMLElement>('.eb-po').forEach((po) => {
    const amp = po.querySelector<HTMLElement>('[data-amp]');
    const axis = po.querySelector<HTMLElement>('[data-axis]');
    if (!amp || !axis) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    let raf = 0;
    const PERIOD = 17000; // 8.5s up, 8.5s down
    const tick = (t: number) => {
      const w = Math.round(600 - 200 * Math.cos((2 * Math.PI * t) / PERIOD));
      amp.style.fontVariationSettings = `'wght' ${w}`;
      axis.textContent = `wght ${w}`;
      raf = requestAnimationFrame(tick);
    };
    new IntersectionObserver((entries) => {
      entries.forEach((en) => {
        if (en.isIntersecting && !raf) raf = requestAnimationFrame(tick);
        else if (!en.isIntersecting && raf) { cancelAnimationFrame(raf); raf = 0; }
      });
    }, { threshold: 0.1 }).observe(po);
  });
</script>

<style>
