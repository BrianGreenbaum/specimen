---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;
---
<div class="iu" style={`--fam:${fam}`}>

  <!-- ============================================================
       01 — INTERACTIVE & EXPERIMENTAL
       Baskerville's 1757 Virgil title page, wiped between ink and light.
       Reference: the quarto Virgil, Birmingham 1757 (letterspaced caps,
       centred axis, the page that made his name).
       ============================================================ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Interactive &mdash; the 1757 Virgil title page, dragged between ink and light</span></figcaption>
    <div class="iu__scene">
      <div class="wipe" data-wipe style="--x:62">
        <div class="wipe__layer wipe__ink">
          <div class="tp">
            <p class="tp__l tp__l--xl">PUBLII VIRGILII</p>
            <p class="tp__l tp__l--lg">MARONIS</p>
            <p class="tp__l tp__l--md">BUCOLICA,</p>
            <p class="tp__l tp__l--md">GEORGICA,</p>
            <p class="tp__l tp__l--sm">ET</p>
            <p class="tp__l tp__l--md">AENEIS.</p>
            <span class="tp__rule" aria-hidden="true"></span>
            <p class="tp__imp">BIRMINGHAMIAE:</p>
            <p class="tp__typis">Typis <span class="tp__jb">JOHANNIS BASKERVILLE</span>.</p>
            <p class="tp__date">MDCCLVII.</p>
          </div>
          <span class="wipe__tag">Ink on hot-pressed wove paper &middot; Birmingham, 1757</span>
        </div>
        <div class="wipe__layer wipe__light" aria-hidden="true">
          <div class="tp">
            <p class="tp__l tp__l--xl">PUBLII VIRGILII</p>
            <p class="tp__l tp__l--lg">MARONIS</p>
            <p class="tp__l tp__l--md">BUCOLICA,</p>
            <p class="tp__l tp__l--md">GEORGICA,</p>
            <p class="tp__l tp__l--sm">ET</p>
            <p class="tp__l tp__l--md">AENEIS.</p>
            <span class="tp__rule" aria-hidden="true"></span>
            <p class="tp__imp">BIRMINGHAMIAE:</p>
            <p class="tp__typis">Typis <span class="tp__jb">JOHANNIS BASKERVILLE</span>.</p>
            <p class="tp__date">MDCCLVII.</p>
          </div>
          <span class="wipe__tag">Light through glass &middot; the browser, 2012</span>
        </div>
        <div class="wipe__handle" data-handle role="slider" tabindex="0"
             aria-label="Wipe between the printed page and the screen rendering"
             aria-valuemin="0" aria-valuemax="100" aria-valuenow="62">
          <span class="wipe__grip" aria-hidden="true"><i>&#9664;</i><i>&#9654;</i></span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Drag the seam (or focus it and use the arrow keys). Same letters, two media &mdash; the whole reason this face exists.</p>
  </figure>

  <!-- ============================================================
       02 — ILLUSTRATION & COMMERCIAL
       Single-typeface cover series, after Fitzcarraldo Editions
       (Ray O'Meara's blue-and-white, type-only covers, est. 2014).
       Covers turn over to a jacket-copy back — the text face at
       its real job. The italic ampersand is the printer's mark at
       the foot of every cover, where Fitzcarraldo set their device.
       ============================================================ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click='[data-flip]'>
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Illustration &amp; commercial &mdash; a one-typeface cover series, after Fitzcarraldo Editions</span></figcaption>
    <div class="iu__scene">
      <div class="cvf">
        <p class="cvf__head">Quire &amp; Wick &middot; New for June</p>
        <div class="cvf__row">

          <div class="cvflip" data-flip role="button" tabindex="0" aria-pressed="false"
               aria-label="Turn over the cover of The Gloaming">
            <div class="cvflip__in">
              <div class="cv cv--blue cv--front">
                <p class="cv__title">The<br/>Gloaming</p>
                <p class="cv__kind">a novel</p>
                <p class="cv__author">Ottilie Merck</p>
                <span class="cv__amp" aria-hidden="true">&amp;</span>
                <p class="cv__pub">Quire &amp; Wick</p>
              </div>
              <div class="cv cv--blue cv--back" aria-hidden="true">
                <p class="cv__bktitle">The Gloaming</p>
                <p class="cv__bkcopy">In the last hour of light, the punch&shy;cutter&rsquo;s daughter walks the towpath out of Birmingham with her father&rsquo;s steel sewn into the hem of her coat. Ottilie Merck&rsquo;s first novel is a book about inheritance &mdash; what a craft weighs when you carry it, and what it costs to set it down. Its drama lives in the half-tones: dusk, doubt, and the long patience of work done well.</p>
                <p class="cv__bkquote">&ldquo;A debut of rare composure.&rdquo;<span>&mdash; The Harborlight Review of Books</span></p>
                <p class="cv__bkmeta">Fiction &middot; &pound;12.99 <span>978&ndash;1&ndash;913097&ndash;44&ndash;2</span></p>
                <span class="cv__amp" aria-hidden="true">&amp;</span>
              </div>
            </div>
          </div>

          <div class="cvflip" data-flip role="button" tabindex="0" aria-pressed="false"
               aria-label="Turn over the cover of On Reading at Night">
            <div class="cvflip__in">
              <div class="cv cv--white cv--front">
                <p class="cv__title cv__title--it">On<br/>Reading<br/>at Night</p>
                <p class="cv__kind">essays</p>
                <p class="cv__author">Daniel Ascher</p>
                <span class="cv__amp" aria-hidden="true">&amp;</span>
                <p class="cv__pub">Quire &amp; Wick</p>
              </div>
              <div class="cv cv--white cv--back" aria-hidden="true">
                <p class="cv__bktitle cv__bktitle--it">On Reading at Night</p>
                <p class="cv__bkcopy">Why do the same sentences read differently after dark? In eleven essays Daniel Ascher follows the lamp-lit hours &mdash; from Baskerville&rsquo;s workshop, where pages were pressed between heated plates, to the backlit page held at arm&rsquo;s length on the last bus home &mdash; and asks what the reading eye actually wants when the rest of the house has gone quiet.</p>
                <p class="cv__bkquote">&ldquo;Essays you finish slower on purpose.&rdquo;<span>&mdash; The Commonplace</span></p>
                <p class="cv__bkmeta">Essays &middot; &pound;11.99 <span>978&ndash;1&ndash;913097&ndash;45&ndash;9</span></p>
                <span class="cv__amp" aria-hidden="true">&amp;</span>
              </div>
            </div>
          </div>

          <div class="cvflip" data-flip role="button" tabindex="0" aria-pressed="false"
               aria-label="Turn over the cover of Wove and Laid">
            <div class="cvflip__in">
              <div class="cv cv--blue cv--front">
                <p class="cv__title">Wove<br/><em class="cv__ampbig">&amp;</em><br/>Laid</p>
                <p class="cv__kind">a novel</p>
                <p class="cv__author">Petra Hale</p>
                <span class="cv__amp" aria-hidden="true">&amp;</span>
                <p class="cv__pub">Quire &amp; Wick</p>
              </div>
              <div class="cv cv--blue cv--back" aria-hidden="true">
                <p class="cv__bktitle">Wove &amp; Laid</p>
                <p class="cv__bkcopy">Two paper mills, one river, and a wager that ruins both houses. Petra Hale&rsquo;s second novel turns the eighteenth-century paper trade into a story of rivalry and grain: the old laid sheets with their ladder of chain lines, and the new wove &mdash; smooth, seamless, modern &mdash; that John Baskerville demanded and the mills did not want to make.</p>
                <p class="cv__bkquote">&ldquo;Industrial history with the pulse of a duel.&rdquo;<span>&mdash; The Harborlight Review of Books</span></p>
                <p class="cv__bkmeta">Fiction &middot; &pound;12.99 <span>978&ndash;1&ndash;913097&ndash;46&ndash;6</span></p>
                <span class="cv__amp" aria-hidden="true">&amp;</span>
              </div>
            </div>
          </div>

        </div>
        <p class="cvf__foot">novels in blue, set roman &middot; essays in white, set italic &middot; nothing on the cover but the house face</p>
      </div>
    </div>
    <p class="iu__hint label">Click a cover (or press Enter) to turn it over: jacket copy justified in the roman at fourteen pixels &mdash; the text face doing its real job. The italic ampersand is the device at every foot.</p>
  </figure>

  <!-- ============================================================
       03 — BRANDING & IDENTITY
       The press itself: wordmark, printer's device & spine system,
       in the colophon tradition of the Aldine anchor-and-dolphin —
       the device now a true roundel with the imprint set around it,
       a letterpress proof filling the upper field, and each spine
       tipping out to its front board (act 02's cover system).
       ============================================================ -->
  <figure class="iu__item" data-shoot-click='.qw__shelf > div:nth-child(3)'>
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Branding &mdash; the press identity: wordmark, device &amp; spines, in the Aldine colophon tradition</span></figcaption>
    <div class="iu__scene">
      <div class="qw">
        <div class="qw__id">
          <p class="qw__mark">Quire<br/><em class="qw__amp">&amp;</em><br/>Wick</p>
          <p class="qw__est">Independent publishers &middot; Birmingham &middot; est. MMXII</p>
          <span class="qw__device" aria-hidden="true">
            <svg viewBox="0 0 100 100">
              <defs><path id="qw-dev-ring" d="M 50,50 m -38,0 a 38,38 0 1,1 76,0 a 38,38 0 1,1 -76,0"/></defs>
              <text class="qw__devring"><textPath href="#qw-dev-ring" startOffset="0">QUIRE &amp; WICK &middot; BIRMINGHAM &middot; MMXII &middot;</textPath></text>
            </svg>
            <em>&amp;</em>
          </span>
          <p class="qw__colophon">All Quire &amp; Wick editions are set in <em>Libre Baskerville</em> &mdash; the 2012 re-cut of the letters John Baskerville perfected two streets from this office &mdash; and bound in eighty-gram cream wove.</p>
        </div>
        <div class="qw__shelfwrap">
          <div class="qw__proof" data-proof>
            <p class="qw__proofline qw__proofline--caps">ABCDEFGHIJKLMNOPQRSTUVWXYZ</p>
            <p class="qw__proofline">abcdefghijklmnopqrstuvwxyz 1234567890</p>
            <p class="qw__proofline qw__proofline--it">abcdefghijklmnopqrstuvwxyz &amp; fi ffi fl</p>
            <p class="qw__proofnote">House proof no. 4 &mdash; roman &amp; italic, pulled June MMXXVI</p>
          </div>
          <div class="qw__shelf">
            <div class="qw__book" tabindex="0" aria-label="The Gloaming — pull from the shelf">
              <div class="qw__bookin">
                <div class="qw__spine qw__spine--ink"><span class="qw__sa">Merck</span><span class="qw__st">The Gloaming</span><span class="qw__sm">Q&amp;W &middot; I</span></div>
                <div class="qw__board qw__board--blue" aria-hidden="true"><p class="qw__bt">The Gloaming</p><p class="qw__bk">a novel</p><p class="qw__ba">Ottilie Merck</p><span class="qw__bamp">&amp;</span></div>
              </div>
            </div>
            <div class="qw__book" tabindex="0" aria-label="On Reading at Night — pull from the shelf">
              <div class="qw__bookin">
                <div class="qw__spine qw__spine--blue"><span class="qw__sa">Ascher</span><span class="qw__st"><em>On Reading at Night</em></span><span class="qw__sm">Q&amp;W &middot; II</span></div>
                <div class="qw__board qw__board--white" aria-hidden="true"><p class="qw__bt qw__bt--it">On Reading at Night</p><p class="qw__bk">essays</p><p class="qw__ba">Daniel Ascher</p><span class="qw__bamp">&amp;</span></div>
              </div>
            </div>
            <div class="qw__book" tabindex="0" aria-label="A Life in Eleven Letters — pull from the shelf">
              <div class="qw__bookin">
                <div class="qw__spine qw__spine--madder"><span class="qw__sa">Voss</span><span class="qw__st"><em>A Life in Eleven Letters</em></span><span class="qw__sm">Q&amp;W &middot; III</span></div>
                <div class="qw__board qw__board--madder" aria-hidden="true"><p class="qw__bt qw__bt--it">A Life in Eleven Letters</p><p class="qw__bk">a biography</p><p class="qw__ba">Eleanor Voss</p><span class="qw__bamp">&amp;</span></div>
              </div>
            </div>
            <div class="qw__book" tabindex="0" aria-label="The Quiet Letter — pull from the shelf">
              <div class="qw__bookin">
                <div class="qw__spine qw__spine--paper"><span class="qw__sa">Ashford</span><span class="qw__st"><em>The Quiet Letter</em></span><span class="qw__sm">Q&amp;W &middot; IV</span></div>
                <div class="qw__board qw__board--paper" aria-hidden="true"><p class="qw__bt qw__bt--it">The Quiet Letter</p><p class="qw__bk">essays</p><p class="qw__ba">Margaret Ashford</p><span class="qw__bamp">&amp;</span></div>
              </div>
            </div>
            <div class="qw__book qw__book--opt" tabindex="0" aria-label="Wove and Laid — pull from the shelf">
              <div class="qw__bookin">
                <div class="qw__spine qw__spine--sage"><span class="qw__sa">Hale</span><span class="qw__st">Wove &amp; Laid</span><span class="qw__sm">Q&amp;W &middot; V</span></div>
                <div class="qw__board qw__board--blue" aria-hidden="true"><p class="qw__bt">Wove &amp; Laid</p><p class="qw__bk">a novel</p><p class="qw__ba">Petra Hale</p><span class="qw__bamp">&amp;</span></div>
              </div>
            </div>
            <div class="qw__book qw__book--opt" tabindex="0" aria-label="The Reading Room — pull from the shelf">
              <div class="qw__bookin">
                <div class="qw__spine qw__spine--slate"><span class="qw__sa">Imrie</span><span class="qw__st"><em>The Reading Room</em></span><span class="qw__sm">Q&amp;W &middot; VI</span></div>
                <div class="qw__board qw__board--slate" aria-hidden="true"><p class="qw__bt qw__bt--it">The Reading Room</p><p class="qw__bk">a memoir</p><p class="qw__ba">Janet Imrie</p><span class="qw__bamp">&amp;</span></div>
              </div>
            </div>
          </div>
          <span class="qw__shelfline" aria-hidden="true"></span>
          <p class="qw__series">The collected list, spines only &mdash; roman for the novels, italic for the lives &amp; essays. The identity is the typesetting, not a logo.</p>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Ease a book from the shelf (hover, tab or tap): it tips out to show its front board, set in the same cover system. One face, two weights, one italic &mdash; a complete identity.</p>
  </figure>

  <!-- ============================================================
       04 — EDITORIAL
       A review-paper front page in the manner of The New York Review
       of Books: citation block, three columns, drop cap, spanning pull,
       and the Levine-caricature slot rebuilt as pure type. The
       double-rule masthead draws in as the page arrives — the
       designed handoff from the press (03) to its press coverage.
       ============================================================ -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Editorial &mdash; a review front page, in the manner of <em>The New York Review of Books</em></span></figcaption>
    <div class="iu__scene">
      <div class="rev">
        <header class="rev__mast" data-draw>
          <p class="rev__name">The Harborlight Review of Books</p>
          <p class="rev__meta"><span>Vol. XIV &middot; No. 11</span><span>June 11, 2026</span><span>Eight dollars</span></p>
        </header>
        <h3 class="rev__head">The Perfectionist of Birmingham</h3>
        <p class="rev__by">Margaret Ashford</p>
        <div class="rev__cite">
          <p><em>Baskerville: A Life in Eleven Letters</em></p>
          <p>by Eleanor Voss.</p>
          <p>Quire &amp; Wick, 312 pp., $28.00</p>
        </div>
        <div class="rev__cols">
          <p><span class="rev__drop">J</span>ohn Baskerville came to printing late and impatient. He had made one fortune teaching penmanship and another in japanned ware &mdash; trays and boxes lacquered to a hard black shine &mdash; and when he turned, past fifty, to the making of books, he brought a tradesman&rsquo;s conviction that everything about them could be done better.</p>
          <p>Voss&rsquo;s biography is best on the apparatus of that conviction. He would not accept the paper of his day, so he commissioned wove sheets without the ladder of chain lines and pressed each printed leaf between heated plates until it shone. He would not accept the ink, so he boiled his own. The letters he cut with John Handy were the point of it all: higher in contrast than Caslon&rsquo;s, rounder in the bowl, rational in their upright stress &mdash; an evenness London called showy and Paris called perfect.</p>
          <figure class="rev__fig">
            <span class="rev__figamp" aria-hidden="true">&amp;</span>
            <figcaption class="rev__figcap">John Baskerville, 1707&ndash;1775; a portrait in lieu of a drawing &mdash; the italic ampersand he cut with John Handy</figcaption>
          </figure>
          <p>The quarto <em>Virgil</em> of 1757 vindicated him by subscription, and the Cambridge folio Bible of 1763 nearly ruined him; he complained that the public would praise his books and buy somebody else&rsquo;s. He refused, to the end, the consolations of the church, and was buried upright in a conical vault in his own garden, a freethinker to the last degree of the compass.</p>
          <p>What Voss adds is the long afterlife. The punches passed to Beaumarchais, who used them to print the complete Voltaire at Kehl; the reputation passed into the name itself, which by the twentieth century simply meant <em>book</em>. Her closing chapter lands in 2012, in Rosario, Argentina, where two designers raise the x-height, open the counters, and ease the hairlines of the 1941 American cut so that Baskerville&rsquo;s letters can survive a medium he never imagined: a page made of light, sixteen pixels tall.</p>
          <p>It is a sympathetic portrait, but not a soft one. The man who emerges is vain, generous, litigious, and right &mdash; right about paper, right about ink, and right that clarity, pursued ruthlessly enough, becomes a kind of beauty. <span class="rev__end" aria-hidden="true">&amp;</span></p>
        </div>
        <blockquote class="rev__pull" data-draw><span class="rev__hq">&ldquo;</span>It will blind the nation,&rdquo; a rival swore of the sparkle; Franklin loved the type and carried it home. Both were answering the same letters &mdash; drawn for an age that had decided clarity was a virtue.</blockquote>
        <footer class="rev__foot">
          <span>Continued on page 14</span>
          <span>Margaret Ashford&rsquo;s <em>A Public Type</em> appears from Quire &amp; Wick next spring.</span>
        </footer>
      </div>
    </div>
    <p class="iu__hint label">A working review-page system: citation block, balanced columns, drop cap, the caricature slot set in pure type &mdash; and rules that draw themselves in as the page arrives.</p>
  </figure>

  <!-- ============================================================
       05 — WEB & APP UI
       A reader interface in the 2011–13 reader-mode current
       (Readability, Instapaper, early Medium) — the exact current
       Libre Baskerville was cut for. Real px, fully user-driven.
       ============================================================ -->
  <figure class="iu__item" data-shoot-click='[data-mode="night"]'>
    <figcaption class="iu__cap"><span class="index-num">05</span><span class="label">Web &amp; app UI &mdash; a reader in the lineage of Readability, Instapaper &amp; early Medium</span></figcaption>
    <div class="iu__scene">
      <div class="iu__device rdr" data-rdr>
        <div class="iu__chrome">
          <div class="iu__dots"><i></i><i></i><i></i></div>
          <span class="iu__addr">thecommonplace.org/the-comfort-of-a-screen-set-well</span>
        </div>

        <div class="rdr__bar">
          <span class="rdr__brand">The Commonplace</span>
          <div class="rdr__tools">
            <div class="rdr__size" role="group" aria-label="Text size">
              <button data-size="dn" aria-label="Smaller text">A</button>
              <span class="rdr__sizeval" data-sizeval>18&#8202;px</span>
              <button data-size="up" aria-label="Larger text" class="rdr__big">A</button>
            </div>
            <div class="rdr__modes" role="group" aria-label="Reading mode">
              <button data-mode="day" class="is-on" aria-pressed="true">Day</button>
              <button data-mode="sepia" aria-pressed="false">Sepia</button>
              <button data-mode="night" aria-pressed="false">Night</button>
            </div>
          </div>
        </div>

        <div class="rdr__progress" aria-hidden="true"><span class="rdr__progressfill" data-progress></span></div>

        <div class="rdr__scroll" data-scroll>
          <article class="rdr__article" data-article>
            <p class="rdr__kicker"><span class="rdr__kdot" aria-hidden="true"></span> An essay on reading</p>
            <h3 class="rdr__title">The comfort of a screen set well</h3>
            <p class="rdr__byline">by Margaret Ashford &middot; 11 min read &middot; June&#8201;2026</p>

            <p class="rdr__lede"><span class="rdr__drop">F</span>or most of its history the printed letter answered to ink and paper. A face was cut, a punch was struck, a matrix was justified, and a compositor set the line by hand. The whole apparatus existed to put marks on a sheet &mdash; and the letters that survived were the ones that printed cleanly, again and again, in that exact medium.</p>

            <p>The screen broke the contract. A backlit display flickers where paper holds still; it renders at a tenth of the resolution of fine printing; it throws light at the eye instead of reflecting it. A hairline serif that looked exquisite pressed into damp paper can simply vanish on a phone held at arm&rsquo;s length on a moving train.</p>

            <p>Libre Baskerville is what happens when a classic answers the new medium honestly. It keeps the bones of Baskerville&rsquo;s transitional roman &mdash; the upright stress, the bracketed serifs, the rational proportions that have signalled <em>the book</em> for two and a half centuries. But it quietly renegotiates every term that the screen would have broken.</p>

            <blockquote class="rdr__quote">A body face does its best work when you finish the paragraph without once having thought about the shapes that carried it there.</blockquote>

            <p>The x-height climbs, so more of every word lands in the band the eye actually scans. The counters open up, so an <em>e</em> or an <em>a</em> will not clog into a dark blot at sixteen pixels. The contrast eases back, so the thin strokes survive the glow instead of guttering out. None of it is showy. All of it is in service of the one thing a reading face is for: keeping you in the text.</p>

            <p>You can feel the result in the rhythm of a long passage. The line holds an even colour. The serifs lay a firm baseline that tugs the eye gently rightward and then returns it, cleanly, to the next line. There are no rivers, no flickering, no fatigue building behind the eyes after the third screen. This is typography as hospitality &mdash; the craft of making a reader feel, for a few thousand words, completely at home.</p>

            <p class="rdr__close">Drag the controls above and watch the column adapt: it was drawn to stay readable across every comfortable size and every light, because comfort, on a screen, is the entire point.</p>
          </article>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Resize the type, switch Day / Sepia / Night, scroll the column &mdash; the progress bar tracks you live. After the monument, the sixteen-pixel ending the story was building to.</p>
  </figure>

</div>

<script>
  // ---- 01 wipe: drag the seam between ink and light ----
  document.querySelectorAll<HTMLElement>('[data-wipe]').forEach((wipe) => {
    const handle = wipe.querySelector<HTMLElement>('[data-handle]')!;
    let x = 62;
    const set = (v: number) => {
      x = Math.max(4, Math.min(96, v));
      wipe.style.setProperty('--x', String(x));
      handle.setAttribute('aria-valuenow', String(Math.round(x)));
    };
    const fromEvent = (e: PointerEvent) => {
      const r = wipe.getBoundingClientRect();
      set(((e.clientX - r.left) / r.width) * 100);
    };
    let dragging = false;
    wipe.addEventListener('pointerdown', (e) => {
      dragging = true;
      wipe.setPointerCapture(e.pointerId);
      fromEvent(e);
    });
    wipe.addEventListener('pointermove', (e) => { if (dragging) fromEvent(e); });
    wipe.addEventListener('pointerup', () => { dragging = false; });
    wipe.addEventListener('pointercancel', () => { dragging = false; });
    handle.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') { set(x - 3); e.preventDefault(); }
      if (e.key === 'ArrowRight' || e.key === 'ArrowUp') { set(x + 3); e.preventDefault(); }
      if (e.key === 'Home') { set(4); e.preventDefault(); }
      if (e.key === 'End') { set(96); e.preventDefault(); }
    });
  });

  // ---- 02 covers: click/Enter turns the cover over ----
  document.querySelectorAll<HTMLElement>('[data-flip]').forEach((flip) => {
    const toggle = () => {
      flip.classList.toggle('is-flipped');
      flip.setAttribute('aria-pressed', flip.classList.contains('is-flipped') ? 'true' : 'false');
    };
    flip.addEventListener('click', toggle);
    flip.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }
    });
  });

  // ---- 03 shelf: click/tap also tips a book out (touch parity with hover) ----
  document.querySelectorAll<HTMLElement>('.qw__book').forEach((book) => {
    book.addEventListener('click', () => book.classList.toggle('is-out'));
  });

  // ---- 04 review: rules draw in as the page arrives ----
  const drawn = document.querySelectorAll<HTMLElement>('[data-draw]');
  if (drawn.length) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-in');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.35 });
    drawn.forEach((el) => io.observe(el));
  }

  // ---- 05 reader: size, mode, live scroll progress ----
  document.querySelectorAll<HTMLElement>('[data-rdr]').forEach((rdr) => {
    const article = rdr.querySelector<HTMLElement>('[data-article]')!;
    const sizeval = rdr.querySelector<HTMLElement>('[data-sizeval]')!;
    const scroll = rdr.querySelector<HTMLElement>('[data-scroll]')!;
    const progress = rdr.querySelector<HTMLElement>('[data-progress]')!;

    let size = 18;
    const SIZES = [15, 16, 17, 18, 20, 22, 24];
    const applySize = () => {
      article.style.fontSize = size + 'px';
      sizeval.textContent = size + ' px';
    };

    rdr.querySelectorAll<HTMLButtonElement>('[data-size]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const i = SIZES.indexOf(size);
        if (btn.dataset.size === 'up') size = SIZES[Math.min(i + 1, SIZES.length - 1)];
        else size = SIZES[Math.max(i - 1, 0)];
        applySize();
        updateProgress();
      });
    });

    const modes: Record<string, [string, string, string, string]> = {
      day:   ['var(--bg)', 'var(--fg)', 'var(--fg-3)', 'var(--accent)'],
      sepia: ['#f4ecd8', '#3a2f22', '#8a7b60', '#9a5b2c'],
      night: ['#16181d', '#d7d3ca', '#8c8a85', '#c9b48a'],
    };
    const applyMode = (mode: string) => {
      const [bg, fg, mut, acc] = modes[mode];
      scroll.style.background = bg;
      article.style.setProperty('--rb', bg);
      article.style.setProperty('--rf', fg);
      article.style.setProperty('--rm', mut);
      article.style.setProperty('--ra', acc);
    };
    rdr.querySelectorAll<HTMLButtonElement>('[data-mode]').forEach((btn) => {
      btn.addEventListener('click', () => {
        rdr.querySelectorAll<HTMLButtonElement>('[data-mode]').forEach((b) => {
          b.classList.remove('is-on'); b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('is-on'); btn.setAttribute('aria-pressed', 'true');
        applyMode(btn.dataset.mode!);
      });
    });

    const updateProgress = () => {
      const max = scroll.scrollHeight - scroll.clientHeight;
      const pct = max > 0 ? (scroll.scrollTop / max) * 100 : 0;
      progress.style.width = Math.max(0, Math.min(100, pct)) + '%';
    };
    scroll.addEventListener('scroll', updateProgress, { passive: true });

    applySize();
    applyMode('day');
    updateProgress();
  });
</script>

<style>
  /* ---- sequence pacing: a slightly tighter stack; the choreography is
     night → deep blue → paper → page → device, monument scale → 16 px ---- */
  .iu { gap: clamp(3.25rem, 8vh, 5.5rem); }
  .iu__item { margin: 0; }
  .iu__hint { margin-top: var(--sp-2); color: var(--fg-3); }
  .iu__scene * { font-family: var(--fam); }
  .iu__scene ::selection { background: var(--accent); color: var(--accent-contrast); }

  /* shared print palette (acts 01 ink-side & 03 share the same paper) */
  .iu {
    --paper: #ede4d0;
    --paper-2: #e4d9c0;
    --ink: #241d12;
    --klein: #0a3ab8;
    --navy: #04205f;
    --madder: #93392c;
    --sage: #5b6b51;
  }

  /* ============================================================
     01 — INK / LIGHT WIPE (bleed, cqi, drag-driven)
     ============================================================ */
  .wipe {
    position: relative;
    height: clamp(480px, 46cqi, 700px);
    cursor: ew-resize;
    touch-action: pan-y;
    user-select: none;
  }
  .wipe__layer {
    position: absolute; inset: 0;
    display: grid; place-items: center;
  }
  .wipe__ink {
    background:
      repeating-linear-gradient(0deg, rgba(36, 29, 18, 0.035) 0 1px, transparent 1px 7px),
      var(--paper);
    color: var(--ink);
  }
  .wipe__light {
    background:
      repeating-linear-gradient(0deg, rgba(232, 223, 200, 0.045) 0 1px, transparent 1px 16px),
      repeating-linear-gradient(90deg, rgba(232, 223, 200, 0.045) 0 1px, transparent 1px 16px),
      #0e1015;
    color: #ecdfc0;
    clip-path: inset(0 0 0 calc(var(--x, 62) * 1%));
  }
  .wipe__light .tp { text-shadow: 0 0 18px rgba(236, 223, 192, 0.32); }
  .wipe__light .tp__rule { background: #ecdfc0; box-shadow: 0 0 10px rgba(236, 223, 192, 0.5); }

  .tp { text-align: center; line-height: 1; padding: 0 6cqi; }
  .tp p { margin: 0; }
  .tp__l { font-weight: 400; }
  /* padding-left equal to tracking re-centres each letterspaced line optically */
  .tp__l--xl { font-size: clamp(30px, 6cqi, 84px); letter-spacing: 0.14em; padding-left: 0.14em; margin-bottom: 0.32em; }
  .tp__l--lg { font-size: clamp(22px, 4.2cqi, 60px); letter-spacing: 0.2em;  padding-left: 0.2em;  margin-bottom: 0.55em; }
  .tp__l--md { font-size: clamp(15px, 2.6cqi, 37px); letter-spacing: 0.24em; padding-left: 0.24em; margin-bottom: 0.5em; }
  .tp__l--sm { font-size: clamp(11px, 1.7cqi, 24px); letter-spacing: 0.3em;  padding-left: 0.3em;  margin-bottom: 0.55em; }
  .tp__rule {
    display: block; width: clamp(90px, 14cqi, 220px); height: 1px;
    background: currentColor; margin: 1.4em auto 1.5em; opacity: 0.85;
  }
  .tp__imp { font-size: clamp(12px, 1.9cqi, 26px); letter-spacing: 0.26em; padding-left: 0.26em; margin-bottom: 0.7em !important; }
  .tp__typis { font-style: italic; font-size: clamp(12px, 1.9cqi, 26px); letter-spacing: 0.02em; margin-bottom: 0.85em !important; }
  .tp__jb { font-style: normal; font-size: 0.86em; letter-spacing: 0.18em; }
  .tp__date { font-size: clamp(11px, 1.6cqi, 22px); letter-spacing: 0.3em; padding-left: 0.3em; }

  .wipe__tag {
    position: absolute; bottom: clamp(0.9rem, 2cqi, 1.6rem);
    font-family: var(--font-mono); font-size: clamp(9px, 1cqi, 11.5px);
    letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.62;
    white-space: nowrap;
  }
  .wipe__ink .wipe__tag { left: clamp(1rem, 3cqi, 2.5rem); }
  .wipe__light .wipe__tag { right: clamp(1rem, 3cqi, 2.5rem); }

  .wipe__handle {
    position: absolute; top: 0; bottom: 0;
    left: calc(var(--x, 62) * 1%);
    width: 1px; background: rgba(120, 105, 80, 0.55);
    cursor: ew-resize;
  }
  .wipe__handle:focus-visible { outline: none; }
  .wipe__handle:focus-visible .wipe__grip { box-shadow: 0 0 0 3px rgba(44, 74, 107, 0.55); }
  .wipe__grip {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--ink); color: var(--paper);
    display: flex; align-items: center; justify-content: center; gap: 3px;
    font-size: 9px; font-style: normal;
  }
  .wipe__grip i { font-style: normal; line-height: 1; }

  /* ============================================================
     02 — COVER SERIES (bleed, Klein-blue field, cqi, flippable)
     ============================================================ */
  .cvf {
    background: var(--navy);
    padding: clamp(2.6rem, 6cqi, 5rem) 6cqi clamp(2.2rem, 5cqi, 4rem);
    display: flex; flex-direction: column; align-items: center;
  }
  .cvf__head, .cvf__foot {
    font-size: clamp(10.5px, 1.15cqi, 14px); letter-spacing: 0.3em;
    text-transform: uppercase; color: rgba(237, 228, 208, 0.66); margin: 0;
    text-align: center; text-wrap: balance;
  }
  .cvf__row {
    display: flex; gap: clamp(1.4rem, 3.5cqi, 3.4rem);
    margin: clamp(2rem, 4.5cqi, 3.6rem) 0;
    align-items: stretch;
  }
  .cvflip {
    perspective: 1500px;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .cvflip:focus-visible { outline: 2px solid rgba(237, 228, 208, 0.7); outline-offset: 6px; }
  .cvflip__in {
    position: relative; height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.6s var(--ease, ease-out);
  }
  .cvflip.is-flipped .cvflip__in { transform: rotateY(180deg); }
  /* the single restrained motion besides the turn: the hover lift */
  .cvflip:hover .cvflip__in, .cvflip:focus-visible .cvflip__in { translate: 0 -8px; }
  .cvflip.is-flipped:hover .cvflip__in, .cvflip.is-flipped:focus-visible .cvflip__in { translate: 0 -8px; }

  .cv {
    width: clamp(196px, 23cqi, 312px); aspect-ratio: 5 / 8;
    padding: 9% 8% 7%;
    display: flex; flex-direction: column; align-items: center; text-align: center;
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.45), 0 2px 6px rgba(0, 0, 0, 0.35);
    backface-visibility: hidden;
  }
  .cv--back {
    position: absolute; inset: 0; width: 100%;
    transform: rotateY(180deg);
    padding: 8% 8% 7%;
  }
  .cv--blue { background: var(--klein); color: #f3eee1; }
  .cv--white { background: #f3eee1; color: var(--klein); }
  .cv p { margin: 0; }
  .cv__title {
    font-size: clamp(28px, 4.1cqi, 56px); line-height: 1.06; font-weight: 400;
    letter-spacing: 0.002em; margin-top: 5%;
  }
  .cv__title--it { font-style: italic; }
  .cv__ampbig {
    display: inline-block; font-style: italic; font-weight: 400;
    font-size: 2.3em; line-height: 0.92; padding: 0.04em 0;
  }
  .cv__kind { font-style: italic; font-size: clamp(13px, 1.4cqi, 18px); margin-top: 0.9em; opacity: 0.85; }
  .cv__author {
    font-size: clamp(11px, 1.15cqi, 15px); letter-spacing: 0.26em; text-transform: uppercase;
    margin-top: auto; padding-top: 1.5em;
  }
  /* the printer's mark — the italic ampersand at the foot of every cover,
     where Fitzcarraldo set their device */
  .cv__amp {
    font-style: italic; font-size: clamp(17px, 1.9cqi, 25px); line-height: 1;
    margin-top: 0.9em; opacity: 0.92;
  }
  .cv--back .cv__amp { margin-top: 0.8em; }
  .cv__pub {
    font-size: clamp(9px, 0.95cqi, 12px); letter-spacing: 0.3em; text-transform: uppercase;
    margin-top: 0.9em; opacity: 0.7;
  }
  /* back of jacket: the text face at its real job — justified roman, 14px */
  .cv__bktitle {
    font-size: clamp(15px, 1.6cqi, 20px); font-weight: 400; letter-spacing: 0.01em;
    margin-top: 2%;
    padding-bottom: 0.8em; border-bottom: 1px solid currentColor; width: 100%;
  }
  .cv__bktitle--it { font-style: italic; }
  .cv__bkcopy {
    font-size: 14px; line-height: 1.55; text-align: justify; hyphens: auto;
    -webkit-hyphens: auto; margin-top: 1.1em !important;
  }
  .cv__bkquote {
    font-style: italic; font-size: clamp(12.5px, 1.3cqi, 15px); line-height: 1.4;
    margin-top: auto !important; padding-top: 1em;
  }
  .cv__bkquote span {
    display: block; font-style: normal; font-size: 0.78em;
    letter-spacing: 0.14em; text-transform: uppercase; margin-top: 0.7em; opacity: 0.75;
  }
  .cv__bkmeta {
    font-size: clamp(8.5px, 0.9cqi, 10.5px); letter-spacing: 0.18em; text-transform: uppercase;
    margin-top: 1.2em !important; opacity: 0.7;
  }
  .cv__bkmeta span { display: block; margin-top: 0.4em; white-space: nowrap; }

  /* ============================================================
     03 — PRESS IDENTITY (paper surface, system not logo)
     ============================================================ */
  .qw {
    background:
      repeating-linear-gradient(0deg, rgba(36, 29, 18, 0.03) 0 1px, transparent 1px 7px),
      var(--paper);
    color: var(--ink);
    display: grid; grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    gap: clamp(2rem, 5cqi, 4.5rem);
    padding: clamp(2.4rem, 5.5cqi, 4.5rem) clamp(1.6rem, 5cqi, 4.5rem);
    align-items: end;
  }
  .qw__id { display: flex; flex-direction: column; }
  .qw__mark {
    font-size: clamp(54px, 9cqi, 120px); line-height: 0.94; font-weight: 700;
    letter-spacing: -0.012em; margin: 0;
  }
  .qw__amp {
    font-style: italic; font-weight: 400; color: var(--madder);
    font-size: 0.82em; letter-spacing: 0;
  }
  .qw__est {
    font-size: clamp(10px, 1.15cqi, 13.5px); letter-spacing: 0.26em; text-transform: uppercase;
    color: rgba(36, 29, 18, 0.62); margin: 1.4em 0 0;
  }
  /* the device proper: the imprint set around the ampersand — an actual
     printer's mark in the Aldine colophon tradition */
  .qw__device {
    position: relative;
    width: clamp(92px, 10cqi, 132px); height: clamp(92px, 10cqi, 132px);
    display: grid; place-items: center;
    margin: clamp(1.4rem, 3cqi, 2.4rem) 0 0;
  }
  .qw__device svg { position: absolute; inset: 0; width: 100%; height: 100%; overflow: visible; }
  .qw__devring {
    font-size: 7.6px; letter-spacing: 1.4px; fill: var(--ink);
    font-weight: 400;
  }
  .qw__device em {
    font-style: italic; font-size: clamp(34px, 3.8cqi, 50px); color: var(--ink);
    line-height: 1; transform: translateY(-0.04em);
    width: 56%; aspect-ratio: 1; border: 1px solid var(--ink); border-radius: 50%;
    display: grid; place-items: center;
  }
  .qw__colophon {
    font-size: clamp(12.5px, 1.35cqi, 16px); line-height: 1.62; font-style: italic;
    color: rgba(36, 29, 18, 0.8); max-width: 34ch;
    margin: clamp(1.2rem, 2.6cqi, 2rem) 0 0;
  }
  .qw__colophon em { font-style: normal; }

  .qw__shelfwrap { min-width: 0; }
  /* the letterpress proof that fills the upper field at 1440 */
  .qw__proof {
    text-align: right; color: rgba(36, 29, 18, 0.55);
    padding-bottom: clamp(1.6rem, 4cqi, 3.2rem);
    border-bottom: 1px solid rgba(36, 29, 18, 0.18);
    margin-bottom: clamp(1.2rem, 2.6cqi, 2rem);
  }
  .qw__proofline { margin: 0 0 0.45em; white-space: nowrap; overflow: clip; }
  .qw__proofline--caps { font-size: clamp(14px, 1.75cqi, 23px); letter-spacing: 0.14em; }
  .qw__proofline:not(.qw__proofline--caps) { font-size: clamp(13px, 1.6cqi, 21px); letter-spacing: 0.06em; }
  .qw__proofline--it { font-style: italic; }
  .qw__proofnote {
    font-size: clamp(9.5px, 1cqi, 12px); letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(36, 29, 18, 0.5); margin: 1em 0 0;
  }

  .qw__shelf {
    display: flex; align-items: flex-end; justify-content: flex-end;
    gap: clamp(5px, 0.7cqi, 9px);
  }
  .qw__shelfline { display: block; height: 3px; background: var(--ink); margin-top: 0; }
  .qw__book {
    position: relative;
    perspective: 1100px;
    height: clamp(286px, 27cqi, 330px);
    cursor: default;
  }
  .qw__book:nth-child(2) { height: clamp(296px, 26cqi, 312px); }
  .qw__book:nth-child(3) { height: clamp(330px, 29cqi, 352px); }
  .qw__book:nth-child(4) { height: clamp(290px, 26.5cqi, 320px); }
  .qw__book:nth-child(5) { height: clamp(266px, 24.5cqi, 296px); }
  .qw__book:nth-child(6) { height: clamp(280px, 25cqi, 306px); }
  .qw__book:focus-visible { outline: none; }
  .qw__bookin {
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.45s var(--ease, ease-out);
  }
  /* the payoff: hover/tab/tap tips the book out to show its front board */
  .qw__book:hover { z-index: 6; }
  .qw__book:focus-visible { z-index: 6; }
  .qw__book.is-out { z-index: 6; }
  .qw__book:hover .qw__bookin,
  .qw__book:focus-visible .qw__bookin,
  .qw__book.is-out .qw__bookin { transform: translateY(-14px) rotateY(-42deg); }

  .qw__spine {
    writing-mode: vertical-rl;
    display: flex; align-items: center; gap: 0.9em;
    padding: 1.1em 0;
    width: clamp(40px, 4.6cqi, 60px);
    height: 100%;
    white-space: nowrap; overflow: clip;
  }
  .qw__spine--ink    { background: var(--ink);   color: var(--paper); }
  .qw__spine--blue   { background: var(--klein); color: #f3eee1; }
  .qw__spine--madder { background: var(--madder); color: var(--paper); }
  .qw__spine--paper  { background: var(--paper-2); color: var(--ink); box-shadow: inset 0 0 0 1px rgba(36,29,18,0.35); }
  .qw__spine--sage   { background: var(--sage);  color: var(--paper); }
  .qw__spine--slate  { background: #2c4a6b;      color: var(--paper); }
  .qw__sa { font-size: clamp(9px, 0.95cqi, 11px); letter-spacing: 0.2em; text-transform: uppercase; }
  .qw__st { font-size: clamp(11.5px, 1.25cqi, 15px); letter-spacing: 0.01em; }
  .qw__st em { font-style: italic; }
  .qw__sm { font-size: clamp(8px, 0.85cqi, 9.5px); letter-spacing: 0.16em; margin-top: auto; opacity: 0.75; }

  /* the front board, hinged on the spine's fore-edge — act 02's cover system */
  .qw__board {
    position: absolute; top: 0; left: 100%; height: 100%;
    width: clamp(118px, 13cqi, 168px);
    transform-origin: left center;
    transform: rotateY(90deg);
    backface-visibility: hidden;
    display: flex; flex-direction: column; align-items: center; text-align: center;
    padding: 12% 9% 9%;
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.3);
  }
  .qw__board--blue   { background: var(--klein);  color: #f3eee1; }
  .qw__board--white  { background: #f3eee1;       color: var(--klein); }
  .qw__board--madder { background: var(--madder); color: var(--paper); }
  .qw__board--paper  { background: var(--paper-2); color: var(--ink); box-shadow: inset 0 0 0 1px rgba(36,29,18,0.35), 0 14px 30px rgba(0,0,0,0.3); }
  .qw__board--slate  { background: #2c4a6b;       color: var(--paper); }
  .qw__board p { margin: 0; }
  .qw__bt { font-size: clamp(14px, 1.5cqi, 19px); line-height: 1.15; font-weight: 400; }
  .qw__bt--it { font-style: italic; }
  .qw__bk { font-style: italic; font-size: clamp(10px, 1.05cqi, 12.5px); margin-top: 0.8em !important; opacity: 0.85; }
  .qw__ba { font-size: clamp(8.5px, 0.9cqi, 10.5px); letter-spacing: 0.22em; text-transform: uppercase; margin-top: auto !important; }
  .qw__bamp { font-style: italic; font-size: clamp(13px, 1.4cqi, 17px); line-height: 1; margin-top: 0.8em; opacity: 0.9; }

  .qw__series {
    font-size: clamp(11px, 1.15cqi, 13.5px); font-style: italic; color: rgba(36, 29, 18, 0.6);
    text-align: right; margin: 0.9em 0 0;
  }

  /* ============================================================
     04 — REVIEW FRONT PAGE (theme tokens; NYRB system)
     ============================================================ */
  .rev {
    background: var(--bg); color: var(--fg);
    padding: clamp(1.8rem, 4.5cqi, 4rem) clamp(1.2rem, 5cqi, 4.5rem) clamp(1.6rem, 3.5cqi, 3rem);
    font-feature-settings: 'liga' 1, 'kern' 1;
  }
  /* the 03→04 handoff: the double-rule masthead draws itself in
     as the page arrives (reduced-motion: already drawn) */
  .rev__mast { position: relative; padding-bottom: 0.8em; }
  .rev__mast::after {
    content: ''; position: absolute; left: 0; right: 0; bottom: 0;
    border-bottom: 3px double var(--fg);
  }
  .rev__name {
    font-size: clamp(20px, 3.4cqi, 46px); font-weight: 700; letter-spacing: 0.02em;
    text-align: center; margin: 0; line-height: 1.1;
  }
  .rev__meta {
    display: flex; justify-content: space-between; gap: 1em;
    font-size: clamp(9.5px, 1cqi, 13px); letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--fg-3); margin: 1em 0 0;
  }
  .rev__head {
    font-size: clamp(26px, 4.6cqi, 62px); line-height: 1.04; font-weight: 700;
    letter-spacing: -0.012em; text-align: center;
    margin: clamp(1.4rem, 3cqi, 2.6rem) auto 0; max-width: 24ch;
  }
  .rev__by {
    font-size: clamp(13px, 1.5cqi, 19px); font-style: italic; text-align: center;
    color: var(--fg-2); margin: 0.7em 0 0;
  }
