---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;
// Serif text companion (loaded site-wide in Layout.astro).
const serif = "'Spectral', Georgia, serif";

// NOTE (verified against the woff2): Oswald variable carries ONE axis, wght 200–700,
// and the latin subset's OpenType is ccmp/frac/kern/liga/locl — no tnum, no onum,
// no italic. Every act below performs the weight axis and, where figures align,
// the columns are designed not to depend on tabular spacing.

// --- 02 · Tabloid editions (the replate cycle) ---------------------------
const editions = [
  {
    id: 'early', flag: 'EARLY EDITION', l1: 'STORM SHUTS', l2: 'THE HARBOR',
    deck: 'Gale tops fifty knots overnight — every berth empty by dawn, tugs riding it out in the channel',
    capt: 'Pier 9, 6:04 a.m. — the gantries locked down as the anemometer broke.',
  },
  {
    id: 'late', flag: 'LATE CITY', l1: 'HARBOR BACK —', l2: 'AT A PRICE',
    deck: 'Channel reopens at noon; pilots run the first convoy in, salvage bill put at $4 million',
    capt: 'Midday, the breakwater — the first container ship takes the channel.',
  },
  {
    id: 'final', flag: 'FINAL ★★★', l1: 'CRANE No. 9', l2: 'COMES DOWN',
    deck: 'Storm-cracked gantry demolished at dusk before a crowd of hundreds; port vows rebuild by spring',
    capt: 'Dusk: forty years of skyline folds into the basin in eleven seconds.',
  },
];
const ed0 = editions[0];

// --- 03 · Live match centre ----------------------------------------------
const matches = [
  {
    id: 'a', comp: 'Matchweek 34 · The Derby', venue: 'Empire Stadium', status: "78'", live: true,
    home: { name: 'CITY', sh: 'CIT', g: 2 },
    away: { name: 'UNITED', sh: 'UTD', g: 1 },
    stats: [
      ['Possession', 58, 42],
      ['Shots', 14, 9],
      ['On target', 6, 3],
      ['Corners', 7, 4],
      ['Fouls', 8, 13],
    ] as [string, number, number][],
    events: [
      ['12', 'GOAL', 'Okafor', 'home'],
      ['34', 'GOAL', 'Brennan', 'away'],
      ['52', 'YEL', 'Marsh', 'home'],
      ['61', 'GOAL', 'Da Costa', 'home'],
      ['68', 'SUB', 'Ferreira', 'home'],
      ['74', 'YEL', 'Adeyemi', 'away'],
      ['77', 'SUB', 'Kowalski', 'away'],
    ] as [string, string, string, string][],
  },
  {
    id: 'b', comp: 'Matchweek 34', venue: 'The Hollows', status: 'FT', live: false,
    home: { name: 'ROVERS', sh: 'ROV', g: 3 },
    away: { name: 'ALBION', sh: 'ALB', g: 3 },
    stats: [
      ['Possession', 44, 56],
      ['Shots', 11, 17],
      ['On target', 5, 7],
      ['Corners', 3, 9],
      ['Fouls', 12, 7],
    ] as [string, number, number][],
    events: [
      ['08', 'GOAL', 'Veld', 'away'],
      ['23', 'GOAL', 'Murphy', 'home'],
      ['41', 'YEL', 'Sankoh', 'away'],
      ['55', 'GOAL', 'Pittman', 'home'],
      ['67', 'GOAL', 'Reyes', 'away'],
      ['81', 'GOAL', 'Murphy', 'home'],
      ['90', 'GOAL', 'Veld', 'away'],
    ] as [string, string, string, string][],
  },
  {
    id: 'c', comp: 'Cup · Quarter-final', venue: 'Cathedral Road', status: "23'", live: true,
    home: { name: 'ATHLETIC', sh: 'ATH', g: 0 },
    away: { name: 'WANDERERS', sh: 'WDR', g: 1 },
    stats: [
      ['Possession', 51, 49],
      ['Shots', 4, 6],
      ['On target', 1, 2],
      ['Corners', 2, 3],
      ['Fouls', 4, 5],
    ] as [string, number, number][],
    events: [
      ['09', 'YEL', 'Brandt', 'home'],
      ['19', 'GOAL', 'Essien', 'away'],
      ['21', 'YEL', 'Toure', 'home'],
    ] as [string, string, string, string][],
  },
];
const m0 = matches[0];

// --- 04 · Record sleeve --------------------------------------------------
const sideA = [
  ['Uptown Local', '6:42'],
  ['Ninth Avenue', '5:18'],
  ['Half Past Blue', '7:05'],
] as [string, string][];
const sideB = [
  ['The Turnstile', '4:56'],
  ['Della', '6:11'],
  ['Last Car Home', '8:24'],
] as [string, string][];
const spines = [
  { cat: 'CR-4125', artist: 'RAY FELTON TRIO', title: 'NIGHT WORK', w: 300 },
  { cat: 'CR-4126', artist: 'DELLA MAYES', title: 'CROSSTOWN', w: 500 },
  { cat: 'CR-4127', artist: 'CURTIS LANE QUARTET', title: 'UPTOWN LOCAL', now: true, w: 700 },
];
---
<div class="iu" style={`--fam:${fam}; --serif:${serif}`}>

  <!-- ============ 01 — ILLUSTRATION & COMMERCIAL ============ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap">
      <span class="index-num">01</span>
      <span class="label">Illustration &amp; commercial — a day-glo show card, after the boxing and soul-revue posters of Globe Poster Printing Corp., Baltimore (est. 1929)</span>
    </figcaption>
    <div class="iu__scene">
      <div class="gp" data-gp>
        <div class="gp__wing gp__wing--l" aria-hidden="true"><span>SHOW PRINT</span><span>DAY-GLO</span></div>
        <div class="gp__sheet">
          <p class="gp__venue">ROYAL THEATRE <i>·</i> 1329 PENNSYLVANIA AVE. <i>·</i> BALTIMORE</p>
          <p class="gp__strap">IN PERSON · ONE NITE ONLY · FRI. <b>AUG. 14</b> · TWO SHOWS</p>
          <div class="gp__main">
            <p class="gp__the">THE</p>
            <p class="gp__big gp__big--1" data-gp-fit>SOUL</p>
            <p class="gp__big gp__big--2" data-gp-fit>CYCLONE</p>
            <p class="gp__revue"><span class="gp__star" aria-hidden="true">★</span>REVUE<span class="gp__star" aria-hidden="true">★</span></p>
          </div>
          <div class="gp__panel">
            <p class="gp__head-act" data-gp-fit>LITTLE EDDIE KING <span>&amp; THE CROWNS</span></p>
            <p class="gp__support">MISS DELLA MAYES · THE FAIRMOUNT FOUR · KING COLEMAN’S ORCH.</p>
          </div>
          <div class="gp__bar">
            <p class="gp__price">ADVANCE <b>$2.50</b> — AT THE DOOR <b>$3.00</b></p>
            <p class="gp__doors">DOORS 7:30</p>
          </div>
          <div class="gp__ticker" aria-hidden="true">
            <div class="gp__ticker-track">
              <span class="gp__ticker-run">TICKETS AT PANDORA RECORD SHOP · SHOWS 8:30 &amp; 11:00 · NO ADVANCE REFUNDS · BRING THIS BILL FOR 25¢ OFF · </span>
              <span class="gp__ticker-run">TICKETS AT PANDORA RECORD SHOP · SHOWS 8:30 &amp; 11:00 · NO ADVANCE REFUNDS · BRING THIS BILL FOR 25¢ OFF · </span>
            </div>
          </div>
          <p class="gp__imprint">CHESAPEAKE SHOW PRINT — BALTO. 1, MD. · POSTED BY PERMIT No. 114</p>
        </div>
        <div class="gp__wing gp__wing--r" aria-hidden="true"><span>ONE NITE</span><span>BALTO. MD.</span></div>
      </div>
    </div>
    <p class="iu__hint label">One sheet, one family: the bill climbs Oswald’s weight axis 300 → 700 like a case of wood type, black over fluorescent panels. The bottom strip runs the showtimes.</p>
  </figure>

  <!-- ============ 02 — EDITORIAL ============ -->
  <figure class="iu__item" data-shoot-click="[data-ed='final']">
    <figcaption class="iu__cap">
      <span class="index-num">02</span>
      <span class="label">Editorial — a tabloid hammer front, after the New York <em>Daily News</em> (“Ford to City: Drop Dead,” 1975) and its condensed headline gothic</span>
    </figcaption>
    <div class="iu__scene">
      <div class="tb" data-tb data-edition="early">
        <div class="tb__top">
          <div class="tb__ear tb__ear--l">
            <b>WEATHER</b>
            <span>Gale easing by noon, then clearing — Page 2</span>
          </div>
          <h3 class="tb__nameplate">THE EXPRESS</h3>
          <div class="tb__ear tb__ear--r">
            <b class="tb__flag" data-tb-flag>{ed0.flag}</b>
            <span>Tuesday, March 3 · 15¢</span>
          </div>
        </div>
        <div class="tb__lede">
          <p class="tb__kick">PORT IN CHAOS · SPECIAL HARBOR DESK REPORT</p>
          <h4 class="tb__hammer">
            <span class="tb__h1" data-tb-l1>{ed0.l1}</span>
            <span class="tb__h2" data-tb-l2>{ed0.l2}</span>
          </h4>
          <p class="tb__deck" data-tb-deck>{ed0.deck}</p>
        </div>
        <div class="tb__split">
          <div class="tb__photo" aria-hidden="true">
            <i class="tb__photo-crane"></i>
            <i class="tb__photo-water"></i>
            <p class="tb__capt" data-tb-capt>{ed0.capt}</p>
          </div>
          <div class="tb__copy">
            <p class="tb__byline">By <b>RAY DELGADO</b> · Harbor Bureau</p>
            <p><span class="tb__drop">T</span>he first mooring line parted at four in the morning, and by first light the harbormaster had done what no storm since 1962 has forced: closed the channel, both directions, to everything that floats.</p>
            <p>Longshore crews who reported for the dawn shift were sent home with a day’s pay. The pilots’ association called the swell at the breakwater “the worst working water in a generation,” and the port authority would not put a number on the damage — though everyone on the pier could see Crane No. 9 leaning two degrees out of true.</p>
            <p class="tb__jump">Continued on Page 3 · Photos, Pages 14–15</p>
          </div>
        </div>
        <div class="tb__replate" role="group" aria-label="Edition">
          <span class="tb__replate-k">REPLATE ☞</span>
          {editions.map((e, i) => (
            <button class={`tb__slug ${i === 0 ? 'is-on' : ''}`} data-ed={e.id}>{e.flag.replace(' ★★★','')}</button>
          ))}
          <span class="tb__replate-n">Press run 3 of 3</span>
        </div>
        <div class="tb__derby">
          <span class="tb__derby-l">DERBY NIGHT: <b>CITY v UNITED</b> · KICK-OFF 8:00</span>
          <span class="tb__derby-r">FOLLOW IT LIVE ▼</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Work the replate slugs — the front page re-sets through three editions of one harbor story, the hammer recomposing at full weight while the Spectral body columns hold.</p>
  </figure>

  <!-- ============ 03 — WEB & APP UI ============ -->
  <figure class="iu__item" data-shoot-click="[data-tab='b']">
    <figcaption class="iu__cap">
      <span class="index-num">03</span>
      <span class="label">Web &amp; app UI — a live match centre at real device scale, after FotMob and the broadcast scorebug’s condensed numerals (interactive)</span>
    </figcaption>
    <div class="iu__scene">
      <div class="mc">
        <p class="mc__ghost mc__ghost--l" aria-hidden="true">DERBY</p>
        <p class="mc__ghost mc__ghost--r" aria-hidden="true">NIGHT</p>
        <aside class="mc__rail">
          <p class="mc__rail-ghost" aria-hidden="true">DERBY<br />NIGHT</p>
          <p class="mc__rail-k">TONIGHT’S CARD · MATCHWEEK 34</p>
          {matches.map((mt) => (
            <div class="mc__rail-row">
              <span class="mc__rail-team">{mt.home.name}</span>
              <span class="mc__rail-score">{mt.home.g}–{mt.away.g}</span>
              <span class="mc__rail-team mc__rail-team--a">{mt.away.name}</span>
              <span class={`mc__rail-min ${mt.live ? 'is-live' : ''}`}>{mt.status}</span>
            </div>
          ))}
          <p class="mc__rail-note">Kick-offs 8:00 · full commentary on the match centre — tap a fixture.</p>
        </aside>
        <div class="mc__phone" data-sb>
          <div class="mc__chrome">
            <span class="mc__time">21:18</span>
            <span class="mc__brand">MATCHDAY</span>
            <span class="mc__sig" aria-hidden="true">
              <svg viewBox="0 0 16 12"><rect x="0" y="8" width="3" height="4" rx="0.6"/><rect x="4" y="5" width="3" height="7" rx="0.6"/><rect x="8" y="2" width="3" height="10" rx="0.6"/></svg>
              <svg viewBox="0 0 26 12"><rect x="0.5" y="0.5" width="22" height="11" rx="2.5" fill="none" stroke="currentColor"/><rect x="24" y="3.5" width="2" height="5" rx="1" fill="currentColor"/><rect x="2" y="2" width="14" height="8" rx="1" fill="currentColor"/></svg>
            </span>
          </div>
          <div class="mc__tabs" role="tablist">
            {matches.map((mt, i) => (
              <button class={`mc__tab ${i === 0 ? 'is-on' : ''}`} data-tab={mt.id} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>
                <span class="mc__tab-score"><em>{mt.home.sh}</em><b>{mt.home.g}–{mt.away.g}</b><em>{mt.away.sh}</em></span>
                <span class={`mc__tab-min ${mt.live ? 'is-live' : ''}`}>{mt.status}</span>
              </button>
            ))}
          </div>
          <div class="mc__hero">
            <span class={`mc__badge ${m0.live ? 'is-live' : ''}`} data-status>
              <i class="mc__pulse"></i><span data-statustxt>{m0.live ? `LIVE · ${m0.status}` : 'FULL TIME'}</span>
            </span>
            <div class="mc__bug" role="img" aria-label="Scoreboard">
              <span class="mc__bug-side mc__bug-side--h" data-hname>{m0.home.name}</span>
              <span class="mc__bug-score"><b data-hg>{m0.home.g}</b><i aria-hidden="true">–</i><b class="mc__bug-a" data-ag>{m0.away.g}</b></span>
              <span class="mc__bug-side mc__bug-side--a" data-aname>{m0.away.name}</span>
              <span class="mc__bug-min"><b data-minute>{m0.status}</b></span>
            </div>
            <span class="mc__venue" data-venue>{m0.comp} · {m0.venue}</span>
          </div>
          <div class="mc__stats" data-stats>
            {m0.stats.map((s) => {
              const total = s[1] + s[2];
              return (
              <div class="mc__stat" data-stat>
                <span class="mc__stat-k" data-sk>{s[0]}</span>
                <span class="mc__stat-v mc__stat-v--h" data-sh>{s[1]}{s[0]==='Possession'?'%':''}</span>
                <span class="mc__stat-track">
                  <i class="mc__stat-fill mc__stat-fill--h" data-fillh style={`width:${(s[1]/total)*100}%`}></i>
                  <i class="mc__stat-fill mc__stat-fill--a" data-filla style={`width:${(s[2]/total)*100}%`}></i>
                </span>
                <span class="mc__stat-v mc__stat-v--a" data-sa>{s[2]}{s[0]==='Possession'?'%':''}</span>
              </div>
            );})}
          </div>
          <div class="mc__feed-h"><span>Match feed</span><span class="mc__feed-key"><i class="mc__key mc__key--h"></i>Home<i class="mc__key mc__key--a"></i>Away</span></div>
          <ul class="mc__feed" data-feed>
            {m0.events.slice().reverse().map((e) => (
              <li class={`mc__ev mc__ev--${e[3]}`}>
                <span class="mc__ev-min">{e[0]}'</span>
                <span class={`mc__ev-tag mc__ev-tag--${e[1].toLowerCase()}`}>{e[1]}</span>
                <span class="mc__ev-name">{e[2]}</span>
              </li>
            ))}
          </ul>
          <template data-ev-tpl>
            <li class="mc__ev">
              <span class="mc__ev-min"></span>
              <span class="mc__ev-tag"></span>
              <span class="mc__ev-name"></span>
            </li>
          </template>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Tap a fixture — score, momentum bars and the feed reload. Thirteen-pixel labels stay readable because the tall x-height is what lets Oswald run this narrow.</p>
  </figure>

  <!-- ============ 04 — BRANDING & IDENTITY ============ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap">
      <span class="index-num">04</span>
      <span class="label">Branding &amp; identity — a jazz label system, after Reid Miles’s type-led Blue Note sleeves (1956–67): one gothic, two inks, cropped hard</span>
    </figcaption>
    <div class="iu__scene">
      <div class="rv" data-rv data-ink="0">
        <div class="rv__front" data-rv-front role="button" tabindex="0" aria-label="Proof the next duotone ink pair">
          <div class="rv__label-row">
            <span class="rv__mark" aria-hidden="true">C</span>
            <span class="rv__label-t">CRESCENT RECORDS · NEW YORK 23</span>
            <span class="rv__cat">CR-4127</span>
          </div>
          <div class="rv__title">
            <p class="rv__t1">UPTOWN</p>
            <p class="rv__t2">LOCAL</p>
          </div>
          <div class="rv__artist">
            <p class="rv__a1">THE CURTIS LANE QUARTET</p>
            <p class="rv__a2">CURTIS LANE, tenor saxophone · RAY FELTON, piano · BILL MOTT, bass · PETE DANIELS, drums</p>
          </div>
          <span class="rv__fid">HIGH FIDELITY</span>
        </div>
        <div class="rv__side">
          <div class="rv__spines">
            <p class="rv__spines-k">THE SPINE IS THE SYSTEM — ONE GOTHIC, GRADED BY WEIGHT · SERIES CR-4100</p>
            {spines.map((s) => (
              <div class={`rv__spine ${s.now ? 'is-now' : ''}`}>
                <span class="rv__spine-cat">{s.cat}</span>
                <span class="rv__spine-artist">{s.artist}</span>
                <span class="rv__spine-title" style={`font-weight:${s.w}`} data-rv-now={s.now ? '' : undefined}>{s.title}</span>
                <span class="rv__spine-w">wght {s.w}</span>
                <span class="rv__spine-lbl">CRESCENT</span>
              </div>
            ))}
          </div>
          <div class="rv__back">
            <div class="rv__back-col">
              <p class="rv__side-k">SIDE ONE</p>
              {sideA.map((t) => (
                <p class="rv__track"><span>{t[0]}</span><i></i><span>{t[1]}</span></p>
              ))}
            </div>
            <div class="rv__back-col">
              <p class="rv__side-k">SIDE TWO</p>
              {sideB.map((t) => (
                <p class="rv__track"><span>{t[0]}</span><i></i><span>{t[1]}</span></p>
              ))}
            </div>
            <p class="rv__micro">LONG PLAYING <b class="rv__frac">33 1/3</b> R.P.M. MICROGROOVE · RECORDED AT BERGEN ST. STUDIOS · ENGINEER: R. V. GELLER</p>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Tap or hover the cover to proof the press’s three duotone ink pairs — orange, blue, green over black. The 33 1/3 is a true typographic fraction (<code>frac</code>, verified in the file).</p>
  </figure>

  <!-- ============ 05 — INTERACTIVE & EXPERIMENTAL ============ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click="[data-cf-preset='2']">
    <figcaption class="iu__cap">
      <span class="index-num">05</span>
      <span class="label">Interactive &amp; experimental — <em>Counting Heads</em>, a copyfitting instrument; width-graded gothics like ATF’s Alternate Gothic (M. F. Benton, 1903) were cut to win exactly this game</span>
    </figcaption>
    <div class="iu__scene">
      <div class="cf" data-cf style="--colw:78%">
        <div class="cf__head-row">
          <h4 class="cf__name">COUNTING HEADS</h4>
          <p class="cf__sub">The composing-room problem: a fixed column, a head that must fill it. Alternate Gothic shipped in three widths to solve it; Oswald solves it with one live axis. The instrument finds the exact weight where the line fills the measure.</p>
        </div>
        <div class="cf__stage">
          <div class="cf__dead cf__dead--l" aria-hidden="true"></div>
          <div class="cf__col" data-cf-col>
            <span class="cf__colrule cf__colrule--l" aria-hidden="true"></span>
            <span class="cf__headline" data-cf-head>STORM SHUTS THE HARBOR</span>
            <span class="cf__colrule cf__colrule--r" aria-hidden="true"></span>
          </div>
          <div class="cf__dead cf__dead--r" aria-hidden="true"></div>
        </div>
        <p class="cf__slug"><b>THE EXPRESS</b><span>FINAL ★★★</span><span>PAGE 1</span><span data-cf-cols>COLS 1–5 OF 6</span><span>HEAD: SCHEDULE A · 1 LINE · U&amp;LC OFF</span></p>
        <div class="cf__read">
          <span class="cf__r"><b data-cf-wght>—</b><i>wght</i></span>
          <span class="cf__r"><b data-cf-picas>—</b><i>picas</i></span>
          <span class="cf__r"><b data-cf-chars>—</b><i>characters</i></span>
          <span class="cf__verdict" data-cf-verdict>FITS</span>
        </div>
        <div class="cf__ctrl">
          <label class="cf__measure">
            <span>COLUMN MEASURE</span>
            <input type="range" min="34" max="100" step="1" value="78" data-cf-width aria-label="Column measure" />
          </label>
          <label class="cf__write">
            <span>WRITE THE HEAD</span>
            <input type="text" maxlength="26" value="STORM SHUTS THE HARBOR" data-cf-input aria-label="Headline text" />
          </label>
          <div class="cf__presets" role="group" aria-label="Headline schedule">
            <button class="cf__preset" data-cf-preset="0">MAYOR VOWS VETO</button>
            <button class="cf__preset" data-cf-preset="1">LAST TRAIN OUT TONIGHT</button>
            <button class="cf__preset" data-cf-preset="2">EIGHT-ALARM FIRE ON DOCK STREET</button>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Drag the measure or write your own head — the instrument solves the weight axis live so the line exactly fills the column. Too long even at 200? That’s a bust: cut the head.</p>
  </figure>

</div>

<script id="oswald-iu-data" type="application/json" set:html={JSON.stringify({ editions, matches })} is:inline></script>

<script>
  type Edition = { id: string; flag: string; l1: string; l2: string; deck: string; capt: string };
  type Match = {
    id: string; comp: string; venue: string; status: string; live: boolean;
    home: { name: string; sh: string; g: number };
    away: { name: string; sh: string; g: number };
    stats: [string, number, number][];
    events: [string, string, string, string][];
  };
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const island = document.getElementById('oswald-iu-data');
  let data: { editions: Edition[]; matches: Match[] } = { editions: [], matches: [] };
  try { data = island ? JSON.parse(island.textContent || '{}') : data; } catch {}

  // ===== 01 · Globe show card — wood-type copyfit =====
  // A show card forces every display line full measure: size each big line so
  // its set width exactly fills the sheet column, whatever the act's width.
  document.querySelectorAll<HTMLElement>('[data-gp]').forEach((gp) => {
    const lines = Array.from(gp.querySelectorAll<HTMLElement>('[data-gp-fit]'));
    if (!lines.length) return;
    let raf = 0;
    const fit = () => {
      raf = 0;
      lines.forEach((el) => {
        const target = el.clientWidth;
        if (!target) return;
        el.style.fontSize = '100px';
        const w = el.scrollWidth;
        if (w > 0) el.style.fontSize = `${Math.floor(100 * (target / w) * 0.995 * 10) / 10}px`;
      });
    };
    const schedule = () => { if (!raf) raf = requestAnimationFrame(fit); };
    if ('ResizeObserver' in window) new ResizeObserver(schedule).observe(gp);
    document.fonts.ready.then(schedule);
    schedule();
  });

  // ===== 02 · Tabloid replate =====
  document.querySelectorAll<HTMLElement>('[data-tb]').forEach((tb) => {
    const byId: Record<string, Edition> = {};
    data.editions.forEach((e) => (byId[e.id] = e));
    const flag = tb.querySelector('[data-tb-flag]') as HTMLElement;
    const l1 = tb.querySelector('[data-tb-l1]') as HTMLElement;
    const l2 = tb.querySelector('[data-tb-l2]') as HTMLElement;
    const deck = tb.querySelector('[data-tb-deck]') as HTMLElement;
    const capt = tb.querySelector('[data-tb-capt]') as HTMLElement;
    tb.querySelectorAll<HTMLButtonElement>('[data-ed]').forEach((btn) =>
      btn.addEventListener('click', () => {
        const e = byId[btn.dataset.ed || ''];
        if (!e) return;
        tb.dataset.edition = e.id;
        flag.textContent = e.flag;
        l1.textContent = e.l1;
        l2.textContent = e.l2;
        deck.textContent = e.deck;
        capt.textContent = e.capt;
        tb.querySelectorAll('[data-ed]').forEach((b) => b.classList.toggle('is-on', b === btn));
      })
    );
  });

  // ===== 03 · Match centre (template-cloned feed rows) =====
  document.querySelectorAll<HTMLElement>('[data-sb]').forEach((sb) => {
    if (!data.matches.length) return;
    const byId: Record<string, Match> = {};
    data.matches.forEach((m) => (byId[m.id] = m));
    const q = (s: string) => sb.querySelector(s) as HTMLElement | null;
    const hg = q('[data-hg]')!, ag = q('[data-ag]')!;
    const hname = q('[data-hname]')!, aname = q('[data-aname]')!;
    const venue = q('[data-venue]')!;
    const badge = q('[data-status]')!, statustxt = q('[data-statustxt]')!;
    const minute = q('[data-minute]')!;
    const feed = q('[data-feed]')!;
    const tpl = sb.querySelector('[data-ev-tpl]') as HTMLTemplateElement;
    const statRows = Array.from(sb.querySelectorAll('[data-stat]'));
    let currentId = data.matches[0].id;

    // The single-axis performance, inside the device: numerals land light and
    // snap to the 700 cut, like a scorebug taking a goal.
    const snap = (els: HTMLElement[]) => {
      if (reduce) { els.forEach((el) => (el.style.fontVariationSettings = "'wght' 700")); return; }
      els.forEach((el) => { el.style.transition = 'none'; el.style.fontVariationSettings = "'wght' 200"; });
      void els[0].offsetWidth;
      els.forEach((el) => { el.style.transition = ''; el.style.fontVariationSettings = "'wght' 700"; });
    };

    function render(id: string) {
      const m = byId[id];
      if (!m) return;
      currentId = id;
      hg.textContent = String(m.home.g);
      ag.textContent = String(m.away.g);
      hname.textContent = m.home.name;
      aname.textContent = m.away.name;
      venue.textContent = `${m.comp} · ${m.venue}`;
      badge.classList.toggle('is-live', m.live);
      statustxt.textContent = m.live ? `LIVE · ${m.status}` : 'FULL TIME';
      minute.textContent = m.status;
      snap([hg, ag, minute]);

      statRows.forEach((row, i) => {
        const s = m.stats[i];
        const el = row as HTMLElement;
        if (!s) { el.style.display = 'none'; return; }
        el.style.display = '';
        const total = s[1] + s[2];
        const pct = s[0] === 'Possession' ? '%' : '';
        (row.querySelector('[data-sh]') as HTMLElement).textContent = s[1] + pct;
        (row.querySelector('[data-sa]') as HTMLElement).textContent = s[2] + pct;
        (row.querySelector('[data-sk]') as HTMLElement).textContent = s[0];
        (row.querySelector('[data-fillh]') as HTMLElement).style.width = (s[1] / total) * 100 + '%';
        (row.querySelector('[data-filla]') as HTMLElement).style.width = (s[2] / total) * 100 + '%';
      });

      feed.replaceChildren();
      m.events.slice().reverse().forEach((e) => {
        const li = (tpl.content.firstElementChild as HTMLElement).cloneNode(true) as HTMLElement;
        li.classList.add(`mc__ev--${e[3]}`);
        (li.querySelector('.mc__ev-min') as HTMLElement).textContent = `${e[0]}'`;
        const tag = li.querySelector('.mc__ev-tag') as HTMLElement;
        tag.classList.add(`mc__ev-tag--${e[1].toLowerCase()}`);
        tag.textContent = e[1];
        (li.querySelector('.mc__ev-name') as HTMLElement).textContent = e[2];
        feed.appendChild(li);
      });

      sb.querySelectorAll('[data-tab]').forEach((t) => {
        const on = (t as HTMLElement).dataset.tab === id;
        t.classList.toggle('is-on', on);
        t.setAttribute('aria-selected', on ? 'true' : 'false');
      });
    }

    sb.querySelectorAll<HTMLButtonElement>('[data-tab]').forEach((btn) =>
      btn.addEventListener('click', () => render(btn.dataset.tab!))
    );

    // Live minute: the clock runs while a match is live, the numeral pulsing
    // up the weight axis on each tick (stilled under reduced motion).
    if (!reduce) {
      setInterval(() => {
        const m = byId[currentId];
        if (!m || !m.live) return;
        const n = parseInt(m.status, 10);
        if (Number.isNaN(n) || n >= 90) return;
        m.status = `${n + 1}'`;
        minute.textContent = m.status;
        statustxt.textContent = `LIVE · ${m.status}`;
        snap([minute]);
        const tabMin = sb.querySelector(`[data-tab="${m.id}"] .mc__tab-min`);
        if (tabMin) tabMin.textContent = m.status;
      }, 6000);
    }
  });

  // ===== 04 · Sleeve duotone proofing =====
  document.querySelectorAll<HTMLElement>('[data-rv]').forEach((rv) => {
    const front = rv.querySelector('[data-rv-front]') as HTMLElement;
    let ink = 0;
    const next = () => {
      ink = (ink + 1) % 3;
      rv.dataset.ink = String(ink);
      // replay the press pass: headline jolts off-register, now-spine pulses 200→its cut
      rv.classList.remove('is-pressing');
      void rv.offsetWidth;
      rv.classList.add('is-pressing');
    };
    front.addEventListener('click', next);
    front.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); next(); } });
    if (!reduce) front.addEventListener('mouseenter', next);
  });

  // ===== 05 · Counting Heads — solve wght so the line fills the measure =====
  document.querySelectorAll<HTMLElement>('[data-cf]').forEach((cf) => {
    const head = cf.querySelector('[data-cf-head]') as HTMLElement;
    const col = cf.querySelector('[data-cf-col]') as HTMLElement;
    const width = cf.querySelector('[data-cf-width]') as HTMLInputElement;
    const input = cf.querySelector('[data-cf-input]') as HTMLInputElement;
    const oW = cf.querySelector('[data-cf-wght]') as HTMLElement;
    const oP = cf.querySelector('[data-cf-picas]') as HTMLElement;
    const oC = cf.querySelector('[data-cf-chars]') as HTMLElement;
    const verdict = cf.querySelector('[data-cf-verdict]') as HTMLElement;
    const cols = cf.querySelector('[data-cf-cols]') as HTMLElement;
    let raf = 0;

    const setW = (w: number) => { head.style.fontVariationSettings = `'wght' ${w}`; };
    const wide = () => head.scrollWidth;

    function fit() {
      raf = 0;
      const target = col.clientWidth;
      if (!target) return;
      let result = 200;
      let state = 'FITS';
      setW(200);
      if (wide() > target) {
        // teach like a galley proof: say by how much the head busts
        const over = (wide() - target) / 16;
        state = `BUST — ${over.toFixed(1)} PICAS OVER · CUT IT`;
        result = 200;
      } else {
        setW(700);
        if (wide() <= target) {
          state = 'PADS — FATTEN IT';
          result = 700;
        } else {
          let lo = 200, hi = 700;
          for (let i = 0; i < 9; i++) {
            const mid = Math.round((lo + hi) / 2);
            setW(mid);
            if (wide() > target) hi = mid; else lo = mid;
          }
          result = lo;
          setW(lo);
        }
      }
      oW.textContent = String(result);
      oP.textContent = String(Math.round(target / 16));
      oC.textContent = String(head.textContent?.length || 0);
      const nCols = Math.max(2, Math.round((Number(width.value) / 100) * 6));
      cols.textContent = `COLS 1–${nCols} OF 6`;
      verdict.textContent = state;
      verdict.dataset.state = state === 'FITS' ? 'fit' : state.startsWith('BUST') ? 'bust' : 'pads';
    }
    const schedule = () => { if (!raf) raf = requestAnimationFrame(fit); };

    width.addEventListener('input', () => {
      cf.style.setProperty('--colw', width.value + '%');
      schedule();
    });
    input.addEventListener('input', () => {
      head.textContent = (input.value || 'WRITE THE HEAD').toUpperCase();
      schedule();
    });
    cf.querySelectorAll<HTMLButtonElement>('[data-cf-preset]').forEach((btn) =>
      btn.addEventListener('click', () => {
        const t = btn.textContent || '';
        head.textContent = t;
        input.value = t;
        schedule();
      })
    );
    if ('ResizeObserver' in window) new ResizeObserver(schedule).observe(col);
    document.fonts.ready.then(schedule);
    schedule();
  });
</script>

