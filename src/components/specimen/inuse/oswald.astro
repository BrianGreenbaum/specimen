  .tb__derby {
    display: flex; align-items: baseline; justify-content: space-between; gap: 1rem;
    background: var(--tred); color: var(--paper);
    margin: 0 calc(-1 * clamp(0.9rem, 3cqi, 2.75rem));
    padding: clamp(0.55rem, 1.5cqi, 1.05rem) clamp(0.9rem, 3cqi, 2.75rem);
  }
  .tb__derby-l { font-size: clamp(13px, 2cqi, 22px); font-weight: 400; letter-spacing: 0.06em; }
  .tb__derby-l b { font-weight: 700; }
  .tb__derby-r { font-size: clamp(11px, 1.5cqi, 16px); font-weight: 700; letter-spacing: 0.2em; white-space: nowrap; }
  @container (max-width: 640px) {
    .tb__top { grid-template-columns: 1fr; gap: 0.4rem; }
    .tb__nameplate { order: -1; text-align: center; }
    .tb__ear { flex-direction: row; justify-content: space-between; align-items: baseline; gap: 0.8rem; }
    .tb__ear--r { text-align: left; }
    .tb__split { grid-template-columns: 1fr; }
    .tb__h1, .tb__h2 { font-size: clamp(2.4rem, 14.5cqi, 4.6rem); }
    .tb__replate-n { display: none; }
  }

  /* ============================================================
     03 — MATCH CENTRE · floodlit field, phone at real px
     ============================================================ */
  .mc {
    position: relative;
    background:
      radial-gradient(120% 90% at 50% -10%, #1c2733 0%, #121922 52%, #0c1118 100%);
    display: grid; place-items: center;
    padding: clamp(1.75rem, 4.5cqi, 4rem) clamp(0.9rem, 3cqi, 3rem);
    overflow: clip;
  }
  .mc__ghost {
    position: absolute; top: 50%; transform: translateY(-50%);
    font-size: clamp(6rem, 16cqi, 15rem); font-weight: 200; line-height: 0.9;
    letter-spacing: 0.04em; color: transparent;
    -webkit-text-stroke: 1px #ffffff1c;
    pointer-events: none; user-select: none;
  }
  .mc__ghost--l { left: clamp(0.5rem, 3cqi, 3.5rem); }
  .mc__ghost--r { right: clamp(0.5rem, 3cqi, 3.5rem); }
  @container (max-width: 1000px) { .mc__ghost { display: none; } }

  .mc__phone {
    position: relative; width: 348px; max-width: 100%; height: 634px;
    display: flex; flex-direction: column;
    background: #141a21; color: #eef1f4;
    border-radius: 30px; border: 1px solid #ffffff24;
    box-shadow: 0 30px 70px -28px rgba(0, 0, 0, 0.85);
    overflow: hidden;
    --red: #e8482c; --away: #6f8cb0;
    --pline: #ffffff1f; --pline-soft: #ffffff10;
    --pdim: #97a1ac; --pfaint: #66707b;
    font-size: 13px;
  }
  .mc__chrome {
    display: flex; align-items: center; justify-content: space-between; gap: 0.7rem;
    padding: 0.6rem 1.1rem 0.5rem; border-bottom: 1px solid var(--pline);
    background: #0f141a; flex: none;
  }
  .mc__time { font-size: 12px; font-weight: 600; letter-spacing: 0.02em; }
  .mc__brand { font-size: 12px; font-weight: 700; letter-spacing: 0.16em; color: var(--red); }
  .mc__sig { display: inline-flex; align-items: center; gap: 6px; color: var(--pdim); }
  .mc__sig svg { display: block; }
  .mc__sig svg:first-child { width: 15px; height: 11px; }
  .mc__sig svg:first-child rect { fill: currentColor; }
  .mc__sig svg:last-child { width: 22px; height: 10px; }

  .mc__tabs { display: flex; border-bottom: 1px solid var(--pline); flex: none; }
  .mc__tab {
    flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px;
    padding: 10px 6px; border-right: 1px solid var(--pline-soft);
    border-bottom: 2px solid transparent; min-width: 0;
    transition: background 0.15s var(--ease);
  }
  .mc__tab:last-child { border-right: 0; }
  .mc__tab:hover { background: #ffffff0a; }
  .mc__tab.is-on { border-bottom-color: var(--red); background: #e8482c14; }
  .mc__tab-score { display: flex; align-items: baseline; gap: 5px; }
  .mc__tab-score em { font-size: 11px; font-weight: 600; color: var(--pdim); letter-spacing: 0.05em; }
  .mc__tab-score b { font-size: 17px; font-weight: 700; letter-spacing: 0.01em; }
  .mc__tab-min { font-size: 10px; font-weight: 600; letter-spacing: 0.08em; color: var(--pfaint); }
  .mc__tab-min.is-live { color: var(--red); }

  .mc__hero {
    flex: none; padding: 14px 18px 13px; text-align: center;
    border-bottom: 1px solid var(--pline);
    background: linear-gradient(180deg, #e8482c14, transparent 78%);
  }
  .mc__badge {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 10px; font-weight: 600; letter-spacing: 0.16em;
    color: var(--pfaint); margin-bottom: 9px;
    padding: 2px 9px; border-radius: 100px; border: 1px solid var(--pline);
  }
  .mc__badge.is-live { color: var(--red); border-color: #e8482c66; }
  .mc__pulse { width: 6px; height: 6px; border-radius: 50%; background: currentColor; opacity: 0.4; }
  .mc__badge.is-live .mc__pulse { opacity: 1; }
  @media (prefers-reduced-motion: no-preference) {
    .mc__badge.is-live .mc__pulse { animation: mc-pulse 1.4s var(--ease, ease-in-out) infinite; }
    @keyframes mc-pulse { 0%, 100% { box-shadow: 0 0 0 0 #e8482cb0; } 70% { box-shadow: 0 0 0 5px transparent; } }
  }
  /* the broadcast scorebug, set in the device: solid team blocks, a numeral
     plate, the running minute — straight off the top-left of a match feed */
  .mc__bug {
    display: grid; grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr) auto;
    align-items: stretch; border-radius: 7px; overflow: hidden;
    border: 1px solid var(--pline); text-align: center;
  }
  .mc__bug-side {
    display: flex; align-items: center; justify-content: center;
    font-size: 15px; font-weight: 600; letter-spacing: 0.05em; line-height: 1;
    padding: 0 8px; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .mc__bug-side--h { background: var(--red); color: #16110f; }
  .mc__bug-side--a { background: var(--away); color: #0d1218; }
  .mc__bug-score {
    display: flex; align-items: baseline; gap: 7px;
    padding: 9px 13px 7px; background: #0f141a;
  }
  .mc__bug-score b { font-size: 32px; font-weight: 700; line-height: 0.85; }
  .mc__bug-a { color: var(--pdim); }
  .mc__bug-score i { font-style: normal; font-size: 18px; font-weight: 300; color: var(--pfaint); }
  .mc__bug-min {
    display: flex; align-items: center; justify-content: center;
    min-width: 42px; padding: 0 9px; background: #ffffff0d; border-left: 1px solid var(--pline);
  }
  .mc__bug-min b { font-size: 14px; font-weight: 700; letter-spacing: 0.04em; color: var(--red); }
  @media (prefers-reduced-motion: no-preference) {
    .mc__bug-score b, .mc__bug-min b { transition: font-variation-settings 0.5s var(--ease-out); }
  }
  .mc__venue { display: block; margin-top: 9px; font-size: 10px; letter-spacing: 0.16em; color: var(--pfaint); }

  /* tablet fixtures rail — 768 gets its own composition beside the phone */
  .mc__rail { display: none; }
  .mc__rail-ghost {
    font-size: clamp(4rem, 11cqi, 6.5rem); font-weight: 200; line-height: 0.92;
    letter-spacing: 0.04em; color: transparent; -webkit-text-stroke: 1px #ffffff26;
    user-select: none; margin-bottom: 18px;
  }
  .mc__rail-k {
    font-size: 10px; font-weight: 600; letter-spacing: 0.22em; color: var(--pfaint, #66707b);
    border-bottom: 1px solid #ffffff1f; padding-bottom: 8px; margin-bottom: 4px;
  }
  .mc__rail-row {
    display: grid; grid-template-columns: 1fr auto 1fr auto; align-items: baseline; gap: 12px;
    padding: 10px 0; border-bottom: 1px solid #ffffff10; color: #eef1f4;
  }
  .mc__rail-team { font-size: 13px; font-weight: 600; letter-spacing: 0.05em; text-align: right; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-width: 0; }
  .mc__rail-team--a { text-align: left; color: #97a1ac; }
  .mc__rail-score { font-size: 26px; font-weight: 700; line-height: 0.9; }
  .mc__rail-min { font-size: 11px; font-weight: 600; letter-spacing: 0.08em; color: #66707b; min-width: 26px; text-align: right; }
  .mc__rail-min.is-live { color: #e8482c; }
  .mc__rail-note { font-size: 11px; font-weight: 300; letter-spacing: 0.06em; color: #66707b; margin-top: 12px; }
  @container (min-width: 641px) and (max-width: 1000px) {
    .mc { grid-template-columns: minmax(0, 1fr) auto; justify-items: stretch; align-items: center; gap: clamp(1.5rem, 4cqi, 3rem); }
    .mc__rail { display: block; max-width: 340px; justify-self: center; width: 100%; }
    .mc__phone { justify-self: center; }
  }

  .mc__stats { flex: none; padding: 12px 18px; display: flex; flex-direction: column; gap: 9px; border-bottom: 1px solid var(--pline); }
  .mc__stat { display: grid; grid-template-columns: auto 28px 1fr 28px; align-items: center; gap: 10px; }
  .mc__stat-k { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--pfaint); white-space: nowrap; }
  .mc__stat-v { font-size: 12.5px; font-weight: 700; }
  .mc__stat-v--h { text-align: right; }
  .mc__stat-v--a { text-align: left; color: var(--away); }
  .mc__stat-track { display: flex; height: 5px; gap: 2px; }
  .mc__stat-fill { display: block; height: 100%; transition: width 0.5s var(--ease); }
  .mc__stat-fill--h { background: var(--red); border-radius: 3px 0 0 3px; margin-left: auto; }
  .mc__stat-fill--a { background: var(--away); border-radius: 0 3px 3px 0; }
  @media (prefers-reduced-motion: reduce) { .mc__stat-fill { transition: none; } }

  .mc__feed-h { flex: none; padding: 11px 18px 4px; display: flex; align-items: baseline; justify-content: space-between; }
  .mc__feed-h > span:first-child { font-size: 9px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--pfaint); }
  .mc__feed-key { display: inline-flex; align-items: center; gap: 5px; font-size: 8.5px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--pfaint); }
  .mc__key { width: 7px; height: 7px; border-radius: 2px; }
  .mc__key--h { background: var(--red); }
  .mc__key--a { background: var(--away); margin-left: 7px; }
  .mc__feed { flex: 1; overflow: auto; margin: 0; padding: 2px 18px 12px; list-style: none; display: flex; flex-direction: column; }
  .mc__ev { display: flex; align-items: center; gap: 11px; padding: 6px 0; border-bottom: 1px solid var(--pline-soft); }
  .mc__ev:last-child { border-bottom: 0; }
  .mc__ev-min { font-size: 12px; font-weight: 600; color: var(--pfaint); min-width: 24px; }
  .mc__ev-tag { font-size: 9px; font-weight: 700; letter-spacing: 0.08em; padding: 2px 6px; border-radius: 3px; line-height: 1.2; min-width: 32px; text-align: center; }
  .mc__ev-tag--goal { background: var(--red); color: #16110f; }
  .mc__ev-tag--yel { background: #d8a200; color: #1a1500; }
  .mc__ev-tag--sub { background: #6f8cb038; color: var(--away); }
  .mc__ev-name { font-size: 14px; font-weight: 500; letter-spacing: 0.01em; }
  .mc__ev--away { flex-direction: row-reverse; }
  .mc__ev--away .mc__ev-name { text-align: right; color: var(--pdim); }

  @container (max-width: 420px) {
    .mc { padding-inline: 0.5rem; }
    .mc__bug-side { font-size: 13px; letter-spacing: 0.03em; }
    .mc__bug-score b { font-size: 28px; }
  }

  /* ============================================================
     04 — CRESCENT RECORDS · Reid Miles duotone sleeve system
     ============================================================ */
  .rv {
    --board: #f1e9d4;
    --rink: #16130e;
    background: #0f0d0a;
    display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(1.25rem, 3.5cqi, 3.5rem);
    padding: clamp(1.5rem, 4.5cqi, 4.5rem) clamp(1rem, 5cqi, 5.5rem);
    align-items: center;
  }
  /* duotone press variants — each ink pair registers a little differently,
     the way a two-pass litho run actually lands */
  .rv[data-ink='0'] { --hue: #e8581c; --mx: 0.032em; --my: 0.024em; }
  .rv[data-ink='1'] { --hue: #2257a8; --mx: -0.045em; --my: 0.028em; }
  .rv[data-ink='2'] { --hue: #1e6e46; --mx: 0.02em; --my: -0.038em; }
  .rv__front {
    position: relative; aspect-ratio: 1; width: min(100%, 560px); justify-self: end;
    background: var(--board); color: var(--rink);
    padding: clamp(1rem, 3.2cqi, 2.6rem);
    display: flex; flex-direction: column;
    overflow: hidden; cursor: pointer; user-select: none;
    transition: box-shadow 0.25s var(--ease);
    box-shadow: 0 26px 60px -30px rgba(0, 0, 0, 0.9);
  }
  .rv__front:focus-visible { outline: 2px solid var(--hue); outline-offset: 4px; }
  .rv__label-row {
    display: flex; align-items: center; gap: 0.7em;
    border-bottom: 2px solid var(--rink); padding-bottom: clamp(0.5rem, 1.4cqi, 1rem);
  }
  .rv__mark {
    width: clamp(20px, 3.4cqi, 30px); height: clamp(20px, 3.4cqi, 30px); border-radius: 50%;
    background: var(--hue); color: var(--board);
    display: grid; place-items: center;
    font-size: clamp(12px, 2cqi, 18px); font-weight: 700;
    transition: background 0.35s var(--ease);
  }
  .rv__label-t { font-size: clamp(9px, 1.45cqi, 13px); font-weight: 500; letter-spacing: 0.24em; }
  .rv__cat { margin-left: auto; font-size: clamp(10px, 1.6cqi, 15px); font-weight: 700; letter-spacing: 0.08em; }
  .rv__title { flex: 1; display: flex; flex-direction: column; justify-content: center; margin: 0 calc(-1 * clamp(1rem, 3.2cqi, 2.6rem)); }
  .rv__t1, .rv__t2 { font-weight: 700; line-height: 0.84; letter-spacing: -0.005em; white-space: nowrap; }
  /* Miles crop: the title runs off the board on both sides */
  /* the color plate carries UPTOWN; the black pass sits a hair off-register
     beneath it, and the offset jumps with every ink proof */
  .rv__t1 {
    font-size: clamp(4.6rem, 17cqi, 13rem); color: var(--hue); margin-left: -0.03em;
    text-shadow: var(--mx) var(--my) 0 var(--rink);
    transition: color 0.35s var(--ease), text-shadow 0.35s var(--ease);
  }
  .rv__t2 {
    font-size: clamp(4.6rem, 17cqi, 13rem); align-self: flex-end; margin-right: -0.04em;
    margin-top: -0.1em; mix-blend-mode: multiply; /* LOCAL overprints the color pass */
  }
  @media (prefers-reduced-motion: no-preference) {
    .rv.is-pressing .rv__t1 { animation: rv-kick 0.45s var(--ease-out); }
    @keyframes rv-kick {
      0% { transform: translate(-0.05em, 0.015em); }
      55% { transform: translate(0.02em, -0.008em); }
      100% { transform: none; }
    }
    .rv.is-pressing .rv__spine.is-now .rv__spine-title { animation: rv-wpulse 0.7s var(--ease-out); }
    @keyframes rv-wpulse {
      from { font-variation-settings: 'wght' 200; }
      to { font-variation-settings: 'wght' 700; }
    }
  }
  .rv__artist { border-top: 2px solid var(--rink); padding-top: clamp(0.5rem, 1.4cqi, 1rem); }
  .rv__a1 { font-size: clamp(1rem, 3cqi, 2.1rem); font-weight: 600; letter-spacing: 0.06em; }
  .rv__a2 { font-size: clamp(8.5px, 1.4cqi, 13px); font-weight: 300; letter-spacing: 0.1em; margin-top: 0.5em; color: #4d4332; }
  .rv__fid {
    position: absolute; top: clamp(1rem, 3.2cqi, 2.6rem); right: 0;
    writing-mode: vertical-rl;
    font-size: clamp(8px, 1.2cqi, 11px); font-weight: 500; letter-spacing: 0.34em;
    color: var(--hue); padding-right: 0.35em;
    transition: color 0.35s var(--ease);
  }
  .rv__side { display: flex; flex-direction: column; gap: clamp(1.25rem, 3cqi, 2.5rem); min-width: 0; max-width: 620px; }
  .rv__spines-k { font-size: clamp(9px, 1.25cqi, 12px); font-weight: 600; letter-spacing: 0.26em; color: #8a8273; margin-bottom: 0.9em; }
  .rv__spine {
    display: flex; align-items: baseline; gap: 1em;
    background: #1c1813; color: #d8d0bd;
    padding: 0.55em 0.9em; margin-top: 6px;
    font-size: clamp(10px, 1.5cqi, 15px);
    white-space: nowrap; overflow: hidden;
  }
  .rv__spine.is-now { background: var(--hue); color: #0f0d0a; transition: background 0.35s var(--ease); }
  .rv__spine-cat { font-weight: 700; letter-spacing: 0.06em; }
  .rv__spine-artist { font-weight: 300; letter-spacing: 0.12em; overflow: hidden; text-overflow: ellipsis; }
  .rv__spine-title { letter-spacing: 0.06em; } /* weight comes per-row: the graded system */
  .rv__spine-w { font-family: var(--font-mono); font-size: 0.68em; font-weight: 400; letter-spacing: 0.1em; color: #8a8273; }
  .rv__spine.is-now .rv__spine-w { color: #0f0d0ab8; }
  .rv__spine-lbl { margin-left: auto; font-weight: 500; letter-spacing: 0.3em; font-size: 0.82em; }
  .rv__back {
    display: grid; grid-template-columns: 1fr 1fr; gap: clamp(0.9rem, 2.4cqi, 2rem);
    border-top: 1px solid #ffffff22; padding-top: clamp(0.9rem, 2.4cqi, 2rem);
    color: #d8d0bd;
  }
  .rv__side-k { font-size: clamp(9px, 1.25cqi, 12px); font-weight: 700; letter-spacing: 0.3em; color: var(--hue); margin-bottom: 0.8em; transition: color 0.35s var(--ease); }
  .rv__track { display: flex; align-items: baseline; gap: 0.6em; font-size: clamp(11px, 1.6cqi, 16px); font-weight: 400; letter-spacing: 0.04em; margin-top: 0.45em; }
  .rv__track i { flex: 1; border-bottom: 1px dotted #d8d0bd44; transform: translateY(-0.22em); min-width: 1em; }
  .rv__track span:last-child { font-weight: 600; }
  .rv__micro {
    grid-column: 1 / -1;
    font-size: clamp(8.5px, 1.2cqi, 12px); font-weight: 300; letter-spacing: 0.16em;
    color: #8a8273; border-top: 1px solid #ffffff14; padding-top: 1em;
  }
  .rv__frac { font-feature-settings: 'frac'; font-weight: 600; color: #d8d0bd; }
  @container (max-width: 880px) {
    .rv { grid-template-columns: 1fr; }
    .rv__front { justify-self: center; }
    .rv__side { max-width: 560px; margin-inline: auto; width: 100%; }
  }
  @container (max-width: 460px) {
    .rv__back { grid-template-columns: 1fr; }
    .rv__spine-artist { display: none; }
  }

  /* ============================================================
     05 — COUNTING HEADS · composing-room instrument
     ============================================================ */
  .cf {
    --cfk: #131110;
    --cfp: #efece6;
    --cfa: #e8482c;
    background: var(--cfk); color: var(--cfp);
    padding: clamp(1.5rem, 4cqi, 4rem) clamp(1rem, 5cqi, 5.5rem) clamp(1.5rem, 3.5cqi, 3.5rem);
    display: flex; flex-direction: column; gap: clamp(1.25rem, 3cqi, 2.75rem);
  }
  .cf__head-row { display: grid; grid-template-columns: auto minmax(0, 56ch); gap: clamp(1rem, 4cqi, 4rem); align-items: end; }
  .cf__name { font-size: clamp(2rem, 6cqi, 4.6rem); font-weight: 700; line-height: 0.9; letter-spacing: 0.005em; }
  .cf__sub { font-family: var(--font-ui); font-size: clamp(11px, 1.35cqi, 14px); line-height: 1.5; color: #9a948a; }
  .cf__stage {
    display: grid; grid-template-columns: 1fr var(--colw) 1fr;
    align-items: stretch; min-height: clamp(7rem, 18cqi, 15rem);
    border-block: 1px solid #efece622;
  }
  .cf__dead {
    background: repeating-linear-gradient(135deg, transparent 0 7px, #efece60c 7px 8px);
  }
  .cf__col {
    position: relative; display: flex; align-items: center; justify-content: center;
    overflow: hidden; padding-block: clamp(1rem, 3cqi, 2.5rem);
  }
  .cf__colrule { position: absolute; top: 0; bottom: 0; width: 2px; background: var(--cfa); }
  .cf__colrule--l { left: 0; }
  .cf__colrule--r { right: 0; }
  .cf__headline {
    display: inline-block; white-space: nowrap;
    font-size: clamp(1.5rem, 6.2cqi, 5.8rem); font-weight: 500; line-height: 0.95;
    letter-spacing: 0.005em;
  }
  /* the galley slug: edition, page, columns — the composing room's receipt */
  .cf__slug {
    display: flex; align-items: baseline; gap: 0.85em 1.6em; flex-wrap: wrap;
    font-size: clamp(9px, 1.2cqi, 12px); letter-spacing: 0.2em; color: #79736a;
    margin-top: calc(-1 * clamp(0.5rem, 1.5cqi, 1.5rem));
  }
  .cf__slug b { font-weight: 700; color: #b9b3a8; }
  .cf__slug span { font-weight: 300; white-space: nowrap; }
  .cf__read { display: flex; align-items: baseline; gap: clamp(1.25rem, 4cqi, 3.5rem); flex-wrap: wrap; }
  .cf__r { display: inline-flex; align-items: baseline; gap: 0.5em; }
  .cf__r b { font-size: clamp(1.5rem, 3.6cqi, 2.8rem); font-weight: 700; line-height: 1; }
  .cf__r i { font-size: clamp(10px, 1.3cqi, 13px); font-weight: 400; letter-spacing: 0.2em; text-transform: uppercase; color: #79736a; }
  .cf__verdict {
    margin-left: auto;
    font-size: clamp(12px, 1.7cqi, 17px); font-weight: 700; letter-spacing: 0.14em;
    padding: 0.4em 1em;
    background: #2c4a33; color: #9fe0b0;
  }
