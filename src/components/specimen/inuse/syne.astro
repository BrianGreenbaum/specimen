---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// ============================================================
// SYNE — experimental display sans from the contemporary-art
// world (Bonjour Monde / Synesthésie art centre). Scenes lean
// into ART / CULTURE / EXPERIMENTAL and drive the wght axis
// (400–800) kinetically. The face wants to be loud, mismatched,
// set huge across a gallery wall.
// ============================================================

// --- 03 · Arts-festival microsite / ticketing UI (interactive, real px) -----
// A real festival programme the visitor can drive: switch day, pick sessions,
// the basket re-totals. Tabular figures keep prices flush.
const days = [
  {
    id: 'fri', dow: 'FRI', date: '12', label: 'FRIDAY 12',
    sessions: [
      { t: '18:00', title: 'Opening — Soft Machines', venue: 'Grand Hall', kind: 'PERFORMANCE', price: 18, sold: false },
      { t: '19:30', title: 'Anouk Mercier, live A/V', venue: 'Studio B', kind: 'CONCERT', price: 22, sold: false },
      { t: '21:00', title: 'After-hours: Risograph Lab', venue: 'Workshop', kind: 'WORKSHOP', price: 12, sold: true },
    ],
  },
  {
    id: 'sat', dow: 'SAT', date: '13', label: 'SATURDAY 13',
    sessions: [
      { t: '11:00', title: 'Curator walk: Counterforms', venue: 'Gallery 2', kind: 'TALK', price: 0, sold: false },
      { t: '14:00', title: 'Type & Resistance — panel', venue: 'Grand Hall', kind: 'TALK', price: 9, sold: false },
      { t: '16:30', title: 'Variable Bodies (premiere)', venue: 'Studio B', kind: 'PERFORMANCE', price: 24, sold: false },
      { t: '20:00', title: 'Night programme: Synth Choir', venue: 'Grand Hall', kind: 'CONCERT', price: 26, sold: false },
    ],
  },
  {
    id: 'sun', dow: 'SUN', date: '14', label: 'SUNDAY 14',
    sessions: [
      { t: '12:00', title: 'Family atelier: Make a Glyph', venue: 'Workshop', kind: 'WORKSHOP', price: 6, sold: false },
      { t: '15:00', title: 'Closing keynote — Bonjour Monde', venue: 'Grand Hall', kind: 'TALK', price: 14, sold: false },
      { t: '17:30', title: 'Finale: Resonance Ensemble', venue: 'Grand Hall', kind: 'CONCERT', price: 28, sold: false },
    ],
  },
];
const d0 = days[0];

// --- 04 · Kinetic editorial — the manifesto words ---------------------------
const manifesto = ['RESONATE', 'CLASH', 'INSIST'];
---
<div class="iu" style={`--fam:${fam}`}>

  <!-- 01 — EXHIBITION POSTER · kinetic variable-weight display title -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Poster — gallery exhibition, kinetic wght 400→800</span></figcaption>
    <div class="iu__scene scene-tall">
      <div class="exh" data-exh>
        <div class="exh__noise" aria-hidden="true"></div>
        <header class="exh__top">
          <span class="exh__mark"><i class="exh__dot"></i>SYNESTHÉSIE</span>
          <span class="exh__meta">CENTRE D&rsquo;ART · 2026</span>
        </header>

        <div class="exh__hero">
          <span class="exh__kicker">NEW EXHIBITION · FREE ENTRY</span>
          <!-- huge display title; each line breathes the weight axis,
               phase-offset, so the splayed R and clotted a are loudest at peak -->
          <h3 class="exh__title">
            <span class="exh__line" data-flux style="--d:0s">COUNTER</span>
            <span class="exh__line exh__line--accent" data-flux style="--d:-1.8s">FORMS</span>
          </h3>
          <p class="exh__deck">Twelve artists test what a letter can carry when it stops behaving — drawings, sound, and type that argues with the room.</p>
        </div>

        <footer class="exh__foot">
          <span class="exh__when">14 MAR — 09 JUN</span>
          <span class="exh__where">GALLERIES 1—3</span>
        </footer>
      </div>
    </div>
    <p class="iu__hint label">The title swells from regular to Extra Bold across Syne&rsquo;s 400–800 axis, the two lines phase-offset — counters clotting shut at the peak, the splayed R thrown wide. Set huge, the way the face was drawn to argue across a gallery wall.</p>
  </figure>

  <!-- 02 — CULTURAL INSTITUTION IDENTITY · mismatched siblings in one line -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Identity — art-centre brand, mismatched weights side by side</span></figcaption>
    <div class="iu__scene scene-tall">
      <div class="brand" data-brand>
        <header class="brand__top">
          <span class="brand__idx">N<sup>o</sup> 01 — IDENTITY</span>
          <span class="brand__tag">VISUAL SYSTEM</span>
        </header>

        <div class="brand__center">
          <!-- Syne's defining move: an absurdly heavy weight beside a spindly
               light in the SAME wordmark, enjoying the friction -->
          <h3 class="brand__mark" aria-label="Maison Glyphe">
            <span class="brand__w brand__w--thin">maison</span>
            <span class="brand__w brand__w--black">glyphe</span>
          </h3>
          <div class="brand__rule" aria-hidden="true"></div>
          <p class="brand__note">A family of mismatched siblings. We let a spindly Light sit beside a near-black Extra in one line — and enjoy the friction.</p>
        </div>

        <div class="brand__specimen" aria-hidden="true">
          <span class="brand__spec" style="--w:400">Aa</span>
          <span class="brand__spec" style="--w:500">Aa</span>
          <span class="brand__spec" style="--w:600">Aa</span>
          <span class="brand__spec" style="--w:700">Aa</span>
          <span class="brand__spec brand__spec--on" style="--w:800">Aa</span>
        </div>

        <footer class="brand__foot">
          <span>CONTEMPORARY ART · PARIS</span>
          <span class="brand__pal"><i style="--c:var(--accent)"></i><i style="--c:var(--fg)"></i><i style="--c:var(--fg-3)"></i></span>
        </footer>
      </div>
    </div>
    <p class="iu__hint label">The wordmark deliberately clashes — a spindly Light (<b>maison</b>) locked against a clotted Extra Bold (<b>glyphe</b>) in one line, the core of Syne&rsquo;s mismatched-siblings idea. Below, the full 400→800 specimen ladder.</p>
  </figure>

  <!-- 03 — INTERACTIVE arts-festival ticketing microsite (real device scale) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Product UI — arts-festival programme & tickets, real device scale</span></figcaption>
    <div class="iu__scene iu__scene--console">
      <div class="fest" data-fest>
        <div class="fest__bar">
          <span class="fest__logo"><i class="fest__sq"></i>RÉSONANCE&nbsp;FEST</span>
          <span class="fest__edition">3<sup>e</sup> ÉDITION · MARS 2026</span>
        </div>

        <div class="fest__days" role="tablist">
          {days.map((d, i) => (
            <button class={`fest__day ${i === 0 ? 'is-on' : ''}`} data-day={d.id} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>
              <span class="fest__day-dow">{d.dow}</span>
              <span class="fest__day-num">{d.date}</span>
            </button>
          ))}
        </div>

        <div class="fest__body">
          <div class="fest__prog" data-prog>
            <div class="fest__prog-h">
              <div class="fest__prog-hl">
                <span class="fest__prog-day" data-daylabel>{d0.label}</span>
                <span class="fest__prog-now">NOW SHOWING</span>
                <h4 class="fest__headline" data-headline>{d0.sessions[0].title}</h4>
              </div>
              <span class="fest__prog-c"><span data-progcount>{d0.sessions.length}</span> EVENTS</span>
            </div>
            {days.map((d, di) => (
              <div class={`fest__list ${di === 0 ? 'is-on' : ''}`} data-list={d.id}>
                {d.sessions.map((s, i) => (
                  <button
                    class={`fest__row ${s.sold ? 'is-sold' : ''} ${di === 0 && i === 0 ? 'is-sel' : ''}`}
                    data-row data-key={`${d.id}|${i}`}
                    data-title={s.title} data-time={s.t} data-dow={d.dow}
                    data-price={s.price} data-sold={s.sold ? '1' : '0'}
                    aria-pressed={di === 0 && i === 0 ? 'true' : 'false'}
                  >
                    <span class="fest__t">{s.t}</span>
                    <span class="fest__info">
                      <span class="fest__title-r">{s.title}</span>
                      <span class="fest__sub-r"><i class="fest__kind">{s.kind}</i> · {s.venue}</span>
                    </span>
                    <span class="fest__price">{s.sold ? 'SOLD' : s.price === 0 ? 'FREE' : '€' + s.price}</span>
                    <span class="fest__add" aria-hidden="true"></span>
                  </button>
                ))}
              </div>
            ))}
          </div>

          <aside class="fest__cart">
            <span class="fest__cart-h">YOUR PASS</span>
            <div class="fest__cart-list" data-cart>
              <p class="fest__cart-empty" data-empty>Tap an event to add it to your pass.</p>
              <!-- cart items cloned from this hidden template (keeps scoped styles) -->
              <template data-ci-tpl>
                <div class="fest__ci">
                  <span class="fest__ci-meta">
                    <b class="fest__ci-t"></b>
                    <i class="fest__ci-sub"></i>
                  </span>
                  <span class="fest__ci-p"></span>
                  <button class="fest__ci-x" type="button" aria-label="Remove">×</button>
                </div>
              </template>
            </div>
            <div class="fest__cart-foot">
              <div class="fest__total"><span>TOTAL</span><b data-total>€0</b></div>
              <button class="fest__checkout" data-checkout disabled>CHECKOUT</button>
            </div>
          </aside>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Switch day (FRI/SAT/SUN), then tap events to build a festival pass — the basket re-totals live and the count re-keys. Tabular figures keep the time and price columns flush; the heavy display sits in the chrome.</p>
  </figure>

  <!-- 04 — EXPERIMENTAL KINETIC EDITORIAL · pointer-reactive weight -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Editorial — kinetic manifesto, pointer drives the weight axis</span></figcaption>
    <div class="iu__scene scene16">
      <div class="kin" data-kin>
        <div class="kin__rail" aria-hidden="true">
          <span>WGHT</span><span data-wreadout>400</span><span>↦</span><span>800</span>
        </div>
        <div class="kin__stack">
          {manifesto.map((w, i) => (
            <span class={`kin__word kin__word--${i}`} data-word>{w}</span>
          ))}
        </div>
        <p class="kin__caption">Type does not have to behave. Move across it — or wait — and watch the weight clot and thin.</p>
      </div>
    </div>
    <p class="iu__hint label">Move the pointer left→right (or scrub on touch) and Syne&rsquo;s weight axis tracks under your hand, each line lagging the last so the word stack ripples from spindly to near-black. With no pointer it breathes on its own. Reduced-motion holds it at a settled weight.</p>
  </figure>
</div>

<script id="syne-fest-data" type="application/json" set:html={JSON.stringify(days)} is:inline></script>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ===== 03 · arts-festival programme + ticket basket =====
  // Rows are rendered statically (so Astro's scoped grid styles apply); JS only
  // toggles the active day and builds the basket by cloning a styled <template>.
  type Day = { id: string; dow: string; date: string; label: string; sessions: { sold: boolean; title: string }[] };
  const festIsland = document.getElementById('syne-fest-data');
  let days: Day[] = [];
  try { days = festIsland ? JSON.parse(festIsland.textContent || '[]') : []; } catch { days = []; }
  const labelById: Record<string, { label: string; n: number; headline: string }> = {};
  days.forEach((d) => (labelById[d.id] = { label: d.label, n: d.sessions.length, headline: (d.sessions[0]?.title || '') }));

  document.querySelectorAll<HTMLElement>('[data-fest]').forEach((fest) => {
    const dayLabel = fest.querySelector('[data-daylabel]') as HTMLElement;
    const headline = fest.querySelector('[data-headline]') as HTMLElement;
    const progCount = fest.querySelector('[data-progcount]') as HTMLElement;
    const cart = fest.querySelector('[data-cart]') as HTMLElement;
    const totalEl = fest.querySelector('[data-total]') as HTMLElement;
    const checkout = fest.querySelector('[data-checkout]') as HTMLButtonElement;
    const tpl = fest.querySelector('[data-ci-tpl]') as HTMLTemplateElement;
    const emptyEl = cart.querySelector('[data-empty]') as HTMLElement;
    const lists = Array.from(fest.querySelectorAll<HTMLElement>('[data-list]'));
    const rows = Array.from(fest.querySelectorAll<HTMLButtonElement>('[data-row]'));

    // basket keyed by data-key; value carries display fields + the source row
    const basket = new Map<string, { title: string; t: string; dow: string; price: number; row: HTMLButtonElement }>();

    function renderCart() {
      // remove existing cart items (keep the empty <p> and the <template>)
      cart.querySelectorAll('.fest__ci').forEach((n) => n.remove());
      emptyEl.style.display = basket.size === 0 ? '' : 'none';
      basket.forEach((it, key) => {
        const frag = tpl.content.cloneNode(true) as DocumentFragment;
        const node = frag.querySelector('.fest__ci') as HTMLElement;
        (node.querySelector('.fest__ci-t') as HTMLElement).textContent = it.title;
        (node.querySelector('.fest__ci-sub') as HTMLElement).textContent = `${it.dow} · ${it.t}`;
        (node.querySelector('.fest__ci-p') as HTMLElement).textContent = it.price === 0 ? 'FREE' : '€' + it.price;
        (node.querySelector('.fest__ci-x') as HTMLButtonElement).addEventListener('click', () => {
          basket.delete(key);
          it.row.classList.remove('is-sel');
          it.row.setAttribute('aria-pressed', 'false');
          renderCart();
        });
        cart.insertBefore(node, tpl);
      });
      let total = 0; basket.forEach((it) => (total += it.price));
      totalEl.textContent = '€' + total;
      checkout.disabled = basket.size === 0;
      checkout.textContent = basket.size === 0 ? 'CHECKOUT' : `CHECKOUT · ${basket.size}`;
    }

    // promote a title into the big display headline; brief weight punch on change
    let pulseT = 0;
    function setHeadline(title: string) {
      if (!headline || headline.textContent === title) return;
      headline.textContent = title;
      headline.style.fontVariationSettings = "'wght' 820";
      const mine = ++pulseT;
      window.setTimeout(() => { if (mine === pulseT) headline.style.fontVariationSettings = "'wght' 780"; }, 220);
    }

    rows.forEach((row) => {
      if (row.dataset.sold === '1') return;
      const key = row.dataset.key!;
      row.addEventListener('click', () => {
        if (basket.has(key)) {
          basket.delete(key);
          row.classList.remove('is-sel');
          row.setAttribute('aria-pressed', 'false');
        } else {
          basket.set(key, {
            title: row.dataset.title!, t: row.dataset.time!, dow: row.dataset.dow!,
            price: +(row.dataset.price || 0), row,
          });
          row.classList.add('is-sel');
          row.setAttribute('aria-pressed', 'true');
          setHeadline(row.dataset.title!);
        }
        renderCart();
      });
    });

    fest.querySelectorAll<HTMLButtonElement>('[data-day]').forEach((btn) =>
      btn.addEventListener('click', () => {
        const id = btn.dataset.day!;
        fest.querySelectorAll('[data-day]').forEach((b) => { b.classList.remove('is-on'); b.setAttribute('aria-selected', 'false'); });
        btn.classList.add('is-on'); btn.setAttribute('aria-selected', 'true');
        lists.forEach((l) => l.classList.toggle('is-on', l.dataset.list === id));
        const meta = labelById[id];
        if (meta) { dayLabel.textContent = meta.label; progCount.textContent = String(meta.n); setHeadline(meta.headline); }
      })
    );

    // seed the first event into the basket so the live total reads immediately
    const seed = rows.find((r) => r.classList.contains('is-sel'));
    if (seed && seed.dataset.sold !== '1') {
      basket.set(seed.dataset.key!, {
        title: seed.dataset.title!, t: seed.dataset.time!, dow: seed.dataset.dow!,
        price: +(seed.dataset.price || 0), row: seed,
      });
    }
    renderCart();
  });

  // ===== 04 · kinetic manifesto — pointer drives wght, idle breathes =====
  document.querySelectorAll<HTMLElement>('[data-kin]').forEach((kin) => {
    const words = Array.from(kin.querySelectorAll<HTMLElement>('[data-word]'));
    const readout = kin.querySelector('[data-wreadout]') as HTMLElement;
    const MIN = 400, MAX = 800;

    // target weight fraction 0..1 (pointer) and per-word lagging current values
    let target = 0.5;
    let pointerActive = false;
    let idleT = 0;
    const cur = words.map(() => 0.5);

    function apply() {
      words.forEach((w, i) => {
        const wght = Math.round(MIN + cur[i] * (MAX - MIN));
        w.style.fontVariationSettings = `'wght' ${wght}`;
      });
      const lead = Math.round(MIN + cur[0] * (MAX - MIN));
      if (readout) readout.textContent = String(lead);
    }

    kin.addEventListener('pointermove', (e) => {
      const rect = kin.getBoundingClientRect();
      target = Math.min(1, Math.max(0, (e.clientX - rect.left) / rect.width));
      pointerActive = true;
    });
    kin.addEventListener('pointerleave', () => { pointerActive = false; });

    if (reduce) {
      // settled, expressive but static
      target = 0.62;
      cur.forEach((_, i) => (cur[i] = 0.62 - i * 0.12));
      apply();
      return;
    }

    let raf = 0;
    function tick(ts: number) {
      if (!pointerActive) {
        // idle breathing across the axis when no pointer
        idleT = ts / 1000;
        target = 0.5 + 0.42 * Math.sin(idleT * 0.7);
      }
      // each line eases toward target with increasing lag → ripple
      cur.forEach((v, i) => {
        const ease = 0.16 - i * 0.04;
        cur[i] = v + (target - v) * Math.max(0.05, ease);
      });
      apply();
      raf = requestAnimationFrame(tick);
    }
    raf = requestAnimationFrame(tick);

    // pause when offscreen to save cycles
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((ents) => {
        ents.forEach((en) => {
          if (en.isIntersecting) { if (!raf) raf = requestAnimationFrame(tick); }
          else { cancelAnimationFrame(raf); raf = 0; }
        });
      }, { threshold: 0.05 });
      io.observe(kin);
    }
  });
</script>

<style>
  .iu__item { margin: 0; }
  .iu__hint { margin-top: var(--sp-2); color: var(--fg-3); }
  .iu * { font-family: var(--fam); }

  /* shared scene framing — matches space-grotesk.astro / jost.astro */
  .iu__scene {
    container-type: inline-size;
    position: relative;
    border: clamp(22px, 3.4vw, 44px) solid var(--bg-2);
    outline: 1px solid var(--line);
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--bg-2);
  }
  .iu__scene * { font-family: var(--fam); }
  .scene16 { aspect-ratio: 16 / 9; }
  .scene-tall { aspect-ratio: 4 / 5; }
  @container (min-width: 720px) { .scene-tall { aspect-ratio: 5 / 6; } }

  .iu__scene--console { aspect-ratio: 16 / 11; padding: 0; }
  @media (max-width: 680px) { .iu__scene--console { aspect-ratio: 39 / 62; } }

  /* ============================================================
     01 · EXHIBITION POSTER (kinetic variable weight)
     ============================================================ */
  .exh {
    position: absolute; inset: 0; background: var(--bg); color: var(--fg);
    padding: 5cqi 5cqi 4.4cqi; display: flex; flex-direction: column; overflow: hidden;
  }
  .exh__noise {
    position: absolute; inset: 0; pointer-events: none; opacity: 0.5;
    background:
      radial-gradient(60% 50% at 82% 8%, color-mix(in srgb, var(--accent) 22%, transparent) 0%, transparent 60%),
      radial-gradient(70% 55% at 10% 98%, color-mix(in srgb, var(--accent) 10%, transparent) 0%, transparent 55%);
  }
  .exh__top, .exh__hero, .exh__foot { position: relative; }
  .exh__top {
    display: flex; justify-content: space-between; align-items: baseline;
    font-size: 2.1cqi; letter-spacing: 0.16em; text-transform: uppercase; color: var(--fg-2);
    flex: none;
  }
  .exh__mark { display: inline-flex; align-items: center; gap: 1.4cqi; font-weight: 700; color: var(--fg); }
  .exh__dot { width: 1.8cqi; height: 1.8cqi; border-radius: 50%; background: var(--accent); }
  .exh__meta { font-feature-settings: 'tnum'; color: var(--fg-3); }

  .exh__hero { margin: auto 0; }
  .exh__kicker {
    display: block; font-size: 2.2cqi; font-weight: 600; letter-spacing: 0.26em;
    text-transform: uppercase; color: var(--accent); margin-bottom: 2.4cqi;
  }
  .exh__title {
    display: flex; flex-direction: column; gap: 0; line-height: 0.84;
    margin: 0; text-transform: uppercase;
  }
  .exh__line {
    font-size: 15cqi; font-weight: 400; letter-spacing: -0.02em;
    font-variation-settings: 'wght' 480; white-space: nowrap;
  }
  .exh__line--accent { color: var(--accent); }
  .exh__deck {
    font-size: 2.5cqi; line-height: 1.42; color: var(--fg-2); max-width: 78%;
    margin: 3cqi 0 0;
  }
  .exh__foot {
    display: flex; justify-content: space-between; align-items: baseline; flex: none;
    margin-top: 3.4cqi; padding-top: 2.2cqi; border-top: 1px solid var(--line);
    font-size: 2.7cqi; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
    font-feature-settings: 'tnum';
  }
  .exh__where { color: var(--fg-3); font-weight: 600; }

  @media (prefers-reduced-motion: no-preference) {
    .exh__line[data-flux] {
      animation: exh-flux 5.6s cubic-bezier(0.5,0,0.18,1) infinite alternate;
      animation-delay: var(--d, 0s);
    }
    @keyframes exh-flux {
      from { font-variation-settings: 'wght' 400; letter-spacing: -0.005em; }
      to   { font-variation-settings: 'wght' 800; letter-spacing: -0.035em; }
    }
  }

  @container (max-width: 520px) {
    .exh__line { font-size: 17.5cqi; }
    .exh__deck { max-width: 100%; font-size: 3.4cqi; }
    .exh__foot { font-size: 3.4cqi; flex-wrap: wrap; gap: 1cqi; }
  }
  @container (max-width: 360px) {
    .exh__line { font-size: 15cqi; }
  }

  /* ============================================================
     02 · CULTURAL-INSTITUTION IDENTITY (mismatched siblings)
     ============================================================ */
  .brand {
    position: absolute; inset: 0; background: var(--bg); color: var(--fg);
    padding: 5cqi; display: flex; flex-direction: column; overflow: hidden;
  }
  .brand__top {
    display: flex; justify-content: space-between; align-items: baseline; flex: none;
    font-size: 2cqi; letter-spacing: 0.2em; text-transform: uppercase; color: var(--fg-2);
  }
  .brand__idx { font-weight: 600; color: var(--fg); }
  .brand__idx sup { font-size: 0.6em; }
  .brand__tag { color: var(--fg-3); }

  .brand__center { margin: auto 0; }
  .brand__mark { margin: 0; display: flex; flex-direction: column; line-height: 0.86; }
  .brand__w { text-transform: lowercase; letter-spacing: -0.01em; }
  /* the literal Syne move: spindly light beside near-black extra in one mark */
  .brand__w--thin {
    font-size: 13cqi; font-variation-settings: 'wght' 400; font-weight: 400;
    color: var(--fg-2); letter-spacing: 0.04em;
