  }
  .sp-ru__rail { display: flex; flex-direction: column; min-width: 0; }
  .sp-ru__kick {
    font-size: max(11px, 0.85cqi); letter-spacing: 0.18em; text-transform: uppercase;
    color: #b9ad8d;
  }
