  }
  .sp-ru__ruler i::before {
    content: ''; position: absolute; left: 50%; top: -0.62rem;
    width: 1px; height: 0.4rem; background: #8e8467;
  }
  .sp-ru__ruler i:first-of-type { transform: translateX(0); }
  .sp-ru__ruler i:first-of-type::before { left: 0; }
  .sp-ru__ruler i:last-of-type { transform: translateX(-100%); }
  .sp-ru__ruler i:last-of-type::before { left: auto; right: 0; }
  .sp-ru__dot {
