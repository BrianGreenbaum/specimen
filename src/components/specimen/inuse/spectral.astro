  .sp-oh__mast {
    display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;
    padding-bottom: 1rem; border-bottom: 1px solid #eee8d540;
    font-size: max(11px, 0.95cqi);
  }
  .sp-oh__mword { letter-spacing: 0.3em; font-weight: 600; }
  .sp-oh__msub { color: var(--oh-soft); font-style: italic; text-align: center; flex: 1; }
  .sp-oh__missue { color: var(--oh-soft); letter-spacing: 0.08em; }
  .sp-oh__hero { text-align: center; padding: clamp(1.4rem, 3.4cqi, 3rem) 0 clamp(1.2rem, 2.6cqi, 2.2rem); }
  .sp-oh__mark {
