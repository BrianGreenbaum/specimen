---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;
const mono = "'IBM Plex Mono', ui-monospace, monospace";

// ── The sequence ─────────────────────────────────────────────────────────────
// THE QUIET FACE, MEASURED OUT LOUD. Spectral's whole character is evenness —
// the reading grey that survives the backlit screen it was commissioned for
// (Production Type for Google, 2017). So the stack performs evenness five ways:
// the grey itself, as an instrument with a print serif staged beside it (01)
// → the page that grey serves, a Writers-at-Work interview (02) → a press
// that trusts one ligature as its whole identity (03) → the document editor
// it was literally drawn for (04) → the jacket of the novel from act 02,
// a type-only Fitzcarraldo-school cover whose title ligature only this file
// can set (05). Surfaces bookend: dark stage → cream page → moss field →
// token app → ink-blue night. The fiction (Margit Sander / Aftergrass / The
// Meridian Review / Offhand) is one continuous world across the acts.
//
// Honesty notes, verified against the @fontsource/spectral latin woff2s
// (fontTools): static family; loaded weights 300/400/600 roman + 400 italic
// ONLY (italic is never set at any other weight — no synthesis). GSUB carries
// ccmp/dnom/frac/liga/locl/numr/pnum/tnum ONLY — there is NO smcp, NO onum,
// NO dlig, NO sups in this build, and none is claimed anywhere below.
// Default figures are TABULAR lining (every digit advances 500); `pnum` maps
// to the .LP proportional set (one.LP = 425). `liga` is unusually rich:
// fi fl ff ffi ffl ffb ffh ffj ffk fft fb fh fj fk ft — act 03 builds an
// identity on f_f_h, and acts 02/04 let ffl/ft fall naturally in the prose.

// ── Act 01 — the grey of the page, an instrument after Ruder ─────────────────
const distances = [
  { d: 40,  lab: '40 cm', note: 'arm’s length — every counter open.' },
  { d: 100, lab: '1 m',   note: 'across the desk — words dissolving, texture holding.' },
  { d: 200, lab: '2 m',   note: 'across the room — no clots, no rivers.' },
  { d: 300, lab: '3 m',   note: 'gallery distance — one even value of grey.' },
];
const inks = [
  { w: 300, lab: 'Light' },
  { w: 400, lab: 'Regular' },
  { w: 600, lab: 'Semibold' },
];

// ── Act 02 — Writers at Work ─────────────────────────────────────────────────
// q/a strings may be arrays: string segments + { lig: word } markers that the
// template wraps in a dotted-rule span (the "note on the type" apparatus).
type Seg = string | { lig: string };
const qa: { id: string; q: Seg[] | string; a: Seg[] | string }[] = [
  {
    id: 'q1',
    q: ['It has been four years since ', { lig: 'Aftergrass' }, '. Where does a novel begin for you?'],
    a: 'In a sentence I can’t get rid of. Not an idea — ideas are cheap and arrive in crowds. A sentence with the right weight turns up and refuses to leave, and the book is whatever I have to build so that it can live somewhere. The new one began with a man saying “we were never properly introduced” to his own brother. That cost me a winter.',
  },
  {
    id: 'q2',
    q: 'Critics keep calling your prose plain. Does the word bother you?',
    a: 'It used to. Now I take it as a technical report. Plain is what conviction looks like once the effort has been paid off the page. I revise toward evenness — I want the page to be a level grey from across the room, no sentence putting up its hand. Anything that glitters in a paragraph is usually asking the reader to admire me, and the reader has better things to do.',
  },
  {
    id: 'q3',
    q: 'You draft by hand and revise on a screen. Which version is the book?',
    a: 'Neither. The book is the third thing, the one the reader sets. My pages are a score. I am calm about this — type has carried other people’s voices for five hundred years and does not need my supervision. I ask only that it be set in something that doesn’t fidget.',
  },
  {
    id: 'q4',
    q: 'What do you read while you are writing?',
    a: ['Field guides. Ferry timetables. Anything with the courage to be useful. Fiction is dangerous while the cement is wet — another writer’s rhythm gets into your wrists. A timetable never ', { lig: 'afflicted' }, ' anybody’s style.'],
  },
];
const seg = (s: Seg[] | string) => (Array.isArray(s) ? s : [s]);

// ── Act 04 — the document editor (the 2017 commission) ──────────────────────
const outline = [
  { id: 'o1', label: 'A field for slow attention', lvl: 1 },
  { id: 'o2', label: 'The page as an instrument', lvl: 2 },
  { id: 'o3', label: 'What a serif is for', lvl: 2 },
  { id: 'o4', label: 'Notes & sources', lvl: 1 },
];

// ── Act 05 — the Aftergrass jacket (replaces the transit poem; jury redirect) ─
const praise = [
  {
    q: '“She revises toward evenness, and the result is a level grey from across the room — not one sentence raising its hand.”',
    by: 'The Meridian Review',
  },
  {
    q: '“Plain the way a field is plain: alive at every inch you care to kneel and look.”',
    by: 'Offhand, a journal of the essay',
  },
  {
    q: '“Our finest noticer of weather and of grief.”',
    by: 'The Lund Courier',
  },
];
---

<div class="iu sp" style={`--fam:${fam}; --mono:${mono}`}>

  <!-- ════════════════════════════════════════════════════════════════════
       01 · INTERACTIVE & EXPERIMENTAL — the grey of the page.
       Reference: Emil Ruder's grey-value texture studies at the Basel
       school (collected in Typographie, 1967) — the paragraph composed as
       a woven value of grey, judged from across the room. Built as a live
       instrument: a set page on a dark stage, three inks from Spectral's
       static weights, and four viewing distances driven by the user.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click="[data-cmp]">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Experimental — the grey of the page, an instrument after Ruder</span></figcaption>
    <div class="iu__scene sp-ru">
      <div class="sp-ru__in" data-ru>
        <aside class="sp-ru__rail">
          <span class="sp-ru__kick">After Emil Ruder &middot; Basel, 1967</span>
          <h3 class="sp-ru__title">The grey of the page</h3>
          <p class="sp-ru__lede">Ruder taught the paragraph as a woven value of grey — warp of black, weft of white — judged from across the room, where the words give out and only the weave remains. Spectral&rsquo;s entire brief was that weave: a grey tuned to hold on backlit glass.</p>
          <div class="sp-ru__group" role="group" aria-label="Ink weight">
            <span class="sp-ru__lab">Ink</span>
            <div class="sp-ru__seg">
              {inks.map((k, i) => (
                <button type="button" class={i === 1 ? 'is-on' : ''} data-w={k.w}><b>{k.w}</b>{k.lab}</button>
              ))}
            </div>
          </div>
          <div class="sp-ru__group" role="group" aria-label="Viewing distance">
            <span class="sp-ru__lab">Distance</span>
            <div class="sp-ru__seg">
              {distances.map((s, i) => (
                <button type="button" class={i === 0 ? 'is-on' : ''} data-d={s.d} data-note={s.note}>{s.lab}</button>
              ))}
            </div>
          </div>
          <div class="sp-ru__group">
            <span class="sp-ru__lab">Control</span>
            <button type="button" class="sp-ru__cmp" data-cmp aria-pressed="false">Beside a print-era serif</button>
          </div>
          <p class="sp-ru__read">At <b data-dout>40&nbsp;cm</b> the 15.5&nbsp;px body reads as <b data-aout>&asymp;&nbsp;15.5&nbsp;px</b>, the column sampling to <b data-ink>—&nbsp;%</b> ink.<i data-vout>arm&rsquo;s length — every counter open.</i></p>
        </aside>
        <div class="sp-ru__stage">
          <div class="sp-ru__pagebox">
            <div class="sp-ru__pages">
              <div class="sp-ru__pagewrap">
                <div class="sp-ru__page" data-rupage>
                  <span class="sp-ru__ph">On the evenness of grey</span>
                  <div class="sp-ru__cols">
                    <p>A text face is judged at the distance where its letters stop being letters. Stand back from a well-set page and the words dissolve into a value of grey — and that grey is the typeface, more truly than any single letter is. Where the value is even, the page reads; where it clots or pales, the reading stumbles.</p>
                    <p>Ruder asked his students to compose with this in mind: to see the paragraph as cloth, and to weave it level. The exercise survives every technology of the page. A screen only raises the stakes — backlight floods the counters, hairlines drop below the pixel, and an uneven grey turns to static.</p>
                    <p>Spectral was drawn against exactly that hazard: a tall lowercase, open counters, contrast judged to the rendering engine rather than the printing press. Step back. The words go first; the grey stays.</p>
                  </div>
                </div>
                <span class="sp-ru__pglab">Spectral — drawn for the screen, 2017</span>
              </div>
              <div class="sp-ru__pagewrap sp-ru__pagewrap--cmp">
                <div class="sp-ru__page sp-ru__page--cmp" data-rupage>
                  <span class="sp-ru__ph">On the evenness of grey</span>
                  <div class="sp-ru__cols">
                    <p>A text face is judged at the distance where its letters stop being letters. Stand back from a well-set page and the words dissolve into a value of grey — and that grey is the typeface, more truly than any single letter is. Where the value is even, the page reads; where it clots or pales, the reading stumbles.</p>
                    <p>Ruder asked his students to compose with this in mind: to see the paragraph as cloth, and to weave it level. The exercise survives every technology of the page. A screen only raises the stakes — backlight floods the counters, hairlines drop below the pixel, and an uneven grey turns to static.</p>
                    <p>Spectral was drawn against exactly that hazard: a tall lowercase, open counters, contrast judged to the rendering engine rather than the printing press. Step back. The words go first; the grey stays.</p>
                  </div>
                </div>
                <span class="sp-ru__pglab">Times New Roman — cut for newsprint, 1932</span>
              </div>
            </div>
            <p class="sp-ru__ink" aria-hidden="true">page value <b data-inkstamp>—&nbsp;%</b> ink &middot; sampled from the set column</p>
          </div>
          <div class="sp-ru__ruler" aria-hidden="true">
            <span class="sp-ru__dot" data-rudot></span>
            {distances.map((s) => <i style={`--x:${((s.d - 40) / 260) * 100}%`}>{s.lab}</i>)}
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Emil Ruder set his Basel students to compose paragraphs as values of grey and judge them from across the room. Here the exercise is live: step the viewing distance back and the 15.5&nbsp;px page recedes to true apparent size; the ink value on the read-out is sampled from the actual set column, not asserted. Switch the ink between Spectral&rsquo;s 300, 400 and 600 — the value changes, the evenness doesn&rsquo;t. Then stage the same paragraph beside Times New Roman, a serif cut for newsprint: at 2&nbsp;m the screen-tuned page holds one level grey while the print face goes pale and patchy. The claim is shown, not told.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       02 · EDITORIAL — Writers at Work.
       Reference: The Paris Review's "The Art of Fiction" interviews
       (founded 1953, George Plimpton) — the most durable typographic
       system in literary publishing: letterspaced caps for the speakers,
       italic for the questions, roman for the answers, a book page's
       quiet apparatus. Hover or tap a question and the answer it
       provoked takes the margin line.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click="[data-q='q2']">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Editorial — Writers at Work, the interview as a typographic system</span></figcaption>
    <div class="iu__scene sp-pr">
      <article class="sp-pr__page">
        <header class="sp-pr__rh">
          <span>THE MERIDIAN REVIEW</span>
          <span class="sp-pr__rhm">WRITERS AT WORK</span>
          <span class="sp-pr__folio">64</span>
        </header>
        <div class="sp-pr__open">
          <span class="sp-pr__series">The Art of Fiction No. 213</span>
          <h3 class="sp-pr__name">Margit Sander</h3>
          <span class="sp-pr__openrule" aria-hidden="true"></span>
        </div>
        <p class="sp-pr__intro">Margit Sander lives ten minutes from the cathedral in Lund, in a flat where the only visible technology is a telephone from 1986. This interview took place over two mornings at her kitchen table, between pots of black coffee; she answered most questions twice, the second time more slowly. Sander is the author of six novels, among them <em>The Standing Water</em> (2014) and <em class="sp-pr__ligw">Aftergrass</em> (2021), and of <em>The Borrowed Light</em> (2017), her essays on reading.</p>
        <div class="sp-pr__qa">
          {qa.slice(0, 2).map((p) => (
            <>
              <div class="sp-pr__q" data-q={p.id} tabindex="0"><span class="sp-pr__who">Interviewer</span><p><em>{seg(p.q).map((s) => (typeof s === 'string' ? s : <span class="sp-pr__ligw">{s.lig}</span>))}</em></p></div>
              <div class="sp-pr__a" data-a={p.id}><span class="sp-pr__who">Sander</span><p>{seg(p.a).map((s) => (typeof s === 'string' ? s : <span class="sp-pr__ligw">{s.lig}</span>))}</p></div>
            </>
          ))}
          <blockquote class="sp-pr__pull" data-reveal><span class="sp-pr__pullq" aria-hidden="true">&ldquo;</span>By the time a sentence reaches you it should weigh nothing. The weight is spent in the making.<span class="sp-pr__pullq sp-pr__pullq--c" aria-hidden="true">&rdquo;</span></blockquote>
          {qa.slice(2).map((p) => (
            <>
              <div class="sp-pr__q" data-q={p.id} tabindex="0"><span class="sp-pr__who">Interviewer</span><p><em>{seg(p.q).map((s) => (typeof s === 'string' ? s : <span class="sp-pr__ligw">{s.lig}</span>))}</em></p></div>
              <div class="sp-pr__a" data-a={p.id}><span class="sp-pr__who">Sander</span><p>{seg(p.a).map((s) => (typeof s === 'string' ? s : <span class="sp-pr__ligw">{s.lig}</span>))}</p></div>
            </>
          ))}
        </div>
        <footer class="sp-pr__foot">
          <span class="sp-pr__sig">— Interviewed by Tomas Hellqvist &middot; Lund, March 2026</span>
          <span class="sp-pr__footnote"><em>A note on the type:</em> set in Spectral. Where a dotted rule falls — the <em>ft</em> of <span class="sp-pr__ligw">Aftergrass</span>, the <em>ffl</em> of <span class="sp-pr__ligw">afflicted</span> — the letters have fused into a single glyph.</span>
        </footer>
      </article>
    </div>
    <p class="iu__hint label">After the Paris Review&rsquo;s &ldquo;Art of Fiction&rdquo; interviews (since 1953): letterspaced caps name the speakers, the questions take Spectral&rsquo;s true italic, the answers run roman — a system, not a styling. Hover or tap a question and the margin rule draws down the answer it provoked. The page carries its own apparatus: a note on the type marks where the <em>ft</em> of Aftergrass and the <em>ffl</em> of afflicted fall as single glyphs, dotted on the page itself.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       03 · BRANDING & IDENTITY — Offhand, a journal of the essay.
       Reference: the contemporary single-serif magazine identity — The
       Gentlewoman (Jop van Bennekom & Penny Martin, 2010) and its school,
       where one quietly-set text face IS the brand. Offhand goes a step
       further: its mark is a single glyph, the f_f_h ligature few faces
       carry. Flip the wordmark to three letters and the logo dissolves —
       the identity lives in the font file.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed" data-shoot-click="[data-liga-btn]">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Branding — Offhand, an identity built on one ligature</span></figcaption>
    <div class="iu__scene sp-oh" data-oh>
      <div class="sp-oh__in">
        <header class="sp-oh__mast">
          <span class="sp-oh__mword">OFFHAND</span>
          <span class="sp-oh__msub">a journal of the essay &middot; founded 2021 &middot; London &amp; Rotterdam</span>
          <span class="sp-oh__missue">No. 9 &middot; Winter 2026</span>
        </header>
        <div class="sp-oh__hero">
          <h3 class="sp-oh__mark" data-mark><span>O</span><span class="sp-oh__lig">ffh</span><span>and</span></h3>
          <div class="sp-oh__annorow">
            <span class="sp-oh__annoline" aria-hidden="true"></span>
            <p class="sp-oh__anno"><b data-anno-title>One glyph.</b> <span data-anno>f, f and h taken in a single gesture — the ligature few faces carry, and the only logo this house owns.</span></p>
          </div>
        </div>
        <div class="sp-oh__apps">
          <div class="sp-oh__app sp-oh__app--spine">
            <span class="sp-oh__spine"><b class="sp-oh__lig2">Offh</b>and &middot; No. 9<span class="sp-oh__spinemore"> &middot; The Slow Essay &middot; Winter 2026</span></span>
            <i class="sp-oh__applab">the spine</i>
          </div>
          <div class="sp-oh__app sp-oh__app--card">
            <div class="sp-oh__card">
              <span class="sp-oh__mono">ffh</span>
              <span class="sp-oh__cardline">Subscriber 0214</span>
              <span class="sp-oh__cardsub">two years &middot; eight issues &middot; the annual letter</span>
            </div>
            <i class="sp-oh__applab">the subscriber card</i>
          </div>
          <div class="sp-oh__app sp-oh__app--web">
            <div class="sp-oh__webbar">
              <span class="sp-oh__weblogo"><b class="sp-oh__lig2">Offh</b>and</span>
              <nav class="sp-oh__webnav" aria-hidden="true"><span>Essays</span><span>Letters</span><span>Archive</span><span class="sp-oh__webcta">Subscribe</span></nav>
            </div>
            <div class="sp-oh__webbody" aria-hidden="true">
              <span class="sp-oh__webkick">This week</span>
              <span class="sp-oh__webhead">The case for rereading badly</span>
              <span class="sp-oh__webby"><em>by Anneke Vos</em> &middot; 14 min</span>
            </div>
            <i class="sp-oh__applab">offhand.press</i>
          </div>
        </div>
        <footer class="sp-oh__rules">One typeface at every size &middot; two inks, moss and unbleached cream &middot; the ligature is the logo</footer>
      </div>
    </div>
    <p class="iu__hint label">In the school of The Gentlewoman (2010) — magazines whose entire identity is one well-mannered serif — Offhand trusts its name to a single glyph: the <em>ffh</em> ligature, which Spectral carries and most faces don&rsquo;t. The same glyph runs the masthead, the spine, the subscriber card and the site; this identity cannot be re-set in another font, which is the point. <button type="button" class="sp-oh__flip" data-liga-btn aria-pressed="false">Set as three letters</button></p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       04 · WEB & APP UI — the document editor. Real px, user-driven.
       Reference: the artifact Spectral was literally commissioned for —
       Google Docs (Production Type for Google, 2017) — crossed with the
       focused-writing current of iA Writer. Live size and leading on real
       prose, an outline that tracks the scroll, a measure read-out, and a
       serif toggle that shows what the face is buying the page.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item" data-shoot-click="[data-serif]">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Product UI — the document editor it was drawn for (real scale, interactive)</span></figcaption>
    <div class="iu__scene sp-ed-scene">
      <div class="sp-device ed" data-ed>
        <header class="ed__rh">
          <span class="ed__brand"><em>folio</em>press</span>
          <span class="ed__crumb">Drafts &middot; On Reading Slowly <i>— draft</i></span>
          <span class="ed__fol">fol. <b data-fol>1</b> of <b data-fols>2</b></span>
        </header>
        <div class="ed__bar">
          <div class="ed__tools" role="group" aria-label="Type controls">
            <span class="ed__field">
              <button class="ed__step" data-size="-" aria-label="Smaller text">A−</button>
              <span class="ed__val"><i data-size-out>18</i>px</span>
              <button class="ed__step" data-size="+" aria-label="Larger text">A+</button>
            </span>
            <span class="ed__field">
              <span class="ed__flab">Leading</span>
              <input type="range" class="ed__range" data-leading min="130" max="190" step="2" value="166" aria-label="Line height" />
              <span class="ed__val"><i data-leading-out>1.66</i></span>
            </span>
            <button class="ed__toggle" data-serif aria-pressed="true"><span class="ed__dot" aria-hidden="true"></span>Spectral</button>
          </div>
        </div>
        <div class="ed__body">
          <nav class="ed__outline" data-outline>
            <span class="ed__outh">Outline</span>
            {outline.map((o) => (
              <a class={`ed__oitem ed__oitem--l${o.lvl}`} data-jump={o.id}>{o.label}</a>
            ))}
            <div class="ed__measure" aria-hidden="true">
              <span class="ed__mh">Measure</span>
              <span class="ed__mval"><b data-cpl>66</b><i>chars / line</i></span>
              <span class="ed__mbar"><span class="ed__mfill" data-mfill></span></span>
              <span class="ed__mh ed__mh--d" data-dlab>vs. Outfit</span>
              <span class="ed__dval">would set <b data-cpl2>—</b> cpl, <i data-dlines>—</i></span>
            </div>
          </nav>
          <article class="ed__page" data-page tabindex="0">
            <h1 class="ed__h1" id="o1">A field for slow attention</h1>
            <p class="ed__lede">There is a kind of reading the web rarely asks of us any more — the unhurried, continuous kind, where a paragraph is allowed to become a thought. A page set for that kind of reading is doing quiet, deliberate work.</p>
            <h2 class="ed__h2" id="o2">The page as an instrument</h2>
            <p data-probe>Set a measure of roughly 66 characters, give the lines a little air, and the eye stops noticing the type at all. Beatrice Warde called that disappearance <em>the crystal goblet</em> — printing that holds the wine without colouring it — and a face drawn for documents earns its keep exactly there, holding an even colour down a column of prose without a single letter raising its voice.</p>
            <p>Type made for the screen has to survive backlit glass at small sizes, where hairlines thin to nothing and tight counters flood with light. The answer was never to imitate print, but to retune it — a taller lowercase, opener spacing, contrast judged <em>to render</em> rather than to impress.</p>
            <h2 class="ed__h2" id="o3">What a serif is for</h2>
            <p>The little feet at the ends of the strokes are not decoration. They knit one letter to the next along the baseline, building what the old compositors knew as <em>the current of the line</em> — the horizontal pull the eye rides from word to word. Five centuries of reading pages have been built on that current, and it carries just as well through a browser.</p>
            <h2 class="ed__h2" id="o4">Notes &amp; sources</h2>
            <p class="ed__note">Drafted in 2026. See also the companion essay on measure, and the long-standing argument that <em>legibility is a habit</em> as much as a property of the letters themselves.</p>
            <div class="ed__ghostwrap" aria-hidden="true">
              <p class="ed__ghost" data-ghost>Set a measure of roughly 66 characters, give the lines a little air, and the eye stops noticing the type at all. Beatrice Warde called that disappearance the crystal goblet — printing that holds the wine without colouring it — and a face drawn for documents earns its keep exactly there, holding an even colour down a column of prose without a single letter raising its voice.</p>
            </div>
          </article>
        </div>
        <div class="ed__foot">
          <span class="ed__stat"><b data-words>312</b> words</span>
          <span class="ed__stat ed__stat--mid"><b data-chars>1,840</b> characters</span>
          <span class="ed__stat ed__read"><b data-read>2</b> min read</span>
          <span class="ed__saved" data-saved>Saved</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">The artifact this face was commissioned for: Spectral was drawn by Production Type for Google in 2017 as a serif for Docs and the web. Foliopress dresses the editor as a book — a running head under a double rule, a live folio instead of a tab bar. Drag the leading, step the size, jump via the outline; the measure panel prices the typeface in data, quoting what the same paragraph <em>would</em> set in Outfit before you ever flip the toggle. Then flip <b>Spectral → Outfit</b> and watch the quoted cost land on the page: more characters per line, fewer lines, the even reading colour gone.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       05 · ILLUSTRATION & COMMERCIAL — the Aftergrass jacket.
       (Replaces the transit poem per jury redirect — strictly stronger:
       the act-02 fiction swept into a commercial artifact only this font
       file can set.) Reference: Fitzcarraldo Editions (Ray O'Meara, since
       2014) — the type-only literary jacket, one serif and one blue
       carrying the whole list. The unfolded jacket laid flat: back board,
       spine, front board. The title's ft falls as a single glyph at
       display scale (f_t verified in the GSUB); the praise runs in
       Spectral's true italic with hung quotes; the spine whispers in the
       300 Light. One motion idea: the jacket settles flat on scroll.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">05</span><span class="label">Commercial — the Aftergrass jacket, a type-only cover after Fitzcarraldo</span></figcaption>
    <div class="iu__scene sp-bk">
      <div class="sp-bk__lay">
        <div class="sp-bk__panel sp-bk__back" data-reveal>
          <span class="sp-bk__bkick">Praise for Margit Sander</span>
          {praise.map((p) => (
            <blockquote class="sp-bk__q">{p.q}<cite>— {p.by}</cite></blockquote>
          ))}
          <p class="sp-bk__bblurb">A man returns to the farm his brother kept, in the first dry summer anyone can remember, and finds the field has a memory of its own: <em>aftergrass</em>, the finer second growth that comes up after the mowing. Sander&rsquo;s sixth novel begins with one sentence — <em>we were never properly introduced</em> — and spends a year of weather finding out what it costs.</p>
          <div class="sp-bk__bfoot">
            <span class="sp-bk__isbn">ISBN 978&#8209;1&#8209;83668&#8209;214&#8209;7<i>Fiction &middot; &pound;12.99</i></span>
            <span class="sp-bk__bar" aria-hidden="true"></span>
          </div>
        </div>
        <div class="sp-bk__panel sp-bk__spine" data-reveal>
          <span class="sp-bk__spinetext"><b>Aftergrass</b> &middot; Margit Sander</span>
          <span class="sp-bk__spinemark">ALDER</span>
        </div>
        <div class="sp-bk__panel sp-bk__front" data-reveal>
          <span class="sp-bk__kick">a novel</span>
          <h3 class="sp-bk__title">After<br />grass</h3>
          <span class="sp-bk__rule" aria-hidden="true"></span>
          <span class="sp-bk__author">Margit Sander</span>
          <span class="sp-bk__pub">Alder Editions</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">After Fitzcarraldo Editions (Ray O&rsquo;Meara, since 2014) — the type-only literary jacket, one serif and one blue carrying an entire list. The novel is <em>Aftergrass</em>, from act 02&rsquo;s interview, and the jacket is an artifact only this font file can set: the <em>ft</em> of the title falls as a single glyph at display scale, the word broken <em>After / grass</em> on its own seam; the praise — from The Meridian Review and Offhand, the journal of act 03 — runs in Spectral&rsquo;s true italic with hung quotation marks; the spine whispers in the 300 Light. The jacket settles flat as you arrive.</p>
  </figure>

</div>

<script>
  // ── 01 · the Ruder instrument: ink + distance + sampled grey + compare ───
  document.querySelectorAll<HTMLElement>('[data-ru]').forEach((ru) => {
    const pages = Array.from(ru.querySelectorAll<HTMLElement>('[data-rupage]'));
    const spectralPage = pages[0]!;
    const dot = ru.querySelector<HTMLElement>('[data-rudot]');
    const dout = ru.querySelector<HTMLElement>('[data-dout]')!;
    const aout = ru.querySelector<HTMLElement>('[data-aout]')!;
    const vout = ru.querySelector<HTMLElement>('[data-vout]')!;
    const inkOut = ru.querySelector<HTMLElement>('[data-ink]');
    const inkStamp = ru.querySelector<HTMLElement>('[data-inkstamp]');
    const BODY = 15.5; // the page's set size, px
    const dBtns = Array.from(ru.querySelectorAll<HTMLButtonElement>('[data-d]'));
    const wBtns = Array.from(ru.querySelectorAll<HTMLButtonElement>('[data-w]'));
    let curD = 40;
    let curW = 400;

    // the ink value is SAMPLED, not asserted: the column's own text is set on
    // a canvas in the same face/size/leading and the dark fraction is counted.
    const inkCache: Record<number, number> = {};
    const updateInk = async () => {
      const w = curW;
      if (!(w in inkCache)) {
        try { await (document as any).fonts.load(`${w} 15.5px Spectral`); } catch {}
        const FS = 15.5, LH = 24, W = 520;
        const text = (spectralPage.querySelector('.sp-ru__cols')?.textContent || '')
          .replace(/\s+/g, ' ').trim();
        const c = document.createElement('canvas');
        const x = c.getContext('2d', { willReadFrequently: true });
        if (!x) return;
        x.font = `${w} ${FS}px Spectral`;
        const lines: string[] = [];
        let line = '';
        for (const wd of text.split(' ')) {
          const t = line ? line + ' ' + wd : wd;
          if (x.measureText(t).width > W && line) { lines.push(line); line = wd; }
          else line = t;
        }
        if (line) lines.push(line);
        const H = lines.length * LH;
        c.width = W; c.height = H;
        x.fillStyle = '#fff'; x.fillRect(0, 0, W, H);
        x.fillStyle = '#000'; x.font = `${w} ${FS}px Spectral`; x.textBaseline = 'alphabetic';
        lines.forEach((ln, i) => x.fillText(ln, 0, (i + 1) * LH - 6));
        const px = x.getImageData(0, 0, W, H).data;
        let ink = 0;
        for (let i = 0; i < px.length; i += 4) ink += 1 - px[i] / 255;
        inkCache[w] = (ink / (px.length / 4)) * 100;
      }
      if (w !== curW) return; // a newer request superseded this one
      const v = `${inkCache[w].toFixed(1)} %`;
      if (inkOut) inkOut.textContent = v;
      if (inkStamp) inkStamp.textContent = v;
    };

    const setD = (btn: HTMLButtonElement) => {
      const d = parseInt(btn.dataset.d!, 10);
      curD = d;
      const s = 40 / d;
      pages.forEach((p) => { p.style.transform = `scale(${s.toFixed(4)})`; });
      ru.classList.toggle('is-far', d >= 200);
      if (dot) dot.style.left = `${(((d - 40) / 260) * 100).toFixed(1)}%`;
      dout.textContent = btn.textContent || '';
      aout.textContent = `≈ ${(BODY * s).toFixed(1)} px`;
      vout.textContent = btn.dataset.note || '';
      dBtns.forEach((b) => {
        b.classList.toggle('is-on', b === btn);
        b.setAttribute('aria-pressed', String(b === btn));
      });
    };
    dBtns.forEach((b) => b.addEventListener('click', () => setD(b)));
    wBtns.forEach((b) => b.addEventListener('click', () => {
      curW = parseInt(b.dataset.w!, 10);
      spectralPage.style.fontWeight = b.dataset.w!; // the print serif stays at its 400
      wBtns.forEach((x) => {
        x.classList.toggle('is-on', x === b);
        x.setAttribute('aria-pressed', String(x === b));
      });
      updateInk();
    }));

    // compare: stage Times beside Spectral; the judgement distance is 2 m,
    // so enabling the comparison steps back there if you are still close.
    const cmpBtn = ru.querySelector<HTMLButtonElement>('[data-cmp]');
    cmpBtn?.addEventListener('click', () => {
      const on = ru.classList.toggle('is-cmp');
      cmpBtn.setAttribute('aria-pressed', String(on));
      if (on && curD < 200) {
        const b = dBtns.find((x) => x.dataset.d === '200');
        if (b) setD(b);
      }
      // the comparison is only honest from across the room — park the near steps
      dBtns.forEach((b) => { b.disabled = on && parseInt(b.dataset.d!, 10) < 200; });
    });

    updateInk();
  });

  // ── 02 · question ↔ answer crosslight ────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.sp-pr__page').forEach((pg) => {
    const light = (id: string | undefined, on: boolean) => {
      if (!id) return;
      pg.querySelectorAll<HTMLElement>(`[data-q='${id}'], [data-a='${id}']`)
        .forEach((el) => el.classList.toggle('is-lit', on));
    };
    const clear = () => pg.querySelectorAll('.is-lit').forEach((el) => el.classList.remove('is-lit'));
    pg.querySelectorAll<HTMLElement>('[data-q]').forEach((q) => {
      const id = q.dataset.q;
      q.addEventListener('pointerenter', () => { clear(); light(id, true); });
      q.addEventListener('pointerleave', () => light(id, false));
      q.addEventListener('focus', () => { clear(); light(id, true); });
      q.addEventListener('blur', () => light(id, false));
      q.addEventListener('click', () => { clear(); light(id, true); });
    });
  });

  // ── 03 · the wordmark flips: one glyph ↔ three letters ───────────────────
  // (the control lives on the hint line, outside the identity board)
  document.querySelectorAll<HTMLElement>('[data-oh]').forEach((oh) => {
    const btn = oh.closest('figure')?.querySelector<HTMLButtonElement>('[data-liga-btn]');
    if (!btn) return;
    const annoTitle = oh.querySelector<HTMLElement>('[data-anno-title]')!;
    const anno = oh.querySelector<HTMLElement>('[data-anno]')!;
    btn.addEventListener('click', () => {
      const apart = oh.classList.toggle('is-apart');
      btn.setAttribute('aria-pressed', String(apart));
      btn.textContent = apart ? 'Set as one glyph' : 'Set as three letters';
      annoTitle.textContent = apart ? 'Three letters.' : 'One glyph.';
      anno.textContent = apart
        ? 'switch the ligature off and the mark dissolves into typing — the identity lives in the font file, nowhere else.'
        : 'f, f and h taken in a single gesture — the ligature few faces carry, and the only logo this house owns.';
    });
  });

  // ── scroll-into-view reveal (the pull quote) ──────────────────────────────
  {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const targets = document.querySelectorAll<HTMLElement>('[data-reveal]');
    if (reduce || !('IntersectionObserver' in window)) {
      targets.forEach((t) => { t.classList.add('in'); t.removeAttribute('data-reveal'); });
    } else {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { (e.target as HTMLElement).classList.add('in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.4 });
      targets.forEach((t) => io.observe(t));
    }
  }

  // ── 04 · the editor: size / leading / outline / live counts ──────────────
  document.querySelectorAll<HTMLElement>('[data-ed]').forEach((ed) => {
    const page = ed.querySelector<HTMLElement>('[data-page]')!;
    const sizeOut = ed.querySelector<HTMLElement>('[data-size-out]')!;
    const leadOut = ed.querySelector<HTMLElement>('[data-leading-out]')!;
    const leadIn = ed.querySelector<HTMLInputElement>('[data-leading]')!;
    const wordsEl = ed.querySelector<HTMLElement>('[data-words]')!;
    const charsEl = ed.querySelector<HTMLElement>('[data-chars]')!;
    const readEl = ed.querySelector<HTMLElement>('[data-read]')!;
    const saved = ed.querySelector<HTMLElement>('[data-saved]')!;
    let size = 18;

    const fmt = (n: number) => n.toLocaleString('en-US');
    const applySize = () => {
      page.style.setProperty('--ed-fs', `${size}px`);
      sizeOut.textContent = String(size);
    };
    const applyLead = () => {
      const lh = (+leadIn.value / 100);
      page.style.setProperty('--ed-lh', String(lh));
      leadOut.textContent = lh.toFixed(2);
    };

    const countSrc = page.querySelectorAll('p, h1, h2');
    const recount = () => {
      let text = '';
      countSrc.forEach((n) => { text += ' ' + (n.textContent || ''); });
      text = text.replace(/\s+/g, ' ').trim();
      const words = text ? text.split(' ').length : 0;
      const chars = text.replace(/\s/g, '').length;
      wordsEl.textContent = fmt(words);
      charsEl.textContent = fmt(chars);
      readEl.textContent = String(Math.max(1, Math.round(words / 200)));
    };

    let savedT: number | undefined;
    const flashSaved = () => {
      saved.textContent = 'Saving…';
      saved.classList.add('is-busy');
      window.clearTimeout(savedT);
      savedT = window.setTimeout(() => {
        saved.textContent = 'Saved';
        saved.classList.remove('is-busy');
      }, 600);
    };

    ed.querySelectorAll<HTMLButtonElement>('[data-size]').forEach((btn) =>
      btn.addEventListener('click', () => {
        size = Math.min(28, Math.max(13, size + (btn.dataset.size === '+' ? 1 : -1)));
        applySize();
        flashSaved();
        requestAnimationFrame(measure);
      })
    );
    leadIn.addEventListener('input', () => { applyLead(); flashSaved(); requestAnimationFrame(measure); });

    const serifBtn = ed.querySelector<HTMLButtonElement>('[data-serif]');
    const serifLabel = serifBtn?.lastChild;
    serifBtn?.addEventListener('click', () => {
      const off = ed.toggleAttribute('data-serif-off');
      serifBtn.setAttribute('aria-pressed', String(!off));
      if (serifLabel) serifLabel.textContent = off ? 'Outfit' : 'Spectral';
      flashSaved();
      requestAnimationFrame(measure);
    });

    // live "characters per line" — counted from real rendered lines, and the
    // same paragraph laid out invisibly in Outfit so the read-out can quote
    // the measured cost of losing Spectral before the toggle is ever flipped.
    const cpl = ed.querySelector<HTMLElement>('[data-cpl]');
    const cpl2 = ed.querySelector<HTMLElement>('[data-cpl2]');
    const dlines = ed.querySelector<HTMLElement>('[data-dlines]');
    const dlab = ed.querySelector<HTMLElement>('[data-dlab]');
    const mfill = ed.querySelector<HTMLElement>('[data-mfill]');
    const probe = page.querySelector<HTMLElement>('[data-probe]');
    const ghost = page.querySelector<HTMLElement>('[data-ghost]');
    const measure = () => {
      if (!cpl || !mfill || !probe) return;
      const cs = getComputedStyle(probe);
      const lh = parseFloat(cs.lineHeight) || 1;
      const chars = (probe.textContent || '').length;
      const sLines = Math.max(1, Math.round(probe.getBoundingClientRect().height / lh));
      const sCpl = Math.round(chars / sLines);
      cpl.textContent = String(sCpl);
      const pct = Math.max(6, Math.min(100, ((sCpl - 30) / (90 - 30)) * 100));
      mfill.style.width = pct + '%';
      mfill.classList.toggle('is-ideal', sCpl >= 50 && sCpl <= 78);
      if (ghost && cpl2 && dlines) {
        const gLines = Math.max(1, Math.round(ghost.getBoundingClientRect().height / lh));
        cpl2.textContent = String(Math.round(chars / gLines));
        const d = sLines - gLines;
        dlines.textContent = d === 0
          ? 'the same depth'
          : `${Math.abs(d)} line${Math.abs(d) === 1 ? '' : 's'} ${d > 0 ? 'shorter' : 'deeper'}`;
        if (dlab) dlab.textContent = ed.hasAttribute('data-serif-off') ? 'vs. Spectral' : 'vs. Outfit';
      }
    };

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    ed.querySelectorAll<HTMLElement>('[data-jump]').forEach((a) =>
      a.addEventListener('click', () => {
        const t = page.querySelector<HTMLElement>(`#${a.dataset.jump}`);
        if (!t) return;
        ed.querySelectorAll('[data-jump]').forEach((x) => x.classList.remove('is-on'));
        a.classList.add('is-on');
        page.scrollTo({ top: t.offsetTop - 12, behavior: reduce ? 'auto' : 'smooth' });
      })
    );

    const heads = Array.from(page.querySelectorAll<HTMLElement>('h1[id], h2[id]'));
    const folEl = ed.querySelector<HTMLElement>('[data-fol]');
    const folsEl = ed.querySelector<HTMLElement>('[data-fols]');
    let ticking = false;
    const spy = () => {
      ticking = false;
      let active = heads[0]?.id;
      for (const h of heads) {
        if (h.offsetTop - page.scrollTop <= 40) active = h.id;
      }
      ed.querySelectorAll<HTMLElement>('[data-jump]').forEach((a) =>
        a.classList.toggle('is-on', a.dataset.jump === active)
      );
      if (folEl && folsEl) {
        const h = page.clientHeight || 1;
        folsEl.textContent = String(Math.max(1, Math.ceil(page.scrollHeight / h)));
        folEl.textContent = String(Math.min(
          Math.max(1, Math.ceil(page.scrollHeight / h)),
          Math.floor(page.scrollTop / h) + 1
        ));
      }
    };
    page.addEventListener('scroll', () => {
      if (!ticking) { ticking = true; requestAnimationFrame(spy); }
    });
    new ResizeObserver(() => measure()).observe(page);

    applySize(); applyLead(); recount(); spy(); measure();
  });
</script>

<style>
  /* ── the stack: paced tighter than the default; surfaces do the handoffs ── */
  .sp { gap: clamp(3.25rem, 8vh, 5.5rem); }
  .iu__hint { margin-top: var(--sp-2); color: var(--fg-3); }
  .iu__hint em { font-style: italic; }
  .iu__scene { font-family: var(--fam); }
