---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;
const mono = "'IBM Plex Mono', ui-monospace, monospace";

// --- 01 · Writing-app editor (INTERACTIVE, real device scale) -------------
// A focused document editor in the Google-Docs lineage Spectral was drawn for:
// live type-size & line-height controls, a document outline that tracks the
// cursor, and a live word / reading-time count over real prose.
const outline = [
  { id: 'o1', label: 'A field for slow attention', lvl: 1 },
  { id: 'o2', label: 'The page as an instrument', lvl: 2 },
  { id: 'o3', label: 'What a serif is for', lvl: 2 },
  { id: 'o4', label: 'Notes & sources', lvl: 1 },
];

// --- 03 · Dictionary / Lexicon entry (INTERACTIVE, real px) --------------
// Redirected from a near-duplicate wiki to a dictionary spread that exercises
// Spectral's dormant features: small caps (smcp), true italics, old-style
// figures (onum), and discretionary ligatures (dlig) in the etymology.
const lexNav = [
  { w: 'leg·end', on: false },
  { w: 'leg·er·de·main', on: false },
  { w: 'leg·i·ble', on: true },
  { w: 'leg·is·late', on: false },
  { w: 'le·git·i·mate', on: false },
];
---
<div class="iu" style={`--fam:${fam}; --mono:${mono}`}>

  <!-- 01 — INTERACTIVE writing app: type controls + outline + live word count -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Writing app — live reading controls, outline &amp; word count</span></figcaption>
    <div class="iu__scene">
      <div class="iu__device ed" data-ed>
        <div class="iu__chrome">
          <div class="iu__dots"><i></i><i></i><i></i></div>
          <span class="iu__addr">docs.foliopress.app / drafts / the-long-read</span>
        </div>
        <div class="ed__bar">
          <span class="ed__doc">On Reading Slowly<i>— draft</i></span>
          <div class="ed__tools" role="group" aria-label="Type controls">
            <span class="ed__field">
              <button class="ed__step" data-size="-" aria-label="Smaller text">A−</button>
              <span class="ed__val"><i data-size-out>18</i>px</span>
              <button class="ed__step" data-size="+" aria-label="Larger text">A+</button>
            </span>
            <span class="ed__field">
              <span class="ed__flab">Leading</span>
              <input type="range" class="ed__range" data-leading min="130" max="190" step="2" value="166" aria-label="Line height" />
              <span class="ed__val"><i data-leading-out>1.66</i></span>
            </span>
            <button class="ed__toggle" data-serif aria-pressed="true"><span class="ed__dot" aria-hidden="true"></span>Spectral</button>
          </div>
        </div>
        <div class="ed__body">
          <nav class="ed__outline" data-outline>
            <span class="ed__outh">Outline</span>
            {outline.map((o) => (
              <a class={`ed__oitem ed__oitem--l${o.lvl}`} data-jump={o.id}>{o.label}</a>
            ))}
            <div class="ed__measure" aria-hidden="true">
              <span class="ed__mh">Measure</span>
              <span class="ed__mval"><b data-cpl>66</b><i>chars / line</i></span>
              <span class="ed__mbar"><span class="ed__mfill" data-mfill></span></span>
            </div>
          </nav>
          <article class="ed__page" data-page tabindex="0">
            <h1 class="ed__h1" id="o1">A field for slow attention</h1>
            <p class="ed__lede">There is a kind of reading the web rarely asks of us any more — the unhurried, continuous kind, where a paragraph is allowed to become a thought. A page set for that kind of reading is doing quiet, deliberate work.</p>
            <h2 class="ed__h2" id="o2">The page as an instrument</h2>
            <p>Set a measure of roughly <span class="ed__num">66</span> characters, give the lines a little air, and the eye stops noticing the type at all. That disappearance is the goal: the reader is left alone with the sentence. A face drawn for documents earns its keep here, holding an even colour down a column of prose without a single letter raising its voice.</p>
            <p>Type made for the screen has to survive backlit glass at small sizes, where hairlines thin to nothing and tight counters flood with light. The answer was never to imitate print, but to retune it — a taller lowercase, opener spacing, contrast judged to render.</p>
            <h2 class="ed__h2" id="o3">What a serif is for</h2>
            <p>The little feet at the ends of the strokes are not decoration. They knit one letter to the next along the baseline, building the horizontal current the eye rides from word to word. Five centuries of reading pages have been built on that current, and it carries just as well through a browser.</p>
            <h2 class="ed__h2" id="o4">Notes &amp; sources</h2>
            <p class="ed__note">Drafted in <span class="ed__num">2026</span>. See also the companion essay on measure and the long-standing argument that <em>legibility is a habit</em> as much as a property of the letters themselves.</p>
          </article>
        </div>
        <div class="ed__foot">
          <span class="ed__stat"><b data-words>312</b> words</span>
          <span class="ed__stat ed__stat--mid"><b data-chars>1,840</b> characters</span>
          <span class="ed__stat ed__read"><b data-read>2</b> min read</span>
          <span class="ed__saved" data-saved>Saved</span>
        </div>
      </div>
    </div>
    <p class="iu__hint label">Drag the leading, step the size, jump via the outline — the body recomposes live and the measure read-out tracks your column. Flip <b>Spectral → sans</b> to watch the even reading colour break apart: that grey is what the serif is buying you.</p>
  </figure>

  <!-- 02 — typeset long-read / book page: drop cap, footnotes, pull quote -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Book — a typeset long-read with drop cap, footnotes &amp; pull quote</span></figcaption>
    <div class="iu__scene scene-book">
      <div class="book" data-book>
        <span class="book__folio" aria-hidden="true">42</span>
        <header class="book__head">
          <span class="book__series">The Reading Page · Chapter Three</span>
          <h3 class="book__title">The Disappearing Letter</h3>
          <p class="book__by">An essay on the craft of the invisible page</p>
        </header>
        <div class="book__cols">
          <p class="book__open"><span class="book__drop" data-reveal>F</span>or five hundred years the old-style serif has been the natural shape of the reading page — warm, even, descended from the broad-nib pen of the Renaissance scribe. It was never asked to be admired. It was asked to be passed through, like a window, on the way to the meaning behind it.<sup class="book__fn" data-fn="1" tabindex="0" role="button" aria-label="Footnote 1">1</sup></p>
          <p>The arrival of the screen was, for a time, a kind of exile. Delicate strokes vanished into the pixel grid; counters meant to hold a thread of white instead flooded with backlight. The faces that had carried the printed page for centuries faltered on glass.<sup class="book__fn" data-fn="2" tabindex="0" role="button" aria-label="Footnote 2">2</sup> The craft of the century since has been a patient retuning: a taller lowercase to hold its texture small, opener spacing, a contrast judged not by the printing press but by the rendering engine.</p>
          <blockquote class="book__pull" data-reveal>A page, well set, disappears into the act of reading — which is the whole point.</blockquote>
          <p>And so the book learned to live in the browser, and in the document, where it is now read more often than almost any face alive. The achievement is a paradox the trade has always prized: the better the work, the less of it you notice.<sup class="book__fn" data-fn="3" tabindex="0" role="button" aria-label="Footnote 3">3</sup> The highest compliment a text face can earn is to be forgotten while it is being read.</p>
        </div>
        <ol class="book__notes">
          <li data-note="1"><span class="book__nnum">1</span> On the page as window, see Beatrice Warde, <em>The Crystal Goblet</em> (<span class="book__onum">1932</span>) — the founding argument that typography should be invisible.</li>
          <li data-note="2"><span class="book__nnum">2</span> The hinting and anti-aliasing era, roughly <span class="book__onum">1995–2010</span>, before high-density displays made hairlines viable again.</li>
          <li data-note="3"><span class="book__nnum">3</span> A paradox the trade calls <em>the crystal goblet</em>: the vessel that shows the wine, not itself.</li>
        </ol>
      </div>
    </div>
    <p class="iu__hint label">A real book page: ranged drop cap, true-italic citations, oldstyle figures in the apparatus, and a pull quote that breaks the measure. Hover or focus a reference numeral — the marker lifts and its note glows up in the column foot.</p>
  </figure>

  <!-- 03 — INTERACTIVE dictionary / lexicon entry (real device scale) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Lexicon — a dictionary entry: small caps, true italics &amp; old-style figures</span></figcaption>
    <div class="iu__scene">
      <div class="iu__device lex" data-lex>
        <div class="iu__chrome">
          <div class="iu__dots"><i></i><i></i><i></i></div>
          <span class="iu__addr">lexicon.press / entry / legible</span>
        </div>
        <div class="lex__body">
          <nav class="lex__nav" aria-label="Nearby entries">
            <span class="lex__navh">Nearby</span>
            {lexNav.map((n) => (
              <a class={`lex__navlink ${n.on ? 'is-on' : ''}`}>{n.w}</a>
            ))}
            <span class="lex__thumb" aria-hidden="true">L</span>
          </nav>
          <article class="lex__main" data-lexmain>
            <header class="lex__head">
              <div class="lex__headtop">
                <h3 class="lex__word">legible</h3>
                <span class="lex__freq" aria-label="Usage frequency: common">
                  <span class="lex__freqh">freq.</span>
                  <span class="lex__freqbars"><i style="--h:38%"></i><i style="--h:62%"></i><i style="--h:88%"></i><i style="--h:74%"></i><i style="--h:100%"></i></span>
                  <span class="lex__freqn">attested <span class="lex__onum">1432</span></span>
                </span>
              </div>
              <p class="lex__pron"><span class="lex__pos">adjective</span> · <span class="lex__ipa">/ˈledʒəbl̩/</span> · <button class="lex__say" data-say aria-label="Pronunciation note">le-gi-ble</button></p>
            </header>
            <p class="lex__inflect">Comparative <em>more legible</em> · superlative <em>most legible</em></p>

            <ol class="lex__senses">
              <li class="lex__sense" data-sense>
                <span class="lex__snum">1</span>
                <div class="lex__sbody">
                  <span class="lex__field">Of writing or print.</span>
                  <p class="lex__def">Clear enough to be read without effort; able to be deciphered at a glance. <span class="lex__eg">a clean, <em>legible</em> hand</span></p>
                  <ul class="lex__sub">
                    <li><span class="lex__subm">a</span> <span class="lex__field">Typography.</span> Of a typeface: retaining its forms at small sizes and on screen, so that the texture of a page stays even. <span class="lex__eg">set in <em>16</em> px for maximum legibility</span></li>
                    <li><span class="lex__subm">b</span> By extension, of a layout or interface: organised so the eye finds its path unaided.</li>
                  </ul>
                </div>
              </li>
              <li class="lex__sense" data-sense>
                <span class="lex__snum">2</span>
                <div class="lex__sbody">
                  <span class="lex__field">Figurative.</span>
                  <p class="lex__def">Capable of being readily understood or interpreted; transparent in meaning. <span class="lex__eg">a city whose history is <em>legible</em> in its streets</span></p>
                </div>
              </li>
            </ol>

            <div class="lex__etym" data-sense>
              <span class="lex__etymh">Origin</span>
              <p>Late Middle English, from Late Latin <span class="lex__lat">legibilis</span>, from Latin <span class="lex__lat">legere</span> &lsquo;to read, gather, choose.&rsquo; First attested <span class="lex__onum">1432</span>; sense <span class="lex__onum">2</span> emerging by <span class="lex__onum">1880</span>. Cognate with <em>lecture</em>, <em>legend</em>, and <em>elect</em>.</p>
            </div>

            <p class="lex__usage"><span class="lex__usageh">Usage</span> Distinguished from <em>readable</em>, which concerns the comfort of continuous reading rather than the decipherability of single characters.</p>
          </article>
        </div>
      </div>
    </div>
    <p class="iu__hint label">A real dictionary spread driving Spectral&rsquo;s dormant features: <span style="font-feature-settings:'smcp' 1">small caps</span> for field labels, true italics for examples and etymons, and old-style figures in the dates. Click a headword sense to expand the gloss.</p>
  </figure>

  <!-- 04 — editorial / literary feature opener (container-query display) -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Editorial — a literary feature opener</span></figcaption>
    <div class="iu__scene scene-feat">
      <div class="feat" data-feat>
        <div class="feat__rail">
          <span class="feat__kicker">The Review · Essay</span>
          <span class="feat__issue">No. <span class="onum">47</span> · Spring <span class="onum">2026</span></span>
        </div>
        <h3 class="feat__title">The Quiet<br /><em data-reveal>Architecture</em><br />of a Page</h3>
        <span class="feat__rule" data-rule aria-hidden="true"></span>
        <p class="feat__stand">On the invisible craft that carries five centuries of reading onto a backlit screen — and why the best of it is the part you never notice.</p>
        <div class="feat__deck">
          <p class="feat__lede"><span class="feat__drop">W</span>e read with the body before we read with the mind — the eye riding the baseline, the hand turning the leaf. Good typography is the architecture that makes the journey effortless enough to forget.</p>
          <div class="feat__meta">
            <span class="feat__by">By Florian Marchetti</span>
            <span class="feat__stat"><span class="onum">3,400</span> words · <span class="frac">1/2</span> hour</span>
          </div>
        </div>
        <p class="feat__foot">Set in Spectral · <span class="onum">9</span>–<span class="onum">144</span> pt · Production Type, <span class="onum">2017</span></p>
      </div>
    </div>
    <p class="iu__hint label">A feature opener: a stacked title with a true-italic line, oldstyle figures, a real fraction, and a drop cap. Hover the title to let the italic settle in.</p>
  </figure>

</div>

<script>
  // ---- 01 · writing app: size / leading / outline / live counts ----
  document.querySelectorAll<HTMLElement>('[data-ed]').forEach((ed) => {
    const page = ed.querySelector<HTMLElement>('[data-page]')!;
    const sizeOut = ed.querySelector<HTMLElement>('[data-size-out]')!;
    const leadOut = ed.querySelector<HTMLElement>('[data-leading-out]')!;
    const leadIn = ed.querySelector<HTMLInputElement>('[data-leading]')!;
    const wordsEl = ed.querySelector<HTMLElement>('[data-words]')!;
    const charsEl = ed.querySelector<HTMLElement>('[data-chars]')!;
    const readEl = ed.querySelector<HTMLElement>('[data-read]')!;
    const saved = ed.querySelector<HTMLElement>('[data-saved]')!;
    let size = 18;

    const fmt = (n: number) => n.toLocaleString('en-US');
    const applySize = () => {
      page.style.setProperty('--ed-fs', `${size}px`);
      sizeOut.textContent = String(size);
    };
    const applyLead = () => {
      const lh = (+leadIn.value / 100);
      page.style.setProperty('--ed-lh', String(lh));
      leadOut.textContent = lh.toFixed(2);
    };

    // live word / char / reading-time over the actual editable prose
    const countSrc = page.querySelectorAll('p, h1, h2');
    const recount = () => {
      let text = '';
      countSrc.forEach((n) => { text += ' ' + (n.textContent || ''); });
      text = text.replace(/\s+/g, ' ').trim();
      const words = text ? text.split(' ').length : 0;
      const chars = text.replace(/\s/g, '').length;
      wordsEl.textContent = fmt(words);
      charsEl.textContent = fmt(chars);
      readEl.textContent = String(Math.max(1, Math.round(words / 200)));
    };

    let savedT: number | undefined;
    const flashSaved = () => {
      saved.textContent = 'Saving…';
      saved.classList.add('is-busy');
      window.clearTimeout(savedT);
      savedT = window.setTimeout(() => {
        saved.textContent = 'Saved';
        saved.classList.remove('is-busy');
      }, 600);
    };

    ed.querySelectorAll<HTMLButtonElement>('[data-size]').forEach((btn) =>
      btn.addEventListener('click', () => {
        size = Math.min(28, Math.max(13, size + (btn.dataset.size === '+' ? 1 : -1)));
        applySize();
        flashSaved();
      })
    );
    leadIn.addEventListener('input', () => { applyLead(); flashSaved(); });

    // serif on/off — a live demonstration of what the face is doing for the page
    const serifBtn = ed.querySelector<HTMLButtonElement>('[data-serif]');
    const serifLabel = serifBtn?.lastChild;
    serifBtn?.addEventListener('click', () => {
      const off = ed.toggleAttribute('data-serif-off');
      serifBtn.setAttribute('aria-pressed', String(!off));
      if (serifLabel) serifLabel.textContent = off ? 'Outfit' : 'Spectral';
      flashSaved();
      requestAnimationFrame(measure);
    });

    // live "characters per line" read-out — measures a real line in the column
    const cpl = ed.querySelector<HTMLElement>('[data-cpl]');
    const mfill = ed.querySelector<HTMLElement>('[data-mfill]');
    const probe = page.querySelector<HTMLElement>('.ed__page p');
    const measure = () => {
      if (!cpl || !mfill || !probe) return;
      const cs = getComputedStyle(probe);
      const fs = parseFloat(cs.fontSize) || 18;
      // average advance of Spectral ≈ 0.5em; estimate chars from rendered width
      const colW = probe.clientWidth -
        (parseFloat(cs.paddingLeft) || 0) - (parseFloat(cs.paddingRight) || 0);
      const est = Math.round(colW / (fs * 0.5));
      cpl.textContent = String(est);
      // 45–75 is the comfortable band; map to a 0–100 fill, centred on 66
      const pct = Math.max(6, Math.min(100, ((est - 30) / (90 - 30)) * 100));
      mfill.style.width = pct + '%';
      mfill.classList.toggle('is-ideal', est >= 50 && est <= 78);
    };

    // outline → smooth-scroll the page column to the heading
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    ed.querySelectorAll<HTMLElement>('[data-jump]').forEach((a) =>
      a.addEventListener('click', () => {
        const t = page.querySelector<HTMLElement>(`#${a.dataset.jump}`);
        if (!t) return;
        ed.querySelectorAll('[data-jump]').forEach((x) => x.classList.remove('is-on'));
        a.classList.add('is-on');
        page.scrollTo({ top: t.offsetTop - 12, behavior: reduce ? 'auto' : 'smooth' });
      })
    );

    // scroll-spy: highlight the outline entry nearest the top
    const heads = Array.from(page.querySelectorAll<HTMLElement>('h1[id], h2[id]'));
    let ticking = false;
    const spy = () => {
      ticking = false;
      let active = heads[0]?.id;
      for (const h of heads) {
        if (h.offsetTop - page.scrollTop <= 40) active = h.id;
      }
      ed.querySelectorAll<HTMLElement>('[data-jump]').forEach((a) =>
        a.classList.toggle('is-on', a.dataset.jump === active)
      );
    };
    page.addEventListener('scroll', () => {
      if (!ticking) { ticking = true; requestAnimationFrame(spy); }
    });

    ed.querySelectorAll<HTMLButtonElement>('[data-size]').forEach((btn) =>
      btn.addEventListener('click', () => requestAnimationFrame(measure))
    );
    leadIn.addEventListener('input', () => requestAnimationFrame(measure));
    new ResizeObserver(() => measure()).observe(page);

    applySize(); applyLead(); recount(); spy(); measure();
  });

  // ---- 02 · book: hover a reference marker → light its footnote ----
  document.querySelectorAll<HTMLElement>('.book').forEach((book) => {
    const link = (id: string | null, on: boolean) => {
      if (!id) return;
      const note = book.querySelector<HTMLElement>(`[data-note="${id}"]`);
      const mark = book.querySelector<HTMLElement>(`[data-fn="${id}"]`);
      note?.classList.toggle('is-lit', on);
      mark?.classList.toggle('is-lit', on);
    };
    book.querySelectorAll<HTMLElement>('[data-fn]').forEach((fn) => {
      fn.addEventListener('mouseenter', () => link(fn.dataset.fn!, true));
      fn.addEventListener('mouseleave', () => link(fn.dataset.fn!, false));
      fn.addEventListener('focus', () => link(fn.dataset.fn!, true));
      fn.addEventListener('blur', () => link(fn.dataset.fn!, false));
    });
  });

  // ---- scroll-into-view reveals (book drop cap + pull quote, feat italic) ----
  {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const targets = document.querySelectorAll<HTMLElement>('[data-reveal]');
    if (reduce || !('IntersectionObserver' in window)) {
      targets.forEach((t) => { t.classList.add('in'); t.removeAttribute('data-reveal'); });
    } else {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('in');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.4 });
      targets.forEach((t) => io.observe(t));
    }
  }

  // ---- 03 · lexicon: expand a sense; flash etymology cross-refs ----
  document.querySelectorAll<HTMLElement>('[data-lex]').forEach((lex) => {
    const senses = lex.querySelectorAll<HTMLElement>('[data-sense]');
    senses.forEach((s) => {
      s.setAttribute('tabindex', '0');
      s.setAttribute('role', 'button');
      const toggle = () => s.classList.toggle('is-open');
      s.addEventListener('click', toggle);
      s.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }
      });
    });
    // open sense 1 and the etymology by default so the resting state shows
    // the sub-senses and the italic/dlig etymons
    senses.forEach((s) => {
      if (s.classList.contains('lex__sense') && s === senses[0]) s.classList.add('is-open');
      if (s.classList.contains('lex__etym')) s.classList.add('is-open');
    });
    const say = lex.querySelector<HTMLElement>('[data-say]');
    say?.addEventListener('click', () => say.classList.toggle('is-on'));
  });
</script>

<style>
  .iu__item { margin: 0; }
  .iu__hint { margin-top: var(--sp-2); color: var(--fg-3); }
  .iu * { font-family: var(--fam); }

  /* shared scene framing — matches InUse.astro / source-sans-3.astro */
  .iu__scene {
    container-type: inline-size;
    position: relative;
    border: clamp(22px, 3.4vw, 44px) solid var(--bg-2);
    outline: 1px solid var(--line);
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--bg-2);
  }
  .iu__scene * { font-family: var(--fam); }
  .scene-book { aspect-ratio: 4 / 5; }
  .scene-feat { aspect-ratio: 4 / 5; }
  @container (min-width: 720px) {
    .scene-book { aspect-ratio: 16 / 11; }
    .scene-feat { aspect-ratio: 16 / 10; }
  }

  .iu__device {
    position: absolute; inset: 0; display: flex; flex-direction: column;
    background: var(--bg); overflow: hidden;
  }
  .iu__chrome {
    display: flex; align-items: center; gap: 0.7rem; flex: none;
    padding: 0.55rem 0.9rem; border-bottom: 1px solid var(--line); background: var(--bg-2);
  }
  .iu__dots { display: flex; gap: 6px; }
  .iu__dots i { width: 9px; height: 9px; border-radius: 50%; background: color-mix(in srgb, var(--fg) 22%, transparent); }
  .iu__addr {
    font-family: var(--mono) !important; font-size: 11px; color: var(--fg-3); letter-spacing: 0.01em;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    background: color-mix(in srgb, var(--fg) 5%, transparent);
    padding: 3px 10px; border-radius: 6px; margin: 0 auto 0 4px; max-width: 72%;
  }
  .onum { font-feature-settings: 'onum' 1; }
  .frac { font-feature-settings: 'frac' 1; }

  /* ============ 01 · WRITING APP (real px) ============ */
  .ed { font-size: 14px; }
  .ed__bar {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex: none;
    padding: 0.55rem 1rem; border-bottom: 1px solid var(--line); flex-wrap: wrap;
  }
  .ed__doc { font-size: 14px; font-weight: 600; color: var(--fg); white-space: nowrap; }
  .ed__doc i { font-style: italic; font-weight: 400; color: var(--fg-3); margin-left: 0.35rem; }
  .ed__tools { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
  .ed__field {
    display: inline-flex; align-items: center; gap: 0.45rem;
    border: 1px solid var(--line); border-radius: 8px; padding: 0.18rem 0.5rem;
  }
  .ed__step {
    font-size: 12px; font-weight: 600; color: var(--fg-2); cursor: pointer;
    background: transparent; border: none; padding: 0.12rem 0.25rem; line-height: 1;
    border-radius: 5px; transition: background 0.12s var(--ease), color 0.12s var(--ease);
  }
  .ed__step:hover { background: color-mix(in srgb, var(--fg) 7%, transparent); color: var(--fg); }
  .ed__flab { font-size: 10.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--fg-3); }
  .ed__val { font-family: var(--mono) !important; font-size: 11px; color: var(--fg-2); min-width: 2.2em; text-align: right; }
  .ed__val i { font-style: normal; color: var(--fg); }
  .ed__range {
    -webkit-appearance: none; appearance: none; width: 78px; height: 2px;
    background: var(--line); border-radius: 2px; cursor: pointer;
  }
  .ed__range::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none; width: 13px; height: 13px;
    border-radius: 50%; background: var(--accent); border: 2px solid var(--bg);
    box-shadow: 0 0 0 1px var(--accent);
  }
  .ed__range::-moz-range-thumb {
    width: 13px; height: 13px; border-radius: 50%; background: var(--accent);
    border: 2px solid var(--bg); box-shadow: 0 0 0 1px var(--accent);
  }
  .ed__toggle {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-size: 11.5px; font-weight: 600; color: var(--fg-2);
    background: transparent; border: 1px solid var(--line); cursor: pointer;
    padding: 0.3rem 0.6rem 0.3rem 0.55rem; border-radius: 8px; transition: all 0.14s var(--ease);
    min-width: 6.6em; justify-content: flex-start;
  }
  .ed__toggle:hover { border-color: color-mix(in srgb, var(--fg) 28%, transparent); }
  .ed__dot {
    width: 7px; height: 7px; border-radius: 50%; flex: none;
    background: var(--accent); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 18%, transparent);
    transition: background 0.14s var(--ease), box-shadow 0.14s var(--ease);
  }
  .ed[data-serif-off] .ed__dot { background: var(--fg-3); box-shadow: 0 0 0 3px color-mix(in srgb, var(--fg) 10%, transparent); }
  .ed__body { flex: 1; display: grid; grid-template-columns: 178px 1fr; min-height: 0; overflow: hidden; }
  .ed__outline { display: flex; flex-direction: column; gap: 1px; padding: 1rem 0.7rem; border-right: 1px solid var(--line); overflow: auto; background: color-mix(in srgb, var(--fg) 2%, transparent); }
  .ed__outh { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--fg-3); margin-bottom: 0.5rem; }
  .ed__oitem { font-size: 12.5px; color: var(--fg-2); padding: 0.3rem 0.5rem; border-radius: 6px; cursor: pointer; line-height: 1.3; border-left: 2px solid transparent; transition: background 0.12s, color 0.12s; }
  .ed__oitem--l2 { padding-left: 1.1rem; font-size: 12px; color: var(--fg-3); }
  .ed__oitem:hover { background: color-mix(in srgb, var(--fg) 5%, transparent); color: var(--fg); }
  .ed__oitem.is-on { color: var(--accent); border-left-color: var(--accent); font-weight: 600; background: color-mix(in srgb, var(--accent) 9%, transparent); }
  /* measure read-out — a quiet instrument-panel detail tying the type to the column */
  .ed__measure { margin-top: auto; padding-top: 1.1rem; }
  .ed__mh { display: block; font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--fg-3); margin-bottom: 0.4rem; }
  .ed__mval { display: flex; align-items: baseline; gap: 0.35rem; margin-bottom: 0.4rem; }
  .ed__mval b { font-family: var(--mono) !important; font-size: 16px; font-weight: 600; color: var(--fg); font-variant-numeric: tabular-nums; }
  .ed__mval i { font-size: 10.5px; font-style: italic; color: var(--fg-3); }
  .ed__mbar { display: block; height: 3px; border-radius: 3px; background: color-mix(in srgb, var(--fg) 9%, transparent); overflow: hidden; position: relative; }
  /* mark the comfortable 50–78ch band */
  .ed__mbar::before { content: ''; position: absolute; inset: 0 calc(100% - 80%) 0 33%; background: color-mix(in srgb, var(--accent) 16%, transparent); }
  .ed__mfill { display: block; height: 100%; width: 60%; background: var(--fg-3); border-radius: 3px; position: relative; z-index: 1; transition: width 0.18s var(--ease), background 0.18s var(--ease); }
  .ed__mfill.is-ideal { background: var(--accent); }
  .ed__page {
    --ed-fs: 18px; --ed-lh: 1.66;
    overflow: auto; padding: 1.8rem clamp(1.2rem, 6cqi, 3.4rem) 2.4rem;
    outline: none;
  }
  .ed__h1 { font-size: calc(var(--ed-fs) * 1.7); font-weight: 600; line-height: 1.15; letter-spacing: -0.012em; color: var(--fg); margin: 0 0 0.6rem; max-width: 30ch; }
  .ed__lede { font-size: calc(var(--ed-fs) * 1.06); font-style: italic; color: var(--fg-2); line-height: calc(var(--ed-lh) * 0.96); margin: 0 0 1.3em; max-width: 62ch; }
  .ed__h2 { font-size: calc(var(--ed-fs) * 1.12); font-weight: 600; color: var(--fg); margin: 1.6em 0 0.5em; letter-spacing: -0.005em; }
  .ed__page p { font-size: var(--ed-fs); line-height: var(--ed-lh); color: var(--fg); margin: 0 0 1em; max-width: 66ch; }
  .ed__page p em { font-style: italic; }
  .ed__num { font-feature-settings: 'onum' 1; }
  .ed__note { color: var(--fg-2) !important; font-size: calc(var(--ed-fs) * 0.94) !important; }
  /* serif-off comparison state — a named, characterful sans so the A/B is real */
  .ed[data-serif-off] .ed__page * { font-family: 'Outfit Variable', 'Inter Variable', system-ui, sans-serif !important; }
  .ed[data-serif-off] .ed__page { letter-spacing: 0.002em; }
  .ed[data-serif-off] .ed__page h1,
  .ed[data-serif-off] .ed__page h2 { letter-spacing: -0.02em; }
  .ed__foot {
    flex: none; display: flex; align-items: baseline; gap: 1.2rem;
    padding: 0.6rem 1rem; border-top: 1px solid var(--line); font-size: 12px; color: var(--fg-3);
  }
  .ed__stat b { font-family: var(--mono) !important; color: var(--fg); font-weight: 600; font-variant-numeric: tabular-nums; }
  .ed__saved { margin-left: auto; display: inline-flex; align-items: center; gap: 0.35rem; }
  .ed__saved::before { content: '✓'; color: var(--accent); font-weight: 700; }
  .ed__saved.is-busy::before { content: '⋯'; color: var(--fg-3); }

  @container (max-width: 640px) {
    .ed__doc { display: none; }
    .ed__bar { justify-content: flex-start; }
    .ed__body { grid-template-columns: 1fr; }
    .ed__outline { display: none; }
    .ed__stat--mid { display: none; }
  }

  /* ============ 02 · BOOK PAGE (container-query print) ============ */
  .book {
    position: absolute; inset: 0; background: var(--bg); color: var(--fg);
    padding: 5cqi 6cqi 4cqi; display: flex; flex-direction: column; overflow: hidden;
  }
  /* a faint running folio in the margin — the apparatus of a real page */
  .book__folio {
    position: absolute; top: 4cqi; right: 6cqi; font-feature-settings: 'onum' 1;
    font-size: 2.2cqi; letter-spacing: 0.1em; color: var(--fg-3); opacity: 0.7;
  }
  .book__head { text-align: center; border-bottom: 1px solid var(--line); padding-bottom: 3cqi; }
  .book__series { font-size: 1.9cqi; letter-spacing: 0.22em; text-transform: uppercase; color: var(--fg-3); }
  .book__title { font-size: 8cqi; font-weight: 600; line-height: 1.02; letter-spacing: -0.01em; margin: 2.4cqi 0 1.4cqi; color: var(--fg); }
  .book__by { font-size: 2.5cqi; font-style: italic; color: var(--fg-2); margin: 0; }
  .book__cols { columns: 2; column-gap: 5cqi; margin-top: 3.4cqi; font-size: 2.45cqi; }
  .book__cols p { line-height: 1.62; color: var(--fg); margin: 0 0 1em; text-align: left; hyphens: none; text-wrap: pretty; }
  .book__open { break-inside: avoid; }
  .book__drop {
    float: left; font-size: 9.5cqi; line-height: 0.78; font-weight: 600;
    padding: 0.5cqi 1.4cqi 0 0; color: var(--accent);
  }
  /* scroll-into-view reveals */
  .book__drop[data-reveal] { opacity: 0; transform: translateY(0.4cqi) scale(0.9); transform-origin: left top; }
  .book__pull[data-reveal] { opacity: 0; transform: translateY(1.4cqi); }
  .book__drop, .book__pull { transition: opacity 0.7s var(--ease), transform 0.7s var(--ease); }
  .book__drop.in, .book__pull.in { opacity: 1; transform: none; }
  .book__cols em { font-style: italic; }
  .book__fn {
    font-feature-settings: 'sups' 1; color: var(--accent); cursor: pointer;
    font-size: 1.5cqi; padding: 0 0.12em; border-radius: 3px;
    transition: color 0.2s var(--ease), background 0.2s var(--ease), transform 0.2s var(--ease);
    display: inline-block;
  }
  .book__fn::before { content: ''; }
  .book__fn:focus-visible { outline: 1.5px solid var(--accent); outline-offset: 1px; }
  .book__onum { font-feature-settings: 'onum' 1; }
  @media (prefers-reduced-motion: no-preference) {
    .book__fn.is-lit { transform: translateY(-0.4cqi); }
  }
  .book__fn.is-lit { color: var(--accent-contrast); background: var(--accent); }
  .book__pull {
    column-span: all; font-size: 4.2cqi; font-style: italic; line-height: 1.25;
    color: var(--accent); text-align: center; margin: 2cqi auto; max-width: 80%;
    padding: 1cqi 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);
  }
  .book__notes {
    column-span: all; margin: auto 0 0; padding: 2.6cqi 0 0; border-top: 1px solid var(--line);
    list-style: none; display: flex; flex-direction: column; gap: 1cqi;
  }
  .book__notes li {
    font-size: 1.85cqi; line-height: 1.4; color: var(--fg-3); padding: 0.4cqi 1cqi 0.4cqi 3cqi;
    margin-left: -1cqi; position: relative;
    transition: color 0.2s var(--ease), background 0.2s var(--ease), box-shadow 0.2s var(--ease);
    border-radius: 5px; box-shadow: inset 0 0 0 0 var(--accent);
  }
  .book__notes li em { font-style: italic; }
  .book__onum { font-feature-settings: 'onum' 1; }
  .book__nnum {
    position: absolute; left: 1cqi; top: 0.4cqi; color: var(--accent);
    font-feature-settings: 'sups' 1; font-size: 1.5cqi; transition: color 0.2s var(--ease);
  }
  .book__notes li.is-lit {
    color: var(--fg); background: color-mix(in srgb, var(--accent) 9%, transparent);
    box-shadow: inset 0.4cqi 0 0 0 var(--accent);
  }

  @container (max-width: 540px) {
    .book__cols { columns: 1; font-size: 3.4cqi; }
    .book__title { font-size: 10cqi; }
    .book__by { font-size: 3.4cqi; }
    .book__series { font-size: 2.6cqi; }
    .book__pull { font-size: 5.4cqi; }
    .book__drop { font-size: 12cqi; }
    .book__notes li, .book__nnum { font-size: 2.6cqi; }
    .book__fn { font-size: 2cqi; }
  }

  /* ============ 03 · DICTIONARY / LEXICON ENTRY (real px) ============ */
  .lex { font-size: 14px; }
  .lex__body { flex: 1; display: grid; grid-template-columns: 178px 1fr; min-height: 0; overflow: hidden; }
  /* sidebar reads as the deckle edge of a reference volume: tinted, with a thumb index */
  .lex__nav {
    position: relative; display: flex; flex-direction: column; gap: 1px;
    padding: 1.1rem 0.8rem; border-right: 1px solid var(--line); overflow: hidden;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--accent) 7%, transparent), color-mix(in srgb, var(--accent) 2%, transparent));
  }
  .lex__navh { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--fg-3); margin-bottom: 0.5rem; }
  .lex__navlink { font-size: 14px; font-style: italic; color: var(--fg-2); padding: 0.3rem 0.5rem; border-radius: 6px; cursor: pointer; transition: background 0.12s, color 0.12s; }
  .lex__navlink:hover { background: color-mix(in srgb, var(--fg) 5%, transparent); color: var(--fg); }
  .lex__navlink.is-on { background: var(--accent); color: var(--accent-contrast); font-weight: 600; font-style: normal; box-shadow: 0 1px 3px color-mix(in srgb, var(--accent) 30%, transparent); }
  /* oversized ghost initial — the alphabetic thumb index of a dictionary */
  .lex__thumb {
    position: absolute; right: -0.6rem; bottom: -1.4rem; font-size: 120px;
    font-weight: 600; line-height: 1; color: color-mix(in srgb, var(--accent) 16%, transparent);
    pointer-events: none; user-select: none; z-index: 0;
  }
  .lex__navlink, .lex__navh { position: relative; z-index: 1; }
  .lex__main { overflow: auto; padding: 1.7rem 2.2rem 2rem; min-width: 0; }

  .lex__head { border-bottom: 2px solid var(--fg); padding-bottom: 0.55rem; }
  .lex__headtop { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; }
  /* a small frequency sparkline + first-attested date: a real lexicographic detail, in accent */
  .lex__freq { display: flex; flex-direction: column; align-items: flex-end; gap: 0.25rem; padding-bottom: 0.2rem; }
  .lex__freqh { font-feature-settings: 'smcp' 1; text-transform: lowercase; font-size: 10.5px; letter-spacing: 0.1em; color: var(--fg-3); }
  .lex__freqbars { display: flex; align-items: flex-end; gap: 2px; height: 20px; }
  .lex__freqbars i { width: 4px; height: var(--h); background: var(--accent); border-radius: 1px; opacity: 0.85; }
  .lex__freqbars i:last-child { box-shadow: 0 0 0 1.5px color-mix(in srgb, var(--accent) 30%, transparent); }
  .lex__freqn { font-size: 11px; font-style: italic; color: var(--fg-3); white-space: nowrap; }
  .lex__freqn .lex__onum { font-feature-settings: 'onum' 1; color: var(--fg-2); font-style: normal; }
  .lex__word { font-size: 40px; font-weight: 600; letter-spacing: -0.02em; line-height: 0.95; margin: 0; color: var(--fg); }
  .lex__pron { font-size: 14px; color: var(--fg-2); margin: 0.4rem 0 0; display: inline-flex; align-items: baseline; gap: 0.4rem; flex-wrap: wrap; }
  .lex__pos { font-style: italic; color: var(--fg-3); }
  .lex__ipa { font-family: var(--mono) !important; font-size: 12.5px; color: var(--fg-2); }
  .lex__say {
    font-feature-settings: 'smcp' 1; text-transform: lowercase; font-size: 13px;
    letter-spacing: 0.04em; color: var(--accent); background: transparent;
    border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    border-radius: 20px; padding: 0.1rem 0.6rem; cursor: pointer; transition: all 0.15s var(--ease);
  }
  .lex__say:hover, .lex__say.is-on { background: color-mix(in srgb, var(--accent) 14%, transparent); }
  .lex__inflect { font-size: 13px; color: var(--fg-3); margin: 0.5rem 0 1.1rem; }
  .lex__inflect em { font-style: italic; color: var(--fg-2); }

  .lex__senses { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .lex__sense { display: grid; grid-template-columns: 1.7rem 1fr; gap: 0.6rem; cursor: pointer; border-radius: 8px; padding: 0.4rem; margin: -0.4rem; transition: background 0.15s var(--ease); }
  .lex__sense:hover { background: color-mix(in srgb, var(--fg) 3.5%, transparent); }
  .lex__sense:focus-visible { outline: 2px solid var(--accent); outline-offset: 1px; }
  .lex__snum {
    font-size: 19px; font-weight: 600; color: var(--accent); line-height: 1.1;
    font-feature-settings: 'onum' 1;
  }
  .lex__field {
    font-feature-settings: 'smcp' 1; text-transform: lowercase;
    font-size: 13.5px; letter-spacing: 0.05em; color: var(--fg-3); margin-right: 0.4rem;
  }
  .lex__def { font-size: 16.5px; line-height: 1.58; color: var(--fg); margin: 0.15rem 0 0; display: inline; }
  .lex__eg { color: var(--fg-2); }
  .lex__eg em, .lex__def em { font-style: italic; color: var(--accent); }
  /* collapsible sub-senses: closed by default, opened on click */
  .lex__sub {
    list-style: none; margin: 0.5rem 0 0; padding: 0; display: flex; flex-direction: column; gap: 0.4rem;
    overflow: hidden; max-height: 0; opacity: 0; transition: max-height 0.4s var(--ease), opacity 0.3s var(--ease), margin 0.3s var(--ease);
    margin-top: 0;
  }
  .lex__sense.is-open .lex__sub { max-height: 16rem; opacity: 1; margin-top: 0.5rem; }
  .lex__sub li { font-size: 14px; line-height: 1.5; color: var(--fg-2); }
  .lex__subm { font-weight: 600; font-style: italic; color: var(--accent); margin-right: 0.3rem; font-feature-settings: 'onum' 1; }
  .lex__sub em { font-style: italic; color: var(--accent); }

  .lex__etym {
    margin: 1.4rem 0 0; padding: 0.9rem 1rem; border-radius: 10px;
    background: color-mix(in srgb, var(--fg) 3%, transparent);
    border-left: 2px solid var(--accent); cursor: pointer;
    overflow: hidden; max-height: 2.4rem; transition: max-height 0.45s var(--ease), background 0.15s;
  }
  .lex__etym:hover { background: color-mix(in srgb, var(--fg) 5%, transparent); }
  .lex__etym.is-open { max-height: 12rem; }
  .lex__etymh, .lex__usageh {
    display: inline-block; font-feature-settings: 'smcp' 1; text-transform: lowercase;
    font-size: 13px; letter-spacing: 0.08em; color: var(--fg-3); margin-right: 0.5rem;
  }
  .lex__etym p { font-size: 14px; line-height: 1.55; color: var(--fg-2); margin: 0.35rem 0 0; }
  .lex__etym p em { font-style: italic; color: var(--fg); }
  .lex__lat { font-style: italic; color: var(--accent); font-feature-settings: 'dlig' 1, 'liga' 1; }
  .lex__onum { font-feature-settings: 'onum' 1; color: var(--fg); }
  .lex__usage { font-size: 13.5px; line-height: 1.5; color: var(--fg-3); margin: 1.1rem 0 0; }
  .lex__usage em { font-style: italic; color: var(--fg-2); }

  @container (max-width: 500px) {
    .lex__body { grid-template-columns: 1fr; }
    .lex__nav { display: none; }
    .lex__word { font-size: 32px; }
  }

  /* ============ 04 · EDITORIAL FEATURE OPENER (container-query) ============ */
  .feat {
    position: absolute; inset: 0; background: var(--bg); color: var(--fg);
    padding: 6cqi 7cqi; display: flex; flex-direction: column; overflow: hidden;
  }
  .feat__rail {
    display: flex; justify-content: space-between; align-items: baseline;
    font-size: 2.1cqi; letter-spacing: 0.18em; text-transform: uppercase; color: var(--fg-3);
    border-bottom: 1px solid var(--line); padding-bottom: 2.4cqi;
  }
  .feat__rail .onum { color: var(--accent); letter-spacing: 0.1em; }
  .feat__title {
    font-size: 15cqi; line-height: 0.94; font-weight: 600; letter-spacing: -0.02em;
    margin: 3cqi 0 0; color: var(--fg);
  }
  .feat__title em {
    font-style: italic; font-weight: 400; color: var(--accent);
    display: inline-block; transition: transform 0.6s var(--ease), color 0.6s var(--ease), opacity 0.6s var(--ease);
  }
  .feat__title em[data-reveal] { opacity: 0; transform: translateX(-2cqi) rotate(-2deg); }
  .feat__title em.in { opacity: 1; transform: none; }
  /* a hairline that draws across on load and tracks the title's italic colour */
  .feat__rule {
    display: block; height: 2px; width: 30cqi; margin: 3cqi 0 0;
    background: var(--accent); transform-origin: left center;
  }
  @media (prefers-reduced-motion: no-preference) {
    .feat__rule { transform: scaleX(0); animation: feat-draw 1s var(--ease-out, ease-out) 0.25s forwards; }
    .feat[data-feat]:hover .feat__rule,
    .feat[data-feat]:focus-within .feat__rule { animation: feat-redraw 0.8s var(--ease-out, ease-out) forwards; }
  }
  @keyframes feat-draw { to { transform: scaleX(1); } }
  @keyframes feat-redraw { 0% { transform: scaleX(0); } 100% { transform: scaleX(1); } }
  /* standfirst fills the gap between the stacked title and the deck */
  .feat__stand {
    font-size: 2.7cqi; font-style: italic; line-height: 1.4; color: var(--fg-2);
    max-width: 38ch; margin: 2.4cqi 0 0; padding-top: 2.4cqi;
    border-top: 1px solid var(--line);
  }
  .feat__deck { display: grid; grid-template-columns: 1fr; gap: 3cqi; margin-top: auto; }
  .feat__lede { font-size: 3.3cqi; line-height: 1.42; color: var(--fg); margin: 0; max-width: 46ch; }
  .feat__drop {
    float: left; font-size: 11cqi; line-height: 0.72; font-weight: 600;
    padding: 0.4cqi 1.2cqi 0 0; color: var(--accent);
  }
  .feat__meta {
    display: flex; justify-content: space-between; align-items: baseline; gap: 2cqi;
    font-size: 2.2cqi; color: var(--fg-2); border-top: 1px solid var(--line); padding-top: 2.4cqi;
  }
  .feat__by { font-style: italic; }
  .feat__stat { color: var(--fg-3); letter-spacing: 0.02em; }
  .feat__stat .onum { font-feature-settings: 'onum' 1; }
