    .sp-ru__cols { columns: 1; }
    .sp-ru__cols p:last-child { display: none; }
  }

  /* ════════════════════════════════════════════════════════════════════
     02 · WRITERS AT WORK — cream book page, red apparatus
     ════════════════════════════════════════════════════════════════════ */
  .sp-pr { background: #f3edde; color: #221c10; }
  .sp-pr__page {
