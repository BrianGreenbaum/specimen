  .sp-oh.is-apart :is(.sp-oh__lig, .sp-oh__lig2, .sp-oh__mono) { font-feature-settings: 'liga' 0; }
  .sp-oh.is-apart .sp-oh__mark .sp-oh__lig { letter-spacing: 0.06em; }
  .sp-oh__annorow {
    display: flex; align-items: center; justify-content: center; gap: 1.1rem; flex-wrap: wrap;
    margin-top: clamp(1rem, 2.2cqi, 1.8rem);
  }
  .sp-oh__annoline { width: 2.6rem; height: 1px; background: #eee8d566; }
  .sp-oh__anno {
    margin: 0; font-size: max(12.5px, 1.05cqi); line-height: 1.5; color: var(--oh-soft);
    max-width: 52ch; text-align: left;
  }
  .sp-oh__anno b { font-weight: 600; color: var(--oh-ink); }
  .sp-oh__flip {
    font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--oh-ink); background: transparent; cursor: pointer;
    border: 1px solid #eee8d559; border-radius: 2px; padding: 0.55rem 1rem;
    transition: background 0.2s var(--ease), color 0.2s var(--ease);
  }
  .sp-oh__flip:hover { background: var(--oh-ink); color: var(--oh-field); }
  .sp-oh__apps {
    display: grid; grid-template-columns: auto 1fr 1.6fr; gap: clamp(1rem, 2.4cqi, 2.2rem);
    align-items: stretch; margin-top: clamp(1.2rem, 2.6cqi, 2.2rem);
    padding-top: clamp(1.2rem, 2.6cqi, 2rem); border-top: 1px solid #eee8d540;
  }
  .sp-oh__app { display: flex; flex-direction: column; gap: 0.6rem; min-width: 0; }
  .sp-oh__applab { font-style: italic; font-size: 12px; color: var(--oh-soft); }
  .sp-oh__app--spine { align-items: center; }
  .sp-oh__spine {
    writing-mode: vertical-rl; background: var(--oh-ink); color: var(--oh-field);
    padding: 1.1rem 0.55rem; font-size: max(12px, 1cqi); letter-spacing: 0.06em;
    min-height: 170px; flex: 1; display: inline-flex; align-items: center;
  }
  .sp-oh__spine b { font-weight: 600; }
  .sp-oh__spine { white-space: nowrap; }
  .sp-oh__card {
    flex: 1; background: var(--oh-ink); color: var(--oh-field);
    padding: clamp(0.9rem, 1.8cqi, 1.4rem) clamp(1rem, 2cqi, 1.5rem);
    display: flex; flex-direction: column; min-height: 170px;
  }
  .sp-oh__mono { font-size: clamp(44px, 5.4cqi, 76px); line-height: 0.95; font-weight: 400; }
  .sp-oh__cardline { margin-top: auto; font-size: max(13px, 1.05cqi); font-weight: 600; font-variant-numeric: tabular-nums; }
  .sp-oh__cardsub { font-size: max(11px, 0.9cqi); font-style: italic; color: #20453ab3; }
  .sp-oh__webbar {
