  .sp-oh__webcta { color: var(--oh-ink); border-bottom: 1px solid var(--oh-ink); }
  .sp-oh__webbody {
    flex: 1; border: 1px solid #eee8d559; padding: 1rem 1rem 1.1rem;
    display: flex; flex-direction: column; gap: 0.3rem; min-height: 0;
  }
  .sp-oh__webkick { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--oh-soft); }
  .sp-oh__webhead { font-size: clamp(19px, 2cqi, 26px); font-weight: 600; line-height: 1.15; }
  .sp-oh__webby { font-size: 13px; color: var(--oh-soft); }
  .sp-oh__webby em { font-style: italic; }
  .sp-oh__rules {
