    will-change: transform;
  }
  .is-far .sp-ru__page { box-shadow: 0 8px 22px -10px rgba(0, 0, 0, 0.75); }
  .sp-ru__page--cmp, .sp-ru__page--cmp .sp-ru__ph, .sp-ru__page--cmp p {
    font-family: 'Times New Roman', Times, serif;
  }
  .sp-ru__ink {
    margin: 0.4rem 0 0; text-align: center;
    font-size: 11.5px; font-style: italic; color: #8e8467;
  }
  .sp-ru__ink b { font-style: normal; font-weight: 600; color: #c8bd9f; font-variant-numeric: tabular-nums; }
  .sp-ru__ph {
    display: block; text-align: center; font-size: 12px; letter-spacing: 0.28em;
    text-transform: uppercase; color: #7a6f53; margin-bottom: 1.2rem;
