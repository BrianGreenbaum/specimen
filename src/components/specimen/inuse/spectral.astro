  /* ════════════════════════════════════════════════════════════════════
     03 · OFFHAND — moss field, two inks, the ligature as the logo
     ════════════════════════════════════════════════════════════════════ */
  .sp-oh { --oh-field: #20453a; --oh-ink: #eee8d5; --oh-soft: #9fb3a3; background: var(--oh-field); color: var(--oh-ink); }
  .sp-oh__in {
    max-width: 1280px; margin-inline: auto;
