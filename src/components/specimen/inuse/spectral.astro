  /* ════════════════════════════════════════════════════════════════════
     01 · THE GREY OF THE PAGE — dark stage, cream page, two controls
     ════════════════════════════════════════════════════════════════════ */
  .sp-ru { background: #211e17; color: #ece5d2; }
