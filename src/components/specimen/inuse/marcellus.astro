---
import type { CollectionEntry } from 'astro:content';
export interface Props { font: CollectionEntry<'fonts'>['data']; }
const { font } = Astro.props;
const fam = font.fontFamily;

// ── The sequence ─────────────────────────────────────────────────────────────
// One art-directed scroll built on a single idea: RVBRICATIO — the red minium
// pigment Roman masons brushed into their carved capitals. The red grows act
// by act: a toggle of pigment in the stone (01), the painted V and numerals of
// an identity (02), the rubric rules of a journal (03), the accents and search
// highlights of an interface (04), until it floods the final poster as a full
// minium field (05). Surfaces alternate: stone → paper → black plate → screen
// (with the stone returning inside the open record) → red.

// ── Act 04 — the epigraphic corpus (real records, real CIL numbers) ─────────
const records = [
  {
    cil: 'CIL VI 1285', period: 'republican', date: 'c. 280 BCE',
    text: 'CORNELIVS·LVCIVS·SCIPIO·BARBATVS',
    monument: 'Sarcophagus of Scipio Barbatus · Tomb of the Scipios, Via Appia',
    trans: '“Lucius Cornelius Scipio Barbatus, sprung from Gnaeus his father, a man strong and wise.”',
    note: 'The oldest hand in the corpus — the capital before the serif settled.',
  },
  {
    cil: 'CIL VI 1274', period: 'republican', date: 'c. 30 BCE',
    text: 'CAECILIAE·Q·CRETICI·F·METELLAE·CRASSI',
    monument: 'Tomb of Caecilia Metella · Via Appia, third milestone',
    trans: '“To Caecilia Metella, daughter of Quintus Creticus, wife of Crassus.”',
    note: 'A single line carried across a drum forty metres round.',
  },
  {
    cil: 'CIL VI 896', period: 'augustan', date: '27 BCE',
    text: 'M·AGRIPPA·L·F·COS·TERTIVM·FECIT',
    monument: 'Pantheon, pronaos frieze · Campus Martius',
    trans: '“Marcus Agrippa, son of Lucius, consul for the third time, built this.”',
    note: 'Bronze letters lost; the V-cut sockets still hold the words.',
  },
  {
    cil: 'CIL VI 945', period: 'flavian', date: '81 CE',
    text: 'SENATVS·POPVLVSQVE·ROMANVS·DIVO·TITO',
    monument: 'Arch of Titus, attic · Summa Sacra Via',
    trans: '“The Senate and the People of Rome, to the deified Titus.”',
    note: 'The attic block reads at two hundred Roman feet.',
  },
  {
    cil: 'CIL VI 960', period: 'trajanic', date: '113 CE',
    text: 'IMP·CAESARI·DIVI·NERVAE·F·TRAIANO',
    monument: 'Column of Trajan, pedestal · Forum of Trajan',
    trans: '“To the emperor Caesar Trajan, son of the deified Nerva…”',
    note: 'The canon — the six lines every revival measures itself against.',
  },
  {
    cil: 'CIL VI 1033', period: 'severan', date: '203 CE',
    text: 'IMP·CAES·LVCIO·SEPTIMIO·SEVERO',
    monument: 'Arch of Septimius Severus · north-west Forum Romanum',
    trans: '“To the emperor Caesar Lucius Septimius Severus…”',
    note: 'The late hand: heavier, closer, the brush almost forgotten.',
  },
];
const periods = [
  { id: 'all', label: 'Omnes' },
  { id: 'republican', label: 'Republican' },
  { id: 'augustan', label: 'Augustan' },
  { id: 'flavian', label: 'Flavian' },
  { id: 'trajanic', label: 'Trajanic' },
  { id: 'severan', label: 'Severan' },
];
---

<div class="iu mr" style={`--fam:${fam}`}>

  <!-- ════════════════════════════════════════════════════════════════════
       01 · INTERACTIVE & EXPERIMENTAL — "The Raking Light"
       Reference: Edward M. Catich, *The Origin of the Serif* (1968), and the
       raking-light photography of Roman inscriptions. The letters are incised
       into travertine; the pointer is the sun. PIGMENTVM pours the minium
       back into the cuts, as the Romans painted them.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">01</span><span class="label">Experimental — the raking light, after Catich</span></figcaption>
    <div class="iu__scene mr-stone" data-stone>
      <div class="mr-stone__bed" aria-hidden="true"></div>
      <svg class="mr-stone__grain" aria-hidden="true">
        <filter id="mr-grain"><feTurbulence type="fractalNoise" baseFrequency="0.82" numOctaves="3" stitchTiles="stitch" /><feColorMatrix type="saturate" values="0" /></filter>
        <rect width="100%" height="100%" filter="url(#mr-grain)" />
      </svg>
      <div class="mr-stone__sun" aria-hidden="true"></div>
      <div class="mr-stone__field">
        <span class="mr-stone__kicker">IMP·CAESAR·DIVI·F·AVGVSTVS·FECIT</span>
        <span class="mr-stone__line">THEATRVM</span>
        <span class="mr-stone__line">MARCELLI</span>
        <span class="mr-stone__base">M&middot;CLAVDIO&middot;MARCELLO <span class="mr-stone__sep">&middot;</span> NEPOTI&middot;SVO</span>
      </div>
      <button class="mr-stone__pig" data-pigment type="button" aria-pressed="false">
        <i aria-hidden="true"></i>PIGMENTVM
      </button>
    </div>
    <p class="iu__hint label">Move the pointer — it is the sun raking across incised travertine, the light Catich used to prove the serif began as a brushstroke. Press <strong>PIGMENTVM</strong> to pour the minium red back into the cuts, as Rome painted them.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       02 · BRANDING & IDENTITY — Museo Lapidario Maffeiano, Verona (est. 1745,
       the oldest public museum of inscriptions). Reference: Alan Fletcher's
       V&A wordmark (Pentagram, 1989) — classical capitals with one witty
       subtraction. The wit is epigraphic: the museum sets its U as the Romans
       cut it — V — painted in minium; and the wordmark is JUSTIFIED the way an
       inscription is — each line cut to its own size so the block squares up,
       measured live (rest and tracked states both), not eyeballed.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">02</span><span class="label">Branding — Museo Lapidario Maffeiano, an identity in one weight</span></figcaption>
    <div class="iu__scene">
      <div class="mr-id" data-id>
      <div class="mr-id__mark">
        <div class="mr-id__block" data-mark>
          <span class="mr-id__l mr-id__l--1" data-line>M<span class="mr-id__v">V</span>SE<span class="mr-id__end">O</span></span>
          <span class="mr-id__l mr-id__l--2" data-line>LAPIDARI<span class="mr-id__end">O</span></span>
          <span class="mr-id__l mr-id__l--3" data-line>MAFFEIAN<span class="mr-id__end">O</span></span>
        </div>
        <span class="mr-id__est">VERONA <span class="mr-id__dot">&middot;</span> MDCCXLV</span>
        <p class="mr-id__note">One weight, no italic — the system is carried by scale and letter-fit alone, the way an inscription carries a wall. The museum sets its U as the Romans cut it: <strong>V</strong>, painted in minium; the minium then numbers every room.</p>
      </div>
      <div class="mr-id__system">
        <div class="mr-id__sign">
          <span class="mr-id__ghost" aria-hidden="true">XAIPE</span>
          <span class="mr-id__room">SALA&middot;<b class="mr-id__num">I</b></span>
          <span class="mr-id__coll">GRAECA</span>
          <svg class="mr-id__arr" viewBox="0 0 34 10" aria-hidden="true"><path d="M0 5h31M27 1l5 4-5 4" fill="none" stroke="currentColor" stroke-width="1.1" /></svg>
        </div>
        <div class="mr-id__sign">
          <span class="mr-id__ghost mr-id__ghost--retro" aria-hidden="true">AVILS</span>
          <span class="mr-id__room">SALA&middot;<b class="mr-id__num">II</b></span>
          <span class="mr-id__coll">ETRVSCA</span>
          <svg class="mr-id__arr" viewBox="0 0 34 10" aria-hidden="true"><path d="M0 5h31M27 1l5 4-5 4" fill="none" stroke="currentColor" stroke-width="1.1" /></svg>
        </div>
        <div class="mr-id__sign">
          <span class="mr-id__ghost" aria-hidden="true">S&middot;P&middot;Q&middot;R</span>
          <span class="mr-id__room">SALA&middot;<b class="mr-id__num">III</b></span>
          <span class="mr-id__coll">ROMANA</span>
          <svg class="mr-id__arr" viewBox="0 0 34 10" aria-hidden="true"><path d="M0 5h31M27 1l5 4-5 4" fill="none" stroke="currentColor" stroke-width="1.1" /></svg>
        </div>
        <div class="mr-id__dida">
          <span class="mr-id__dnum">INV&middot;<b class="mr-id__num">CCXIV</b></span>
          <span class="mr-id__dtitle">STELE DI&nbsp;CLAVDIA&nbsp;TERTVLLA</span>
          <span class="mr-id__dmat">Calcare bianco, I secolo d.C. &mdash; raccolta di Scipione Maffei, Verona</span>
        </div>
        <div class="mr-id__ticket">
          <div class="mr-id__tleft">
            <span class="mr-id__tmus">M<span class="mr-id__v">V</span>SEO&middot;LAPIDARIO</span>
            <span class="mr-id__tbig">INGRESSO</span>
            <span class="mr-id__tmeta">INTERO &mdash; SCALONE DI&nbsp;CASTELVECCHIO</span>
          </div>
          <div class="mr-id__tright">
            <span class="mr-id__tno">N. 004182</span>
            <span class="mr-id__tdate">IX&middot;IV&middot;MMXXVI</span>
            <span class="mr-id__tprice">&euro; 7</span>
          </div>
        </div>
      </div>
      </div>
    </div>
    <p class="iu__hint label">An identity after Alan Fletcher&rsquo;s V&amp;A — classical capitals, one knowing move. Hover the wordmark: the lines track out to inscription spacing and each line re-cuts its own size, so the block stays squared to the edge in both states. The Greek room greets in the museum&rsquo;s own capitals (<strong>XAIPE</strong>); the Etruscan room runs retrograde, as Etruscan did.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       03 · EDITORIAL — "Capitalis", a quarterly of the lettered arts.
       Reference: FMR magazine (Franco Maria Ricci, 1982) — the black plate,
       the rubricated folio, scholarship set like jewellery. Left page: the
       tail of Q as a full-page plate. Right page: the Catich essay.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">03</span><span class="label">Editorial — Capitalis quarterly, in the manner of FMR</span></figcaption>
    <div class="iu__scene mr-fmr">
      <div class="mr-fmr__spread">
        <div class="mr-fmr__plate">
          <span class="mr-fmr__tab">TAB&middot;VII</span>
          <span class="mr-fmr__q" aria-hidden="true">Q</span>
          <span class="mr-fmr__platecap">Capitalis monumentalis &mdash; the tail of&nbsp;Q, the one flourish the chisel allowed&nbsp;itself.</span>
        </div>
        <div class="mr-fmr__page">
          <div class="mr-fmr__head">
            <span class="mr-fmr__journal">CAPITALIS</span>
            <span class="mr-fmr__issue">No. VIII &middot; HIEMS&middot;MMXXVI</span>
          </div>
          <h3 class="mr-fmr__title">The Serif Began<br />as a Brushstroke</h3>
          <span class="mr-fmr__rule" aria-hidden="true"></span>
          <p class="mr-fmr__deck">Edward Catich spent thirty years on a scaffold beside the Trajan inscription and came down with a heresy: the chisel invented nothing.</p>
          <div class="mr-fmr__body">
            <p><span class="mr-fmr__drop">I</span>n 1968 a Catholic priest and former Chicago show-card writer published the most persuasive answer ever given to a very old question. The serif, Catich argued in <em>The Origin of the Serif</em>, was not born of stone at all: a signwriter laid out every Roman inscription with a flat brush, and the small confident flick that finishes each stroke is simply what a flat brush does when it stops. The mason&rsquo;s chisel only followed.</p>
            <blockquote class="mr-fmr__pull">&middot;THE CHISEL OBEYED<br />THE BRVSH&middot;</blockquote>
            <p>Once seen, it cannot be unseen. The flared terminals of Marcellus &mdash; cut for the screen two millennia later &mdash; still carry that turn of the wrist: pressure, release, and the quiet authority of a letter that knows it will outlive its author.</p>
          </div>
          <div class="mr-fmr__folio">
            <span>XXI</span>
            <span class="mr-fmr__fjournal">CAPITALIS &middot; A QVARTERLY OF LETTERS</span>
            <span>XXII</span>
          </div>
        </div>
      </div>
    </div>
    <p class="iu__hint label">A spread in the manner of Franco Maria Ricci&rsquo;s <em>FMR</em>: the black plate, the rubricated rule, Marcellus titling over a Spectral reading column. The rule draws itself in; select the pull quote to see the minium.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       04 · WEB & APP UI — "Lapidarium", a digital-epigraphy corpus browser.
       Reference: the contemporary museum-collection web current set off by
       Rijksstudio (Fabrique & Q42, 2012) — generous masthead, the artifact
       itself shown large. Real records, real CIL numbers, real px. Search
       (matches pick up the minium), filter, reverse the chronology, and the
       open record shows the stone: the inscription at plate scale, raking-lit
       exactly as in act 01.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item">
    <figcaption class="iu__cap"><span class="index-num">04</span><span class="label">Product UI — Lapidarium, an epigraphic corpus (real scale, interactive)</span></figcaption>
    <div class="iu__scene">
      <div class="iu__device mr-lp" data-corpus>
        <div class="iu__chrome">
          <div class="iu__dots"><i></i><i></i><i></i></div>
          <span class="iu__addr">lapidarium.roma.it/corpus</span>
        </div>
        <header class="mr-lp__head">
          <span class="mr-lp__logo">LAPIDARIVM</span>
          <span class="mr-lp__count">Inscriptiones&nbsp;<strong data-count>VI</strong></span>
          <span class="mr-lp__sub">Corpus of the Roman capital &middot; digital epigraphy</span>
        </header>
        <div class="mr-lp__tools">
          <input class="mr-lp__search" data-search type="search" placeholder="Search the corpus — try AGRIPPA" aria-label="Search inscriptions" />
          <nav class="mr-lp__chips" aria-label="Filter by period">
            {periods.map((p, i) => (
              <button class={i === 0 ? 'is-on' : ''} data-period={p.id} type="button">{p.label}</button>
            ))}
          </nav>
          <button class="mr-lp__sort" data-sort type="button" aria-pressed="false" title="Reverse chronological order">ORDO&nbsp;<b data-sortlabel>VETVS&nbsp;&rarr;&nbsp;NOVVM</b></button>
        </div>
        <ul class="mr-lp__list">
          {records.map((r) => (
            <li class={`mr-lp__rec${r.period === 'trajanic' ? ' is-open' : ''}`} data-period={r.period} data-q={`${r.text} ${r.monument} ${r.cil} ${r.date}`.toLowerCase()}>
              <button class="mr-lp__row" type="button" aria-expanded={r.period === 'trajanic' ? 'true' : 'false'}>
                <span class="mr-lp__cil"><i>CIL&nbsp;VI</i><b>{r.cil.replace('CIL VI ', '')}</b></span>
                <span class="mr-lp__insc">{r.text.split('·').map((part, i, arr) => (
                  i < arr.length - 1 ? <>{part}&middot;<wbr /></> : part
                ))}</span>
                <span class="mr-lp__meta">{r.monument.split(' · ')[0]}</span>
                <span class="mr-lp__date">{r.date}</span>
                <span class="mr-lp__more" aria-hidden="true">+</span>
              </button>
              <div class="mr-lp__panel">
                <div class="mr-lp__plate">
                  <span class="mr-lp__platetab">{r.cil}</span>
                  <span class="mr-lp__platetext">{r.text.split('·').map((part, i, arr) => (
                    i < arr.length - 1 ? <>{part}&middot;<wbr /></> : part
                  ))}</span>
                </div>
                <p class="mr-lp__trans">{r.trans}</p>
                <p class="mr-lp__note"><span class="mr-lp__site">{r.monument}</span> — {r.note}</p>
              </div>
            </li>
          ))}
        </ul>
        <p class="mr-lp__empty" data-empty hidden>NVLLAE — no inscriptions answer. Clear the search and try the chisel again.</p>
      </div>
    </div>
    <p class="iu__hint label">Six real entries from the <em>Corpus Inscriptionum Latinarum</em>, in the museum-collection idiom Rijksstudio set in 2012. Search the stones — matches take the minium — flip the chronology, open a record: the corpus shows the stone itself, raking-lit at plate scale.</p>
  </figure>

  <!-- ════════════════════════════════════════════════════════════════════
       05 · ILLUSTRATION & COMMERCIAL — the exhibition broadside.
       Reference: a knowing collision — Josef Müller-Brockmann's Musica Viva
       concert posters (Tonhalle Zürich, 1950s): a strict 6-column modular
       grid, the title STEPPED down the columns, detail lines ruled to grid
       increments — carrying the Roman capital. Content after *The Eternal
       Letter* (ed. Paul Shaw, MIT Press, 2015). The specimen letter prints
       OVER the composition in multiply, so figure and text truly collide;
       each letter argues its own anatomy. The minium of act 01 is now the
       whole field.
       ═══════════════════════════════════════════════════════════════════ -->
  <figure class="iu__item iu__item--bleed">
    <figcaption class="iu__cap"><span class="index-num">05</span><span class="label">Poster — The Eternal Letter, a Musica Viva broadside</span></figcaption>
    <div class="iu__scene mr-post" data-poster>
      <div class="mr-post__grid">
        <span class="mr-post__kicker">LETTERFORM ARCHIVE &middot; SAN FRANCISCO</span>
        <span class="mr-post__t mr-post__t--1">THE</span>
        <span class="mr-post__t mr-post__t--2">ETERNAL</span>
        <span class="mr-post__t mr-post__t--3">LETTER</span>
        <span class="mr-post__sub">Two thousand years of the Roman capital</span>
        <div class="mr-post__details">
          <span>XVIII&middot;IV &mdash; XXIX&middot;VIII&middot;MMXXVII</span>
          <span>Opening lecture &mdash; The Brush Behind the Chisel</span>
          <span>Admission free &middot; Tuesday&ndash;Sunday</span>
        </div>
        <div class="mr-post__anat" aria-live="polite">
          <span class="mr-post__a is-on" data-a><b>R</b>the inscriptional leg &mdash; the low, confident kick that gave the letter its footing on the stone</span>
          <span class="mr-post__a" data-a><b>Q</b>the long Roman tail &mdash; the one flourish the chisel allowed itself below the baseline</span>
          <span class="mr-post__a" data-a><b>M</b>the classical proportions &mdash; wide, vertex to the baseline, as the Republic set them</span>
        </div>
        <span class="mr-post__imprint">After the volume edited by Paul Shaw &middot; The MIT Press &middot; MMXV &mdash; specimen letters R&middot;Q&middot;M, cut by Brian J. Bonislawsky</span>
      </div>
      <div class="mr-post__glyphs" aria-hidden="true">
        <span class="mr-post__g is-on" data-g>R</span>
        <span class="mr-post__g" data-g>Q</span>
        <span class="mr-post__g" data-g>M</span>
      </div>
    </div>
    <p class="iu__hint label">The minium field, at last — the pigment of act 01 becomes the poster&rsquo;s ground. M&uuml;ller-Brockmann&rsquo;s Musica Viva grid carries the capital: the title steps down the columns, the rules are cut to grid increments, and the specimen letter prints over the type in multiply. It turns R&nbsp;&rarr;&nbsp;Q&nbsp;&rarr;&nbsp;M on a slow beat — or at a click — each letter arguing its own anatomy.</p>
  </figure>

</div>

<script>
  // ── 01 · the raking light ──────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-stone]').forEach((stone) => {
    let raf = 0;
    stone.addEventListener('pointermove', (e) => {
      if (raf) return;
      const x = e.clientX, y = e.clientY;
      raf = requestAnimationFrame(() => {
        raf = 0;
        const r = stone.getBoundingClientRect();
        const nx = ((x - r.left) / r.width) * 2 - 1;   // −1 … 1
        const ny = ((y - r.top) / r.height) * 2 - 1;
        const m = Math.max(0.55, Math.hypot(nx, ny));
        stone.style.setProperty('--mr-lx', String(nx / m));
        stone.style.setProperty('--mr-ly', String(ny / m));
        stone.style.setProperty('--mr-mx', `${(nx * 0.5 + 0.5) * 100}%`);
        stone.style.setProperty('--mr-my', `${(ny * 0.5 + 0.5) * 100}%`);
        stone.classList.add('is-lit');
      });
    });
    stone.addEventListener('pointerleave', () => {
      stone.classList.remove('is-lit');
      ['--mr-lx', '--mr-ly', '--mr-mx', '--mr-my'].forEach((p) => stone.style.removeProperty(p));
    });
    const pig = stone.querySelector<HTMLButtonElement>('[data-pigment]');
    pig?.addEventListener('click', () => {
      const on = stone.classList.toggle('is-pigmented');
      pig.setAttribute('aria-pressed', String(on));
    });
  });

  // ── 02 · epigraphic justification: each line cut to its own size ───────
  // Measured live in BOTH states (rest tracking .08em, hover tracking .14em)
  // so the block stays squared to the right edge while the letters breathe.
  document.querySelectorAll<HTMLElement>('[data-id]').forEach((id) => {
    const mark = id.querySelector<HTMLElement>('[data-mark]');
    if (!mark) return;
    const lines = Array.from(mark.querySelectorAll<HTMLElement>('[data-line]'));
    let lastW = 0;
    const fit = () => {
      const target = mark.clientWidth;
      if (!target) return;
      mark.classList.add('is-measuring');
      [false, true].forEach((tracked) => {
        mark.classList.toggle('is-tracked', tracked);
        lines.forEach((l, i) => {
          l.style.fontSize = '100px';
          const w = l.getBoundingClientRect().width;
          l.style.fontSize = '';
          if (w > 0) mark.style.setProperty(tracked ? `--fs${i}h` : `--fs${i}`, `${(100 * target) / w}px`);
        });
      });
      mark.classList.remove('is-tracked');
      void mark.offsetWidth;            // commit final sizes before re-enabling transitions
      mark.classList.remove('is-measuring');
    };
    const ro = new ResizeObserver((entries) => {
      const w = entries[0].contentRect.width;
      if (Math.abs(w - lastW) < 0.5) return;
      lastW = w;
      fit();
    });
    ro.observe(mark);
    document.fonts?.ready.then(fit);
  });

  // ── 04 · the corpus browser ────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-corpus]').forEach((app) => {
    const list = app.querySelector<HTMLElement>('.mr-lp__list')!;
    const recs = Array.from(app.querySelectorAll<HTMLElement>('.mr-lp__rec'));
    const count = app.querySelector<HTMLElement>('[data-count]')!;
    const empty = app.querySelector<HTMLElement>('[data-empty]')!;
    const search = app.querySelector<HTMLInputElement>('[data-search]')!;
    const chips = Array.from(app.querySelectorAll<HTMLButtonElement>('[data-period]'));
    const sort = app.querySelector<HTMLButtonElement>('[data-sort]');
    const sortLabel = app.querySelector<HTMLElement>('[data-sortlabel]');
    const ROMAN = ['NVLLAE', 'I', 'II', 'III', 'IV', 'V', 'VI'];
    let period = 'all';
    let desc = false;

    // the matched fragment takes the minium (CSS Custom Highlight API)
    const highlight = (q: string) => {
      const css = CSS as any;
      if (!css.highlights) return;
      css.highlights.delete('mr-q');
      if (!q) return;
      const ranges: Range[] = [];
      recs.forEach((r) => {
        if (r.classList.contains('is-hidden')) return;
        r.querySelectorAll('.mr-lp__insc, .mr-lp__cil, .mr-lp__meta, .mr-lp__date, .mr-lp__platetext').forEach((el) => {
          const tw = document.createTreeWalker(el, NodeFilter.SHOW_TEXT);
          let n: Node | null;
          while ((n = tw.nextNode())) {
            const t = (n.textContent || '').toLowerCase();
            let idx = 0;
            while ((idx = t.indexOf(q, idx)) !== -1) {
              const range = new Range();
              range.setStart(n, idx);
              range.setEnd(n, idx + q.length);
              ranges.push(range);
              idx += q.length;
            }
          }
        });
      });
      if (ranges.length) css.highlights.set('mr-q', new (window as any).Highlight(...ranges));
    };

    const apply = () => {
      const q = search.value.trim().toLowerCase();
      let shown = 0;
      recs.forEach((r) => {
        const hit = (period === 'all' || r.dataset.period === period) &&
                    (!q || (r.dataset.q ?? '').includes(q));
        r.classList.toggle('is-hidden', !hit);
        if (hit) shown++;
      });
      count.textContent = ROMAN[shown];
      empty.hidden = shown !== 0;
      highlight(q);
    };

    chips.forEach((c) => c.addEventListener('click', () => {
      chips.forEach((x) => x.classList.remove('is-on'));
      c.classList.add('is-on');
      period = c.dataset.period!;
      apply();
    }));
    search.addEventListener('input', apply);

    // chronology toggle — the corpus is dated; let the user flip it
    sort?.addEventListener('click', () => {
      desc = !desc;
      (desc ? recs.slice().reverse() : recs).forEach((r) => list.appendChild(r));
      sort.setAttribute('aria-pressed', String(desc));
      if (sortLabel) sortLabel.textContent = desc ? 'NOVVM → VETVS' : 'VETVS → NOVVM';
    });

    recs.forEach((r) => {
      const row = r.querySelector<HTMLButtonElement>('.mr-lp__row')!;
      row.addEventListener('click', () => {
        const open = r.classList.toggle('is-open');
        row.setAttribute('aria-expanded', String(open));
      });
    });
  });

  // ── 05 · the specimen letter turns R → Q → M, arguing its anatomy ──────
  document.querySelectorAll<HTMLElement>('[data-poster]').forEach((post) => {
    const glyphs = Array.from(post.querySelectorAll<HTMLElement>('[data-g]'));
    const caps = Array.from(post.querySelectorAll<HTMLElement>('[data-a]'));
    let i = 0;
    const show = (n: number) => {
      i = (n + glyphs.length) % glyphs.length;
      glyphs.forEach((g, k) => g.classList.toggle('is-on', k === i));
      caps.forEach((c, k) => c.classList.toggle('is-on', k === i));
    };
    post.addEventListener('click', () => show(i + 1));
    if (window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
      setInterval(() => show(i + 1), 5600);
    }
  });
</script>

