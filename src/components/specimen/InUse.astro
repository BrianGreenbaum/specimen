---
import type { CollectionEntry } from 'astro:content';
import BrandScene from './BrandScene.astro';
export interface Props {
  font: CollectionEntry<'fonts'>['data'];
}
const { font } = Astro.props;
const fam = font.fontFamily;
---
<div class="inuse" style={`--fam:${fam}`}>
  {font.inUse.map((scene, i) => (
    <figure class="inuse__item" data-reveal style={`--reveal-delay:${i * 60}ms`}>
      <figcaption class="inuse__cap">
        <span class="index-num">{String(i + 1).padStart(2, '0')}</span>
        <span class="label">{scene.label}</span>
      </figcaption>

      <div class={`scene scene--${scene.kind}`}>
        {scene.kind === 'brand' && (
          <BrandScene font={font} variant={scene.variant} />
        )}

        {scene.kind === 'app-ui' && (
          <div class="s-app">
            <div class="s-app__bar">
              <span class="s-app__logo">◆ {font.name.split(' ')[0]}</span>
              <span class="s-app__nav"><b>Overview</b><span>Reports</span><span>Settings</span></span>
              <span class="s-app__avatar">RA</span>
            </div>
            <div class="s-app__body">
              <aside class="s-app__side">
                <span class="on">Dashboard</span><span>Revenue</span><span>Customers</span><span>Activity</span>
              </aside>
              <main class="s-app__main">
                <div class="s-app__cards">
                  <div class="s-app__card"><span class="k">Revenue</span><b>$48,290</b><i class="up">▲ 12.4%</i></div>
                  <div class="s-app__card"><span class="k">Active users</span><b>9,318</b><i class="up">▲ 3.1%</i></div>
                  <div class="s-app__card"><span class="k">Churn</span><b>1.08%</b><i class="dn">▼ 0.3%</i></div>
                </div>
                <div class="s-app__chart">
                  {[42, 60, 38, 72, 55, 81, 64, 90, 48, 76, 58, 96].map((h) => (
                    <span style={`height:${h}%`}></span>
                  ))}
                </div>
              </main>
            </div>
          </div>
        )}

        {scene.kind === 'data' && (
          <div class="s-data">
            <div class="s-data__head"><span>Instrument</span><span>Last</span><span>Chg</span><span>Vol</span></div>
            {[
              ['Aldus Corp.', '184.20', '+1.8%', '2,410,998'],
              ['Garamond Inc.', '92.51', '−0.4%', '880,417'],
              ['Baskerville Co.', '1,204.00', '+5.2%', '11,902'],
              ['Didot Holdings', '47.83', '+0.1%', '309,556'],
              ['Bodoni & Sons', '768.49', '−2.7%', '64,330'],
            ].map((r) => (
              <div class="s-data__row">
                <span>{r[0]}</span>
                <span class="num">{r[1]}</span>
                <span class={`num ${r[2].startsWith('+') ? 'up' : 'dn'}`}>{r[2]}</span>
                <span class="num dim">{r[3]}</span>
              </div>
            ))}
          </div>
        )}

        {scene.kind === 'terminal' && (
          <div class="s-term">
            <div class="s-term__bar"><i></i><i></i><i></i><span>— zsh — {font.name.toLowerCase().replace(/\s+/g, '-')}</span></div>
            <pre class="s-term__body"><span class="c">~/specimen</span> <span class="p">❯</span> npm run build
<span class="d">▸ building 7 specimen pages…</span>
<span class="g">✓ inter</span>      <span class="d">128 glyphs · variable</span>
<span class="g">✓ fraunces</span>   <span class="d">4 axes: wght opsz SOFT WONK</span>
<span class="g">✓ ibm-plex</span>   <span class="d">man &amp; machine</span>
<span class="ok">◆ done in 0.42s</span> <span class="cur">█</span></pre>
          </div>
        )}

        {scene.kind === 'invitation' && (
          <div class="s-invite">
            <span class="s-invite__eyebrow">Together with their families</span>
            <p class="s-invite__pre">request the pleasure of your company at the marriage of</p>
            <h3 class="s-invite__names">Eleanor<span class="amp"> &amp; </span>Auguste</h3>
            <div class="s-invite__rule"><span>✦</span></div>
            <p class="s-invite__detail">Saturday, the twelfth of September · half past four<br/>The Old Print Works · Birmingham</p>
            <span class="s-invite__rsvp">Black tie · Reply by August</span>
          </div>
        )}

        {scene.kind === 'editorial' && (
          <div class="s-edit">
            <span class="s-edit__kicker">Identity / {font.year}</span>
            <h3 class="s-edit__head">{font.headline}</h3>
            <div class="s-edit__cols">
              <p>A typeface is a point of view. {font.name} carries one into every word it sets, shaping the voice of a brand long before a single sentence is read.</p>
              <p>Drawn by {font.designer}, it moves between the practical and the expressive — equally at home on a sign, a page, or a screen held at arm’s length.</p>
            </div>
          </div>
        )}

        {scene.kind === 'poster' && (
          <div class="s-poster">
            <span class="s-poster__edge s-poster__edge--l">{font.classification}</span>
            <span class="s-poster__edge s-poster__edge--r">No. {String(font.order).padStart(2, '0')}</span>
            <div class="s-poster__center">
              <span class="s-poster__small">The Type Society presents</span>
              <h3 class="s-poster__title">{font.headline}</h3>
              <span class="s-poster__meta">Fri 21 · 8PM · Hall A</span>
            </div>
            <span class="s-poster__foot">{font.name} — {font.designer}</span>
          </div>
        )}

        {scene.kind === 'magazine' && (
          <div class="s-mag">
            <div class="s-mag__left">
              <span class="s-mag__folio">Feature</span>
              <span class="s-mag__issue">Issue {font.year}</span>
            </div>
            <div class="s-mag__right">
              <h3 class="s-mag__head">The Shape<br/>of <em>Language</em></h3>
              <p class="s-mag__deck">On {font.designer} and the quiet art of giving words a face.</p>
              <div class="s-mag__body">
                <p><span class="s-mag__drop">T</span>he page is a stage, and the typeface is the actor’s voice. Set the right one and the words seem inevitable; set the wrong one and even a true sentence rings false.</p>
              </div>
            </div>
          </div>
        )}

        {scene.kind === 'article' && (
          <div class="s-article">
            <span class="s-article__kicker">Long read · {font.classification}</span>
            <h3 class="s-article__head">In defence of reading at length</h3>
            <span class="s-article__byline">by {font.designer}</span>
            <p class="s-article__body"><span class="s-article__drop">F</span>or all the noise of the modern page, the deepest pleasure type can offer is still the simplest: a long passage, well set, that disappears entirely into the act of reading. Good body type does not ask to be admired. It asks only to be forgotten, so that the words can be remembered.</p>
            <blockquote class="s-article__quote">“Type is a beautiful group of letters, not a group of beautiful letters.”</blockquote>
          </div>
        )}
      </div>
    </figure>
  ))}
</div>

<style>
  .inuse { display: flex; flex-direction: column; gap: var(--sp-6); }
  .inuse__cap { display: flex; align-items: baseline; gap: 0.7rem; margin-bottom: var(--sp-2); }

  .scene {
    container-type: inline-size;
    position: relative;
    border: 1px solid var(--line);
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--bg-2);
  }
  .scene * { font-family: var(--fam); }

  /* ---------- APP UI ---------- */
  .scene--app-ui { background: var(--bg); }
  .s-app { position: absolute; inset: 0; display: flex; flex-direction: column; font-size: 2.6cqi; }
  .s-app__bar { display: flex; align-items: center; gap: 3cqi; padding: 2.4cqi 3cqi; border-bottom: 1px solid var(--line); }
  .s-app__logo { font-weight: 700; color: var(--accent); }
  .s-app__nav { display: flex; gap: 2.4cqi; color: var(--fg-3); }
  .s-app__nav b { color: var(--fg); font-weight: 600; }
  .s-app__avatar { margin-left: auto; width: 6cqi; height: 6cqi; border-radius: 50%; background: var(--accent); color: var(--accent-contrast); display: grid; place-items: center; font-size: 2.2cqi; font-weight: 600; }
  .s-app__body { flex: 1; display: grid; grid-template-columns: 22% 1fr; }
  .s-app__side { display: flex; flex-direction: column; gap: 2.4cqi; padding: 3cqi; border-right: 1px solid var(--line); color: var(--fg-3); }
  .s-app__side .on { color: var(--fg); font-weight: 600; }
  .s-app__main { padding: 3cqi; display: flex; flex-direction: column; gap: 3cqi; }
  .s-app__cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.4cqi; }
  .s-app__card { border: 1px solid var(--line); padding: 2.4cqi; display: flex; flex-direction: column; gap: 1cqi; }
  .s-app__card .k { color: var(--fg-3); font-size: 2.2cqi; }
  .s-app__card b { font-size: 5cqi; font-weight: 700; font-feature-settings: 'tnum'; letter-spacing: -0.01em; }
  .s-app__card .up { color: #1f9d57; font-size: 2.2cqi; }
  .s-app__card .dn { color: #c8442b; font-size: 2.2cqi; }
  .s-app__chart { flex: 1; display: flex; align-items: flex-end; gap: 1.6cqi; padding-top: 2cqi; }
  .s-app__chart span { flex: 1; background: var(--accent); opacity: 0.85; border-radius: 1px 1px 0 0; }
  .s-app__chart span:nth-child(even) { opacity: 0.4; }

  /* ---------- DATA ---------- */
  .scene--data { background: var(--bg); }
  .s-data { position: absolute; inset: 0; display: flex; flex-direction: column; font-size: 3cqi; padding: 1cqi 0; }
  .s-data__head, .s-data__row { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1.4fr; gap: 2cqi; padding: 2.1cqi 4cqi; align-items: baseline; }
  .s-data__head { color: var(--fg-3); font-size: 2.3cqi; text-transform: uppercase; letter-spacing: 0.08em; border-bottom: 1px solid var(--fg); }
  .s-data__row { border-bottom: 1px solid var(--line-soft); }
  .s-data .num { text-align: right; font-feature-settings: 'tnum'; }
  .s-data .up { color: #1f9d57; }
  .s-data .dn { color: #c8442b; }
  .s-data .dim { color: var(--fg-3); }

  /* ---------- TERMINAL ---------- */
  .scene--terminal { background: #0a0e14; border-color: #1d2733; }
  .s-term { position: absolute; inset: 0; display: flex; flex-direction: column; }
  .s-term__bar { display: flex; align-items: center; gap: 1.5cqi; padding: 2cqi 3cqi; background: #111722; color: #5f6e80; font-size: 2.3cqi; }
  .s-term__bar i { width: 2.4cqi; height: 2.4cqi; border-radius: 50%; background: #2a3543; }
  .s-term__bar i:nth-child(1) { background: #ff5f57; } .s-term__bar i:nth-child(2) { background: #febc2e; } .s-term__bar i:nth-child(3) { background: #28c840; }
  .s-term__bar span { margin-left: auto; }
  .s-term__body { padding: 3cqi; color: #cfd8e3; font-size: 2.9cqi; line-height: 1.7; white-space: pre-wrap; }
  .s-term .c { color: #4d8dff; } .s-term .p { color: #28c840; } .s-term .d { color: #5f6e80; }
  .s-term .g { color: #28c840; } .s-term .ok { color: #febc2e; }
  .s-term .cur { animation: blink 1.1s steps(1) infinite; color: #cfd8e3; }
  @keyframes blink { 50% { opacity: 0; } }

  /* ---------- INVITATION ---------- */
  .scene--invitation { background: #f7f3ea; color: #1f1a12; }
  .s-invite { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 2cqi; padding: 5cqi; }
  .s-invite__eyebrow { font-size: 2.6cqi; letter-spacing: 0.25em; text-transform: uppercase; color: var(--accent); }
  .s-invite__pre { font-size: 3cqi; font-style: italic; color: #5a5240; max-width: 60%; }
  .s-invite__names { font-size: 13cqi; line-height: 0.95; font-weight: 500; }
  .s-invite__names .amp { font-style: italic; color: var(--accent); }
  .s-invite__rule { display: flex; align-items: center; gap: 2cqi; width: 40%; color: var(--accent); }
  .s-invite__rule::before, .s-invite__rule::after { content: ''; flex: 1; height: 1px; background: currentColor; opacity: 0.5; }
  .s-invite__detail { font-size: 2.8cqi; line-height: 1.7; color: #3b3527; }
  .s-invite__rsvp { font-size: 2.2cqi; letter-spacing: 0.18em; text-transform: uppercase; color: #8a7f63; margin-top: 1cqi; }

  /* ---------- EDITORIAL ---------- */
  .scene--editorial { background: var(--bg); }
  .s-edit { position: absolute; inset: 0; padding: 5cqi; display: flex; flex-direction: column; justify-content: center; gap: 3cqi; }
  .s-edit__kicker { font-size: 2.4cqi; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); }
  .s-edit__head { font-size: 13cqi; line-height: 0.92; font-weight: 600; letter-spacing: -0.02em; }
  .s-edit__cols { display: grid; grid-template-columns: 1fr 1fr; gap: 5cqi; font-size: 2.7cqi; line-height: 1.6; color: var(--fg-2); max-width: 88%; }

  /* ---------- POSTER ---------- */
  .scene--poster { background: var(--accent); color: var(--accent-contrast); }
  .s-poster { position: absolute; inset: 0; padding: 3cqi; display: flex; flex-direction: column; }
  .s-poster__edge { position: absolute; top: 50%; font-size: 2.3cqi; letter-spacing: 0.2em; text-transform: uppercase; }
  .s-poster__edge--l { left: 3cqi; transform: rotate(-90deg) translateX(50%); transform-origin: left; }
  .s-poster__edge--r { right: 3cqi; transform: rotate(90deg) translateX(-50%); transform-origin: right; }
  .s-poster__center { margin: auto; text-align: center; display: flex; flex-direction: column; gap: 2cqi; }
  .s-poster__small { font-size: 2.8cqi; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.8; }
  .s-poster__title { font-size: 17cqi; line-height: 0.86; font-weight: 700; letter-spacing: -0.02em; }
  .s-poster__meta { font-size: 3.4cqi; letter-spacing: 0.04em; }
  .s-poster__foot { text-align: center; font-size: 2.3cqi; opacity: 0.8; border-top: 1px solid currentColor; padding-top: 2cqi; }

  /* ---------- MAGAZINE ---------- */
  .scene--magazine { background: var(--bg); }
  .s-mag { position: absolute; inset: 0; display: grid; grid-template-columns: 26% 1fr; }
  .s-mag__left { border-right: 1px solid var(--line); padding: 3cqi; display: flex; flex-direction: column; justify-content: space-between; }
  .s-mag__folio { font-size: 2.4cqi; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); }
  .s-mag__issue { font-size: 2.4cqi; color: var(--fg-3); }
  .s-mag__right { padding: 4cqi; display: flex; flex-direction: column; gap: 2cqi; }
  .s-mag__head { font-size: 12cqi; line-height: 0.9; font-weight: 700; letter-spacing: -0.02em; }
  .s-mag__head em { font-style: italic; color: var(--accent); font-weight: 400; }
  .s-mag__deck { font-size: 3cqi; font-style: italic; color: var(--fg-2); }
  .s-mag__body { columns: 2; column-gap: 4cqi; font-size: 2.4cqi; line-height: 1.55; color: var(--fg-2); }
  .s-mag__drop { float: left; font-size: 9cqi; line-height: 0.8; font-weight: 700; padding-right: 1.4cqi; color: var(--accent); }

  /* ---------- ARTICLE ---------- */
  .scene--article { background: var(--bg); }
  .s-article { position: absolute; inset: 0; padding: 5cqi 7cqi; display: flex; flex-direction: column; gap: 1.6cqi; justify-content: center; }
  .s-article__kicker { font-size: 2.3cqi; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); }
  .s-article__head { font-size: 8cqi; line-height: 1; font-weight: 700; letter-spacing: -0.01em; }
  .s-article__byline { font-size: 2.5cqi; font-style: italic; color: var(--fg-3); }
  .s-article__body { font-size: 2.8cqi; line-height: 1.62; color: var(--fg-2); max-width: 64ch; margin-top: 1cqi; }
  .s-article__drop { float: left; font-size: 9cqi; line-height: 0.74; font-weight: 700; padding: 0.4cqi 1.4cqi 0 0; color: var(--fg); }
  .s-article__quote { font-size: 3.6cqi; line-height: 1.3; font-style: italic; color: var(--fg); border-left: 2px solid var(--accent); padding-left: 3cqi; margin-top: 1cqi; max-width: 80%; }

  @media (max-width: 600px) {
    .scene { aspect-ratio: 4 / 5; }
  }
</style>
