---
// A small library of brand / identity layouts, each themed to the font on show.
// Five distinct variants — wordmark, monogram, seal, stack, grid — so the
// "in use → brand" scene varies across the collection while staying on-brand.
// Self-contained: fills its parent (an .iu__scene / .scene) and drives type
// off the container with cqi units, so it scales with the frame.
import type { CollectionEntry } from 'astro:content';
export interface Props {
  font: CollectionEntry<'fonts'>['data'];
  variant?: 'wordmark' | 'monogram' | 'seal' | 'stack' | 'grid';
}
const VARIANTS = ['wordmark', 'monogram', 'seal', 'stack', 'grid'] as const;
const { font, variant } = Astro.props;
const fam = font.fontFamily;
const initial = font.name.charAt(0);
// Deterministic per-font fallback so the variant is stable across builds.
const hash = [...font.name].reduce((a, c) => a + c.charCodeAt(0), 0);
const v = variant ?? VARIANTS[hash % VARIANTS.length];
---
<div class:list={['brand', `brand--${v}`]} style={`--fam:${fam}`}>
  {v === 'wordmark' && (
    <div class="brand__wordmark">
      <span class="brand__mark" aria-hidden="true">✳</span>
      <h3 class="brand__word">{font.name}</h3>
      <p class="brand__tag">{font.headline} · est. {font.year}</p>
      <div class="brand__lockups"><span>™</span><span>{font.category}</span><span>Aa</span></div>
    </div>
  )}

  {v === 'monogram' && (
    <div class="brand__monogram">
      <div class="brand__mono-frame"><span class="brand__mono-letter">{initial}</span></div>
      <span class="brand__mono-name">{font.name}</span>
      <span class="brand__mono-sub">{font.classification}</span>
    </div>
  )}

  {v === 'seal' && (
    <div class="brand__seal">
      <div class="brand__seal-disc">
        <span class="brand__seal-top">EST · {font.year}</span>
        <span class="brand__seal-letter">{initial}</span>
        <span class="brand__seal-bottom">{font.category} · Type</span>
      </div>
      <span class="brand__seal-name">{font.name}</span>
    </div>
  )}

  {v === 'stack' && (
    <div class="brand__stack">
      <span class="brand__stack-mark" aria-hidden="true">◆</span>
      <h3 class="brand__stack-name">{font.name}</h3>
      <span class="brand__stack-rule" aria-hidden="true"></span>
      <span class="brand__stack-meta">{font.classification} · {font.year}</span>
    </div>
  )}

  {v === 'grid' && (
    <div class="brand__grid">
      <div class="brand__cell brand__cell--word"><span>{font.name}</span></div>
      <div class="brand__cell brand__cell--mono"><span>{initial}</span></div>
      <div class="brand__cell brand__cell--swatch"><span class="brand__cell-tag">{font.category}</span></div>
      <div class="brand__cell brand__cell--est"><span>est.</span><b>{font.year}</b></div>
    </div>
  )}
</div>

<style>
  .brand {
    position: absolute; inset: 0;
    container-type: inline-size;
  }
  .brand * { font-family: var(--fam); }

  /* ---------- WORDMARK ---------- */
  .brand--wordmark { background: var(--fg); color: var(--bg); }
  .brand__wordmark {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3cqi;
  }
  .brand__mark { color: var(--accent); font-size: 7cqi; }
  .brand__word { font-size: 16cqi; font-weight: 600; line-height: 0.9; letter-spacing: -0.02em; text-align: center; }
  .brand__tag { font-size: 3cqi; opacity: 0.7; letter-spacing: 0.02em; }
  .brand__lockups { display: flex; gap: 4cqi; margin-top: 1cqi; font-size: 3cqi; opacity: 0.55; border-top: 1px solid currentColor; padding-top: 2cqi; }

  /* ---------- MONOGRAM ---------- */
  .brand--monogram { background: var(--bg-2); color: var(--fg); }
  .brand__monogram {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3cqi;
  }
  .brand__mono-frame {
    width: 44cqi; height: 44cqi; display: grid; place-items: center;
    border: 1.5px solid var(--accent); border-radius: 50%;
    position: relative;
  }
  .brand__mono-frame::after {
    content: ''; position: absolute; inset: 2.4cqi; border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent); border-radius: 50%;
  }
  .brand__mono-letter { font-size: 26cqi; font-weight: 600; line-height: 1; color: var(--accent); }
  .brand__mono-name { font-size: 5cqi; letter-spacing: 0.3em; text-transform: uppercase; }
  .brand__mono-sub { font-size: 2.4cqi; letter-spacing: 0.2em; text-transform: uppercase; color: var(--fg-3); }

  /* ---------- SEAL ---------- */
  .brand--seal { background: var(--accent); color: var(--accent-contrast); }
  .brand__seal {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3.5cqi;
  }
  .brand__seal-disc {
    width: 46cqi; height: 46cqi; border-radius: 50%;
    border: 1px solid currentColor;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1cqi;
    position: relative;
  }
  .brand__seal-disc::before, .brand__seal-disc::after {
    content: ''; position: absolute; left: 14%; right: 14%; height: 1px; background: currentColor; opacity: 0.5;
  }
  .brand__seal-disc::before { top: 30%; }
  .brand__seal-disc::after { bottom: 30%; }
  .brand__seal-top, .brand__seal-bottom { font-size: 2.4cqi; letter-spacing: 0.28em; text-transform: uppercase; opacity: 0.85; }
  .brand__seal-letter { font-size: 18cqi; font-weight: 600; line-height: 1; }
  .brand__seal-name { font-size: 4.4cqi; letter-spacing: 0.18em; text-transform: uppercase; }

  /* ---------- STACK ---------- */
  .brand--stack { background: var(--bg); color: var(--fg); }
  .brand__stack {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: flex-start; justify-content: center;
    gap: 2cqi; padding: 8cqi;
    border-left: 1.5cqi solid var(--accent);
  }
  .brand__stack-mark { color: var(--accent); font-size: 6cqi; }
  .brand__stack-name { font-size: 17cqi; font-weight: 600; line-height: 0.88; letter-spacing: -0.03em; }
  .brand__stack-rule { width: 18cqi; height: 2px; background: var(--accent); margin: 1cqi 0; }
  .brand__stack-meta { font-size: 2.8cqi; letter-spacing: 0.12em; text-transform: uppercase; color: var(--fg-2); }

  /* ---------- GRID ---------- */
  .brand--grid { background: var(--line); }
  .brand__grid {
    position: absolute; inset: 0;
    display: grid; grid-template-columns: 1.3fr 1fr; grid-template-rows: 1fr 0.7fr;
    gap: 1px;
  }
  .brand__cell { background: var(--bg); display: flex; align-items: center; justify-content: center; overflow: hidden; padding: 3cqi; }
  .brand__cell--word { font-size: 11cqi; font-weight: 600; letter-spacing: -0.02em; line-height: 0.9; text-align: center; color: var(--fg); }
  .brand__cell--mono { background: var(--fg); color: var(--bg); font-size: 26cqi; font-weight: 600; }
  .brand__cell--swatch { background: var(--accent); }
  .brand__cell-tag { color: var(--accent-contrast); font-size: 3cqi; letter-spacing: 0.18em; text-transform: uppercase; }
  .brand__cell--est { flex-direction: column; gap: 0.5cqi; color: var(--fg); }
  .brand__cell--est span { font-size: 2.6cqi; letter-spacing: 0.2em; text-transform: uppercase; color: var(--fg-3); }
  .brand__cell--est b { font-size: 7cqi; font-weight: 600; font-feature-settings: 'tnum'; }
</style>
