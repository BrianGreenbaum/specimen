---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  font: CollectionEntry<'fonts'>['data'];
}
const { font } = Astro.props;
const num = String(font.order).padStart(2, '0');
const initial = font.name.charAt(0);
const wghtAxis = font.axes.find((a) => a.tag === 'wght');
---
<header
  class="hero"
  style={`--fam:${font.fontFamily}`}
  data-hero
  data-variable={font.isVariable ? 'true' : 'false'}
  data-wmin={wghtAxis?.min ?? 400}
  data-wmax={wghtAxis?.max ?? 400}
  data-wdef={wghtAxis?.default ?? 400}
>
  <div class="hero__ghost" aria-hidden="true" data-hero-ghost>{initial}</div>

  <div class="container hero__inner">
    <div class="hero__top" data-reveal>
      <span class="index-num">{num}</span>
      <span class="label">{font.category} · {font.classification}</span>
      <span class="label hero__year">{font.year}</span>
    </div>

    <h1 class="hero__name" data-reveal data-hero-name style="--reveal-delay:80ms">{font.name}</h1>

    <p class="hero__headline" data-reveal style="--reveal-delay:160ms">{font.headline}</p>

    <div class="hero__meta" data-reveal style="--reveal-delay:240ms">
      <p class="hero__blurb">{font.blurb}</p>
      <p class="hero__credit label">
        Designed by <strong>{font.designer}</strong>
        {font.foundry && <> · {font.foundry}</>}
      </p>
    </div>
  </div>
</header>

<script>
  // Cursor-reactive hero: the giant name's weight follows the pointer,
  // the ghost letter parallaxes. Refined, and disabled for reduced-motion.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  document.querySelectorAll<HTMLElement>('[data-hero]').forEach((hero) => {
    const name = hero.querySelector('[data-hero-name]') as HTMLElement;
    const ghost = hero.querySelector('[data-hero-ghost]') as HTMLElement;

    // Long names ("Libre Baskerville") can overflow the display size —
    // shrink to fit the container once the real font has loaded.
    const fit = () => {
      name.style.fontSize = '';
      const avail = name.clientWidth;
      const w = name.scrollWidth;
      if (w > avail) {
        const cur = parseFloat(getComputedStyle(name).fontSize);
        name.style.fontSize = `${Math.floor(cur * (avail / w) * 0.98)}px`;
      }
    };
    document.fonts.ready.then(fit);
    window.addEventListener('resize', fit);
    const isVar = hero.dataset.variable === 'true';
    const wmin = +(hero.dataset.wmin || 400);
    const wmax = +(hero.dataset.wmax || 400);
    const wdef = +(hero.dataset.wdef || 400);
    if (reduce) return;

    let cx = 0.5, cy = 0.5, curW = Math.max(wmin, 200), tgtW = wdef, gx = 0, gy = 0;
    let active = false;

    hero.addEventListener('pointermove', (e) => {
      const r = hero.getBoundingClientRect();
      cx = (e.clientX - r.left) / r.width;
      cy = (e.clientY - r.top) / r.height;
      active = true;
      if (isVar && wmax > wmin) tgtW = wmin + Math.min(1, Math.max(0, cx)) * (wmax - wmin);
    });
    hero.addEventListener('pointerleave', () => { active = false; tgtW = wdef; });

    const loop = () => {
      curW += (tgtW - curW) * 0.09;
      if (isVar && wmax > wmin) name.style.fontVariationSettings = `'wght' ${curW.toFixed(0)}`;
      const tgx = active ? (cx - 0.5) * -34 : 0;
      const tgy = active ? (cy - 0.5) * -22 : 0;
      gx += (tgx - gx) * 0.06; gy += (tgy - gy) * 0.06;
      if (ghost) ghost.style.transform = `translate(${gx.toFixed(2)}px, ${gy.toFixed(2)}px)`;
      requestAnimationFrame(loop);
    };
    requestAnimationFrame(loop);
  });
</script>

<style>
  .hero {
    position: relative;
    overflow: clip;
    padding-block: clamp(3rem, 8vh, 7rem) clamp(2.5rem, 6vh, 5rem);
    border-bottom: 1px solid var(--line);
    min-height: min(92vh, 900px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero__ghost {
    position: absolute;
    font-family: var(--fam);
    font-weight: 900;
    font-size: clamp(30rem, 80vw, 64rem);
    line-height: 0.7;
    right: -0.08em;
    bottom: -0.22em;
    color: var(--accent);
    opacity: 0.07;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .hero__inner { position: relative; z-index: 1; }

  .hero__top {
    display: flex;
    align-items: baseline;
    gap: var(--sp-4);
    padding-bottom: var(--sp-4);
  }
  .hero__year { margin-left: auto; }

  .hero__name {
    font-family: var(--fam);
    font-weight: 600;
    font-size: var(--display);
    line-height: 0.86;
    letter-spacing: -0.02em;
    margin-block: 0.1em 0.08em;
    animation: heroWeight 1.4s var(--ease) both;
  }
  @keyframes heroWeight {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: none; }
  }
  .hero__ghost { transition: transform 0.1s linear; will-change: transform; }

  .hero__headline {
    font-family: var(--fam);
    font-size: var(--step-3);
    font-weight: 400;
    line-height: 1;
    color: var(--accent);
    letter-spacing: -0.01em;
    /* keep clear of the oversized display name above it */
    margin-top: var(--sp-3);
    margin-bottom: var(--sp-5);
  }

  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3) var(--sp-6);
    align-items: baseline;
    max-width: 78ch;
    margin-bottom: var(--sp-4);
  }
  .hero__blurb { font-size: var(--step-1); color: var(--fg-2); max-width: 58ch; }
  .hero__credit { font-size: var(--step--1); }
  .hero__credit strong { color: var(--fg); }

  @media (max-width: 640px) {
    .hero { min-height: auto; }
    .hero__name { font-size: clamp(3.5rem, 20vw, 6rem); }
    .hero__year { margin-left: 0; }
    .hero__top { flex-wrap: wrap; gap: var(--sp-2) var(--sp-3); }
  }
</style>
