---
// Base HTML shell for every page.
// Loads global styles + all seven self-hosted specimen typefaces.
import '../styles/global.css';

// --- Variable specimen fonts (full axis sets) ---
import '@fontsource-variable/inter/opsz.css';
import '@fontsource-variable/inter/opsz-italic.css';
import '@fontsource-variable/fraunces/full.css';
import '@fontsource-variable/fraunces/full-italic.css';
import '@fontsource-variable/space-grotesk/index.css';
import '@fontsource-variable/playfair-display/wght.css';
import '@fontsource-variable/playfair-display/wght-italic.css';

// --- Static specimen fonts (weights we showcase) ---
import '@fontsource/ibm-plex-mono/100.css';
import '@fontsource/ibm-plex-mono/200.css';
import '@fontsource/ibm-plex-mono/300.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/ibm-plex-mono/600.css';
import '@fontsource/ibm-plex-mono/700.css';
import '@fontsource/ibm-plex-mono/400-italic.css';
import '@fontsource/ibm-plex-mono/500-italic.css';
import '@fontsource/ibm-plex-mono/700-italic.css';

import '@fontsource/libre-baskerville/400.css';
import '@fontsource/libre-baskerville/700.css';
import '@fontsource/libre-baskerville/400-italic.css';

import '@fontsource/cormorant-garamond/300.css';
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/700.css';
import '@fontsource/cormorant-garamond/400-italic.css';
import '@fontsource/cormorant-garamond/600-italic.css';

// --- Gap-filling specimens (history timeline) ---
import '@fontsource-variable/cinzel/wght.css';
import '@fontsource-variable/eb-garamond/wght.css';
import '@fontsource-variable/eb-garamond/wght-italic.css';
import '@fontsource-variable/bodoni-moda/opsz.css';
import '@fontsource-variable/bodoni-moda/wght-italic.css';
import '@fontsource-variable/besley/wght.css';
import '@fontsource-variable/besley/wght-italic.css';
import '@fontsource-variable/jost/wght.css';
import '@fontsource-variable/jost/wght-italic.css';

// --- New full specimens (added with the History redesign) ---
import '@fontsource-variable/newsreader/opsz.css';
import '@fontsource-variable/newsreader/opsz-italic.css';
import '@fontsource-variable/outfit/wght.css';
import '@fontsource-variable/roboto-slab/wght.css';
import '@fontsource-variable/source-sans-3/wght.css';
import '@fontsource-variable/source-sans-3/wght-italic.css';

// --- Timeline-only faces (shown in History chapters; no specimen page) ---
import '@fontsource/marcellus/400.css';
import '@fontsource-variable/oswald/wght.css';
import '@fontsource/spectral/300.css';
import '@fontsource/spectral/400.css';
import '@fontsource/spectral/600.css';
import '@fontsource/spectral/400-italic.css';
import '@fontsource/dm-serif-display/400.css';
import '@fontsource/dm-serif-display/400-italic.css';

export interface Props {
  title: string;
  description?: string;
  /** Inline CSS custom properties for per-font theming */
  themeStyle?: string;
  mode?: 'light' | 'dark';
  /** Fixed-art-direction pages (font/era specimens) ignore the global toggle. */
  fixedTheme?: boolean;
}

const {
  title,
  description = 'A living library of beautiful, in-depth type specimens for the web.',
  themeStyle,
  mode = 'light',
  fixedTheme = false,
} = Astro.props;
---

<!doctype html>
<html lang="en" data-mode={mode} data-fixed-theme={fixedTheme ? '' : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body style={themeStyle}>
    <slot />

    <script>
      // Dev-only visual feedback overlay (agentation). The `import.meta.env.DEV`
      // guard is statically false in production, so Vite dead-code-eliminates this
      // whole block — agentation and React never enter the prod bundle.
      if (import.meta.env.DEV) {
        const [{ createRoot }, { createElement }, { Agentation }] = await Promise.all([
          import('react-dom/client'),
          import('react'),
          import('agentation'),
        ]);
        const host = document.createElement('div');
        host.id = 'agentation-root';
        document.body.appendChild(host);
        createRoot(host).render(createElement(Agentation));
      }
    </script>

    <script>
      // --- Color-mode persistence ---
      // Fixed-theme pages (font/era specimens) carry their own art direction and
      // must NOT be repainted by the global toggle — skip the override there.
      const KEY = 'specimen-mode';
      const fixed = document.documentElement.hasAttribute('data-fixed-theme');
      if (!fixed) {
        const saved = localStorage.getItem(KEY);
        if (saved === 'light' || saved === 'dark') {
          document.documentElement.setAttribute('data-mode', saved);
        }
      }
      document.addEventListener('click', (e) => {
        const t = (e.target as HTMLElement).closest('[data-mode-toggle]');
        if (!t) return;
        const cur = document.documentElement.getAttribute('data-mode') === 'dark' ? 'dark' : 'light';
        const next = cur === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-mode', next);
        localStorage.setItem(KEY, next);
      });

      // --- Scroll reveal ---
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          }
        },
        { rootMargin: '0px 0px -8% 0px', threshold: 0.05 }
      );
      const watch = () =>
        document.querySelectorAll('[data-reveal]:not(.is-visible)').forEach((el) => io.observe(el));
      watch();
      document.addEventListener('astro:after-swap', watch);
    </script>
  </body>
</html>
