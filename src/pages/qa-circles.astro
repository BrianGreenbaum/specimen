---
// TEMPORARY QA PAGE — renders every circled annotation (font callouts,
// glossary focus spots, era trait callouts & scrubber spotlights) in one grid
// so circle placement can be visually verified at a glance. Delete before ship.
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { glossary } from '../lib/glossary';

const fonts = await getCollection('fonts');
const eras = await getCollection('eras');

type Cell = {
  source: string;
  family: string;
  glyph: string;
  weight: number;
  guides: string[];
  focus: any[];
};

const cells: Cell[] = [];

for (const f of fonts) {
  for (const c of f.data.callouts) {
    if (!c.focus?.length) continue;
    cells.push({
      source: `${f.data.name} · ${c.title}`,
      family: f.data.fontFamily,
      glyph: c.glyph,
      weight: c.weight,
      guides: c.guides,
      focus: c.focus,
    });
  }
}

for (const key of Object.keys(glossary)) {
  const g = glossary[key];
  if (!g.focus?.length) continue;
  cells.push({
    source: `Glossary · ${g.term}`,
    family: g.family || 'Source Sans 3 Variable',
    glyph: g.glyph || 'n',
    weight: 400,
    guides: g.guides || [],
    focus: g.focus,
  });
}

for (const e of eras) {
  for (const c of e.data.traitCallouts) {
    if (!c.focus?.length) continue;
    cells.push({
      source: `Era ${e.data.name} · ${c.title}`,
      family: c.family ?? e.data.specimenFont.family,
      glyph: c.glyph,
      weight: c.weight,
      guides: c.guides,
      focus: c.focus,
    });
  }
  if (e.data.spotlightFocus?.length) {
    cells.push({
      source: `Era ${e.data.name} · scrubber`,
      family: e.data.specimenFont.family,
      glyph: e.data.spotlightGlyph,
      weight: e.data.specimenFont.weight,
      guides: [],
      focus: e.data.spotlightFocus,
    });
  }
}
---
<Layout title="QA — circles">
  <main class="qa">
    <h1>Circle QA — {cells.length} annotations</h1>
    <div class="grid">
      {cells.map((c) => (
        <figure class="cell">
          <svg
            class="diag"
            data-qa
            data-family={c.family}
            data-glyph={c.glyph}
            data-weight={c.weight}
            data-guides={JSON.stringify(c.guides)}
            data-focus={JSON.stringify(c.focus)}
            preserveAspectRatio="xMidYMid meet"
          ></svg>
          <figcaption>{c.source}<br /><code>{c.glyph}</code> {JSON.stringify(c.focus)}</figcaption>
        </figure>
      ))}
    </div>
  </main>
</Layout>

<script>
  import { renderGlyphDiagram } from '../lib/diagram';
  const draw = () => {
    document.querySelectorAll<SVGElement>('[data-qa]').forEach((svg) => {
      if (svg.dataset.drawn) return;
      svg.dataset.drawn = '1';
      renderGlyphDiagram(svg, {
        family: svg.dataset.family!,
        glyph: svg.dataset.glyph!,
        weight: +(svg.dataset.weight || 400),
        guides: JSON.parse(svg.dataset.guides || '[]'),
        focus: JSON.parse(svg.dataset.focus || '[]'),
        fill: 0.62,
      });
    });
  };
  (document as any).fonts?.ready.then(draw);
  draw();
</script>

<style>
  .qa { padding: 2rem; }
  .qa h1 { font-size: 1.4rem; margin-bottom: 1.5rem; }
  .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); }
  .cell { background: var(--bg); margin: 0; }
  .diag { width: 100%; aspect-ratio: 1 / 1; display: block; background: var(--bg-2); }
  figcaption { padding: 0.5rem 0.6rem; font-size: 0.62rem; line-height: 1.3; color: var(--fg-2); font-family: var(--font-mono); border-top: 1px solid var(--line); }
  figcaption code { color: var(--accent); font-weight: 700; }
</style>
