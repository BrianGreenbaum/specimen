---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Hero from '../../components/specimen/Hero.astro';
import JumpNav from '../../components/specimen/JumpNav.astro';
import Section from '../../components/specimen/Section.astro';
import TypeTester from '../../components/specimen/TypeTester.astro';
import WeightsShowcase from '../../components/specimen/WeightsShowcase.astro';
import DetailCallouts from '../../components/specimen/DetailCallouts.astro';
import InUse from '../../components/specimen/InUse.astro';
import GlyphGrid from '../../components/specimen/GlyphGrid.astro';
import TechSpecs from '../../components/specimen/TechSpecs.astro';
import Outlines from '../../components/specimen/Outlines.astro';
import Glossary from '../../components/Glossary.astro';
import { themeToStyle } from '../../lib/theme';
import { getOutlines } from '../../lib/outlines';

export async function getStaticPaths() {
  const fonts = (await getCollection('fonts')).sort((a, b) => a.data.order - b.data.order);
  const eras = await getCollection('eras');
  return fonts.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: fonts[(i - 1 + fonts.length) % fonts.length],
      next: fonts[(i + 1) % fonts.length],
      era: eras.find((e) => e.data.slug === entry.data.era) ?? null,
    },
  }));
}

const { entry, prev, next, era } = Astro.props;
const font = entry.data;
const { Content } = await render(entry);
const themeStyle = themeToStyle(font.theme);

// Bespoke per-font In-Use scene (falls back to the generic InUse component)
const inUseComponents = import.meta.glob('../../components/specimen/inuse/*.astro', { eager: true });
const BespokeInUse = (inUseComponents[`../../components/specimen/inuse/${entry.id}.astro`] as any)?.default;

// Real Bézier outlines, decoded from the font binary at build time.
const outlines = await getOutlines({
  id: entry.id,
  isVariable: font.isVariable,
  axes: font.axes,
  callouts: font.callouts,
});

// Ordered for engagement: seduce (In Use), then play (Tester), then read
// (Story), then go progressively deeper. Reference material closes the page.
const sections = [
  { id: 'in-use', label: 'In Use' },
  { id: 'tester', label: 'Type Tester' },
  { id: 'story', label: 'Story' },
  { id: 'weights', label: 'Weights' },
  { id: 'anatomy', label: 'Anatomy' },
  ...(outlines ? [{ id: 'drawing', label: 'The Drawing' }] : []),
  { id: 'glyphs', label: 'Glyphs' },
  { id: 'specs', label: 'Specs' },
];
// Section numbers follow the (possibly shorter) section list.
const num = (id: string) => String(sections.findIndex((s) => s.id === id) + 1).padStart(2, '0');
---
<Layout
  title={`${font.name} — Specimen`}
  description={font.blurb}
  themeStyle={themeStyle}
  mode={font.theme.mode}
  fixedTheme
>
  <SiteHeader current={font.name} showToggle={false} />
  <JumpNav sections={sections} />
  <Hero font={font} />

  <main>
    <Section id="in-use" num={num('in-use')} title="In use" note="Built live with the real webfont.">
      {BespokeInUse
        ? <BespokeInUse font={font} />
        : font.inUse.length > 0 && <InUse font={font} startIndex={1} />}
    </Section>

    <Section id="tester" num={num('tester')} title="Type tester" note="Edit the text. Drag the axes.">
      <TypeTester font={font} />
    </Section>

    <Section id="story" num={num('story')} title="The story">
      <div class="story">
        <div class="story-prose prose" data-glossary style={`--term-fam:'${font.fontFamily}'`}>
          <Content />
        </div>
        <aside class="story-rail">
          <p class="story-orn" style={`font-family:'${font.fontFamily}'`} aria-hidden="true">{font.pangram}</p>
          {era && (
            <a class="story-era" href={`/history/${era.data.slug}`} style={`--era-accent:${era.data.theme.accent}`}>
              <span class="label story-era__kicker">In the history of type</span>
              <span class="story-era__era">{String(era.data.order).padStart(2, '0')} · {era.data.name}</span>
              <span class="story-era__note">{font.historyNote}</span>
              <span class="story-era__cta label">Explore the era →</span>
            </a>
          )}
        </aside>
      </div>
    </Section>

    <Section id="weights" num={num('weights')} title="Weights & styles" note={`${font.weights.length} weights${font.hasItalic ? ' + italics' : ''}`}>
      <WeightsShowcase font={font} />
    </Section>

    <Section id="anatomy" num={num('anatomy')} title="Details & anatomy" note="The marks that make it unmistakable.">
      <DetailCallouts callouts={font.callouts} family={font.fontFamily} editCollection="fonts" editId={entry.id} editField="callouts" />
    </Section>

    {outlines && (
      <Section id="drawing" num={num('drawing')} title="The drawing" note="Real Bézier curves, decoded from the font file.">
        <Outlines font={font} data={outlines} />
      </Section>
    )}

    <Section id="glyphs" num={num('glyphs')} title="Character set" note="Click any glyph to inspect.">
      <GlyphGrid font={font} />
    </Section>

    <Section id="specs" num={num('specs')} title="Technical specifications">
      <TechSpecs font={font} />
    </Section>
  </main>

  <SiteFooter prev={prev} next={next} />
  <Glossary />
</Layout>

<style>
  /* --- The story: one readable column + a sticky editorial rail --- */
  .story {
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(15rem, 24vw, 21rem);
    gap: var(--sp-7);
    align-items: start;
  }

  .story-prose {
    font-size: var(--step-1);
    max-width: 62ch;
  }
  .story-prose :global(p) {
    margin-bottom: 1.2em;
    line-height: 1.65;
  }
  /* opening paragraph reads as a lede */
  .story-prose :global(p:first-of-type) {
    font-size: calc(var(--step-1) * 1.16);
    line-height: 1.52;
  }
  .story-prose :global(p:first-of-type)::first-letter {
    font-size: 3.2em;
    line-height: 0.8;
    float: left;
    font-weight: 600;
    padding: 0.05em 0.12em 0 0;
    color: var(--accent);
  }

  .story-rail {
    position: sticky;
    top: 96px;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  /* the face itself, decorating its own story */
  .story-orn {
    font-size: var(--step-3);
    line-height: 1.18;
    color: var(--fg-2);
    padding-block: var(--sp-3);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .story-orn::first-letter { color: var(--accent); }

  /* Editorial "where this sits in history" card, stacked in the rail. */
  .story-era {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.6rem;
    padding: var(--sp-4);
    border: 1px solid var(--line);
    border-left: 3px solid var(--era-accent);
    border-radius: 3px;
    background: var(--bg-2);
    transition: background 0.3s var(--ease);
  }
  .story-era:hover { background: color-mix(in srgb, var(--era-accent) 10%, var(--bg-2)); }
  .story-era__kicker { color: var(--era-accent); }
  .story-era__era { font-family: var(--font-ui); font-weight: 640; font-size: var(--step-1); letter-spacing: -0.01em; }
  .story-era__note { color: var(--fg-2); font-size: var(--step--1); line-height: 1.5; }
  .story-era__cta { color: var(--era-accent); }

  /* space between bespoke scenes and the shared generic scenes that follow */
  .inuse-after { margin-top: var(--sp-6); }

  @media (max-width: 900px) {
    .story { grid-template-columns: 1fr; gap: var(--sp-5); }
    .story-rail { position: static; }
    .story-orn { display: none; }
  }
</style>
