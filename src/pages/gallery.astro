---
// The Gallery — thirty letterforms hung as art.
// One monumental glyph per face, each in its own themed room with a museum
// plaque. Scroll-snap rooms, keyboard navigation, and a dot rail. Variable
// faces breathe gently along their weight axis while their room is in view.
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { themeToStyle } from '../lib/theme';

const fonts = (await getCollection('fonts')).sort((a, b) => a.data.order - b.data.order);
const eras = await getCollection('eras');

// Curated piece per face: the glyph that shows its character best, the
// weight / style it should hang at, and the wall text — why THIS letter.
const ART: Record<string, { g: string; w?: number; i?: boolean; spot?: { x: number; y: number; r?: number }; note: string }> = {
  cinzel: { g: 'A', w: 500, spot: { x: 51, y: 24.6 }, note: 'The splayed apex and knife-edge serifs come straight from the capitals cut into Trajan’s Column — the alphabet at its most imperial.' },
  marcellus: { g: 'R', spot: { x: 71, y: 73.5 }, note: 'The leg kicks out straight and proud — the classic inscriptional gesture, poised like a chisel stroke leaving the stone.' },
  'eb-garamond': { g: 'a', spot: { x: 55, y: 48.2 }, note: 'A small bowl held high on a humanist frame: the double-storey a that has made books readable for five hundred years.' },
  'cormorant-garamond': { g: 'g', w: 500, spot: { x: 47.6, y: 88.5, r: 9 }, note: 'Garamond’s g re-cut for display: razor serifs, a looping descender, and hairlines that only survive at large sizes.' },
  lora: { g: 'k', w: 500, spot: { x: 56.9, y: 60.5 }, note: 'The junctions spring like a loaded brush — Lora’s curves remember the pen, even on a backlit screen.' },
  'libre-baskerville': { g: 'Q', spot: { x: 58.1, y: 87, r: 9 }, note: 'Baskerville’s signature letter: the tail still sweeps below the baseline — the eighteenth century’s flourish, tempered for the screen.' },
  'playfair-display': { g: '&', w: 500, i: true, spot: { x: 71.4, y: 31.6 }, note: 'The italic ampersand — an “Et” written in one flourish — is the most theatrical glyph in the family, all hairlines and ball terminals.' },
  newsreader: { g: 'y', i: true, spot: { x: 38.4, y: 80.3, r: 9 }, note: 'The italic y trails a long, inky descender — drawn on an optical-size axis for headlines, where descenders can afford to stretch.' },
  spectral: { g: 'a', spot: { x: 66.9, y: 69.1 }, note: 'A sturdy double-storey a with an open aperture — a serif engineered to keep its head at paragraph sizes on screen.' },
  'bodoni-moda': { g: 'R', w: 500, spot: { x: 68.4, y: 74.9 }, note: 'A hairline meets a full-weight stem and the leg curls away — Didone contrast, the look that made Bodoni the face of fashion.' },
  'dm-serif-display': { g: 'g', spot: { x: 68.5, y: 42.6 }, note: 'A high-contrast double-storey g with a cocked ear — Didone drama scaled for headlines, never footnotes.' },
  fraunces: { g: 'g', w: 600, spot: { x: 68.9, y: 43.9 }, note: 'Generous upper bowl, looping lower storey, a jaunty ear — the wonky old-style g of Cooper and Souvenir, reborn variable.' },
  besley: { g: 'R', w: 600, spot: { x: 71.7, y: 77.3 }, note: 'The Clarendon R plants its curled leg like a boot heel — bracketed slabs built to shout from Victorian posters.' },
  'roboto-slab': { g: '2', w: 500, spot: { x: 52.2, y: 76 }, note: 'Even the figures wear slabs: an unbracketed foot and even strokes — ornament stripped, geometry left standing.' },
  oswald: { g: 'G', w: 500, spot: { x: 66.1, y: 61.8 }, note: 'A condensed gothic G with a bearded spur and a tight aperture — wood-type proportions compressed for the headline column.' },
  archivo: { g: 'K', w: 800, spot: { x: 52.3, y: 54.8 }, note: 'The arms strike the stem in one tense junction — a headline grotesque holding its nerve across weight and width.' },
  inter: { g: 'R', w: 500, spot: { x: 69.2, y: 74.3 }, note: 'A neo-grotesque R with a dead-straight leg, drawn to a pixel grid — the quiet workhorse letter of the modern interface.' },
  'source-sans-3': { g: 'a', w: 500, spot: { x: 49.8, y: 68.7 }, note: 'The two-storey a with an open bowl — Adobe’s first open-source face keeping a trace of the pen at interface sizes.' },
  jost: { g: 'g', spot: { x: 44.6, y: 48.9 }, note: 'A geometric g drawn from circle and stem — Bauhaus reduction doing the work of calligraphy.' },
  outfit: { g: 'O', w: 500, spot: { x: 65.2, y: 35.2 }, note: 'A perfect circle for an O — monoline, unmodulated, the geometric thesis stated in a single glyph.' },
  fredoka: { g: 'e', w: 500, spot: { x: 49.8, y: 60 }, note: 'A buoyant e with a level bar and rounded terminals — the whole face reads like a smile, and this is the curve of it.' },
  'space-grotesk': { g: 'G', w: 500, spot: { x: 67.8, y: 58.2 }, note: 'The crossbar sits flat and the curves square off slightly — Space Mono’s eccentric DNA, freed from the fixed-width cell.' },
  syne: { g: 'S', w: 700, spot: { x: 55.1, y: 29.9 }, note: 'Wide, flat-shouldered, nearly architectural — an S from a family drawn for an art centre and pushed toward abstraction.' },
  'big-shoulders': { g: 'B', w: 800, spot: { x: 58.4, y: 38.2 }, note: 'A compressed B with flat sides and slivers of counter — American gothic condensed, named for Sandburg’s Chicago.' },
  'bricolage-grotesque': { g: 'a', w: 600, spot: { x: 66.8, y: 71.9 }, note: 'A grotesque a with ink-trapped joins and a heavy hooked finial — British eccentricity worn over Swiss bones.' },
  unbounded: { g: 'Ø', w: 800, spot: { x: 50.1, y: 50.1, r: 9 }, note: 'A rounded superellipse sliced clean through — drawn to hold its shape from a watch face to a billboard.' },
  'martian-mono': { g: 'M', w: 700, spot: { x: 48.8, y: 41.9, r: 9 }, note: 'A wide M squeezed into the same cell as every other letter — the monospace bargain, struck with engineering humour.' },
  'ibm-plex-mono': { g: 'a', spot: { x: 51.9, y: 57.6 }, note: 'A double-storey a tucked into a fixed-width cell, warmth surviving the grid — IBM’s typewriter voice, modernised.' },
  'instrument-serif': { g: 'J', spot: { x: 59.3, y: 26.7 }, note: 'Needle serifs and sudden contrast on a compact J — a display face that spends its whole budget on style.' },
  'pinyon-script': { g: 'G', spot: { x: 49.7, y: 48.4, r: 9 }, note: 'A copperplate capital G unwinding in a single Spencerian stroke — engraving-plate romance, set in type.' },
};

// Museum-catalog identity line for the chosen glyph, e.g. "Lowercase g · U+0067".
function glyphIdentity(g: string): string {
  const cp = `U+${g.codePointAt(0)!.toString(16).toUpperCase().padStart(4, '0')}`;
  let kind = 'Glyph';
  if (/\p{Lu}/u.test(g)) kind = `Capital ${g}`;
  else if (/\p{Ll}/u.test(g)) kind = `Lowercase ${g}`;
  else if (/\d/.test(g)) kind = `Figure ${g}`;
  else if (g === '&') kind = 'Ampersand';
  return `${kind} · ${cp}`;
}

const rooms = fonts.map((f) => {
  const art = ART[f.id] ?? { g: f.data.callouts[0]?.glyph ?? 'A', note: '' };
  const era = eras.find((e) => e.data.slug === f.data.era);
  const wght = f.data.axes.find((a) => a.tag === 'wght');
  const w = art.w ?? wght?.default ?? 400;
  // breathing range: a gentle push up the weight axis, never past its end
  const breatheTo = wght ? Math.min(wght.max, w + (wght.max - wght.min) * 0.22) : w;
  const styles = f.data.weights.length * (f.data.hasItalic ? 2 : 1);
  const medium = f.data.isVariable
    ? `Variable type, ${f.data.axes.length} ${f.data.axes.length === 1 ? 'axis' : 'axes'} — ${styles} styles`
    : `Static type — ${styles} ${styles === 1 ? 'style' : 'styles'}`;
  return { f, art, era, w, breatheTo, medium };
});
---

<Layout title="The Gallery — Specimen" description="Thirty letterforms, hung as art. One glyph per face, each in its own room." mode="dark" fixedTheme>
  <SiteHeader current="Gallery" showToggle={false} />

  <main class="gallery" data-gallery>
    <section class="room room--intro" id="r-intro" data-room>
      <div class="intro">
        <p class="label intro__kicker" data-reveal>The permanent collection · {fonts.length} pieces</p>
        <h1 class="intro__title" data-reveal style="--reveal-delay:90ms">The<br />Gallery</h1>
        <p class="intro__lede" data-reveal style="--reveal-delay:180ms">
          One glyph per face, hung at monumental size — the letterform as the artwork.
          Walk the wings in historical order, from Roman marble to variable type.
        </p>
        <p class="intro__hint label" data-reveal style="--reveal-delay:280ms">Scroll, or use ↑ ↓ <span class="intro__hint-sep">·</span> each room links to its specimen</p>
      </div>
    </section>

    {rooms.map(({ f, art, era, w, breatheTo, medium }, i) => (
      <section
        class="room"
        id={`r-${f.id}`}
        data-room
        data-name={f.data.name}
        style={themeToStyle(f.data.theme)}
      >
        <span class="room__wing label" aria-hidden="true">
          {era ? `Wing ${String(era.data.order).padStart(2, '0')} — ${era.data.name}` : 'Specimen'}
        </span>
        <span class="room__no label" aria-hidden="true">№ {String(i + 1).padStart(2, '0')} / {rooms.length}</span>

        {(() => {
          const glyphStyle = `font-family:'${f.data.fontFamily}'; font-weight:${w}; --w-a:${w}; --w-b:${Math.round(breatheTo)}; ${art.i ? 'font-style:italic;' : ''}`;
          const spotVars = art.spot
            ? `--ax:${art.spot.x}%; --ay:${art.spot.y}%; --ar:${art.spot.r ?? 7}%; --ring:${(art.spot.r ?? 7) * 1.7}%;`
            : '';
          return (
            <div class="room__piecewrap" style={spotVars}>
              <a class="room__art" href={`/fonts/${f.id}`} aria-label={`${f.data.name} — view specimen`}>
                <span
                  class:list={['room__glyph', f.data.isVariable && 'room__glyph--breathe']}
                  style={glyphStyle}
                  aria-hidden="true"
                >{art.g}</span>
                {art.spot && (
                  <span
                    class:list={['room__glyph', 'room__glyph--lit', f.data.isVariable && 'room__glyph--breathe']}
                    style={glyphStyle}
                    aria-hidden="true"
                  >{art.g}</span>
                )}
                {art.spot && <span class="room__ring" aria-hidden="true"></span>}
              </a>
              {art.spot && art.note && <span class="room__lead" aria-hidden="true"></span>}
              {art.spot && art.note && (
                <div class="room__anno">
                  <span class="room__glyphid">{glyphIdentity(art.g)}{art.i ? ' · italic' : ''}</span>
                  <p class="room__annonote">{art.note}</p>
                </div>
              )}
            </div>
          );
        })()}

        <div class="room__plaque">
          <p class="room__artist">{f.data.designer}</p>
          <p class="room__piece">
            <a href={`/fonts/${f.id}`} class="room__title" style={`font-family:'${f.data.fontFamily}'`}>{f.data.name}</a>
            <span class="room__year">, {f.data.year}</span>
          </p>
          <p class="room__glyphid room__plaque-mobile">{glyphIdentity(art.g)}{art.i ? ' · italic' : ''}</p>
          {art.note && <p class="room__note room__plaque-mobile">{art.note}</p>}
          <p class="room__medium">{medium}</p>
          <p class="room__lender">{f.data.foundry ?? 'Open source'} · {f.data.license}</p>
          <a class="room__cta label" href={`/fonts/${f.id}`}>View specimen →</a>
        </div>
      </section>
    ))}
  </main>

  <nav class="rail" aria-label="Gallery rooms">
    {rooms.map(({ f }, i) => (
      <a class="rail__dot" href={`#r-${f.id}`} data-rail-dot={i} title={f.data.name} aria-label={`Room ${i + 1}: ${f.data.name}`}></a>
    ))}
  </nav>
</Layout>

<script>
  const main = document.querySelector<HTMLElement>('[data-gallery]')!;
  const rooms = [...main.querySelectorAll<HTMLElement>('[data-room]')];
  const dots = [...document.querySelectorAll<HTMLElement>('[data-rail-dot]')];

  // live room tracking: entrance animation + breathing + active rail dot
  const io = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        e.target.classList.toggle('is-live', e.isIntersecting);
        if (e.isIntersecting) {
          const i = rooms.indexOf(e.target as HTMLElement) - 1; // intro has no dot
          dots.forEach((d, di) => d.classList.toggle('is-active', di === i));
        }
      }
    },
    { root: main, threshold: 0.55 }
  );
  rooms.forEach((r) => io.observe(r));

  // keyboard walking
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'ArrowDown' && e.key !== 'ArrowUp') return;
    if ((e.target as HTMLElement).closest('input, textarea, [contenteditable]')) return;
    e.preventDefault();
    const live = rooms.findIndex((r) => r.classList.contains('is-live'));
    const next = Math.min(rooms.length - 1, Math.max(0, live + (e.key === 'ArrowDown' ? 1 : -1)));
    rooms[next]?.scrollIntoView({ behavior: 'smooth' });
  });
</script>

<style>
  /* a registered number so the weight axis itself can interpolate */
  @property --gw {
    syntax: '<number>';
    inherits: false;
    initial-value: 400;
  }

  .gallery {
    height: calc(100dvh - 64px);
    overflow-y: auto;
    scroll-snap-type: y mandatory;
    overscroll-behavior: contain;
  }

  .room {
    position: relative;
    height: 100%;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    background: var(--bg);
    color: var(--fg);
    overflow: hidden;
    display: grid;
    place-items: center;
  }

  /* --- intro room --- */
  .room--intro { place-items: center start; }
  .intro { padding-inline: var(--gutter, clamp(1.25rem, 5vw, 4rem)); max-width: 60rem; }
  .intro__kicker { color: var(--accent); display: block; margin-bottom: var(--sp-4); }
  .intro__title {
    font-family: var(--font-ui);
    font-weight: 680;
    font-size: clamp(4rem, 17vh, 11rem);
    line-height: 0.88;
    letter-spacing: -0.04em;
  }
  .intro__lede {
    max-width: 44ch;
    margin-top: var(--sp-5);
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--fg-2);
  }
  .intro__hint { display: block; margin-top: var(--sp-6); color: var(--fg-3); }
  .intro__hint-sep { color: var(--accent); }

  /* --- the artwork --- */
  .room__piecewrap { position: relative; width: fit-content; }
  .room__art { display: block; line-height: 0; position: relative; }
  .room__glyph {
    display: block;
    font-size: min(58vh, 56vw);
    line-height: 1;
    /* Ink can paint far past the advance width (italic overhangs, swash
       tails). Once the breathe animation promotes the glyph to its own
       compositing layer, anything outside the element box gets clipped —
       so grow the box symmetrically to keep the ink inside it. */
    padding: 0.28em 0.45em;
    font-variation-settings: 'wght' var(--gw);
    --gw: var(--w-a);
    opacity: 0;
    transform: translateY(4vh) scale(0.97);
    transition: opacity 0.9s var(--ease), transform 0.9s var(--ease);
  }
  .room.is-live .room__glyph { opacity: 1; transform: none; }
  .room.is-live .room__glyph--breathe {
    animation: breathe 7s ease-in-out infinite alternate;
  }
  @keyframes breathe {
    from { --gw: var(--w-a); }
    to { --gw: var(--w-b); }
  }
  .room__art:hover .room__glyph { color: var(--accent); transition: color 0.5s var(--ease), opacity 0.9s var(--ease), transform 0.9s var(--ease); }

  /* The annotated feature: a duplicate glyph in accent, revealed through a
     circular mask — same spotlight language as the Anatomy plates. */
  .room__glyph--lit {
    position: absolute;
    inset: 0;
    color: var(--accent);
    clip-path: circle(var(--ar) at var(--ax) var(--ay));
    transition-delay: 0.35s;
  }
  .room__ring {
    position: absolute;
    left: var(--ax);
    top: var(--ay);
    height: var(--ring);
    aspect-ratio: 1;
    transform: translate(-50%, -50%) scale(0.6);
    border: 1px solid var(--accent);
    border-radius: 50%;
    opacity: 0;
    transition: opacity 0.6s var(--ease) 0.45s, transform 0.6s var(--ease) 0.45s;
    pointer-events: none;
  }
  .room.is-live .room__ring { opacity: 1; transform: translate(-50%, -50%); }

  /* The wall text sits fully clear of the letter — anchored to the right of
     the whole glyph box — with a hairline leader running back to the ring. */
  .room__anno {
    position: absolute;
    left: calc(100% + clamp(1.5rem, 2.5vw, 3rem));
    top: var(--ay);
    transform: translateY(-50%);
    width: max-content;
    max-width: min(24ch, 19vw);
    opacity: 0;
    translate: -10px 0;
    transition: opacity 0.7s var(--ease) 0.6s, translate 0.7s var(--ease) 0.6s;
    z-index: 2;
  }
  .room.is-live .room__anno { opacity: 1; translate: 0 0; }
  .room__lead {
    position: absolute;
    left: var(--ax);
    top: var(--ay);
    width: calc(100% - var(--ax) + clamp(1.5rem, 2.5vw, 3rem) - 0.9rem);
    height: 1px;
    background: color-mix(in srgb, var(--accent) 55%, transparent);
    opacity: 0;
    transition: opacity 0.7s var(--ease) 0.6s;
    pointer-events: none;
  }
  .room.is-live .room__lead { opacity: 1; }
  .room__annonote {
    margin-top: 0.4rem;
    font-size: var(--step--1);
    line-height: 1.5;
    color: var(--fg-2);
  }

  /* --- room chrome --- */
  .room__wing,
  .room__no {
    position: absolute;
    top: var(--sp-4);
    color: var(--fg-3);
  }
  .room__wing { left: var(--gutter, clamp(1.25rem, 5vw, 4rem)); }
  .room__no { right: var(--gutter, clamp(1.25rem, 5vw, 4rem)); font-variant-numeric: tabular-nums; }

  /* --- museum plaque --- */
  .room__plaque {
    position: absolute;
    left: var(--gutter, clamp(1.25rem, 5vw, 4rem));
    bottom: clamp(1.5rem, 5vh, 3.5rem);
    width: min(22rem, 72vw);
    padding: var(--sp-4);
    background: color-mix(in srgb, var(--bg-2) 88%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.7s var(--ease) 0.18s, transform 0.7s var(--ease) 0.18s;
  }
  .room.is-live .room__plaque { opacity: 1; transform: none; }

  .room__artist {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--fg-2);
  }
  .room__piece { margin-top: 0.45rem; line-height: 1.1; }
  .room__title {
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    color: var(--fg);
    transition: color 0.25s var(--ease);
  }
  .room__title:hover { color: var(--accent); }
  .room__year { color: var(--fg-3); font-size: var(--step-0); }
  .room__glyphid {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .room__plaque .room__glyphid { margin-top: 0.55rem; }
  .room__note {
    margin-top: 0.45rem;
    font-size: var(--step--1);
    line-height: 1.55;
    color: var(--fg-2);
  }
  /* the letter's story lives on the annotation at desktop sizes */
  .room__plaque-mobile { display: none; }
  .room__medium { margin-top: 0.65rem; font-size: var(--step--1); color: var(--fg-3); }
  .room__lender { margin-top: 0.15rem; font-size: var(--step--1); color: var(--fg-3); }
  .room__cta { display: inline-block; margin-top: 0.8rem; color: var(--accent); }
  .room__cta:hover { text-decoration: underline; text-underline-offset: 3px; }

  /* --- dot rail --- */
  .rail {
    position: fixed;
    right: clamp(0.6rem, 1.4vw, 1.3rem);
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 7px;
    z-index: 60;
    mix-blend-mode: difference;
  }
  .rail__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #fff;
    opacity: 0.32;
    transition: opacity 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .rail__dot:hover { opacity: 0.8; }
  .rail__dot.is-active { opacity: 1; transform: scale(1.5); }

  /* Below ~1280px the side annotation can collide with the viewport edge on
     wide glyphs — the feature stays lit on the letter, but the wall text
     moves back into the plaque. */
  @media (max-width: 1280px) {
    .room__anno,
    .room__lead { display: none; }
    .room__plaque-mobile { display: block; }
  }

  @media (max-width: 900px) {
    .rail { display: none; }
    .room__wing { display: none; }
    .room__glyph { font-size: min(46vh, 72vw); }
    .room__plaque { width: calc(100% - 2 * var(--gutter, 1.25rem)); }
    /* tight rooms: spotlight chrome and catalog lines give way so the
       letter stays visible */
    .room__ring,
    .room__glyph--lit,
    .room__medium,
    .room__lender { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .room__glyph,
    .room__ring,
    .room__anno,
    .room__lead,
    .room__plaque { transition: none; opacity: 1; transform: none; translate: none; }
    .room__ring { transform: translate(-50%, -50%); }
    .room__anno { transform: translateY(-50%); }
    .room.is-live .room__glyph--breathe { animation: none; }
  }
</style>
