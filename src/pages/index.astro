---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import EvolutionScrubber from '../components/history/EvolutionScrubber.astro';

const fonts = (await getCollection('fonts')).sort((a, b) => a.data.order - b.data.order);
const eras = (await getCollection('eras')).sort((a, b) => a.data.order - b.data.order);
const firstEra = eras[0];
---
<Layout title="Specimen — A living library of type">
  <SiteHeader />

  <header class="home-hero">
    <div class="container">
      <p class="home-hero__eyebrow label" data-reveal>The type specimen library · {fonts.length} faces · {eras.length} chapters</p>
      <h1 class="home-hero__title" data-reveal style="--reveal-delay:80ms">
        Specimen<span class="home-hero__period">.</span>
      </h1>
      <p class="home-hero__lede" data-reveal style="--reveal-delay:160ms">
        Two thousand years of the alphabet, and the best open-source typefaces on the web,
        in one place. Trace a single letter through the whole history of type, then drag the
        axes and read the story behind every face — each one self-hosted, free, and shown at
        the standard it deserves.
      </p>
      <p class="home-hero__cue label" data-reveal style="--reveal-delay:240ms">Scroll to begin ↓</p>
    </div>
  </header>

  <main class="container">
    <section class="home-history" aria-labelledby="history-head">
      <div class="section-head" data-reveal>
        <span class="index-num">✳</span>
        <h2 id="history-head">The letter, through time</h2>
        <a class="home-history__more label" href="/history">A history of type →</a>
      </div>

      <p class="home-history__intro prose" data-reveal>
        This library begins with a story two thousand years long. Grab the letter and drag it
        through the eras — then read the whole history as a guided journey, one chapter at a time.
      </p>

      <div data-reveal style="--reveal-delay:80ms">
        <EvolutionScrubber eras={eras} compact />
      </div>

      <a class="home-begin" href={`/history/${firstEra.data.slug}`} style={`--era-accent:${firstEra.data.theme.accent}`} data-reveal>
        <span class="home-begin__text">
          <span class="home-begin__label label">Begin the journey</span>
          <span class="home-begin__name">Chapter 01 · {firstEra.data.name}</span>
        </span>
        <span class="home-begin__arrow" aria-hidden="true">→</span>
      </a>

      <ol class="era-strip" aria-label="The eight chapters">
        {eras.map((e, i) => (
          <li class="era-strip__item" data-reveal style={`--era-accent:${e.data.theme.accent}; --reveal-delay:${i * 40}ms`}>
            <a class="era-strip__link" href={`/history/${e.data.slug}`}>
              <span class="era-strip__top">
                <span class="era-strip__num index-num">{String(e.data.order).padStart(2, '0')}</span>
                <span class="era-strip__swatch" aria-hidden="true"></span>
              </span>
              <span class="era-strip__period label">{e.data.period}</span>
              <span class="era-strip__name">{e.data.name}</span>
            </a>
          </li>
        ))}
        <li class="era-strip__item era-strip__item--all" data-reveal style={`--reveal-delay:${eras.length * 40}ms`}>
          <a class="era-strip__link era-strip__link--all" href="/history">
            <span class="era-strip__all-num index-num">↗</span>
            <span class="era-strip__name">All eight<br />chapters</span>
            <span class="label era-strip__period">Enter the history →</span>
          </a>
        </li>
      </ol>
    </section>

    <section class="home-fonts" aria-labelledby="fonts-head">
      <div class="section-head" id="index">
        <span class="index-num">✳</span>
        <h2 id="fonts-head">The faces behind the story</h2>
        <span class="label">{fonts.length} specimens · each its own chapter</span>
      </div>

    <ul class="index-list">
      {fonts.map((f) => (
        <li
          class="index-row"
          style={`--row-accent:${f.data.theme.accent}; --fam:${f.data.fontFamily}`}
        >
          <a href={`/fonts/${f.id}`} class="index-row__link" data-reveal>
            <span class="index-row__num index-num">{String(f.data.order).padStart(2, '0')}</span>
            <span class="index-row__name">{f.data.name}</span>
            <span class="index-row__meta">
              <span class="index-row__cat label">{f.data.category}</span>
              <span class="index-row__designer">{f.data.designer}</span>
              <span class="index-row__year label">{f.data.year}</span>
            </span>
            <span class="index-row__arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
    </section>

    <section class="home-about">
      <div class="section-head" data-reveal>
        <span class="index-num">✳</span>
        <h2>About this library</h2>
      </div>
      <div class="home-about__grid">
        <p class="home-about__lead prose" data-reveal>
          Every typeface here is studied the way the best foundries present their own:
          a giant showing, a live tester wired to each variable axis, a ramp of sizes,
          a full character set, the OpenType refinements, the letterform details that
          make it unmistakable, and the story of how it came to be.
        </p>
        <dl class="home-about__facts" data-reveal>
          <div><dt class="label">Built with</dt><dd>Astro · self-hosted fonts</dd></div>
          <div><dt class="label">Licensing</dt><dd>All faces free &amp; open source</dd></div>
          <div><dt class="label">Growing</dt><dd>New specimens added over time</dd></div>
        </dl>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>

<style>
  .home-hero {
    padding-block: clamp(3rem, 12vh, 9rem) clamp(2rem, 6vh, 5rem);
    border-bottom: 1px solid var(--line);
  }
  .home-hero__eyebrow { display: block; margin-bottom: var(--sp-4); }
  .home-hero__title {
    font-family: var(--font-ui);
    font-weight: 680;
    font-size: clamp(3.5rem, 16vw, 13rem);
    line-height: 0.9;
    letter-spacing: -0.04em;
  }
  .home-hero__period { color: var(--accent); }
  .home-hero__lede {
    max-width: 54ch;
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--fg-2);
    margin-top: var(--sp-5);
  }
  .home-hero__cue { display: block; margin-top: var(--sp-6); }

  /* History feature */
  .home-history { padding-block: clamp(2.5rem, 7vh, 5rem) clamp(2rem, 5vh, 4rem); }
  .home-history__more { margin-left: auto; color: var(--accent); transition: opacity 0.2s var(--ease); }
  .home-history__more:hover { opacity: 0.7; }
  .home-history__intro { font-size: var(--step-1); margin-bottom: var(--sp-5); color: var(--fg-2); max-width: 60ch; }

  .home-begin {
    display: flex; align-items: center; gap: var(--sp-4);
    margin-top: var(--sp-4);
    padding: clamp(1.2rem, 3vw, 1.8rem) clamp(1.4rem, 4vw, 2.4rem);
    background:
      radial-gradient(120% 160% at 6% 0%, color-mix(in srgb, var(--era-accent) 24%, transparent), transparent 58%),
      color-mix(in srgb, var(--era-accent) 9%, var(--bg));
    border: 1px solid color-mix(in srgb, var(--era-accent) 38%, var(--line));
    transition: transform 0.4s var(--ease), border-color 0.3s var(--ease);
  }
  .home-begin:hover { transform: translateY(-2px); border-color: var(--era-accent); }
  .home-begin__text { display: flex; flex-direction: column; gap: 0.25rem; }
  .home-begin__label { color: var(--era-accent); }
  .home-begin__name { font-family: var(--font-ui); font-weight: 660; font-size: var(--step-1); letter-spacing: -0.01em; }
  .home-begin__arrow { margin-left: auto; font-size: var(--step-2); color: var(--era-accent); transition: transform 0.4s var(--ease); }
  .home-begin:hover .home-begin__arrow { transform: translateX(0.4rem); }

  /* Eras strip */
  .era-strip {
    margin-top: var(--sp-4);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .era-strip__item { background: var(--bg); }
  .era-strip__link {
    display: flex; flex-direction: column; gap: 0.5rem;
    height: 100%; padding: var(--sp-4);
    transition: background 0.25s var(--ease);
  }
  .era-strip__link:hover { background: color-mix(in srgb, var(--era-accent) 9%, var(--bg)); }
  .era-strip__top { display: flex; align-items: center; justify-content: space-between; }
  .era-strip__num { color: var(--era-accent); }
  .era-strip__swatch { width: 11px; height: 11px; border-radius: 50%; background: var(--era-accent); }
  .era-strip__period { color: var(--fg-3); }
  .era-strip__name {
    font-family: var(--font-ui); font-weight: 640; font-size: var(--step-1);
    letter-spacing: -0.01em; line-height: 1.05; margin-top: auto;
    transition: color 0.2s var(--ease);
  }
  .era-strip__link:hover .era-strip__name { color: var(--era-accent); }

  .era-strip__link--all {
    background: var(--accent); color: var(--accent-contrast);
    justify-content: space-between;
  }
  .era-strip__link--all:hover { filter: brightness(1.06); background: var(--accent); }
  .era-strip__link--all .index-num,
  .era-strip__link--all .label { color: var(--accent-contrast); }
  .era-strip__all-num { font-size: var(--step-2); line-height: 1; }
  .era-strip__link--all .era-strip__name { color: var(--accent-contrast); }

  /* Fonts section */
  .home-fonts { padding-block: clamp(2rem, 5vh, 4rem) 0; }
  .home-fonts .section-head { scroll-margin-top: 80px; }

  /* Index list */
  .index-list { border-bottom: 1px solid var(--line); }
  .index-row { border-top: 1px solid var(--line); }
  .index-row__link {
    display: grid;
    grid-template-columns: 3.5rem 1fr auto 2rem;
    align-items: center;
    gap: var(--sp-4);
    padding-block: clamp(1.2rem, 3.5vh, 2.6rem);
    position: relative;
    transition: padding-left 0.4s var(--ease);
  }
  .index-row__num { align-self: center; color: var(--fg-3); transition: color 0.3s var(--ease); }
  .index-row__name {
    font-family: var(--fam);
    font-size: clamp(2.6rem, 8vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    transition: color 0.3s var(--ease);
  }
  .index-row__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
    text-align: right;
  }
  .index-row__designer { font-size: var(--step-0); color: var(--fg-2); }
  .index-row__arrow {
    font-family: var(--font-mono);
    color: var(--row-accent);
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 0.3s var(--ease), transform 0.3s var(--ease);
    font-size: 1.4rem;
  }
  .index-row:hover .index-row__name { color: var(--row-accent); }
  .index-row:hover .index-row__num { color: var(--row-accent); }
  .index-row:hover .index-row__link { padding-left: 1rem; }
  .index-row:hover .index-row__arrow { opacity: 1; transform: none; }

  /* About */
  .home-about { padding-block: clamp(3rem, 8vh, 6rem); }
  .home-about__grid { display: grid; grid-template-columns: 1.6fr 1fr; gap: var(--sp-7); align-items: start; }
  .home-about__lead { font-size: var(--step-1); }
  .home-about__facts div { padding-block: 0.8rem; border-top: 1px solid var(--line-soft); }
  .home-about__facts div:first-child { border-top: 1px solid var(--fg); }
  .home-about__facts dt { margin-bottom: 3px; }
  .home-about__facts dd { font-size: var(--step-0); }

  @media (max-width: 760px) {
    .index-row__link { grid-template-columns: 2.2rem 1fr; gap: var(--sp-2); }
    .index-row__meta { display: none; }
    .index-row__arrow { display: none; }
    .home-about__grid { grid-template-columns: 1fr; gap: var(--sp-5); }

    /* Eras become a horizontal snap scroller */
    .era-strip {
      display: flex; overflow-x: auto; gap: var(--sp-2);
      border: 0; background: transparent; padding-bottom: var(--sp-2);
      scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;
    }
    .era-strip__item {
      scroll-snap-align: start; flex: 0 0 auto;
      min-width: clamp(200px, 64vw, 250px);
      border: 1px solid var(--line);
    }
    .era-strip__link { min-height: 150px; }
  }
</style>
