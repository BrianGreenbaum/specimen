---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const fonts = (await getCollection('fonts')).sort((a, b) => a.data.order - b.data.order);
const eras = (await getCollection('eras')).sort((a, b) => a.data.order - b.data.order);
---
<Layout title="Specimen — A living library of type">
  <SiteHeader />

  <header class="home-hero">
    <div class="container">
      <p class="home-hero__eyebrow label" data-reveal>The type specimen library · {fonts.length} faces · {eras.length} chapters</p>
      <h1 class="home-hero__title" data-reveal style="--reveal-delay:80ms">
        Specimen<span class="home-hero__period">.</span>
      </h1>
      <p class="home-hero__lede" data-reveal style="--reveal-delay:160ms">
        Two thousand years of the alphabet, and the best open-source typefaces on the web,
        in one place. Trace a single letter through the whole history of type, then drag the
        axes and read the story behind every face — each one self-hosted, free, and shown at
        the standard it deserves.
      </p>
    </div>
  </header>

  <main class="container">
    <section class="home-history" aria-labelledby="history-head">
      <div class="section-head" data-reveal>
        <span class="index-num">✳</span>
        <h2 id="history-head">Two thousand years, eight chapters</h2>
        <a class="home-history__more label" href="/history">A history of type →</a>
      </div>

      <p class="home-history__intro prose" data-reveal>
        Before the faces, the story: how the letter travelled from Roman marble to the
        variable fonts in your browser. A teaser of the eight eras — read the whole journey
        when you’re ready, or compare the faces themselves side by side.
      </p>

      <div class="era-frame" data-reveal>
      <ol class="era-timeline" aria-label="The eight chapters">
        {eras.map((e, i) => (
          <li
            class:list={['era-timeline__item', i % 2 === 0 ? 'era-timeline__item--left' : 'era-timeline__item--right']}
            style={`--era-accent:${e.data.theme.accent}`}
          >
            <a class="era-timeline__link" href={`/history/${e.data.slug}`}>
              <span class="era-timeline__dot" aria-hidden="true"></span>
              <span class="era-timeline__meta label">{String(e.data.order).padStart(2, '0')} · {e.data.period}</span>
              <span class="era-timeline__name" style={`font-family:'${e.data.specimenFont.family}'`}>{e.data.name}</span>
            </a>
          </li>
        ))}
      </ol>
      </div>

      <div class="home-history__links" data-reveal>
        <a class="home-history__cta" href="/history">Read the full history <span aria-hidden="true">→</span></a>
        <a class="home-history__cta home-history__cta--alt" href="/compare">Compare the type <span aria-hidden="true">→</span></a>
        <a class="home-history__cta home-history__cta--alt" href="/gallery">Walk the gallery <span aria-hidden="true">→</span></a>
      </div>
    </section>

    <section class="home-fonts" aria-labelledby="fonts-head">
      <div class="section-head" id="index">
        <span class="index-num">✳</span>
        <h2 id="fonts-head">The faces behind the story</h2>
        <span class="label">{fonts.length} specimens · each its own chapter</span>
      </div>

    <ul class="index-list">
      {fonts.map((f) => (
        <li
          class="index-row"
          style={`--row-accent:${f.data.theme.accent}; --fam:${f.data.fontFamily}`}
        >
          <a href={`/fonts/${f.id}`} class="index-row__link" data-reveal>
            <span class="index-row__num index-num">{String(f.data.order).padStart(2, '0')}</span>
            <span class="index-row__name">{f.data.name}</span>
            <span class="index-row__meta">
              <span class="index-row__cat label">{f.data.category}</span>
              <span class="index-row__designer">{f.data.designer}</span>
              <span class="index-row__year label">{f.data.year}</span>
            </span>
            <span class="index-row__arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
    </section>
  </main>

  <SiteFooter />
</Layout>

<style>
  .home-hero {
    padding-block: clamp(3rem, 12vh, 9rem) clamp(2rem, 6vh, 5rem);
    border-bottom: 1px solid var(--line);
  }
  .home-hero__eyebrow { display: block; margin-bottom: var(--sp-4); }
  .home-hero__title {
    font-family: var(--font-ui);
    font-weight: 680;
    font-size: clamp(3.5rem, 16vw, 13rem);
    line-height: 0.9;
    letter-spacing: -0.04em;
  }
  .home-hero__period { color: var(--accent); }
  .home-hero__lede {
    max-width: 54ch;
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--fg-2);
    margin-top: var(--sp-5);
  }

  /* History teaser — slim, so the specimens stay high on the page */
  .home-history { padding-block: clamp(2.5rem, 7vh, 4.5rem) clamp(1.5rem, 4vh, 3rem); }
  .home-history__more { margin-left: auto; color: var(--accent); transition: opacity 0.2s var(--ease); }
  .home-history__more:hover { opacity: 0.7; }
  .home-history__intro { font-size: var(--step-1); margin-bottom: var(--sp-4); color: var(--fg-2); max-width: 64ch; }

  /* Framed mat around the timeline, matching the in-use examples */
  .era-frame {
    margin-top: var(--sp-5);
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 4vw, 3.5rem) clamp(1.2rem, 4vw, 3rem);
  }

  /* Vertical timeline with a central spine; eras alternate left/right */
  .era-timeline { position: relative; }
  .era-timeline::before {
    content: ''; position: absolute; left: 50%; top: 10px; bottom: 10px;
    width: 1px; background: var(--line); transform: translateX(-50%);
  }
  .era-timeline__item { position: relative; width: 50%; padding-block: clamp(1rem, 2.6vh, 2rem); }
  .era-timeline__item--left { text-align: right; padding-right: clamp(1.6rem, 4vw, 3.2rem); }
  .era-timeline__item--right { margin-left: 50%; text-align: left; padding-left: clamp(1.6rem, 4vw, 3.2rem); }

  .era-timeline__link { display: block; }
  .era-timeline__dot {
    position: absolute; top: clamp(1.3rem, 3vh, 2.4rem);
    width: 13px; height: 13px; border-radius: 50%;
    background: var(--era-accent);
    box-shadow: 0 0 0 4px var(--bg-2), 0 0 0 5px var(--line);
    transition: transform 0.25s var(--ease);
  }
  .era-timeline__item--left .era-timeline__dot { right: -7px; }
  .era-timeline__item--right .era-timeline__dot { left: -7px; }
  .era-timeline__link:hover .era-timeline__dot { transform: scale(1.35); }

  .era-timeline__meta { display: block; color: var(--accent); margin-bottom: 0.4rem; }
  .era-timeline__name {
    font-size: clamp(1.9rem, 4.5vw, 3.4rem);
    line-height: 1.0; letter-spacing: -0.01em; color: var(--fg);
    transition: color 0.25s var(--ease);
  }
  .era-timeline__link:hover .era-timeline__name { color: var(--accent); }

  .home-history__links { display: flex; flex-wrap: wrap; gap: var(--sp-3) var(--sp-5); margin-top: var(--sp-4); }
  .home-history__cta {
    font-family: var(--font-mono); font-size: var(--step--1); color: var(--accent);
    text-transform: uppercase; letter-spacing: 0.04em;
    border-bottom: 1px solid transparent; transition: border-color 0.2s var(--ease);
  }
  .home-history__cta:hover { border-color: var(--accent); }
  .home-history__cta--alt { color: var(--fg-2); }
  .home-history__cta--alt:hover { color: var(--fg); border-color: var(--fg); }

  /* Fonts section */
  .home-fonts { padding-block: clamp(2rem, 5vh, 4rem) 0; }
  .home-fonts .section-head { scroll-margin-top: 80px; }

  /* Index list */
  .index-list { border-bottom: 1px solid var(--line); }
  .index-row { border-top: 1px solid var(--line); }
  .index-row__link {
    display: grid;
    grid-template-columns: 3.5rem 1fr auto 2rem;
    align-items: center;
    gap: var(--sp-4);
    padding-block: clamp(1.7rem, 4.5vh, 3.4rem);
    position: relative;
    transition: padding-left 0.4s var(--ease);
  }
  .index-row__num { align-self: center; color: var(--fg-3); transition: color 0.3s var(--ease); }
  .index-row__name {
    font-family: var(--fam);
    font-size: clamp(2rem, 5.2vw, 4.4rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    transition: color 0.3s var(--ease);
  }
  .index-row__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
    text-align: right;
  }
  .index-row__designer { font-size: var(--step-0); color: var(--fg-2); }
  .index-row__arrow {
    font-family: var(--font-mono);
    color: var(--accent);
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 0.3s var(--ease), transform 0.3s var(--ease);
    font-size: 1.4rem;
  }
  /* hover uses the brand accent (legible in both modes) — a font's own accent
     can be a bright lime/amber that's unreadable on the neutral home. */
  .index-row:hover .index-row__name { color: var(--accent); }
  .index-row:hover .index-row__num { color: var(--accent); }
  .index-row:hover .index-row__link { padding-left: 1rem; }
  .index-row:hover .index-row__arrow { opacity: 1; transform: none; }

  @media (max-width: 760px) {
    .index-row__link { grid-template-columns: 2.2rem 1fr; gap: var(--sp-2); }
    .index-row__meta { display: none; }
    .index-row__arrow { display: none; }
    /* timeline collapses to a single column with the spine on the left */
    .era-timeline::before { left: 6px; transform: none; }
    .era-timeline__item,
    .era-timeline__item--left,
    .era-timeline__item--right {
      width: 100%; margin-left: 0; text-align: left;
      padding-left: var(--sp-5); padding-right: 0;
    }
    .era-timeline__item--left .era-timeline__dot,
    .era-timeline__item--right .era-timeline__dot { left: 0; right: auto; }
  }
</style>
